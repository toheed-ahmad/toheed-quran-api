{
  "surah_id": 83,
  "surah_name": "Al-Mutaffifin",
  "arabic_name": "سُورَةُ المُطَفِّفِينَ",
  "revelation_type": "Meccan",
  "total_ayahs": 36,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَیْلٌ لِّلْمُطَفِّفِیْنَۙ۝۱",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "الَّذِیْنَ اِذَا اكْتَالُوْا عَلَی النَّاسِ یَسْتَوْفُوْنَؗۖ۝۲",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ اِذَا كَالُوْهُمْ اَوْ وَّ زَنُوْهُمْ یُخْسِرُوْنَؕ۝۳",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اَلَا یَظُنُّ اُولٰٓىِٕكَ اَنَّهُمْ مَّبْعُوْثُوْنَۙ۝۴",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "لِیَوْمٍ عَظِیْمٍۙ۝۵",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "یَّوْمَ یَقُوْمُ النَّاسُ لِرَبِّ الْعٰلَمِیْنَؕ۝۶",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "كَلَّاۤ اِنَّ كِتٰبَ الْفُجَّارِ لَفِیْ سِجِّیْنٍؕ۝۷",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا سِجِّیْنٌؕ۝۸",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "كِتٰبٌ مَّرْقُوْمٌؕ۝۹",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَیْلٌ یَّوْمَىِٕذٍ لِّلْمُكَذِّبِیْنَۙ۝۱۰",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "الَّذِیْنَ یُكَذِّبُوْنَ بِیَوْمِ الدِّیْنِؕ۝۱۱",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ مَا یُكَذِّبُ بِهٖۤ اِلَّا كُلُّ مُعْتَدٍ اَثِیْمٍۙ۝۱۲",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "اِذَا تُتْلٰی عَلَیْهِ اٰیٰتُنَا قَالَ اَسَاطِیْرُ الْاَوَّلِیْنَؕ۝۱۳",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "كَلَّا بَلْ ٚ رَانَ عَلٰی قُلُوْبِهِمْ مَّا كَانُوْا یَكْسِبُوْنَ۝۱۴",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "كَلَّاۤ اِنَّهُمْ عَنْ رَّبِّهِمْ یَوْمَىِٕذٍ لَّمَحْجُوْبُوْنَؕ۝۱۵",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "ثُمَّ اِنَّهُمْ لَصَالُوا الْجَحِیْمِؕ۝۱۶",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "ثُمَّ یُقَالُ هٰذَا الَّذِیْ كُنْتُمْ بِهٖ تُكَذِّبُوْنَؕ۝۱۷",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "كَلَّاۤ اِنَّ كِتٰبَ الْاَبْرَارِ لَفِیْ عِلِّیِّیْنَؕ۝۱۸",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا عِلِّیُّوْنَؕ۝۱۹",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "كِتٰبٌ مَّرْقُوْمٌۙ۝۲۰",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "یَّشْهَدُهُ الْمُقَرَّبُوْنَۙ۝۲۱",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "اِنَّ الْاَبْرَارَ لَفِیْ نَعِیْمٍۙ۝۲۲",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "عَلَی الْاَرَآىِٕكِ یَنْظُرُوْنَۙ۝۲۳",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "تَعْرِفُ فِیْ وُجُوْهِهِمْ نَضْرَةَ النَّعِیْمِۚ۝۲۴",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "یُسْقَوْنَ مِنْ رَّحِیْقٍ مَّخْتُوْمٍۙ۝۲۵",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "خِتٰمُهٗ مِسْكٌ ؕ وَ فِیْ ذٰلِكَ فَلْیَتَنَافَسِ الْمُتَنَافِسُوْنَؕ۝۲۶",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَ مِزَاجُهٗ مِنْ تَسْنِیْمٍۙ۝۲۷",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "عَیْنًا یَّشْرَبُ بِهَا الْمُقَرَّبُوْنَؕ۝۲۸",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "اِنَّ الَّذِیْنَ اَجْرَمُوْا كَانُوْا مِنَ الَّذِیْنَ اٰمَنُوْا یَضْحَكُوْنَؗۖ۝۲۹",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَ اِذَا مَرُّوْا بِهِمْ یَتَغَامَزُوْنَؗۖ۝۳۰",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "وَ اِذَا انْقَلَبُوْۤا اِلٰۤی اَهْلِهِمُ انْقَلَبُوْا فَكِهِیْنَؗۖ۝۳۱",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "وَ اِذَا رَاَوْهُمْ قَالُوْۤا اِنَّ هٰۤؤُلَآءِ لَضَآلُّوْنَۙ۝۳۲",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "وَ مَاۤ اُرْسِلُوْا عَلَیْهِمْ حٰفِظِیْنَؕ۝۳۳",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "فَالْیَوْمَ الَّذِیْنَ اٰمَنُوْا مِنَ الْكُفَّارِ یَضْحَكُوْنَۙ۝۳۴",
      "juz": 30,
      "page": 588,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "عَلَی الْاَرَآىِٕكِ ۙ یَنْظُرُوْنَؕ۝۳۵",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "هَلْ ثُوِّبَ الْكُفَّارُ مَا كَانُوْا یَفْعَلُوْنَ۠۝۳۶",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 525,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "83:36"
    }
  ]
}