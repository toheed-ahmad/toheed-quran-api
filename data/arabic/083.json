{
  "surah_id": 83,
  "surah_name": "Al-Mutaffifin",
  "arabic_name": "سُورَةُ الْمُطَفِّفِينَ",
  "revelation_type": "Meccan",
  "total_ayahs": 36,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَیْلٌ لِّلْمُطَفِّفِیْنَۙ",
      "verse_key": "83:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "الَّذِیْنَ اِذَا اكْتَالُوْا عَلَى النَّاسِ یَسْتَوْفُوْنَ٘ۖ",
      "verse_key": "83:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ اِذَا كَالُوْهُمْ اَوْ وَّ زَنُوْهُمْ یُخْسِرُوْنَؕ",
      "verse_key": "83:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اَلَا یَظُنُّ اُولٰٓئِكَ اَنَّهُمْ مَّبْعُوْثُوْنَۙ",
      "verse_key": "83:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "لِیَوْمٍ عَظِیْمٍۙ",
      "verse_key": "83:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "یَّوْمَ یَقُوْمُ النَّاسُ لِرَبِّ الْعٰلَمِیْنَؕ",
      "verse_key": "83:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "كَلَّاۤ اِنَّ كِتٰبَ الْفُجَّارِ لَفِیْ سِجِّیْنٍؕ",
      "verse_key": "83:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا سِجِّیْنٌؕ",
      "verse_key": "83:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "كِتٰبٌ مَّرْقُوْمٌؕ",
      "verse_key": "83:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَۙ",
      "verse_key": "83:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "الَّذِیْنَ یُكَذِّبُوْنَ بِیَوْمِ الدِّیْنِؕ",
      "verse_key": "83:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ مَا یُكَذِّبُ بِهٖۤ اِلَّا كُلُّ مُعْتَدٍ اَثِیْمٍۙ",
      "verse_key": "83:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "اِذَا تُتْلٰى عَلَیْهِ اٰیٰتُنَا قَالَ اَسَاطِیْرُ الْاَوَّلِیْنَؕ",
      "verse_key": "83:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "كَلَّا بَلْ١ٚ رَانَ عَلٰى قُلُوْبِهِمْ مَّا كَانُوْا یَكْسِبُوْنَ",
      "verse_key": "83:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "كَلَّاۤ اِنَّهُمْ عَنْ رَّبِّهِمْ یَوْمَئِذٍ لَّمَحْجُوْبُوْنَؕ",
      "verse_key": "83:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "ثُمَّ اِنَّهُمْ لَصَالُوا الْجَحِیْمِؕ",
      "verse_key": "83:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "ثُمَّ یُقَالُ هٰذَا الَّذِیْ كُنْتُمْ بِهٖ تُكَذِّبُوْنَؕ",
      "verse_key": "83:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "كَلَّاۤ اِنَّ كِتٰبَ الْاَبْرَارِ لَفِیْ عِلِّیِّیْنَؕ",
      "verse_key": "83:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا عِلِّیُّوْنَؕ",
      "verse_key": "83:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "كِتٰبٌ مَّرْقُوْمٌۙ",
      "verse_key": "83:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "یَّشْهَدُهُ الْمُقَرَّبُوْنَۙ",
      "verse_key": "83:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "اِنَّ الْاَبْرَارَ لَفِیْ نَعِیْمٍۙ",
      "verse_key": "83:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "عَلَى الْاَرَآئِكِ یَنْظُرُوْنَۙ",
      "verse_key": "83:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "تَعْرِفُ فِیْ وُجُوْهِهِمْ نَضْرَةَ النَّعِیْمِۚ",
      "verse_key": "83:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "یُسْقَوْنَ مِنْ رَّحِیْقٍ مَّخْتُوْمٍۙ",
      "verse_key": "83:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "خِتٰمُهٗ مِسْكٌ١ؕ وَ فِیْ ذٰلِكَ فَلْیَتَنَافَسِ الْمُتَنَافِسُوْنَؕ",
      "verse_key": "83:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَ مِزَاجُهٗ مِنْ تَسْنِیْمٍۙ",
      "verse_key": "83:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "عَیْنًا یَّشْرَبُ بِهَا الْمُقَرَّبُوْنَؕ",
      "verse_key": "83:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "اِنَّ الَّذِیْنَ اَجْرَمُوْا كَانُوْا مِنَ الَّذِیْنَ اٰمَنُوْا یَضْحَكُوْنَ٘ۖ",
      "verse_key": "83:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَ اِذَا مَرُّوْا بِهِمْ یَتَغَامَزُوْنَ٘ۖ",
      "verse_key": "83:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "وَ اِذَا انْقَلَبُوْۤا اِلٰۤى اَهْلِهِمُ انْقَلَبُوْا فَكِهِیْنَ٘ۖ",
      "verse_key": "83:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "وَ اِذَا رَاَوْهُمْ قَالُوْۤا اِنَّ هٰۤؤُلَآءِ لَضَآلُّوْنَۙ",
      "verse_key": "83:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "وَ مَاۤ اُرْسِلُوْا عَلَیْهِمْ حٰفِظِیْنَؕ",
      "verse_key": "83:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "فَالْیَوْمَ الَّذِیْنَ اٰمَنُوْا مِنَ الْكُفَّارِ یَضْحَكُوْنَۙ",
      "verse_key": "83:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "عَلَى الْاَرَآئِكِ١ۙ یَنْظُرُوْنَؕ",
      "verse_key": "83:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "هَلْ ثُوِّبَ الْكُفَّارُ مَا كَانُوْا یَفْعَلُوْنَ۠",
      "verse_key": "83:36"
    }
  ]
}