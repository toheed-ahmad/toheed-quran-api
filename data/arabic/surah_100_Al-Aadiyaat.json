      "sajdah": false,
      "verse_key": "100:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَوَسَطْنَ بِهٖ جَمْعًاۙ۝۵",
      "juz": 30,
      "page": 599,
      "manzil": 7,
      "ruku": 542,
      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "100:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اِنَّ الْاِنْسَانَ لِرَبِّهٖ لَكَنُوْدٌۚ۝۶",
      "juz": 30,
      "page": 599,
      "manzil": 7,
      "ruku": 542,
      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "100:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ اِنَّهٗ عَلٰی ذٰلِكَ لَشَهِیْدٌۚ۝۷",
      "juz": 30,
      "page": 599,
      "manzil": 7,
      "ruku": 542,
