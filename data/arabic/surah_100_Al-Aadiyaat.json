      "hizb": 60,
      "hizbQuarter": 240,
      "sajdah": false,
      "verse_key": "100:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ حُصِّلَ مَا فِی الصُّدُوْرِۙ۝۱۰",
      "juz": 30,
      "page": 600,
      "manzil": 7,
