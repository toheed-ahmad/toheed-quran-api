      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "100:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ اِنَّهٗ لِحُبِّ الْخَیْرِ لَشَدِیْدٌؕ۝۸",
      "juz": 30,
      "page": 599,
      "manzil": 7,
      "ruku": 542,
      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "100:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "اَفَلَا یَعْلَمُ اِذَا بُعْثِرَ مَا فِی الْقُبُوْرِۙ۝۹",
      "juz": 30,
      "page": 599,
      "manzil": 7,
