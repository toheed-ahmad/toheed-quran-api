{
  "surah_id": 75,
  "surah_name": "Al-Qiyaama",
  "arabic_name": "爻購賵乇賻丞購 丕賱賯賽賷賻丕賲賻丞賽",
  "revelation_type": "Meccan",
  "total_ayahs": 40,
  "bismillah": "亘賽爻賿賲賽 丕賱賱賾侔賴賽 丕賱乇賾賻丨賿賲侔賳賽 丕賱乇賾賻丨賽蹖賿賲賽",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "賱賻丕郅 丕購賯賿爻賽賲購 亘賽蹖賻賵賿賲賽 丕賱賿賯賽蹖侔賲賻丞賽蹤蹪郾",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "賵賻 賱賻丕郅 丕購賯賿爻賽賲購 亘賽丕賱賳賾賻賮賿爻賽 丕賱賱賾賻賵賾賻丕賲賻丞賽貢蹪鄄",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "丕賻蹖賻丨賿爻賻亘購 丕賱賿丕賽賳賿爻賻丕賳購 丕賻賱賾賻賳賿 賳賾賻噩賿賲賻毓賻 毓賽馗賻丕賲賻賴贄貢蹪鄢",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "亘賻賱侔賶 賯侔丿賽乇賽蹖賿賳賻 毓賻賱侔郅蹖 丕賻賳賿 賳賾購爻賻賵賾賽蹖賻 亘賻賳賻丕賳賻賴贄蹪鄞",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "亘賻賱賿 蹖購乇賽蹖賿丿購 丕賱賿丕賽賳賿爻賻丕賳購 賱賽蹖賻賮賿噩購乇賻 丕賻賲賻丕賲賻賴贄蹥蹪鄣",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "蹖賻爻賿賭贁賻賱購 丕賻蹖賾賻丕賳賻 蹖賻賵賿賲購 丕賱賿賯賽蹖侔賲賻丞賽貢蹪鄱",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "賮賻丕賽匕賻丕 亘賻乇賽賯賻 丕賱賿亘賻氐賻乇購蹤蹪鄯",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "賵賻 禺賻爻賻賮賻 丕賱賿賯賻賲賻乇購蹤蹪鄹",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "賵賻 噩購賲賽毓賻 丕賱卮賾賻賲賿爻購 賵賻 丕賱賿賯賻賲賻乇購蹤蹪酃",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "蹖賻賯購賵賿賱購 丕賱賿丕賽賳賿爻賻丕賳購 蹖賻賵賿賲賻賶贂賽匕賺 丕賻蹖賿賳賻 丕賱賿賲賻賮賻乇賾購蹥蹪郾郯",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "賰賻賱賾賻丕 賱賻丕 賵賻夭賻乇賻貢蹪郾郾",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "丕賽賱侔賶 乇賻亘賾賽賰賻 蹖賻賵賿賲賻賶贂賽匕賽 蹮賽丕賱賿賲購爻賿鬲賻賯賻乇賾購貢蹪郾鄄",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "蹖購賳賻亘賾賻丐購丕 丕賱賿丕賽賳賿爻賻丕賳購 蹖賻賵賿賲賻賶贂賽匕賺郗 亘賽賲賻丕 賯賻丿賾賻賲賻 賵賻 丕賻禺賾賻乇賻貢蹪郾鄢",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "亘賻賱賽 丕賱賿丕賽賳賿爻賻丕賳購 毓賻賱侔賶 賳賻賮賿爻賽賴贃 亘賻氐賽蹖賿乇賻丞賹蹤蹪郾鄞",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "賵賾賻 賱賻賵賿 丕賻賱賿賯侔賶 賲賻毓賻丕匕賽蹖賿乇賻賴贄貢蹪郾鄣",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "賱賻丕 鬲購丨賻乇賾賽賰賿 亘賽賴贃 賱賽爻賻丕賳賻賰賻 賱賽鬲賻毓賿噩賻賱賻 亘賽賴贃貢蹪郾鄱",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "丕賽賳賾賻 毓賻賱賻蹖賿賳賻丕 噩賻賲賿毓賻賴贄 賵賻 賯購乇賿丕侔賳賻賴贄蹥蹡蹪郾鄯",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "賮賻丕賽匕賻丕 賯賻乇賻丕賿賳侔賴購 賮賻丕鬲賾賻亘賽毓賿 賯購乇賿丕侔賳賻賴贄蹥蹪郾鄹",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "孬購賲賾賻 丕賽賳賾賻 毓賻賱賻蹖賿賳賻丕 亘賻蹖賻丕賳賻賴贄貢蹪郾酃",
      "juz": 29,
      "page": 577,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "賰賻賱賾賻丕 亘賻賱賿 鬲購丨賽亘賾購賵賿賳賻 丕賱賿毓賻丕噩賽賱賻丞賻蹤蹪鄄郯",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "賵賻 鬲賻匕賻乇購賵賿賳賻 丕賱賿丕侔禺賽乇賻丞賻貢蹪鄄郾",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "賵購噩購賵賿賴賹 蹖賾賻賵賿賲賻賶贂賽匕賺 賳賾賻丕囟賽乇賻丞賹蹤蹪鄄鄄",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "丕賽賱侔賶 乇賻亘賾賽賴賻丕 賳賻丕馗賽乇賻丞賹蹥蹪鄄鄢",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "賵賻 賵購噩購賵賿賴賹 蹖賾賻賵賿賲賻賶贂賽匕賺郗 亘賻丕爻賽乇賻丞賹蹤蹪鄄鄞",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "鬲賻馗購賳賾購 丕賻賳賿 蹖賾購賮賿毓賻賱賻 亘賽賴賻丕 賮賻丕賯賽乇賻丞賹貢蹪鄄鄣",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "賰賻賱賾賻丕郅 丕賽匕賻丕 亘賻賱賻睾賻鬲賽 丕賱鬲賾賻乇賻丕賯賽蹖賻蹤蹪鄄鄱",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "賵賻 賯賽蹖賿賱賻 賲賻賳賿 贇 乇賻丕賯賺蹤蹪鄄鄯",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "賵賾賻 馗賻賳賾賻 丕賻賳賾賻賴購 丕賱賿賮賽乇賻丕賯購蹤蹪鄄鄹",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "賵賻 丕賱賿鬲賻賮賾賻鬲賽 丕賱爻賾賻丕賯購 亘賽丕賱爻賾賻丕賯賽蹤蹪鄄酃",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "丕賽賱侔賶 乇賻亘賾賽賰賻 蹖賻賵賿賲賻賶贂賽匕賽 蹮賽丕賱賿賲賻爻賻丕賯購  貢蹱蹪鄢郯",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 512,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "賮賻賱賻丕 氐賻丿賾賻賯賻 賵賻 賱賻丕 氐賻賱賾侔賶蹤蹪鄢郾",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 513,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "賵賻 賱侔賰賽賳賿 賰賻匕賾賻亘賻 賵賻 鬲賻賵賻賱賾侔賶蹤蹪鄢鄄",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 513,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "孬購賲賾賻 匕賻賴賻亘賻 丕賽賱侔郅蹖 丕賻賴賿賱賽賴贃 蹖賻鬲賻賲賻胤賾侔賶貢蹪鄢鄢",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 513,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "丕賻賵賿賱侔賶 賱賻賰賻 賮賻丕賻賵賿賱侔賶蹤蹪鄢鄞",
      "juz": 29,
