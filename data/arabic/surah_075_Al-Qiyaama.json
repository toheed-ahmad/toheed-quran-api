      "manzil": 7,
      "ruku": 513,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "孬購賲賾賻 丕賻賵賿賱侔賶 賱賻賰賻 賮賻丕賻賵賿賱侔賶貢蹪鄢鄣",
      "juz": 29,
