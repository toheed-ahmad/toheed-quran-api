      "verse_key": "75:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "丕賻蹖賻丨賿爻賻亘購 丕賱賿丕賽賳賿爻賻丕賳購 丕賻賳賿 蹖賾購鬲賿乇賻賰賻 爻購丿賸蹖貢蹪鄢鄱",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 513,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "75:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "丕賻賱賻賲賿 蹖賻賰購 賳購胤賿賮賻丞賸 賲賾賽賳賿 賲賾賻賳賽蹖賾賺 蹖賾購賲賿賳侔賶蹤蹪鄢鄯",
      "juz": 29,
