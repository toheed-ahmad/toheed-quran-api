{
  "surah_id": 93,
  "surah_name": "Ad-Duha",
  "arabic_name": "سُورَةُ الضُّحَى",
  "revelation_type": "Meccan",
  "total_ayahs": 11,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الضُّحٰىۙ",
      "verse_key": "93:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ الَّیْلِ اِذَا سَجٰىۙ",
      "verse_key": "93:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "مَا وَدَّعَكَ رَبُّكَ وَ مَا قَلٰىؕ",
      "verse_key": "93:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ لَلْاٰخِرَةُ خَیْرٌ لَّكَ مِنَ الْاُوْلٰىؕ",
      "verse_key": "93:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ لَسَوْفَ یُعْطِیْكَ رَبُّكَ فَتَرْضٰىؕ",
      "verse_key": "93:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اَلَمْ یَجِدْكَ یَتِیْمًا فَاٰوٰى۪",
      "verse_key": "93:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ وَجَدَكَ ضَآلًّا فَهَدٰى۪",
      "verse_key": "93:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ وَجَدَكَ عَآئِلًا فَاَغْنٰىؕ",
      "verse_key": "93:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "فَاَمَّا الْیَتِیْمَ فَلَا تَقْهَرْؕ",
      "verse_key": "93:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ اَمَّا السَّآئِلَ فَلَا تَنْهَرْؕ",
      "verse_key": "93:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ اَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ۠",
      "verse_key": "93:11"
    }
  ]
}