      "manzil": 5,
      "ruku": 382,
      "hizb": 44,
      "hizbQuarter": 176,
      "sajdah": false,
      "verse_key": "36:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "丕賽賳賾賽蹖賿郅 丕侔賲賻賳賿鬲購 亘賽乇賻亘賾賽賰購賲賿 賮賻丕爻賿賲賻毓購賵賿賳賽貢蹪鄄鄣",
      "juz": 22,
      "page": 441,
      "manzil": 5,
      "ruku": 382,
      "hizb": 44,
      "hizbQuarter": 176,
