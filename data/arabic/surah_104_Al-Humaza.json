      "hizbQuarter": 240,
      "sajdah": false,
      "verse_key": "104:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "ِ۟الَّذِیْ جَمَعَ مَالًا وَّ عَدَّدَهٗۙ۝۲",
      "juz": 30,
      "page": 601,
      "manzil": 7,
      "ruku": 546,
      "hizb": 60,
      "hizbQuarter": 240,
      "sajdah": false,
      "verse_key": "104:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "یَحْسَبُ اَنَّ مَالَهٗۤ اَخْلَدَهٗۚ۝۳",
      "juz": 30,
      "page": 601,
      "manzil": 7,
      "ruku": 546,
      "hizb": 60,
      "hizbQuarter": 240,
      "sajdah": false,
      "verse_key": "104:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "كَلَّا لَیُنْۢبَذَنَّ فِی الْحُطَمَةِؗۖ۝۴",
      "juz": 30,
      "page": 601,
      "manzil": 7,
      "ruku": 546,
      "hizb": 60,
      "hizbQuarter": 240,
      "sajdah": false,
      "verse_key": "104:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا الْحُطَمَةُؕ۝۵",
      "juz": 30,
      "page": 601,
      "manzil": 7,
      "ruku": 546,
      "hizb": 60,
      "hizbQuarter": 240,
      "sajdah": false,
      "verse_key": "104:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "نَارُ اللّٰهِ الْمُوْقَدَةُۙ۝۶",
      "juz": 30,
      "page": 601,
      "manzil": 7,
      "ruku": 546,
      "hizb": 60,
      "hizbQuarter": 240,
      "sajdah": false,
      "verse_key": "104:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "الَّتِیْ تَطَّلِعُ عَلَی الْاَفْـِٕدَةِؕ۝۷",
      "juz": 30,
      "page": 601,
      "manzil": 7,
      "ruku": 546,
      "hizb": 60,
      "hizbQuarter": 240,
      "sajdah": false,
      "verse_key": "104:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اِنَّهَا عَلَیْهِمْ مُّؤْصَدَةٌۙ۝۸",
      "juz": 30,
      "page": 601,
      "manzil": 7,
