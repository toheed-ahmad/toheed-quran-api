{
  "surah_id": 74,
  "surah_name": "Al-Muddaththir",
  "arabic_name": "سُورَةُ الْمُدَّثِّرِ",
  "revelation_type": "Meccan",
  "total_ayahs": 56,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "یٰۤاَیُّهَا الْمُدَّثِّرُۙ",
      "verse_key": "74:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "قُمْ فَاَنْذِرْ۪ۙ",
      "verse_key": "74:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ رَبَّكَ فَكَبِّرْ۪ۙ",
      "verse_key": "74:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ ثِیَابَكَ فَطَهِّرْ۪ۙ",
      "verse_key": "74:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ الرُّجْزَ فَاهْجُرْ۪ۙ",
      "verse_key": "74:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَ لَا تَمْنُنْ تَسْتَكْثِرُ۪ۙ",
      "verse_key": "74:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ لِرَبِّكَ فَاصْبِرْؕ",
      "verse_key": "74:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "فَاِذَا نُقِرَ فِی النَّاقُوْرِۙ",
      "verse_key": "74:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "فَذٰلِكَ یَوْمَئِذٍ یَّوْمٌ عَسِیْرٌۙ",
      "verse_key": "74:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "عَلَى الْكٰفِرِیْنَ غَیْرُ یَسِیْرٍ",
      "verse_key": "74:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "ذَرْنِیْ وَ مَنْ خَلَقْتُ وَحِیْدًاۙ",
      "verse_key": "74:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَّ جَعَلْتُ لَهٗ مَالًا مَّمْدُوْدًاۙ",
      "verse_key": "74:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَّ بَنِیْنَ شُهُوْدًاۙ",
      "verse_key": "74:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَّ مَهَّدْتُّ لَهٗ تَمْهِیْدًاۙ",
      "verse_key": "74:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "ثُمَّ یَطْمَعُ اَنْ اَزِیْدَۗۙ",
      "verse_key": "74:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "كَلَّا١ؕ اِنَّهٗ كَانَ لِاٰیٰتِنَا عَنِیْدًاؕ",
      "verse_key": "74:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "سَاُرْهِقُهٗ صَعُوْدًاؕ",
      "verse_key": "74:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "اِنَّهٗ فَكَّرَ وَ قَدَّرَۙ",
      "verse_key": "74:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "فَقُتِلَ كَیْفَ قَدَّرَۙ",
      "verse_key": "74:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "ثُمَّ قُتِلَ كَیْفَ قَدَّرَۙ",
      "verse_key": "74:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "ثُمَّ نَظَرَۙ",
      "verse_key": "74:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "ثُمَّ عَبَسَ وَ بَسَرَۙ",
      "verse_key": "74:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "ثُمَّ اَدْبَرَ وَ اسْتَكْبَرَۙ",
      "verse_key": "74:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "فَقَالَ اِنْ هٰذَاۤ اِلَّا سِحْرٌ یُّؤْثَرُۙ",
      "verse_key": "74:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اِنْ هٰذَاۤ اِلَّا قَوْلُ الْبَشَرِؕ",
      "verse_key": "74:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "سَاُصْلِیْهِ سَقَرَ",
      "verse_key": "74:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا سَقَرُؕ",
      "verse_key": "74:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "لَا تُبْقِیْ وَ لَا تَذَرُۚ",
      "verse_key": "74:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "لَوَّاحَةٌ لِّلْبَشَرِۚۖ",
      "verse_key": "74:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "عَلَیْهَا تِسْعَةَ عَشَرَؕ",
      "verse_key": "74:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "وَ مَا جَعَلْنَاۤ اَصْحٰبَ النَّارِ اِلَّا مَلٰٓئِكَةً١۪ وَّ مَا جَعَلْنَا عِدَّتَهُمْ اِلَّا فِتْنَةً لِّلَّذِیْنَ كَفَرُوْا١ۙ لِیَسْتَیْقِنَ الَّذِیْنَ اُوْتُوا الْكِتٰبَ وَ یَزْدَادَ الَّذِیْنَ اٰمَنُوْۤا اِیْمَانًا وَّ لَا یَرْتَابَ الَّذِیْنَ اُوْتُوا الْكِتٰبَ وَ الْمُؤْمِنُوْنَ١ۙ وَ لِیَقُوْلَ الَّذِیْنَ فِیْ قُلُوْبِهِمْ مَّرَضٌ وَّ الْكٰفِرُوْنَ مَا ذَاۤ اَرَادَ اللّٰهُ بِهٰذَا مَثَلًا١ؕ كَذٰلِكَ یُضِلُّ اللّٰهُ مَنْ یَّشَآءُ وَ یَهْدِیْ مَنْ یَّشَآءُ١ؕ وَ مَا یَعْلَمُ جُنُوْدَ رَبِّكَ اِلَّا هُوَ١ؕ وَ مَا هِیَ اِلَّا ذِكْرٰى لِلْبَشَرِ۠",
      "verse_key": "74:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "كَلَّا وَ الْقَمَرِۙ",
      "verse_key": "74:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "وَ الَّیْلِ اِذْ اَدْبَرَۙ",
      "verse_key": "74:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَ الصُّبْحِ اِذَاۤ اَسْفَرَۙ",
      "verse_key": "74:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اِنَّهَا لَاِحْدَى الْكُبَرِۙ",
      "verse_key": "74:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "نَذِیْرًا لِّلْبَشَرِۙ",
      "verse_key": "74:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "لِمَنْ شَآءَ مِنْكُمْ اَنْ یَّتَقَدَّمَ اَوْ یَتَاَخَّرَؕ",
      "verse_key": "74:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "كُلُّ نَفْسٍۭ بِمَا كَسَبَتْ رَهِیْنَةٌۙ",
      "verse_key": "74:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "اِلَّاۤ اَصْحٰبَ الْیَمِیْنِؕۛ",
      "verse_key": "74:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "فِیْ جَنّٰتٍ١ۛؕ۫ یَتَسَآءَلُوْنَۙ",
      "verse_key": "74:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "عَنِ الْمُجْرِمِیْنَۙ",
      "verse_key": "74:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "مَا سَلَكَكُمْ فِیْ سَقَرَ",
      "verse_key": "74:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "قَالُوْا لَمْ نَكُ مِنَ الْمُصَلِّیْنَۙ",
      "verse_key": "74:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "وَ لَمْ نَكُ نُطْعِمُ الْمِسْكِیْنَۙ",
      "verse_key": "74:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "وَ كُنَّا نَخُوْضُ مَعَ الْخَآئِضِیْنَۙ",
      "verse_key": "74:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "وَ كُنَّا نُكَذِّبُ بِیَوْمِ الدِّیْنِۙ",
      "verse_key": "74:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "حَتّٰۤى اَتٰىنَا الْیَقِیْنُؕ",
      "verse_key": "74:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "فَمَا تَنْفَعُهُمْ شَفَاعَةُ الشّٰفِعِیْنَؕ",
      "verse_key": "74:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "فَمَا لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِیْنَۙ",
      "verse_key": "74:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "كَاَنَّهُمْ حُمُرٌ مُّسْتَنْفِرَةٌۙ",
      "verse_key": "74:50"
    },
    {
      "ayah_number": 51,
      "arabic_text": "فَرَّتْ مِنْ قَسْوَرَةٍؕ",
      "verse_key": "74:51"
    },
    {
      "ayah_number": 52,
      "arabic_text": "بَلْ یُرِیْدُ كُلُّ امْرِئٍ مِّنْهُمْ اَنْ یُّؤْتٰى صُحُفًا مُّنَشَّرَةًۙ",
      "verse_key": "74:52"
    },
    {
      "ayah_number": 53,
      "arabic_text": "كَلَّا١ؕ بَلْ لَّا یَخَافُوْنَ الْاٰخِرَةَؕ",
      "verse_key": "74:53"
    },
    {
      "ayah_number": 54,
      "arabic_text": "كَلَّاۤ اِنَّهٗ تَذْكِرَةٌۚ",
      "verse_key": "74:54"
    },
    {
      "ayah_number": 55,
      "arabic_text": "فَمَنْ شَآءَ ذَكَرَهٗؕ",
      "verse_key": "74:55"
    },
    {
      "ayah_number": 56,
      "arabic_text": "وَ مَا یَذْكُرُوْنَ اِلَّاۤ اَنْ یَّشَآءَ اللّٰهُ١ؕ هُوَ اَهْلُ التَّقْوٰى وَ اَهْلُ الْمَغْفِرَةِ۠",
      "verse_key": "74:56"
    }
  ]
}