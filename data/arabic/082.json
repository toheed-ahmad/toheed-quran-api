{
  "surah_id": 82,
  "surah_name": "Al-Infitar",
  "arabic_name": "سُورَةُ الْإِنْفِطَارِ",
  "revelation_type": "Meccan",
  "total_ayahs": 19,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اِذَا السَّمَآءُ انْفَطَرَتْۙ",
      "verse_key": "82:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ اِذَا الْكَوَاكِبُ انْتَثَرَتْۙ",
      "verse_key": "82:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ اِذَا الْبِحَارُ فُجِّرَتْۙ",
      "verse_key": "82:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ اِذَا الْقُبُوْرُ بُعْثِرَتْۙ",
      "verse_key": "82:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَ اَخَّرَتْؕ",
      "verse_key": "82:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "یٰۤاَیُّهَا الْاِنْسَانُ مَا غَرَّكَ بِرَبِّكَ الْكَرِیْمِۙ",
      "verse_key": "82:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "الَّذِیْ خَلَقَكَ فَسَوّٰىكَ فَعَدَلَكَۙ",
      "verse_key": "82:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "فِیْۤ اَیِّ صُوْرَةٍ مَّا شَآءَ رَكَّبَكَؕ",
      "verse_key": "82:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "كَلَّا بَلْ تُكَذِّبُوْنَ بِالدِّیْنِۙ",
      "verse_key": "82:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ اِنَّ عَلَیْكُمْ لَحٰفِظِیْنَۙ",
      "verse_key": "82:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "كِرَامًا كَاتِبِیْنَۙ",
      "verse_key": "82:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "یَعْلَمُوْنَ مَا تَفْعَلُوْنَ",
      "verse_key": "82:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "اِنَّ الْاَبْرَارَ لَفِیْ نَعِیْمٍۚ",
      "verse_key": "82:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ اِنَّ الْفُجَّارَ لَفِیْ جَحِیْمٍۚۖ",
      "verse_key": "82:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "یَّصْلَوْنَهَا یَوْمَ الدِّیْنِ",
      "verse_key": "82:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "وَ مَا هُمْ عَنْهَا بِغَآئِبِیْنَؕ",
      "verse_key": "82:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا یَوْمُ الدِّیْنِۙ",
      "verse_key": "82:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "ثُمَّ مَاۤ اَدْرٰىكَ مَا یَوْمُ الدِّیْنِؕ",
      "verse_key": "82:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "یَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَیْئًا١ؕ وَ الْاَمْرُ یَوْمَئِذٍ لِّلّٰهِ۠",
      "verse_key": "82:19"
    }
  ]
}