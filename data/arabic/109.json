  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "قُلْ یٰۤاَیُّهَا الْكٰفِرُوْنَۙ",
      "verse_key": "109:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "لَاۤ اَعْبُدُ مَا تَعْبُدُوْنَۙ",
      "verse_key": "109:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ لَاۤ اَنْتُمْ عٰبِدُوْنَ مَاۤ اَعْبُدُۚ",
      "verse_key": "109:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ لَاۤ اَنَا عَابِدٌ مَّا عَبَدْتُّمْۙ",
      "verse_key": "109:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ لَاۤ اَنْتُمْ عٰبِدُوْنَ مَاۤ اَعْبُدُؕ",
      "verse_key": "109:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "لَكُمْ دِیْنُكُمْ وَ لِیَ دِیْنِ۠",
