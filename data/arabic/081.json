{
  "surah_id": 81,
  "surah_name": "At-Takwir",
  "arabic_name": "سُورَةُ التَّكْوِيرِ",
  "revelation_type": "Meccan",
  "total_ayahs": 29,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اِذَا الشَّمْسُ كُوِّرَتْ۪ۙ",
      "verse_key": "81:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ اِذَا النُّجُوْمُ انْكَدَرَتْ۪ۙ",
      "verse_key": "81:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ اِذَا الْجِبَالُ سُیِّرَتْ۪ۙ",
      "verse_key": "81:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ اِذَا الْعِشَارُ عُطِّلَتْ۪ۙ",
      "verse_key": "81:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ اِذَا الْوُحُوْشُ حُشِرَتْ۪ۙ",
      "verse_key": "81:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَ اِذَا الْبِحَارُ سُجِّرَتْ۪ۙ",
      "verse_key": "81:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ اِذَا النُّفُوْسُ زُوِّجَتْ۪ۙ",
      "verse_key": "81:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ اِذَا الْمَوْءٗدَةُ سُئِلَتْ۪ۙ",
      "verse_key": "81:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "بِاَیِّ ذَنْۢبٍ قُتِلَتْۚ",
      "verse_key": "81:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ اِذَا الصُّحُفُ نُشِرَتْ۪ۙ",
      "verse_key": "81:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ اِذَا السَّمَآءُ كُشِطَتْ۪ۙ",
      "verse_key": "81:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ اِذَا الْجَحِیْمُ سُعِّرَتْ۪ۙ",
      "verse_key": "81:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَ اِذَا الْجَنَّةُ اُزْلِفَتْ۪ۙ",
      "verse_key": "81:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "عَلِمَتْ نَفْسٌ مَّاۤ اَحْضَرَتْؕ",
      "verse_key": "81:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "فَلَاۤ اُقْسِمُ بِالْخُنَّسِۙ",
      "verse_key": "81:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "الْجَوَارِ الْكُنَّسِۙ",
      "verse_key": "81:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ الَّیْلِ اِذَا عَسْعَسَۙ",
      "verse_key": "81:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَ الصُّبْحِ اِذَا تَنَفَّسَۙ",
      "verse_key": "81:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "اِنَّهٗ لَقَوْلُ رَسُوْلٍ كَرِیْمٍۙ",
      "verse_key": "81:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "ذِیْ قُوَّةٍ عِنْدَ ذِی الْعَرْشِ مَكِیْنٍۙ",
      "verse_key": "81:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "مُّطَاعٍ ثَمَّ اَمِیْنٍؕ",
      "verse_key": "81:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "وَ مَا صَاحِبُكُمْ بِمَجْنُوْنٍۚ",
      "verse_key": "81:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "وَ لَقَدْ رَاٰهُ بِالْاُفُقِ الْمُبِیْنِۚ",
      "verse_key": "81:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَ مَا هُوَ عَلَى الْغَیْبِ بِضَنِیْنٍۚ",
      "verse_key": "81:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "وَ مَا هُوَ بِقَوْلِ شَیْطٰنٍ رَّجِیْمٍۙ",
      "verse_key": "81:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "فَاَیْنَ تَذْهَبُوْنَؕ",
      "verse_key": "81:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "اِنْ هُوَ اِلَّا ذِكْرٌ لِّلْعٰلَمِیْنَۙ",
      "verse_key": "81:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "لِمَنْ شَآءَ مِنْكُمْ اَنْ یَّسْتَقِیْمَؕ",
      "verse_key": "81:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَ مَا تَشَآءُوْنَ اِلَّاۤ اَنْ یَّشَآءَ اللّٰهُ رَبُّ الْعٰلَمِیْنَ۠",
      "verse_key": "81:29"
    }
  ]
}