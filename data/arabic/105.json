  "total_ayahs": 5,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اَلَمْ تَرَ كَیْفَ فَعَلَ رَبُّكَ بِاَصْحٰبِ الْفِیْلِؕ",
      "verse_key": "105:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "اَلَمْ یَجْعَلْ كَیْدَهُمْ فِیْ تَضْلِیْلٍۙ",
      "verse_key": "105:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَّ اَرْسَلَ عَلَیْهِمْ طَیْرًا اَبَابِیْلَۙ",
      "verse_key": "105:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "تَرْمِیْهِمْ بِحِجَارَةٍ مِّنْ سِجِّیْلٍ۪ۙ",
      "verse_key": "105:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَجَعَلَهُمْ كَعَصْفٍ مَّاْكُوْلٍ۠",
      "verse_key": "105:5"
    }
  ]
}