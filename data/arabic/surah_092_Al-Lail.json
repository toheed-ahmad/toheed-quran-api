  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الَّیْلِ اِذَا یَغْشٰیۙ۝۱",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ النَّهَارِ اِذَا تَجَلّٰیۙ۝۲",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ مَا خَلَقَ الذَّكَرَ وَ الْاُنْثٰۤیۙ۝۳",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اِنَّ سَعْیَكُمْ لَشَتّٰیؕ۝۴",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَاَمَّا مَنْ اَعْطٰی وَ اتَّقٰیۙ۝۵",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَ صَدَّقَ بِالْحُسْنٰیۙ۝۶",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "فَسَنُیَسِّرُهٗ لِلْیُسْرٰیؕ۝۷",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ اَمَّا مَنْۢ بَخِلَ وَ اسْتَغْنٰیۙ۝۸",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ كَذَّبَ بِالْحُسْنٰیۙ۝۹",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فَسَنُیَسِّرُهٗ لِلْعُسْرٰیؕ۝۱۰",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ مَا یُغْنِیْ عَنْهُ مَالُهٗۤ اِذَا تَرَدّٰیؕ۝۱۱",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "اِنَّ عَلَیْنَا لَلْهُدٰیؗۖ۝۱۲",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَ اِنَّ لَنَا لَلْاٰخِرَةَ وَ الْاُوْلٰی۝۱۳",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "فَاَنْذَرْتُكُمْ نَارًا تَلَظّٰیۚ۝۱۴",
      "juz": 30,
      "page": 595,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "لَا یَصْلٰىهَاۤ اِلَّا الْاَشْقَیۙ۝۱۵",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "الَّذِیْ كَذَّبَ وَ تَوَلّٰیؕ۝۱۶",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ سَیُجَنَّبُهَا الْاَتْقَیۙ۝۱۷",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "الَّذِیْ یُؤْتِیْ مَالَهٗ یَتَزَكّٰیۚ۝۱۸",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ مَا لِاَحَدٍ عِنْدَهٗ مِنْ نِّعْمَةٍ تُجْزٰۤیۙ۝۱۹",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 534,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "92:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "اِلَّا ابْتِغَآءَ وَجْهِ رَبِّهِ الْاَعْلٰیۚ۝۲۰",
      "juz": 30,
      "page": 596,
      "manzil": 7,
