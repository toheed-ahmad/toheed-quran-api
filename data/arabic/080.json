{
  "surah_id": 80,
  "surah_name": "'Abasa",
  "arabic_name": "سُورَةُ عَبَسَ",
  "revelation_type": "Meccan",
  "total_ayahs": 42,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "عَبَسَ وَ تَوَلّٰۤىۙ",
      "verse_key": "80:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "اَنْ جَآءَهُ الْاَعْمٰىؕ",
      "verse_key": "80:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ مَا یُدْرِیْكَ لَعَلَّهٗ یَزَّكّٰۤىۙ",
      "verse_key": "80:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اَوْ یَذَّكَّرُ فَتَنْفَعَهُ الذِّكْرٰىؕ",
      "verse_key": "80:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "اَمَّا مَنِ اسْتَغْنٰىۙ",
      "verse_key": "80:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "فَاَنْتَ لَهٗ تَصَدّٰىؕ",
      "verse_key": "80:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ مَا عَلَیْكَ اَلَّا یَزَّكّٰىؕ",
      "verse_key": "80:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ اَمَّا مَنْ جَآءَكَ یَسْعٰىۙ",
      "verse_key": "80:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ هُوَ یَخْشٰىۙ",
      "verse_key": "80:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فَاَنْتَ عَنْهُ تَلَهّٰىۚ",
      "verse_key": "80:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "كَلَّاۤ اِنَّهَا تَذْكِرَةٌۚ",
      "verse_key": "80:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "فَمَنْ شَآءَ ذَكَرَهٗۘ",
      "verse_key": "80:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "فِیْ صُحُفٍ مُّكَرَّمَةٍۙ",
      "verse_key": "80:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "مَّرْفُوْعَةٍ مُّطَهَّرَةٍۭۙ",
      "verse_key": "80:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "بِاَیْدِیْ سَفَرَةٍۙ",
      "verse_key": "80:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "كِرَامٍۭ بَرَرَةٍؕ",
      "verse_key": "80:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "قُتِلَ الْاِنْسَانُ مَاۤ اَكْفَرَهٗؕ",
      "verse_key": "80:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "مِنْ اَیِّ شَیْءٍ خَلَقَهٗؕ",
      "verse_key": "80:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "مِنْ نُّطْفَةٍ١ؕ خَلَقَهٗ فَقَدَّرَهٗۙ",
      "verse_key": "80:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "ثُمَّ السَّبِیْلَ یَسَّرَهٗۙ",
      "verse_key": "80:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "ثُمَّ اَمَاتَهٗ فَاَقْبَرَهٗۙ",
      "verse_key": "80:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "ثُمَّ اِذَا شَآءَ اَنْشَرَهٗؕ",
      "verse_key": "80:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "كَلَّا لَمَّا یَقْضِ مَاۤ اَمَرَهٗؕ",
      "verse_key": "80:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "فَلْیَنْظُرِ الْاِنْسَانُ اِلٰى طَعَامِهٖۤۙ",
      "verse_key": "80:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اَنَّا صَبَبْنَا الْمَآءَ صَبًّاۙ",
      "verse_key": "80:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "ثُمَّ شَقَقْنَا الْاَرْضَ شَقًّاۙ",
      "verse_key": "80:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "فَاَنْۢبَتْنَا فِیْهَا حَبًّاۙ",
      "verse_key": "80:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "وَّ عِنَبًا وَّ قَضْبًاۙ",
      "verse_key": "80:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَّ زَیْتُوْنًا وَّ نَخْلًاۙ",
      "verse_key": "80:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَّ حَدَآئِقَ غُلْبًاۙ",
      "verse_key": "80:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "وَّ فَاكِهَةً وَّ اَبًّاۙ",
      "verse_key": "80:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "مَّتَاعًا لَّكُمْ وَ لِاَنْعَامِكُمْؕ",
      "verse_key": "80:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "فَاِذَا جَآءَتِ الصَّآخَّةُ٘",
      "verse_key": "80:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "یَوْمَ یَفِرُّ الْمَرْءُ مِنْ اَخِیْهِۙ",
      "verse_key": "80:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "وَ اُمِّهٖ وَ اَبِیْهِۙ",
      "verse_key": "80:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "وَ صَاحِبَتِهٖ وَ بَنِیْهِؕ",
      "verse_key": "80:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "لِكُلِّ امْرِئٍ مِّنْهُمْ یَوْمَئِذٍ شَاْنٌ یُّغْنِیْهِؕ",
      "verse_key": "80:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "وُجُوْهٌ یَّوْمَئِذٍ مُّسْفِرَةٌۙ",
      "verse_key": "80:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌۚ",
      "verse_key": "80:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "وَ وُجُوْهٌ یَّوْمَئِذٍ عَلَیْهَا غَبَرَةٌۙ",
      "verse_key": "80:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "تَرْهَقُهَا قَتَرَةٌؕ",
      "verse_key": "80:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "اُولٰٓئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ۠",
      "verse_key": "80:42"
    }
  ]
}