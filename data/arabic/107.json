      "verse_key": "107:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "فَذٰلِكَ الَّذِیْ یَدُعُّ الْیَتِیْمَۙ۝۲",
      "juz": 30,
      "page": 602,
      "manzil": 7,
