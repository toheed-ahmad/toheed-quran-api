{
  "surah_id": 107,
  "surah_name": "Al-Ma'un",
  "arabic_name": "سُورَةُ الْمَاعُونِ",
  "revelation_type": "Meccan",
  "total_ayahs": 7,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اَرَءَیْتَ الَّذِیْ یُكَذِّبُ بِالدِّیْنِؕ",
      "verse_key": "107:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "فَذٰلِكَ الَّذِیْ یَدُعُّ الْیَتِیْمَۙ",
      "verse_key": "107:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ لَا یَحُضُّ عَلٰى طَعَامِ الْمِسْكِیْنِؕ",
      "verse_key": "107:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "فَوَیْلٌ لِّلْمُصَلِّیْنَۙ",
      "verse_key": "107:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "الَّذِیْنَ هُمْ عَنْ صَلَاتِهِمْ سَاهُوْنَۙ",
      "verse_key": "107:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "الَّذِیْنَ هُمْ یُرَآءُوْنَۙ",
      "verse_key": "107:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ یَمْنَعُوْنَ الْمَاعُوْنَ۠",
      "verse_key": "107:7"
    }
  ]
}