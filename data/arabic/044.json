{
  "surah_id": 44,
  "surah_name": "Ad-Dukhaan",
  "arabic_name": "سُورَةُ الدُّخَانِ",
  "revelation_type": "Meccan",
  "total_ayahs": 59,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "حٰمٓۚۛ۝۱",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ الْكِتٰبِ الْمُبِیْنِۙۛ۝۲",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "اِنَّاۤ اَنْزَلْنٰهُ فِیْ لَیْلَةٍ مُّبٰرَكَةٍ اِنَّا كُنَّا مُنْذِرِیْنَ۝۳",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "فِیْهَا یُفْرَقُ كُلُّ اَمْرٍ حَكِیْمٍۙ۝۴",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "اَمْرًا مِّنْ عِنْدِنَا ؕ اِنَّا كُنَّا مُرْسِلِیْنَۚ۝۵",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "رَحْمَةً مِّنْ رَّبِّكَ ؕ اِنَّهٗ هُوَ السَّمِیْعُ الْعَلِیْمُۙ۝۶",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "رَبِّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا ۘ اِنْ كُنْتُمْ مُّوْقِنِیْنَ۝۷",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "لَاۤ اِلٰهَ اِلَّا هُوَ یُحْیٖ وَ یُمِیْتُ ؕ رَبُّكُمْ وَ رَبُّ اٰبَآىِٕكُمُ الْاَوَّلِیْنَ۝۸",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "بَلْ هُمْ فِیْ شَكٍّ یَّلْعَبُوْنَ۝۹",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فَارْتَقِبْ یَوْمَ تَاْتِی السَّمَآءُ بِدُخَانٍ مُّبِیْنٍۙ۝۱۰",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "یَّغْشَی النَّاسَ ؕ هٰذَا عَذَابٌ اَلِیْمٌ۝۱۱",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "رَبَّنَا اكْشِفْ عَنَّا الْعَذَابَ اِنَّا مُؤْمِنُوْنَ۝۱۲",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "اَنّٰی لَهُمُ الذِّكْرٰی وَ قَدْ جَآءَهُمْ رَسُوْلٌ مُّبِیْنٌۙ۝۱۳",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "ثُمَّ تَوَلَّوْا عَنْهُ وَ قَالُوْا مُعَلَّمٌ مَّجْنُوْنٌۘ۝۱۴",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "اِنَّا كَاشِفُوا الْعَذَابِ قَلِیْلًا اِنَّكُمْ عَآىِٕدُوْنَۘ۝۱۵",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "یَوْمَ نَبْطِشُ الْبَطْشَةَ الْكُبْرٰی ۚ اِنَّا مُنْتَقِمُوْنَ۝۱۶",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "44:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ لَقَدْ فَتَنَّا قَبْلَهُمْ قَوْمَ فِرْعَوْنَ وَ جَآءَهُمْ رَسُوْلٌ كَرِیْمٌۙ۝۱۷",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "اَنْ اَدُّوْۤا اِلَیَّ عِبَادَ اللّٰهِ ؕ اِنِّیْ لَكُمْ رَسُوْلٌ اَمِیْنٌۙ۝۱۸",
      "juz": 25,
      "page": 496,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَّ اَنْ لَّا تَعْلُوْا عَلَی اللّٰهِ ۚ اِنِّیْۤ اٰتِیْكُمْ بِسُلْطٰنٍ مُّبِیْنٍۚ۝۱۹",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ اِنِّیْ عُذْتُ بِرَبِّیْ وَ رَبِّكُمْ اَنْ تَرْجُمُوْنِؗ۝۲۰",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَ اِنْ لَّمْ تُؤْمِنُوْا لِیْ فَاعْتَزِلُوْنِ۝۲۱",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "فَدَعَا رَبَّهٗۤ اَنَّ هٰۤؤُلَآءِ قَوْمٌ مُّجْرِمُوْنَ۝۲۲",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "فَاَسْرِ بِعِبَادِیْ لَیْلًا اِنَّكُمْ مُّتَّبَعُوْنَۙ۝۲۳",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَ اتْرُكِ الْبَحْرَ رَهْوًا ؕ اِنَّهُمْ جُنْدٌ مُّغْرَقُوْنَ۝۲۴",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "كَمْ تَرَكُوْا مِنْ جَنّٰتٍ وَّ عُیُوْنٍۙ۝۲۵",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَّ زُرُوْعٍ وَّ مَقَامٍ كَرِیْمٍۙ۝۲۶",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَّ نَعْمَةٍ كَانُوْا فِیْهَا فٰكِهِیْنَۙ۝۲۷",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "كَذٰلِكَ ۫ وَ اَوْرَثْنٰهَا قَوْمًا اٰخَرِیْنَ۝۲۸",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "فَمَا بَكَتْ عَلَیْهِمُ السَّمَآءُ وَ الْاَرْضُ وَ مَا كَانُوْا مُنْظَرِیْنَ۠۝۲۹",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 431,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَ لَقَدْ نَجَّیْنَا بَنِیْۤ اِسْرَآءِیْلَ مِنَ الْعَذَابِ الْمُهِیْنِۙ۝۳۰",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "مِنْ فِرْعَوْنَ ؕ اِنَّهٗ كَانَ عَالِیًا مِّنَ الْمُسْرِفِیْنَ۝۳۱",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "وَ لَقَدِ اخْتَرْنٰهُمْ عَلٰی عِلْمٍ عَلَی الْعٰلَمِیْنَۚ۝۳۲",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "وَ اٰتَیْنٰهُمْ مِّنَ الْاٰیٰتِ مَا فِیْهِ بَلٰٓؤٌا مُّبِیْنٌ۝۳۳",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "اِنَّ هٰۤؤُلَآءِ لَیَقُوْلُوْنَۙ۝۳۴",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اِنْ هِیَ اِلَّا مَوْتَتُنَا الْاُوْلٰی وَ مَا نَحْنُ بِمُنْشَرِیْنَ۝۳۵",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "فَاْتُوْا بِاٰبَآىِٕنَاۤ اِنْ كُنْتُمْ صٰدِقِیْنَ۝۳۶",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "اَهُمْ خَیْرٌ اَمْ قَوْمُ تُبَّعٍ ۙ وَّ الَّذِیْنَ مِنْ قَبْلِهِمْ ؕ اَهْلَكْنٰهُمْ ؗ اِنَّهُمْ كَانُوْا مُجْرِمِیْنَ۝۳۷",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "وَ مَا خَلَقْنَا السَّمٰوٰتِ وَ الْاَرْضَ وَ مَا بَیْنَهُمَا لٰعِبِیْنَ۝۳۸",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "مَا خَلَقْنٰهُمَاۤ اِلَّا بِالْحَقِّ وَ لٰكِنَّ اَكْثَرَهُمْ لَا یَعْلَمُوْنَ۝۳۹",
      "juz": 25,
      "page": 497,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "اِنَّ یَوْمَ الْفَصْلِ مِیْقَاتُهُمْ اَجْمَعِیْنَۙ۝۴۰",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "یَوْمَ لَا یُغْنِیْ مَوْلًی عَنْ مَّوْلًی شَیْـًٔا وَّ لَا هُمْ یُنْصَرُوْنَۙ۝۴۱",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "اِلَّا مَنْ رَّحِمَ اللّٰهُ ؕ اِنَّهُ هُوَ الْعَزِیْزُ الرَّحِیْمُ۠۝۴۲",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 432,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "اِنَّ شَجَرَتَ الزَّقُّوْمِۙ۝۴۳",
      "juz": 25,
      "page": 498,
