    },
    {
      "ayah_number": 44,
      "arabic_text": "طَعَامُ الْاَثِیْمِ    ۖۛۚ۝۴۴",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "كَالْمُهْلِ ۛۚ یَغْلِیْ فِی الْبُطُوْنِۙ۝۴۵",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "كَغَلْیِ الْحَمِیْمِ۝۴۶",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "خُذُوْهُ فَاعْتِلُوْهُ اِلٰی سَوَآءِ الْجَحِیْمِۗۖ۝۴۷",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "ثُمَّ صُبُّوْا فَوْقَ رَاْسِهٖ مِنْ عَذَابِ الْحَمِیْمِؕ۝۴۸",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "ذُقْ ۙۚ اِنَّكَ اَنْتَ الْعَزِیْزُ الْكَرِیْمُ۝۴۹",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "اِنَّ هٰذَا مَا كُنْتُمْ بِهٖ تَمْتَرُوْنَ۝۵۰",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:50"
    },
    {
      "ayah_number": 51,
      "arabic_text": "اِنَّ الْمُتَّقِیْنَ فِیْ مَقَامٍ اَمِیْنٍۙ۝۵۱",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:51"
    },
    {
      "ayah_number": 52,
      "arabic_text": "فِیْ جَنّٰتٍ وَّ عُیُوْنٍۚۙ۝۵۲",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:52"
    },
    {
      "ayah_number": 53,
      "arabic_text": "یَّلْبَسُوْنَ مِنْ سُنْدُسٍ وَّ اِسْتَبْرَقٍ مُّتَقٰبِلِیْنَۚۙ۝۵۳",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:53"
    },
    {
      "ayah_number": 54,
      "arabic_text": "كَذٰلِكَ ۫ وَ زَوَّجْنٰهُمْ بِحُوْرٍ عِیْنٍؕ۝۵۴",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:54"
    },
    {
      "ayah_number": 55,
      "arabic_text": "یَدْعُوْنَ فِیْهَا بِكُلِّ فَاكِهَةٍ اٰمِنِیْنَۙ۝۵۵",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:55"
    },
    {
      "ayah_number": 56,
      "arabic_text": "لَا یَذُوْقُوْنَ فِیْهَا الْمَوْتَ اِلَّا الْمَوْتَةَ الْاُوْلٰی ۚ وَ وَقٰىهُمْ عَذَابَ الْجَحِیْمِۙ۝۵۶",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:56"
    },
    {
      "ayah_number": 57,
      "arabic_text": "فَضْلًا مِّنْ رَّبِّكَ ؕ ذٰلِكَ هُوَ الْفَوْزُ الْعَظِیْمُ۝۵۷",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:57"
    },
    {
      "ayah_number": 58,
      "arabic_text": "فَاِنَّمَا یَسَّرْنٰهُ بِلِسَانِكَ لَعَلَّهُمْ یَتَذَكَّرُوْنَ۝۵۸",
      "juz": 25,
      "page": 498,
      "manzil": 6,
      "ruku": 433,
      "hizb": 50,
      "hizbQuarter": 199,
      "sajdah": false,
      "verse_key": "44:58"
    },
    {
      "ayah_number": 59,
      "arabic_text": "فَارْتَقِبْ اِنَّهُمْ مُّرْتَقِبُوْنَ۠۝۵۹",
      "juz": 25,
