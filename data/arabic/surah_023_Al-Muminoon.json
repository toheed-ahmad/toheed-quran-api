  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "قَدْ اَفْلَحَ الْمُؤْمِنُوْنَۙ۝۱",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "الَّذِیْنَ هُمْ فِیْ صَلَاتِهِمْ خٰشِعُوْنَۙ۝۲",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ الَّذِیْنَ هُمْ عَنِ اللَّغْوِ مُعْرِضُوْنَۙ۝۳",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ الَّذِیْنَ هُمْ لِلزَّكٰوةِ فٰعِلُوْنَۙ۝۴",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ الَّذِیْنَ هُمْ لِفُرُوْجِهِمْ حٰفِظُوْنَۙ۝۵",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اِلَّا عَلٰۤی اَزْوَاجِهِمْ اَوْ مَا مَلَكَتْ اَیْمَانُهُمْ فَاِنَّهُمْ غَیْرُ مَلُوْمِیْنَۚ۝۶",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "فَمَنِ ابْتَغٰی وَرَآءَ ذٰلِكَ فَاُولٰٓىِٕكَ هُمُ الْعٰدُوْنَۚ۝۷",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ الَّذِیْنَ هُمْ لِاَمٰنٰتِهِمْ وَ عَهْدِهِمْ رٰعُوْنَۙ۝۸",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ الَّذِیْنَ هُمْ عَلٰی صَلَوٰتِهِمْ یُحَافِظُوْنَۘ۝۹",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "اُولٰٓىِٕكَ هُمُ الْوٰرِثُوْنَۙ۝۱۰",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "الَّذِیْنَ یَرِثُوْنَ الْفِرْدَوْسَ ؕ هُمْ فِیْهَا خٰلِدُوْنَ۝۱۱",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ لَقَدْ خَلَقْنَا الْاِنْسَانَ مِنْ سُلٰلَةٍ مِّنْ طِیْنٍۚ۝۱۲",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "ثُمَّ جَعَلْنٰهُ نُطْفَةً فِیْ قَرَارٍ مَّكِیْنٍ۪۝۱۳",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "ثُمَّ خَلَقْنَا النُّطْفَةَ عَلَقَةً فَخَلَقْنَا الْعَلَقَةَ مُضْغَةً فَخَلَقْنَا الْمُضْغَةَ عِظٰمًا فَكَسَوْنَا الْعِظٰمَ لَحْمًا ۗ ثُمَّ اَنْشَاْنٰهُ خَلْقًا اٰخَرَ ؕ فَتَبٰرَكَ اللّٰهُ اَحْسَنُ الْخٰلِقِیْنَؕ۝۱۴",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "ثُمَّ اِنَّكُمْ بَعْدَ ذٰلِكَ لَمَیِّتُوْنَؕ۝۱۵",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "ثُمَّ اِنَّكُمْ یَوْمَ الْقِیٰمَةِ تُبْعَثُوْنَ۝۱۶",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ لَقَدْ خَلَقْنَا فَوْقَكُمْ سَبْعَ طَرَآىِٕقَ ۖۗ وَ مَا كُنَّا عَنِ الْخَلْقِ غٰفِلِیْنَ۝۱۷",
      "juz": 18,
      "page": 342,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَ اَنْزَلْنَا مِنَ السَّمَآءِ مَآءًۢ بِقَدَرٍ فَاَسْكَنّٰهُ فِی الْاَرْضِ ۖۗ وَ اِنَّا عَلٰی ذَهَابٍۭ بِهٖ لَقٰدِرُوْنَۚ۝۱۸",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "فَاَنْشَاْنَا لَكُمْ بِهٖ جَنّٰتٍ مِّنْ نَّخِیْلٍ وَّ اَعْنَابٍ ۘ لَكُمْ فِیْهَا فَوَاكِهُ كَثِیْرَةٌ وَّ مِنْهَا تَاْكُلُوْنَۙ۝۱۹",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ شَجَرَةً تَخْرُجُ مِنْ طُوْرِ سَیْنَآءَ تَنْۢبُتُ بِالدُّهْنِ وَ صِبْغٍ لِّلْاٰكِلِیْنَ۝۲۰",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَ اِنَّ لَكُمْ فِی الْاَنْعَامِ لَعِبْرَةً ؕ نُسْقِیْكُمْ مِّمَّا فِیْ بُطُوْنِهَا وَ لَكُمْ فِیْهَا مَنَافِعُ كَثِیْرَةٌ وَّ مِنْهَا تَاْكُلُوْنَۙ۝۲۱",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "وَ عَلَیْهَا وَ عَلَی الْفُلْكِ تُحْمَلُوْنَ۠۝۲۲",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 295,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "وَ لَقَدْ اَرْسَلْنَا نُوْحًا اِلٰی قَوْمِهٖ فَقَالَ یٰقَوْمِ اعْبُدُوا اللّٰهَ مَا لَكُمْ مِّنْ اِلٰهٍ غَیْرُهٗ ؕ اَفَلَا تَتَّقُوْنَ۝۲۳",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "فَقَالَ الْمَلَؤُا الَّذِیْنَ كَفَرُوْا مِنْ قَوْمِهٖ مَا هٰذَاۤ اِلَّا بَشَرٌ مِّثْلُكُمْ ۙ یُرِیْدُ اَنْ یَّتَفَضَّلَ عَلَیْكُمْ ؕ وَ لَوْ شَآءَ اللّٰهُ لَاَنْزَلَ مَلٰٓىِٕكَةً ۖۚ مَّا سَمِعْنَا بِهٰذَا فِیْۤ اٰبَآىِٕنَا الْاَوَّلِیْنَۚ۝۲۴",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اِنْ هُوَ اِلَّا رَجُلٌۢ بِهٖ جِنَّةٌ فَتَرَبَّصُوْا بِهٖ حَتّٰی حِیْنٍ۝۲۵",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "قَالَ رَبِّ انْصُرْنِیْ بِمَا كَذَّبُوْنِ۝۲۶",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "فَاَوْحَیْنَاۤ اِلَیْهِ اَنِ اصْنَعِ الْفُلْكَ بِاَعْیُنِنَا وَ وَحْیِنَا فَاِذَا جَآءَ اَمْرُنَا وَ فَارَ التَّنُّوْرُ ۙ فَاسْلُكْ فِیْهَا مِنْ كُلٍّ زَوْجَیْنِ اثْنَیْنِ وَ اَهْلَكَ اِلَّا مَنْ سَبَقَ عَلَیْهِ الْقَوْلُ مِنْهُمْ ۚ وَ لَا تُخَاطِبْنِیْ فِی الَّذِیْنَ ظَلَمُوْا ۚ اِنَّهُمْ مُّغْرَقُوْنَ۝۲۷",
      "juz": 18,
      "page": 343,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "فَاِذَا اسْتَوَیْتَ اَنْتَ وَ مَنْ مَّعَكَ عَلَی الْفُلْكِ فَقُلِ الْحَمْدُ لِلّٰهِ الَّذِیْ نَجّٰىنَا مِنَ الْقَوْمِ الظّٰلِمِیْنَ۝۲۸",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَ قُلْ رَّبِّ اَنْزِلْنِیْ مُنْزَلًا مُّبٰرَكًا وَّ اَنْتَ خَیْرُ الْمُنْزِلِیْنَ۝۲۹",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ وَّ اِنْ كُنَّا لَمُبْتَلِیْنَ۝۳۰",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "ثُمَّ اَنْشَاْنَا مِنْۢ بَعْدِهِمْ قَرْنًا اٰخَرِیْنَۚ۝۳۱",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "فَاَرْسَلْنَا فِیْهِمْ رَسُوْلًا مِّنْهُمْ اَنِ اعْبُدُوا اللّٰهَ مَا لَكُمْ مِّنْ اِلٰهٍ غَیْرُهٗ ؕ اَفَلَا تَتَّقُوْنَ۠۝۳۲",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 296,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "وَ قَالَ الْمَلَاُ مِنْ قَوْمِهِ الَّذِیْنَ كَفَرُوْا وَ كَذَّبُوْا بِلِقَآءِ الْاٰخِرَةِ وَ اَتْرَفْنٰهُمْ فِی الْحَیٰوةِ الدُّنْیَا ۙ مَا هٰذَاۤ اِلَّا بَشَرٌ مِّثْلُكُمْ ۙ یَاْكُلُ مِمَّا تَاْكُلُوْنَ مِنْهُ وَ یَشْرَبُ مِمَّا تَشْرَبُوْنَ۪ۙ۝۳۳",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَ لَىِٕنْ اَطَعْتُمْ بَشَرًا مِّثْلَكُمْ اِنَّكُمْ اِذًا لَّخٰسِرُوْنَۙ۝۳۴",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اَیَعِدُكُمْ اَنَّكُمْ اِذَا مِتُّمْ وَ كُنْتُمْ تُرَابًا وَّ عِظَامًا اَنَّكُمْ مُّخْرَجُوْنَ۪ۙ۝۳۵",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 137,
      "sajdah": false,
      "verse_key": "23:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "هَیْهَاتَ هَیْهَاتَ لِمَا تُوْعَدُوْنَ۪ۙ۝۳۶",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "اِنْ هِیَ اِلَّا حَیَاتُنَا الدُّنْیَا نَمُوْتُ وَ نَحْیَا وَ مَا نَحْنُ بِمَبْعُوْثِیْنَ۪ۙ۝۳۷",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "اِنْ هُوَ اِلَّا رَجُلُ ِ۟افْتَرٰی عَلَی اللّٰهِ كَذِبًا وَّ مَا نَحْنُ لَهٗ بِمُؤْمِنِیْنَ۝۳۸",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "قَالَ رَبِّ انْصُرْنِیْ بِمَا كَذَّبُوْنِ۝۳۹",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "قَالَ عَمَّا قَلِیْلٍ لَّیُصْبِحُنَّ نٰدِمِیْنَۚ۝۴۰",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "فَاَخَذَتْهُمُ الصَّیْحَةُ بِالْحَقِّ فَجَعَلْنٰهُمْ غُثَآءً ۚ فَبُعْدًا لِّلْقَوْمِ الظّٰلِمِیْنَ۝۴۱",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "ثُمَّ اَنْشَاْنَا مِنْۢ بَعْدِهِمْ قُرُوْنًا اٰخَرِیْنَؕ۝۴۲",
      "juz": 18,
      "page": 344,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "مَا تَسْبِقُ مِنْ اُمَّةٍ اَجَلَهَا وَ مَا یَسْتَاْخِرُوْنَؕ۝۴۳",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "ثُمَّ اَرْسَلْنَا رُسُلَنَا تَتْرَا ؕ كُلَّمَا جَآءَ اُمَّةً رَّسُوْلُهَا كَذَّبُوْهُ فَاَتْبَعْنَا بَعْضَهُمْ بَعْضًا وَّ جَعَلْنٰهُمْ اَحَادِیْثَ ۚ فَبُعْدًا لِّقَوْمٍ لَّا یُؤْمِنُوْنَ۝۴۴",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "ثُمَّ اَرْسَلْنَا مُوْسٰی وَ اَخَاهُ هٰرُوْنَ ۙ۬ بِاٰیٰتِنَا وَ سُلْطٰنٍ مُّبِیْنٍۙ۝۴۵",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "اِلٰی فِرْعَوْنَ وَ مَلَاۡىِٕهٖ فَاسْتَكْبَرُوْا وَ كَانُوْا قَوْمًا عَالِیْنَۚ۝۴۶",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "فَقَالُوْۤا اَنُؤْمِنُ لِبَشَرَیْنِ مِثْلِنَا وَ قَوْمُهُمَا لَنَا عٰبِدُوْنَۚ۝۴۷",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "فَكَذَّبُوْهُمَا فَكَانُوْا مِنَ الْمُهْلَكِیْنَ۝۴۸",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "وَ لَقَدْ اٰتَیْنَا مُوْسَی الْكِتٰبَ لَعَلَّهُمْ یَهْتَدُوْنَ۝۴۹",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "وَ جَعَلْنَا ابْنَ مَرْیَمَ وَ اُمَّهٗۤ اٰیَةً وَّ اٰوَیْنٰهُمَاۤ اِلٰی رَبْوَةٍ ذَاتِ قَرَارٍ وَّ مَعِیْنٍ۠۝۵۰",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 297,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:50"
    },
    {
      "ayah_number": 51,
      "arabic_text": "یٰۤاَیُّهَا الرُّسُلُ كُلُوْا مِنَ الطَّیِّبٰتِ وَ اعْمَلُوْا صَالِحًا ؕ اِنِّیْ بِمَا تَعْمَلُوْنَ عَلِیْمٌؕ۝۵۱",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:51"
    },
    {
      "ayah_number": 52,
      "arabic_text": "وَ اِنَّ هٰذِهٖۤ اُمَّتُكُمْ اُمَّةً وَّاحِدَةً وَّ اَنَا رَبُّكُمْ فَاتَّقُوْنِ۝۵۲",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:52"
    },
    {
      "ayah_number": 53,
      "arabic_text": "فَتَقَطَّعُوْۤا اَمْرَهُمْ بَیْنَهُمْ زُبُرًا ؕ كُلُّ حِزْبٍۭ بِمَا لَدَیْهِمْ فَرِحُوْنَ۝۵۳",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:53"
    },
    {
      "ayah_number": 54,
      "arabic_text": "فَذَرْهُمْ فِیْ غَمْرَتِهِمْ حَتّٰی حِیْنٍ۝۵۴",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:54"
    },
    {
      "ayah_number": 55,
      "arabic_text": "اَیَحْسَبُوْنَ اَنَّمَا نُمِدُّهُمْ بِهٖ مِنْ مَّالٍ وَّ بَنِیْنَۙ۝۵۵",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:55"
    },
    {
      "ayah_number": 56,
      "arabic_text": "نُسَارِعُ لَهُمْ فِی الْخَیْرٰتِ ؕ بَلْ لَّا یَشْعُرُوْنَ۝۵۶",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:56"
    },
    {
      "ayah_number": 57,
      "arabic_text": "اِنَّ الَّذِیْنَ هُمْ مِّنْ خَشْیَةِ رَبِّهِمْ مُّشْفِقُوْنَۙ۝۵۷",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:57"
    },
    {
      "ayah_number": 58,
      "arabic_text": "وَ الَّذِیْنَ هُمْ بِاٰیٰتِ رَبِّهِمْ یُؤْمِنُوْنَۙ۝۵۸",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:58"
    },
    {
      "ayah_number": 59,
      "arabic_text": "وَ الَّذِیْنَ هُمْ بِرَبِّهِمْ لَا یُشْرِكُوْنَۙ۝۵۹",
      "juz": 18,
      "page": 345,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:59"
    },
    {
      "ayah_number": 60,
      "arabic_text": "وَ الَّذِیْنَ یُؤْتُوْنَ مَاۤ اٰتَوْا وَّ قُلُوْبُهُمْ وَجِلَةٌ اَنَّهُمْ اِلٰی رَبِّهِمْ رٰجِعُوْنَۙ۝۶۰",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:60"
    },
    {
      "ayah_number": 61,
      "arabic_text": "اُولٰٓىِٕكَ یُسٰرِعُوْنَ فِی الْخَیْرٰتِ وَ هُمْ لَهَا سٰبِقُوْنَ۝۶۱",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:61"
    },
    {
      "ayah_number": 62,
      "arabic_text": "وَ لَا نُكَلِّفُ نَفْسًا اِلَّا وُسْعَهَا وَ لَدَیْنَا كِتٰبٌ یَّنْطِقُ بِالْحَقِّ وَ هُمْ لَا یُظْلَمُوْنَ۝۶۲",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:62"
    },
    {
      "ayah_number": 63,
      "arabic_text": "بَلْ قُلُوْبُهُمْ فِیْ غَمْرَةٍ مِّنْ هٰذَا وَ لَهُمْ اَعْمَالٌ مِّنْ دُوْنِ ذٰلِكَ هُمْ لَهَا عٰمِلُوْنَ۝۶۳",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:63"
    },
    {
      "ayah_number": 64,
      "arabic_text": "حَتّٰۤی اِذَاۤ اَخَذْنَا مُتْرَفِیْهِمْ بِالْعَذَابِ اِذَا هُمْ یَجْـَٔرُوْنَؕ۝۶۴",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:64"
    },
    {
      "ayah_number": 65,
      "arabic_text": "لَا تَجْـَٔرُوا الْیَوْمَ ۫ اِنَّكُمْ مِّنَّا لَا تُنْصَرُوْنَ۝۶۵",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:65"
    },
    {
      "ayah_number": 66,
      "arabic_text": "قَدْ كَانَتْ اٰیٰتِیْ تُتْلٰی عَلَیْكُمْ فَكُنْتُمْ عَلٰۤی اَعْقَابِكُمْ تَنْكِصُوْنَۙ۝۶۶",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:66"
    },
    {
      "ayah_number": 67,
      "arabic_text": "مُسْتَكْبِرِیْنَ ۖۗ بِهٖ سٰمِرًا تَهْجُرُوْنَ۝۶۷",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:67"
    },
    {
      "ayah_number": 68,
      "arabic_text": "اَفَلَمْ یَدَّبَّرُوا الْقَوْلَ اَمْ جَآءَهُمْ مَّا لَمْ یَاْتِ اٰبَآءَهُمُ الْاَوَّلِیْنَؗ۝۶۸",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:68"
    },
    {
      "ayah_number": 69,
      "arabic_text": "اَمْ لَمْ یَعْرِفُوْا رَسُوْلَهُمْ فَهُمْ لَهٗ مُنْكِرُوْنَؗ۝۶۹",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:69"
    },
    {
      "ayah_number": 70,
      "arabic_text": "اَمْ یَقُوْلُوْنَ بِهٖ جِنَّةٌ ؕ بَلْ جَآءَهُمْ بِالْحَقِّ وَ اَكْثَرُهُمْ لِلْحَقِّ كٰرِهُوْنَ۝۷۰",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:70"
    },
    {
      "ayah_number": 71,
      "arabic_text": "وَ لَوِ اتَّبَعَ الْحَقُّ اَهْوَآءَهُمْ لَفَسَدَتِ السَّمٰوٰتُ وَ الْاَرْضُ وَ مَنْ فِیْهِنَّ ؕ بَلْ اَتَیْنٰهُمْ بِذِكْرِهِمْ فَهُمْ عَنْ ذِكْرِهِمْ مُّعْرِضُوْنَؕ۝۷۱",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:71"
    },
    {
      "ayah_number": 72,
      "arabic_text": "اَمْ تَسْـَٔلُهُمْ خَرْجًا فَخَرَاجُ رَبِّكَ خَیْرٌ ۖۗ وَّ هُوَ خَیْرُ الرّٰزِقِیْنَ۝۷۲",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:72"
    },
    {
      "ayah_number": 73,
      "arabic_text": "وَ اِنَّكَ لَتَدْعُوْهُمْ اِلٰی صِرَاطٍ مُّسْتَقِیْمٍ۝۷۳",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:73"
    },
    {
      "ayah_number": 74,
      "arabic_text": "وَ اِنَّ الَّذِیْنَ لَا یُؤْمِنُوْنَ بِالْاٰخِرَةِ عَنِ الصِّرَاطِ لَنٰكِبُوْنَ۝۷۴",
      "juz": 18,
      "page": 346,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 138,
      "sajdah": false,
      "verse_key": "23:74"
    },
    {
      "ayah_number": 75,
      "arabic_text": "وَ لَوْ رَحِمْنٰهُمْ وَ كَشَفْنَا مَا بِهِمْ مِّنْ ضُرٍّ لَّلَجُّوْا فِیْ طُغْیَانِهِمْ یَعْمَهُوْنَ۝۷۵",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:75"
    },
    {
      "ayah_number": 76,
      "arabic_text": "وَ لَقَدْ اَخَذْنٰهُمْ بِالْعَذَابِ فَمَا اسْتَكَانُوْا لِرَبِّهِمْ وَ مَا یَتَضَرَّعُوْنَ۝۷۶",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:76"
    },
    {
      "ayah_number": 77,
      "arabic_text": "حَتّٰۤی اِذَا فَتَحْنَا عَلَیْهِمْ بَابًا ذَا عَذَابٍ شَدِیْدٍ اِذَا هُمْ فِیْهِ مُبْلِسُوْنَ۠۝۷۷",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 298,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:77"
    },
    {
      "ayah_number": 78,
      "arabic_text": "وَ هُوَ الَّذِیْۤ اَنْشَاَ لَكُمُ السَّمْعَ وَ الْاَبْصَارَ وَ الْاَفْـِٕدَةَ ؕ قَلِیْلًا مَّا تَشْكُرُوْنَ۝۷۸",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:78"
    },
    {
      "ayah_number": 79,
      "arabic_text": "وَ هُوَ الَّذِیْ ذَرَاَكُمْ فِی الْاَرْضِ وَ اِلَیْهِ تُحْشَرُوْنَ۝۷۹",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:79"
    },
    {
      "ayah_number": 80,
      "arabic_text": "وَ هُوَ الَّذِیْ یُحْیٖ وَ یُمِیْتُ وَ لَهُ اخْتِلَافُ الَّیْلِ وَ النَّهَارِ ؕ اَفَلَا تَعْقِلُوْنَ۝۸۰",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:80"
    },
    {
      "ayah_number": 81,
      "arabic_text": "بَلْ قَالُوْا مِثْلَ مَا قَالَ الْاَوَّلُوْنَ۝۸۱",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:81"
    },
    {
      "ayah_number": 82,
      "arabic_text": "قَالُوْۤا ءَاِذَا مِتْنَا وَ كُنَّا تُرَابًا وَّ عِظَامًا ءَاِنَّا لَمَبْعُوْثُوْنَ۝۸۲",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:82"
    },
    {
      "ayah_number": 83,
      "arabic_text": "لَقَدْ وُعِدْنَا نَحْنُ وَ اٰبَآؤُنَا هٰذَا مِنْ قَبْلُ اِنْ هٰذَاۤ اِلَّاۤ اَسَاطِیْرُ الْاَوَّلِیْنَ۝۸۳",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:83"
    },
    {
      "ayah_number": 84,
      "arabic_text": "قُلْ لِّمَنِ الْاَرْضُ وَ مَنْ فِیْهَاۤ اِنْ كُنْتُمْ تَعْلَمُوْنَ۝۸۴",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:84"
    },
    {
      "ayah_number": 85,
      "arabic_text": "سَیَقُوْلُوْنَ لِلّٰهِ ؕ قُلْ اَفَلَا تَذَكَّرُوْنَ۝۸۵",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:85"
    },
    {
      "ayah_number": 86,
      "arabic_text": "قُلْ مَنْ رَّبُّ السَّمٰوٰتِ السَّبْعِ وَ رَبُّ الْعَرْشِ الْعَظِیْمِ۝۸۶",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:86"
    },
    {
      "ayah_number": 87,
      "arabic_text": "سَیَقُوْلُوْنَ لِلّٰهِ ؕ قُلْ اَفَلَا تَتَّقُوْنَ۝۸۷",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:87"
    },
    {
      "ayah_number": 88,
      "arabic_text": "قُلْ مَنْۢ بِیَدِهٖ مَلَكُوْتُ كُلِّ شَیْءٍ وَّ هُوَ یُجِیْرُ وَ لَا یُجَارُ عَلَیْهِ اِنْ كُنْتُمْ تَعْلَمُوْنَ۝۸۸",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:88"
    },
    {
      "ayah_number": 89,
      "arabic_text": "سَیَقُوْلُوْنَ لِلّٰهِ ؕ قُلْ فَاَنّٰی تُسْحَرُوْنَ۝۸۹",
      "juz": 18,
      "page": 347,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:89"
    },
    {
      "ayah_number": 90,
      "arabic_text": "بَلْ اَتَیْنٰهُمْ بِالْحَقِّ وَ اِنَّهُمْ لَكٰذِبُوْنَ۝۹۰",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:90"
    },
    {
      "ayah_number": 91,
      "arabic_text": "مَا اتَّخَذَ اللّٰهُ مِنْ وَّلَدٍ وَّ مَا كَانَ مَعَهٗ مِنْ اِلٰهٍ اِذًا لَّذَهَبَ كُلُّ اِلٰهٍۭ بِمَا خَلَقَ وَ لَعَلَا بَعْضُهُمْ عَلٰی بَعْضٍ ؕ سُبْحٰنَ اللّٰهِ عَمَّا یَصِفُوْنَۙ۝۹۱",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:91"
    },
    {
      "ayah_number": 92,
      "arabic_text": "عٰلِمِ الْغَیْبِ وَ الشَّهَادَةِ فَتَعٰلٰی عَمَّا یُشْرِكُوْنَ۠۝۹۲",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 299,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:92"
    },
    {
      "ayah_number": 93,
      "arabic_text": "قُلْ رَّبِّ اِمَّا تُرِیَنِّیْ مَا یُوْعَدُوْنَۙ۝۹۳",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:93"
    },
    {
      "ayah_number": 94,
      "arabic_text": "رَبِّ فَلَا تَجْعَلْنِیْ فِی الْقَوْمِ الظّٰلِمِیْنَ۝۹۴",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:94"
    },
    {
      "ayah_number": 95,
      "arabic_text": "وَ اِنَّا عَلٰۤی اَنْ نُّرِیَكَ مَا نَعِدُهُمْ لَقٰدِرُوْنَ۝۹۵",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:95"
    },
    {
      "ayah_number": 96,
      "arabic_text": "اِدْفَعْ بِالَّتِیْ هِیَ اَحْسَنُ السَّیِّئَةَ ؕ نَحْنُ اَعْلَمُ بِمَا یَصِفُوْنَ۝۹۶",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:96"
    },
    {
      "ayah_number": 97,
      "arabic_text": "وَ قُلْ رَّبِّ اَعُوْذُ بِكَ مِنْ هَمَزٰتِ الشَّیٰطِیْنِۙ۝۹۷",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:97"
    },
    {
      "ayah_number": 98,
      "arabic_text": "وَ اَعُوْذُ بِكَ رَبِّ اَنْ یَّحْضُرُوْنِ۝۹۸",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:98"
    },
    {
      "ayah_number": 99,
      "arabic_text": "حَتّٰۤی اِذَا جَآءَ اَحَدَهُمُ الْمَوْتُ قَالَ رَبِّ ارْجِعُوْنِۙ۝۹۹",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:99"
    },
    {
      "ayah_number": 100,
      "arabic_text": "لَعَلِّیْۤ اَعْمَلُ صَالِحًا فِیْمَا تَرَكْتُ كَلَّا ؕ اِنَّهَا كَلِمَةٌ هُوَ قَآىِٕلُهَا ؕ وَ مِنْ وَّرَآىِٕهِمْ بَرْزَخٌ اِلٰی یَوْمِ یُبْعَثُوْنَ۝۱۰۰",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:100"
    },
    {
      "ayah_number": 101,
      "arabic_text": "فَاِذَا نُفِخَ فِی الصُّوْرِ فَلَاۤ اَنْسَابَ بَیْنَهُمْ یَوْمَىِٕذٍ وَّ لَا یَتَسَآءَلُوْنَ۝۱۰۱",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:101"
    },
    {
      "ayah_number": 102,
      "arabic_text": "فَمَنْ ثَقُلَتْ مَوَازِیْنُهٗ فَاُولٰٓىِٕكَ هُمُ الْمُفْلِحُوْنَ۝۱۰۲",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:102"
    },
    {
      "ayah_number": 103,
      "arabic_text": "وَ مَنْ خَفَّتْ مَوَازِیْنُهٗ فَاُولٰٓىِٕكَ الَّذِیْنَ خَسِرُوْۤا اَنْفُسَهُمْ فِیْ جَهَنَّمَ خٰلِدُوْنَۚ۝۱۰۳",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:103"
    },
    {
      "ayah_number": 104,
      "arabic_text": "تَلْفَحُ وُجُوْهَهُمُ النَّارُ وَ هُمْ فِیْهَا كٰلِحُوْنَ۝۱۰۴",
      "juz": 18,
      "page": 348,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:104"
    },
    {
      "ayah_number": 105,
      "arabic_text": "اَلَمْ تَكُنْ اٰیٰتِیْ تُتْلٰی عَلَیْكُمْ فَكُنْتُمْ بِهَا تُكَذِّبُوْنَ۝۱۰۵",
      "juz": 18,
      "page": 349,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:105"
    },
    {
      "ayah_number": 106,
      "arabic_text": "قَالُوْا رَبَّنَا غَلَبَتْ عَلَیْنَا شِقْوَتُنَا وَ كُنَّا قَوْمًا ضَآلِّیْنَ۝۱۰۶",
      "juz": 18,
      "page": 349,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:106"
    },
    {
      "ayah_number": 107,
      "arabic_text": "رَبَّنَاۤ اَخْرِجْنَا مِنْهَا فَاِنْ عُدْنَا فَاِنَّا ظٰلِمُوْنَ۝۱۰۷",
      "juz": 18,
      "page": 349,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:107"
    },
    {
      "ayah_number": 108,
      "arabic_text": "قَالَ اخْسَـُٔوْا فِیْهَا وَ لَا تُكَلِّمُوْنِ۝۱۰۸",
      "juz": 18,
      "page": 349,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:108"
    },
    {
      "ayah_number": 109,
      "arabic_text": "اِنَّهٗ كَانَ فَرِیْقٌ مِّنْ عِبَادِیْ یَقُوْلُوْنَ رَبَّنَاۤ اٰمَنَّا فَاغْفِرْ لَنَا وَ ارْحَمْنَا وَ اَنْتَ خَیْرُ الرّٰحِمِیْنَۚۖ۝۱۰۹",
      "juz": 18,
      "page": 349,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:109"
    },
    {
      "ayah_number": 110,
      "arabic_text": "فَاتَّخَذْتُمُوْهُمْ سِخْرِیًّا حَتّٰۤی اَنْسَوْكُمْ ذِكْرِیْ وَ كُنْتُمْ مِّنْهُمْ تَضْحَكُوْنَ۝۱۱۰",
      "juz": 18,
      "page": 349,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:110"
    },
    {
      "ayah_number": 111,
      "arabic_text": "اِنِّیْ جَزَیْتُهُمُ الْیَوْمَ بِمَا صَبَرُوْۤا ۙ اَنَّهُمْ هُمُ الْفَآىِٕزُوْنَ۝۱۱۱",
      "juz": 18,
      "page": 349,
      "manzil": 4,
      "ruku": 300,
      "hizb": 35,
      "hizbQuarter": 139,
      "sajdah": false,
      "verse_key": "23:111"
    },
    {
      "ayah_number": 112,
      "arabic_text": "قٰلَ كَمْ لَبِثْتُمْ فِی الْاَرْضِ عَدَدَ سِنِیْنَ۝۱۱۲",
      "juz": 18,
      "page": 349,
