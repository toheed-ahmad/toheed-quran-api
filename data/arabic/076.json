{
  "surah_id": 76,
  "surah_name": "Al-Insaan",
  "arabic_name": "سُورَةُ الإِنسَانِ",
  "revelation_type": "Medinan",
  "total_ayahs": 31,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "هَلْ اَتٰی عَلَی الْاِنْسَانِ حِیْنٌ مِّنَ الدَّهْرِ لَمْ یَكُنْ شَیْـًٔا مَّذْكُوْرًا۝۱",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "اِنَّا خَلَقْنَا الْاِنْسَانَ مِنْ نُّطْفَةٍ اَمْشَاجٍ ۖۗ نَّبْتَلِیْهِ فَجَعَلْنٰهُ سَمِیْعًۢا بَصِیْرًا۝۲",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "اِنَّا هَدَیْنٰهُ السَّبِیْلَ اِمَّا شَاكِرًا وَّ اِمَّا كَفُوْرًا۝۳",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اِنَّاۤ اَعْتَدْنَا لِلْكٰفِرِیْنَ سَلٰسِلَاۡ وَ اَغْلٰلًا وَّ سَعِیْرًا۝۴",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "اِنَّ الْاَبْرَارَ یَشْرَبُوْنَ مِنْ كَاْسٍ كَانَ مِزَاجُهَا كَافُوْرًاۚ۝۵",
      "juz": 29,
      "page": 578,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "عَیْنًا یَّشْرَبُ بِهَا عِبَادُ اللّٰهِ یُفَجِّرُوْنَهَا تَفْجِیْرًا۝۶",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "یُوْفُوْنَ بِالنَّذْرِ وَ یَخَافُوْنَ یَوْمًا كَانَ شَرُّهٗ مُسْتَطِیْرًا۝۷",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ یُطْعِمُوْنَ الطَّعَامَ عَلٰی حُبِّهٖ مِسْكِیْنًا وَّ یَتِیْمًا وَّ اَسِیْرًا۝۸",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "اِنَّمَا نُطْعِمُكُمْ لِوَجْهِ اللّٰهِ لَا نُرِیْدُ مِنْكُمْ جَزَآءً وَّ لَا شُكُوْرًا۝۹",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "اِنَّا نَخَافُ مِنْ رَّبِّنَا یَوْمًا عَبُوْسًا قَمْطَرِیْرًا۝۱۰",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "فَوَقٰىهُمُ اللّٰهُ شَرَّ ذٰلِكَ الْیَوْمِ وَ لَقّٰىهُمْ نَضْرَةً وَّ سُرُوْرًاۚ۝۱۱",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ جَزٰىهُمْ بِمَا صَبَرُوْا جَنَّةً وَّ حَرِیْرًاۙ۝۱۲",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "مُّتَّكِـِٕیْنَ فِیْهَا عَلَی الْاَرَآىِٕكِ ۚ لَا یَرَوْنَ فِیْهَا شَمْسًا وَّ لَا زَمْهَرِیْرًاۚ۝۱۳",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ دَانِیَةً عَلَیْهِمْ ظِلٰلُهَا وَ ذُلِّلَتْ قُطُوْفُهَا تَذْلِیْلًا۝۱۴",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَ یُطَافُ عَلَیْهِمْ بِاٰنِیَةٍ مِّنْ فِضَّةٍ وَّ اَكْوَابٍ كَانَتْ قَؔوَارِیْرَاۡۙ۝۱۵",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "قَؔوَارِیْرَاۡ مِنْ فِضَّةٍ قَدَّرُوْهَا تَقْدِیْرًا۝۱۶",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ یُسْقَوْنَ فِیْهَا كَاْسًا كَانَ مِزَاجُهَا زَنْجَبِیْلًاۚ۝۱۷",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "عَیْنًا فِیْهَا تُسَمّٰی سَلْسَبِیْلًا۝۱۸",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 231,
      "sajdah": false,
      "verse_key": "76:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ یَطُوْفُ عَلَیْهِمْ وِلْدَانٌ مُّخَلَّدُوْنَ ۚ اِذَا رَاَیْتَهُمْ حَسِبْتَهُمْ لُؤْلُؤًا مَّنْثُوْرًا۝۱۹",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ اِذَا رَاَیْتَ ثَمَّ رَاَیْتَ نَعِیْمًا وَّ مُلْكًا كَبِیْرًا۝۲۰",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "عٰلِیَهُمْ ثِیَابُ سُنْدُسٍ خُضْرٌ وَّ اِسْتَبْرَقٌ ؗ وَّ حُلُّوْۤا اَسَاوِرَ مِنْ فِضَّةٍ ۚ وَ سَقٰىهُمْ رَبُّهُمْ شَرَابًا طَهُوْرًا۝۲۱",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "اِنَّ هٰذَا كَانَ لَكُمْ جَزَآءً وَّ كَانَ سَعْیُكُمْ مَّشْكُوْرًا۠۝۲۲",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 514,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "اِنَّا نَحْنُ نَزَّلْنَا عَلَیْكَ الْقُرْاٰنَ تَنْزِیْلًاۚ۝۲۳",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 515,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "فَاصْبِرْ لِحُكْمِ رَبِّكَ وَ لَا تُطِعْ مِنْهُمْ اٰثِمًا اَوْ كَفُوْرًاۚ۝۲۴",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 515,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "وَ اذْكُرِ اسْمَ رَبِّكَ بُكْرَةً وَّ اَصِیْلًاۖۚ۝۲۵",
      "juz": 29,
      "page": 579,
      "manzil": 7,
      "ruku": 515,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَ مِنَ الَّیْلِ فَاسْجُدْ لَهٗ وَ سَبِّحْهُ لَیْلًا طَوِیْلًا۝۲۶",
      "juz": 29,
      "page": 580,
      "manzil": 7,
      "ruku": 515,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "اِنَّ هٰۤؤُلَآءِ یُحِبُّوْنَ الْعَاجِلَةَ وَ یَذَرُوْنَ وَرَآءَهُمْ یَوْمًا ثَقِیْلًا۝۲۷",
      "juz": 29,
      "page": 580,
      "manzil": 7,
      "ruku": 515,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "نَحْنُ خَلَقْنٰهُمْ وَ شَدَدْنَاۤ اَسْرَهُمْ ۚ وَ اِذَا شِئْنَا بَدَّلْنَاۤ اَمْثَالَهُمْ تَبْدِیْلًا۝۲۸",
      "juz": 29,
      "page": 580,
      "manzil": 7,
      "ruku": 515,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "اِنَّ هٰذِهٖ تَذْكِرَةٌ ۚ فَمَنْ شَآءَ اتَّخَذَ اِلٰی رَبِّهٖ سَبِیْلًا۝۲۹",
      "juz": 29,
      "page": 580,
      "manzil": 7,
      "ruku": 515,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَ مَا تَشَآءُوْنَ اِلَّاۤ اَنْ یَّشَآءَ اللّٰهُ ؕ اِنَّ اللّٰهَ كَانَ عَلِیْمًا حَكِیْمًاۗۖ۝۳۰",
      "juz": 29,
      "page": 580,
      "manzil": 7,
      "ruku": 515,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "یُّدْخِلُ مَنْ یَّشَآءُ فِیْ رَحْمَتِهٖ ؕ وَ الظّٰلِمِیْنَ اَعَدَّ لَهُمْ عَذَابًا اَلِیْمًا۠۝۳۱",
      "juz": 29,
      "page": 580,
      "manzil": 7,
      "ruku": 515,
      "hizb": 58,
      "hizbQuarter": 232,
      "sajdah": false,
      "verse_key": "76:31"
    }
  ]
}