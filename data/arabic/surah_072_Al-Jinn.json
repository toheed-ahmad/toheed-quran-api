{
  "surah_id": 72,
  "surah_name": "Al-Jinn",
  "arabic_name": "سُورَةُ الجِنِّ",
  "revelation_type": "Meccan",
  "total_ayahs": 28,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "قُلْ اُوْحِیَ اِلَیَّ اَنَّهُ اسْتَمَعَ نَفَرٌ مِّنَ الْجِنِّ فَقَالُوْۤا اِنَّا سَمِعْنَا قُرْاٰنًا عَجَبًاۙ۝۱",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "یَّهْدِیْۤ اِلَی الرُّشْدِ فَاٰمَنَّا بِهٖ ؕ وَ لَنْ نُّشْرِكَ بِرَبِّنَاۤ اَحَدًاۙ۝۲",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَّ اَنَّهٗ تَعٰلٰی جَدُّ رَبِّنَا مَا اتَّخَذَ صَاحِبَةً وَّ لَا وَلَدًاۙ۝۳",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَّ اَنَّهٗ كَانَ یَقُوْلُ سَفِیْهُنَا عَلَی اللّٰهِ شَطَطًاۙ۝۴",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَّ اَنَّا ظَنَنَّاۤ اَنْ لَّنْ تَقُوْلَ الْاِنْسُ وَ الْجِنُّ عَلَی اللّٰهِ كَذِبًاۙ۝۵",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَّ اَنَّهٗ كَانَ رِجَالٌ مِّنَ الْاِنْسِ یَعُوْذُوْنَ بِرِجَالٍ مِّنَ الْجِنِّ فَزَادُوْهُمْ رَهَقًاۙ۝۶",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَّ اَنَّهُمْ ظَنُّوْا كَمَا ظَنَنْتُمْ اَنْ لَّنْ یَّبْعَثَ اللّٰهُ اَحَدًاۙ۝۷",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَّ اَنَّا لَمَسْنَا السَّمَآءَ فَوَجَدْنٰهَا مُلِئَتْ حَرَسًا شَدِیْدًا وَّ شُهُبًاۙ۝۸",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَّ اَنَّا كُنَّا نَقْعُدُ مِنْهَا مَقَاعِدَ لِلسَّمْعِ ؕ فَمَنْ یَّسْتَمِعِ الْاٰنَ یَجِدْ لَهٗ شِهَابًا رَّصَدًاۙ۝۹",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَّ اَنَّا لَا نَدْرِیْۤ اَشَرٌّ اُرِیْدَ بِمَنْ فِی الْاَرْضِ اَمْ اَرَادَ بِهِمْ رَبُّهُمْ رَشَدًاۙ۝۱۰",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَّ اَنَّا مِنَّا الصّٰلِحُوْنَ وَ مِنَّا دُوْنَ ذٰلِكَ ؕ كُنَّا طَرَآىِٕقَ قِدَدًاۙ۝۱۱",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَّ اَنَّا ظَنَنَّاۤ اَنْ لَّنْ نُّعْجِزَ اللّٰهَ فِی الْاَرْضِ وَ لَنْ نُّعْجِزَهٗ هَرَبًاۙ۝۱۲",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَّ اَنَّا لَمَّا سَمِعْنَا الْهُدٰۤی اٰمَنَّا بِهٖ ؕ فَمَنْ یُّؤْمِنْۢ بِرَبِّهٖ فَلَا یَخَافُ بَخْسًا وَّ لَا رَهَقًاۙ۝۱۳",
      "juz": 29,
      "page": 572,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَّ اَنَّا مِنَّا الْمُسْلِمُوْنَ وَ مِنَّا الْقٰسِطُوْنَ ؕ فَمَنْ اَسْلَمَ فَاُولٰٓىِٕكَ تَحَرَّوْا رَشَدًا۝۱۴",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَ اَمَّا الْقٰسِطُوْنَ فَكَانُوْا لِجَهَنَّمَ حَطَبًاۙ۝۱۵",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "وَّ اَنْ لَّوِ اسْتَقَامُوْا عَلَی الطَّرِیْقَةِ لَاَسْقَیْنٰهُمْ مَّآءً غَدَقًاۙ۝۱۶",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "لِّنَفْتِنَهُمْ فِیْهِ ؕ وَ مَنْ یُّعْرِضْ عَنْ ذِكْرِ رَبِّهٖ یَسْلُكْهُ عَذَابًا صَعَدًاۙ۝۱۷",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَّ اَنَّ الْمَسٰجِدَ لِلّٰهِ فَلَا تَدْعُوْا مَعَ اللّٰهِ اَحَدًاۙ۝۱۸",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَّ اَنَّهٗ لَمَّا قَامَ عَبْدُ اللّٰهِ یَدْعُوْهُ كَادُوْا یَكُوْنُوْنَ عَلَیْهِ لِبَدًا  ؕ۠۝۱۹",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 506,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "قُلْ اِنَّمَاۤ اَدْعُوْا رَبِّیْ وَ لَاۤ اُشْرِكُ بِهٖۤ اَحَدًا۝۲۰",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 507,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "قُلْ اِنِّیْ لَاۤ اَمْلِكُ لَكُمْ ضَرًّا وَّ لَا رَشَدًا۝۲۱",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 507,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "قُلْ اِنِّیْ لَنْ یُّجِیْرَنِیْ مِنَ اللّٰهِ اَحَدٌ ۙ۬ وَّ لَنْ اَجِدَ مِنْ دُوْنِهٖ مُلْتَحَدًاۙ۝۲۲",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 507,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "اِلَّا بَلٰغًا مِّنَ اللّٰهِ وَ رِسٰلٰتِهٖ ؕ وَ مَنْ یَّعْصِ اللّٰهَ وَ رَسُوْلَهٗ فَاِنَّ لَهٗ نَارَ جَهَنَّمَ خٰلِدِیْنَ فِیْهَاۤ اَبَدًاؕ۝۲۳",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 507,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "حَتّٰۤی اِذَا رَاَوْا مَا یُوْعَدُوْنَ فَسَیَعْلَمُوْنَ مَنْ اَضْعَفُ نَاصِرًا وَّ اَقَلُّ عَدَدًا۝۲۴",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 507,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "قُلْ اِنْ اَدْرِیْۤ اَقَرِیْبٌ مَّا تُوْعَدُوْنَ اَمْ یَجْعَلُ لَهٗ رَبِّیْۤ اَمَدًا۝۲۵",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 507,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "عٰلِمُ الْغَیْبِ فَلَا یُظْهِرُ عَلٰی غَیْبِهٖۤ اَحَدًاۙ۝۲۶",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 507,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "اِلَّا مَنِ ارْتَضٰی مِنْ رَّسُوْلٍ فَاِنَّهٗ یَسْلُكُ مِنْۢ بَیْنِ یَدَیْهِ وَ مِنْ خَلْفِهٖ رَصَدًاۙ۝۲۷",
      "juz": 29,
      "page": 573,
      "manzil": 7,
      "ruku": 507,
      "hizb": 58,
      "hizbQuarter": 229,
      "sajdah": false,
      "verse_key": "72:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "لِّیَعْلَمَ اَنْ قَدْ اَبْلَغُوْا رِسٰلٰتِ رَبِّهِمْ وَ اَحَاطَ بِمَا لَدَیْهِمْ وَ اَحْصٰی كُلَّ شَیْءٍ عَدَدًا۠۝۲۸",
      "juz": 29,
