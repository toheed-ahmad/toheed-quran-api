  "revelation_type": "Meccan",
  "total_ayahs": 60,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الذّٰرِیٰتِ ذَرْوًاۙ۝۱",
      "juz": 26,
      "page": 520,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "فَالْحٰمِلٰتِ وِقْرًاۙ۝۲",
      "juz": 26,
      "page": 520,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "فَالْجٰرِیٰتِ یُسْرًاۙ۝۳",
      "juz": 26,
      "page": 520,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "فَالْمُقَسِّمٰتِ اَمْرًاۙ۝۴",
      "juz": 26,
      "page": 520,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "اِنَّمَا تُوْعَدُوْنَ لَصَادِقٌۙ۝۵",
      "juz": 26,
      "page": 520,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَّ اِنَّ الدِّیْنَ لَوَاقِعٌؕ۝۶",
      "juz": 26,
      "page": 520,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ السَّمَآءِ ذَاتِ الْحُبُكِۙ۝۷",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اِنَّكُمْ لَفِیْ قَوْلٍ مُّخْتَلِفٍۙ۝۸",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "یُّؤْفَكُ عَنْهُ مَنْ اُفِكَؕ۝۹",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "قُتِلَ الْخَرّٰصُوْنَۙ۝۱۰",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "الَّذِیْنَ هُمْ فِیْ غَمْرَةٍ سَاهُوْنَۙ۝۱۱",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "یَسْـَٔلُوْنَ اَیَّانَ یَوْمُ الدِّیْنِؕ۝۱۲",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "یَوْمَ هُمْ عَلَی النَّارِ یُفْتَنُوْنَ۝۱۳",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "ذُوْقُوْا فِتْنَتَكُمْ ؕ هٰذَا الَّذِیْ كُنْتُمْ بِهٖ تَسْتَعْجِلُوْنَ۝۱۴",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "اِنَّ الْمُتَّقِیْنَ فِیْ جَنّٰتٍ وَّ عُیُوْنٍۙ۝۱۵",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "اٰخِذِیْنَ مَاۤ اٰتٰىهُمْ رَبُّهُمْ ؕ اِنَّهُمْ كَانُوْا قَبْلَ ذٰلِكَ مُحْسِنِیْنَؕ۝۱۶",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "كَانُوْا قَلِیْلًا مِّنَ الَّیْلِ مَا یَهْجَعُوْنَ۝۱۷",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَ بِالْاَسْحَارِ هُمْ یَسْتَغْفِرُوْنَ۝۱۸",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ فِیْۤ اَمْوَالِهِمْ حَقٌّ لِّلسَّآىِٕلِ وَ الْمَحْرُوْمِ۝۱۹",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ فِی الْاَرْضِ اٰیٰتٌ لِّلْمُوْقِنِیْنَۙ۝۲۰",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَ فِیْۤ اَنْفُسِكُمْ ؕ اَفَلَا تُبْصِرُوْنَ۝۲۱",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "وَ فِی السَّمَآءِ رِزْقُكُمْ وَ مَا تُوْعَدُوْنَ۝۲۲",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "فَوَرَبِّ السَّمَآءِ وَ الْاَرْضِ اِنَّهٗ لَحَقٌّ مِّثْلَ مَاۤ اَنَّكُمْ تَنْطِقُوْنَ۠۝۲۳",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 455,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "هَلْ اَتٰىكَ حَدِیْثُ ضَیْفِ اِبْرٰهِیْمَ الْمُكْرَمِیْنَۘ۝۲۴",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 456,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اِذْ دَخَلُوْا عَلَیْهِ فَقَالُوْا سَلٰمًا ؕ قَالَ سَلٰمٌ ۚ قَوْمٌ مُّنْكَرُوْنَۚ۝۲۵",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 456,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "فَرَاغَ اِلٰۤی اَهْلِهٖ فَجَآءَ بِعِجْلٍ سَمِیْنٍۙ۝۲۶",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 456,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "فَقَرَّبَهٗۤ اِلَیْهِمْ قَالَ اَلَا تَاْكُلُوْنَؗ۝۲۷",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 456,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "فَاَوْجَسَ مِنْهُمْ خِیْفَةً ؕ قَالُوْا لَا تَخَفْ ؕ وَ بَشَّرُوْهُ بِغُلٰمٍ عَلِیْمٍ۝۲۸",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 456,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "فَاَقْبَلَتِ امْرَاَتُهٗ فِیْ صَرَّةٍ فَصَكَّتْ وَجْهَهَا وَ قَالَتْ عَجُوْزٌ عَقِیْمٌ۝۲۹",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 456,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "قَالُوْا كَذٰلِكِ ۙ قَالَ رَبُّكِ ؕ اِنَّهٗ هُوَ الْحَكِیْمُ الْعَلِیْمُ۝۳۰",
      "juz": 26,
      "page": 521,
      "manzil": 7,
      "ruku": 456,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "51:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "قَالَ فَمَا خَطْبُكُمْ اَیُّهَا الْمُرْسَلُوْنَ۝۳۱",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "قَالُوْۤا اِنَّاۤ اُرْسِلْنَاۤ اِلٰی قَوْمٍ مُّجْرِمِیْنَۙ۝۳۲",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "لِنُرْسِلَ عَلَیْهِمْ حِجَارَةً مِّنْ طِیْنٍۙ۝۳۳",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "مُّسَوَّمَةً عِنْدَ رَبِّكَ لِلْمُسْرِفِیْنَ۝۳۴",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "فَاَخْرَجْنَا مَنْ كَانَ فِیْهَا مِنَ الْمُؤْمِنِیْنَۚ۝۳۵",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "فَمَا وَجَدْنَا فِیْهَا غَیْرَ بَیْتٍ مِّنَ الْمُسْلِمِیْنَۚ۝۳۶",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "وَ تَرَكْنَا فِیْهَاۤ اٰیَةً لِّلَّذِیْنَ یَخَافُوْنَ الْعَذَابَ الْاَلِیْمَؕ۝۳۷",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "وَ فِیْ مُوْسٰۤی اِذْ اَرْسَلْنٰهُ اِلٰی فِرْعَوْنَ بِسُلْطٰنٍ مُّبِیْنٍ۝۳۸",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "فَتَوَلّٰی بِرُكْنِهٖ وَ قَالَ سٰحِرٌ اَوْ مَجْنُوْنٌ۝۳۹",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "فَاَخَذْنٰهُ وَ جُنُوْدَهٗ فَنَبَذْنٰهُمْ فِی الْیَمِّ وَ هُوَ مُلِیْمٌؕ۝۴۰",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "وَ فِیْ عَادٍ اِذْ اَرْسَلْنَا عَلَیْهِمُ الرِّیْحَ الْعَقِیْمَۚ۝۴۱",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "مَا تَذَرُ مِنْ شَیْءٍ اَتَتْ عَلَیْهِ اِلَّا جَعَلَتْهُ كَالرَّمِیْمِؕ۝۴۲",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "وَ فِیْ ثَمُوْدَ اِذْ قِیْلَ لَهُمْ تَمَتَّعُوْا حَتّٰی حِیْنٍ۝۴۳",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "فَعَتَوْا عَنْ اَمْرِ رَبِّهِمْ فَاَخَذَتْهُمُ الصّٰعِقَةُ وَ هُمْ یَنْظُرُوْنَ۝۴۴",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "فَمَا اسْتَطَاعُوْا مِنْ قِیَامٍ وَّ مَا كَانُوْا مُنْتَصِرِیْنَۙ۝۴۵",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "وَ قَوْمَ نُوْحٍ مِّنْ قَبْلُ ؕ اِنَّهُمْ كَانُوْا قَوْمًا فٰسِقِیْنَ۠۝۴۶",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 456,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "وَ السَّمَآءَ بَنَیْنٰهَا بِاَیْىدٍ وَّ اِنَّا لَمُوْسِعُوْنَ۝۴۷",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "وَ الْاَرْضَ فَرَشْنٰهَا فَنِعْمَ الْمٰهِدُوْنَ۝۴۸",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "وَ مِنْ كُلِّ شَیْءٍ خَلَقْنَا زَوْجَیْنِ لَعَلَّكُمْ تَذَكَّرُوْنَ۝۴۹",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "فَفِرُّوْۤا اِلَی اللّٰهِ ؕ اِنِّیْ لَكُمْ مِّنْهُ نَذِیْرٌ مُّبِیْنٌۚ۝۵۰",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:50"
    },
    {
      "ayah_number": 51,
      "arabic_text": "وَ لَا تَجْعَلُوْا مَعَ اللّٰهِ اِلٰهًا اٰخَرَ ؕ اِنِّیْ لَكُمْ مِّنْهُ نَذِیْرٌ مُّبِیْنٌۚ۝۵۱",
      "juz": 27,
      "page": 522,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:51"
    },
    {
      "ayah_number": 52,
      "arabic_text": "كَذٰلِكَ مَاۤ اَتَی الَّذِیْنَ مِنْ قَبْلِهِمْ مِّنْ رَّسُوْلٍ اِلَّا قَالُوْا سَاحِرٌ اَوْ مَجْنُوْنٌۚ۝۵۲",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:52"
    },
    {
      "ayah_number": 53,
      "arabic_text": "اَتَوَاصَوْا بِهٖ ۚ بَلْ هُمْ قَوْمٌ طَاغُوْنَۚ۝۵۳",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:53"
    },
    {
      "ayah_number": 54,
      "arabic_text": "فَتَوَلَّ عَنْهُمْ فَمَاۤ اَنْتَ بِمَلُوْمٍ  ۗؗ۝۵۴",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:54"
    },
    {
      "ayah_number": 55,
      "arabic_text": "وَّ ذَكِّرْ فَاِنَّ الذِّكْرٰی تَنْفَعُ الْمُؤْمِنِیْنَ۝۵۵",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:55"
    },
    {
      "ayah_number": 56,
      "arabic_text": "وَ مَا خَلَقْتُ الْجِنَّ وَ الْاِنْسَ اِلَّا لِیَعْبُدُوْنِ۝۵۶",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:56"
    },
    {
      "ayah_number": 57,
      "arabic_text": "مَاۤ اُرِیْدُ مِنْهُمْ مِّنْ رِّزْقٍ وَّ مَاۤ اُرِیْدُ اَنْ یُّطْعِمُوْنِ۝۵۷",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:57"
    },
    {
      "ayah_number": 58,
      "arabic_text": "اِنَّ اللّٰهَ هُوَ الرَّزَّاقُ ذُو الْقُوَّةِ الْمَتِیْنُ۝۵۸",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:58"
    },
    {
      "ayah_number": 59,
      "arabic_text": "فَاِنَّ لِلَّذِیْنَ ظَلَمُوْا ذَنُوْبًا مِّثْلَ ذَنُوْبِ اَصْحٰبِهِمْ فَلَا یَسْتَعْجِلُوْنِ۝۵۹",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "51:59"
    },
    {
      "ayah_number": 60,
      "arabic_text": "فَوَیْلٌ لِّلَّذِیْنَ كَفَرُوْا مِنْ یَّوْمِهِمُ الَّذِیْ یُوْعَدُوْنَ۠۝۶۰",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 457,
      "hizb": 53,
      "hizbQuarter": 209,
