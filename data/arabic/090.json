{
  "surah_id": 90,
  "surah_name": "Al-Balad",
  "arabic_name": "سُورَةُ الْبَلَدِ",
  "revelation_type": "Meccan",
  "total_ayahs": 20,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "لَاۤ اُقْسِمُ بِهٰذَا الْبَلَدِۙ",
      "verse_key": "90:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ اَنْتَ حِلٌّۢ بِهٰذَا الْبَلَدِۙ",
      "verse_key": "90:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ وَالِدٍ وَّ مَا وَلَدَۙ",
      "verse_key": "90:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "لَقَدْ خَلَقْنَا الْاِنْسَانَ فِیْ كَبَدٍؕ",
      "verse_key": "90:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "اَیَحْسَبُ اَنْ لَّنْ یَّقْدِرَ عَلَیْهِ اَحَدٌۘ",
      "verse_key": "90:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "یَقُوْلُ اَهْلَكْتُ مَالًا لُّبَدًاؕ",
      "verse_key": "90:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "اَیَحْسَبُ اَنْ لَّمْ یَرَهٗۤ اَحَدٌؕ",
      "verse_key": "90:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اَلَمْ نَجْعَلْ لَّهٗ عَیْنَیْنِۙ",
      "verse_key": "90:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ لِسَانًا وَّ شَفَتَیْنِۙ",
      "verse_key": "90:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ هَدَیْنٰهُ النَّجْدَیْنِۚ",
      "verse_key": "90:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "فَلَا اقْتَحَمَ الْعَقَبَةَ٘ۖ",
      "verse_key": "90:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا الْعَقَبَةُؕ",
      "verse_key": "90:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "فَكُّ رَقَبَةٍۙ",
      "verse_key": "90:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "اَوْ اِطْعٰمٌ فِیْ یَوْمٍ ذِیْ مَسْغَبَةٍۙ",
      "verse_key": "90:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "یَّتِیْمًا ذَا مَقْرَبَةٍۙ",
      "verse_key": "90:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "اَوْ مِسْكِیْنًا ذَا مَتْرَبَةٍؕ",
      "verse_key": "90:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "ثُمَّ كَانَ مِنَ الَّذِیْنَ اٰمَنُوْا وَ تَوَاصَوْا بِالصَّبْرِ وَ تَوَاصَوْا بِالْمَرْحَمَةِؕ",
      "verse_key": "90:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "اُولٰٓئِكَ اَصْحٰبُ الْمَیْمَنَةِؕ",
      "verse_key": "90:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ الَّذِیْنَ كَفَرُوْا بِاٰیٰتِنَا هُمْ اَصْحٰبُ الْمَشْئَمَةِؕ",
      "verse_key": "90:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "عَلَیْهِمْ نَارٌ مُّؤْصَدَةٌ۠",
      "verse_key": "90:20"
    }
  ]
}