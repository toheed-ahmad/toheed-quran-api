      "ruku": 523,
      "hizb": 59,
      "hizbQuarter": 234,
      "sajdah": false,
      "verse_key": "81:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "賵賻 丕賽匕賻丕 丕賱賿噩賻賳賾賻丞購 丕購夭賿賱賽賮賻鬲賿郦蹤蹪郾鄢",
      "juz": 30,
