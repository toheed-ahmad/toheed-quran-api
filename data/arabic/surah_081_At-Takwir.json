    },
    {
      "ayah_number": 7,
      "arabic_text": "賵賻 丕賽匕賻丕 丕賱賳賾購賮購賵賿爻購 夭購賵賾賽噩賻鬲賿郦蹤蹪鄯",
      "juz": 30,
