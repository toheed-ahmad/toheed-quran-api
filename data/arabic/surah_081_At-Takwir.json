      "hizbQuarter": 234,
      "sajdah": false,
      "verse_key": "81:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "賵賻 丕賽匕賻丕 丕賱賿噩賻丨賽蹖賿賲購 爻購毓賾賽乇賻鬲賿郦蹤蹪郾鄄",
      "juz": 30,
