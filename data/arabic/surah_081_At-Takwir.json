    {
      "ayah_number": 25,
      "arabic_text": "賵賻 賲賻丕 賴購賵賻 亘賽賯賻賵賿賱賽 卮賻蹖賿胤侔賳賺 乇賾賻噩賽蹖賿賲賺蹤蹪鄄鄣",
      "juz": 30,
