      "verse_key": "81:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "賵賻 丕賽匕賻丕 丕賱賿賲賻賵賿亍贄丿賻丞購 爻購賶贂賽賱賻鬲賿郦蹤蹪鄹",
      "juz": 30,
