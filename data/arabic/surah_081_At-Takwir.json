      "hizb": 59,
      "hizbQuarter": 234,
      "sajdah": false,
      "verse_key": "81:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "賮賻賱賻丕郅 丕購賯賿爻賽賲購 亘賽丕賱賿禺購賳賾賻爻賽蹤蹪郾鄣",
      "juz": 30,
      "page": 586,
      "manzil": 7,
      "ruku": 523,
      "hizb": 59,
      "hizbQuarter": 234,
      "sajdah": false,
      "verse_key": "81:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "丕賱賿噩賻賵賻丕乇賽 丕賱賿賰購賳賾賻爻賽蹤蹪郾鄱",
      "juz": 30,
      "page": 586,
      "manzil": 7,
