      "manzil": 7,
      "ruku": 523,
      "hizb": 59,
      "hizbQuarter": 234,
      "sajdah": false,
      "verse_key": "81:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "毓賻賱賽賲賻鬲賿 賳賻賮賿爻賹 賲賾賻丕郅 丕賻丨賿囟賻乇賻鬲賿貢蹪郾鄞",
