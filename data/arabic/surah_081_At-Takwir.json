      "verse_key": "81:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "亘賽丕賻蹖賾賽 匕賻賳邰賿亘賺 賯購鬲賽賱賻鬲賿蹥蹪酃",
      "juz": 30,
