      "sajdah": false,
      "verse_key": "81:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "賵賻 賲賻丕 賴購賵賻 毓賻賱賻蹖 丕賱賿睾賻蹖賿亘賽 亘賽囟賻賳賽蹖賿賳賺蹥蹪鄄鄞",
      "juz": 30,
