      "sajdah": false,
      "verse_key": "81:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "賵賻 丕賱氐賾購亘賿丨賽 丕賽匕賻丕 鬲賻賳賻賮賾賻爻賻蹤蹪郾鄹",
