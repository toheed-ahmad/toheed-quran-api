      "sajdah": false,
      "verse_key": "81:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "賲賾購胤賻丕毓賺 孬賻賲賾賻 丕賻賲賽蹖賿賳賺貢蹪鄄郾",
