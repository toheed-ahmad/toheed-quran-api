      "verse_key": "81:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "丕賽賳賾賻賴贄 賱賻賯賻賵賿賱購 乇賻爻購賵賿賱賺 賰賻乇賽蹖賿賲賺蹤蹪郾酃",
      "juz": 30,
      "page": 586,
      "manzil": 7,
