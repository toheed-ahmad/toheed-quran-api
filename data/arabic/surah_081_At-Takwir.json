      "hizbQuarter": 234,
      "sajdah": false,
      "verse_key": "81:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "賵賻 賲賻丕 氐賻丕丨賽亘購賰購賲賿 亘賽賲賻噩賿賳購賵賿賳賺蹥蹪鄄鄄",
