  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اِذَا زُلْزِلَتِ الْاَرْضُ زِلْزَالَهَاۙ۝۱",
      "juz": 30,
      "page": 599,
      "manzil": 7,
