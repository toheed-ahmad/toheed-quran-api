      "sajdah": false,
      "verse_key": "68:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "賮賻丕賳賿胤賻賱賻賯購賵賿丕 賵賻 賴購賲賿 蹖賻鬲賻禺賻丕賮賻鬲購賵賿賳賻蹤蹪鄄鄢",
      "juz": 29,
