      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "賮賻鬲賻賳賻丕丿賻賵賿丕 賲購氐賿亘賽丨賽蹖賿賳賻蹤蹪鄄郾",
      "juz": 29,
      "page": 565,
      "manzil": 7,
      "ruku": 498,
