      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "賮賻丕賻氐賿亘賻丨賻鬲賿 賰賻丕賱氐賾賻乇賽蹖賿賲賽蹤蹪鄄郯",
