      "sajdah": false,
      "verse_key": "68:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "賮賻胤賻丕賮賻 毓賻賱賻蹖賿賴賻丕 胤賻丕贀賶贂賽賮賹 賲賾賽賳賿 乇賾賻亘賾賽賰賻 賵賻 賴購賲賿 賳賻丕贀賶贂賽賲購賵賿賳賻蹪郾酃",
      "juz": 29,
