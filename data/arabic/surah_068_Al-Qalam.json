      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "賲賻丕郅 丕賻賳賿鬲賻 亘賽賳賽毓賿賲賻丞賽 乇賻亘賾賽賰賻 亘賽賲賻噩賿賳購賵賿賳賺蹥蹪鄄",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "賵賻 丕賽賳賾賻 賱賻賰賻 賱賻丕賻噩賿乇賸丕 睾賻蹖賿乇賻 賲賻賲賿賳購賵賿賳賺蹥蹪鄢",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "賵賻 丕賽賳賾賻賰賻 賱賻毓賻賱侔蹖 禺購賱購賯賺 毓賻馗賽蹖賿賲賺蹪鄞",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "賮賻爻賻鬲購亘賿氐賽乇購 賵賻 蹖購亘賿氐賽乇購賵賿賳賻蹤蹪鄣",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "亘賽丕賻賶蹖賾賽賰購賲購 丕賱賿賲賻賮賿鬲購賵賿賳購蹪鄱",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "丕賽賳賾賻 乇賻亘賾賻賰賻 賴購賵賻 丕賻毓賿賱賻賲購 亘賽賲賻賳賿 囟賻賱賾賻 毓賻賳賿 爻賻亘賽蹖賿賱賽賴贃 郦 賵賻 賴購賵賻 丕賻毓賿賱賻賲購 亘賽丕賱賿賲購賴賿鬲賻丿賽蹖賿賳賻蹪鄯",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "賮賻賱賻丕 鬲購胤賽毓賽 丕賱賿賲購賰賻匕賾賽亘賽蹖賿賳賻蹪鄹",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "賵賻丿賾購賵賿丕 賱賻賵賿 鬲購丿賿賴賽賳購 賮賻蹖購丿賿賴賽賳購賵賿賳賻蹪酃",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "賵賻 賱賻丕 鬲購胤賽毓賿 賰購賱賾賻 丨賻賱賾賻丕賮賺 賲賾賻賴賽蹖賿賳賺蹤蹪郾郯",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "賴賻賲賾賻丕夭賺 賲賾賻卮賾賻丕贀亍賺郗 亘賽賳賻賲賽蹖賿賲賺蹤蹪郾郾",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "賲賾賻賳賾賻丕毓賺 賱賾賽賱賿禺賻蹖賿乇賽 賲購毓賿鬲賻丿賺 丕賻孬賽蹖賿賲賺蹤蹪郾鄄",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "毓購鬲購賱賾賺郗 亘賻毓賿丿賻 匕侔賱賽賰賻 夭賻賳賽蹖賿賲賺蹤蹪郾鄢",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "丕賻賳賿 賰賻丕賳賻 匕賻丕 賲賻丕賱賺 賵賾賻 亘賻賳賽蹖賿賳賻貢蹪郾鄞",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "丕賽匕賻丕 鬲購鬲賿賱侔蹖 毓賻賱賻蹖賿賴賽 丕侔蹖侔鬲購賳賻丕 賯賻丕賱賻 丕賻爻賻丕胤賽蹖賿乇購 丕賱賿丕賻賵賾賻賱賽蹖賿賳賻蹪郾鄣",
      "juz": 29,
      "page": 564,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "爻賻賳賻爻賽賲購賴贄 毓賻賱賻蹖 丕賱賿禺購乇賿胤購賵賿賲賽蹪郾鄱",
      "juz": 29,
      "page": 565,
      "manzil": 7,
      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "丕賽賳賾賻丕 亘賻賱賻賵賿賳侔賴購賲賿 賰賻賲賻丕 亘賻賱賻賵賿賳賻丕郅 丕賻氐賿丨侔亘賻 丕賱賿噩賻賳賾賻丞賽 蹥 丕賽匕賿 丕賻賯賿爻賻賲購賵賿丕 賱賻蹖賻氐賿乇賽賲購賳賾賻賴賻丕 賲購氐賿亘賽丨賽蹖賿賳賻蹤蹪郾鄯",
      "juz": 29,
