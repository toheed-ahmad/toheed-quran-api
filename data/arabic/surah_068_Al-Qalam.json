      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "亘賻賱賿 賳賻丨賿賳購 賲賻丨賿乇購賵賿賲購賵賿賳賻蹪鄄鄯",
      "juz": 29,
