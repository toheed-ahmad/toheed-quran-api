      "ruku": 498,
      "hizb": 57,
      "hizbQuarter": 226,
      "sajdah": false,
      "verse_key": "68:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "賵賻 賱賻丕 蹖賻爻賿鬲賻孬賿賳購賵賿賳賻蹪郾鄹",
