{
  "surah_id": 78,
  "surah_name": "An-Naba",
  "arabic_name": "سُورَةُ النَّبَإِ",
  "revelation_type": "Meccan",
  "total_ayahs": 40,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "عَمَّ یَتَسَآءَلُوْنَۚ",
      "verse_key": "78:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "عَنِ النَّبَاِ الْعَظِیْمِۙ",
      "verse_key": "78:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "الَّذِیْ هُمْ فِیْهِ مُخْتَلِفُوْنَؕ",
      "verse_key": "78:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "كَلَّا سَیَعْلَمُوْنَۙ",
      "verse_key": "78:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "ثُمَّ كَلَّا سَیَعْلَمُوْنَ",
      "verse_key": "78:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اَلَمْ نَجْعَلِ الْاَرْضَ مِهٰدًاۙ",
      "verse_key": "78:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَّ الْجِبَالَ اَوْتَادًا۪ۙ",
      "verse_key": "78:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَّ خَلَقْنٰكُمْ اَزْوَاجًاۙ",
      "verse_key": "78:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَّ جَعَلْنَا نَوْمَكُمْ سُبَاتًاۙ",
      "verse_key": "78:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَّ جَعَلْنَا الَّیْلَ لِبَاسًاۙ",
      "verse_key": "78:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَّ جَعَلْنَا النَّهَارَ مَعَاشًا۪",
      "verse_key": "78:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَّ بَنَیْنَا فَوْقَكُمْ سَبْعًا شِدَادًاۙ",
      "verse_key": "78:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَّ جَعَلْنَا سِرَاجًا وَّهَّاجًا۪ۙ",
      "verse_key": "78:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَّ اَنْزَلْنَا مِنَ الْمُعْصِرٰتِ مَآءً ثَجَّاجًاۙ",
      "verse_key": "78:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "لِّنُخْرِجَ بِهٖ حَبًّا وَّ نَبَاتًاۙ",
      "verse_key": "78:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "وَّ جَنّٰتٍ اَلْفَافًاؕ",
      "verse_key": "78:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "اِنَّ یَوْمَ الْفَصْلِ كَانَ مِیْقَاتًاۙ",
      "verse_key": "78:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "یَّوْمَ یُنْفَخُ فِی الصُّوْرِ فَتَاْتُوْنَ اَفْوَاجًاۙ",
      "verse_key": "78:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَّ فُتِحَتِ السَّمَآءُ فَكَانَتْ اَبْوَابًاۙ",
      "verse_key": "78:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَّ سُیِّرَتِ الْجِبَالُ فَكَانَتْ سَرَابًاؕ",
      "verse_key": "78:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "اِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا۪ۙ",
      "verse_key": "78:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "لِّلطَّاغِیْنَ مَاٰبًاۙ",
      "verse_key": "78:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "لّٰبِثِیْنَ فِیْهَاۤ اَحْقَابًاۚ",
      "verse_key": "78:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "لَا یَذُوْقُوْنَ فِیْهَا بَرْدًا وَّ لَا شَرَابًاۙ",
      "verse_key": "78:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اِلَّا حَمِیْمًا وَّ غَسَّاقًاۙ",
      "verse_key": "78:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "جَزَآءً وِّفَاقًاؕ",
      "verse_key": "78:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "اِنَّهُمْ كَانُوْا لَا یَرْجُوْنَ حِسَابًاۙ",
      "verse_key": "78:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "وَّ كَذَّبُوْا بِاٰیٰتِنَا كِذَّابًاؕ",
      "verse_key": "78:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَ كُلَّ شَیْءٍ اَحْصَیْنٰهُ كِتٰبًاۙ",
      "verse_key": "78:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "فَذُوْقُوْا فَلَنْ نَّزِیْدَكُمْ اِلَّا عَذَابًا۠",
      "verse_key": "78:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "اِنَّ لِلْمُتَّقِیْنَ مَفَازًاۙ",
      "verse_key": "78:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "حَدَآئِقَ وَ اَعْنَابًاۙ",
      "verse_key": "78:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "وَّ كَوَاعِبَ اَتْرَابًاۙ",
      "verse_key": "78:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَّ كَاْسًا دِهَاقًاؕ",
      "verse_key": "78:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "لَا یَسْمَعُوْنَ فِیْهَا لَغْوًا وَّ لَا كِذّٰبًاۚ",
      "verse_key": "78:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "جَزَآءً مِّنْ رَّبِّكَ عَطَآءً حِسَابًاۙ",
      "verse_key": "78:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "رَّبِّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا الرَّحْمٰنِ لَا یَمْلِكُوْنَ مِنْهُ خِطَابًاۚ",
      "verse_key": "78:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "یَوْمَ یَقُوْمُ الرُّوْحُ وَ الْمَلٰٓئِكَةُ صَفًّا١ۙۗؕ لَّا یَتَكَلَّمُوْنَ اِلَّا مَنْ اَذِنَ لَهُ الرَّحْمٰنُ وَ قَالَ صَوَابًا",
      "verse_key": "78:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "ذٰلِكَ الْیَوْمُ الْحَقُّ١ۚ فَمَنْ شَآءَ اتَّخَذَ اِلٰى رَبِّهٖ مَاٰبًا",
      "verse_key": "78:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "اِنَّاۤ اَنْذَرْنٰكُمْ عَذَابًا قَرِیْبًا١ۖۚ۬ یَوْمَ یَنْظُرُ الْمَرْءُ مَا قَدَّمَتْ یَدٰهُ وَ یَقُوْلُ الْكٰفِرُ یٰلَیْتَنِیْ كُنْتُ تُرٰبًا۠",
      "verse_key": "78:40"
    }
  ]
}