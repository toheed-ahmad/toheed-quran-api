      "sajdah": false,
      "verse_key": "20:97"
    },
    {
      "ayah_number": 98,
      "arabic_text": "اِنَّمَاۤ اِلٰهُكُمُ اللّٰهُ الَّذِیْ لَاۤ اِلٰهَ اِلَّا هُوَ ؕ وَسِعَ كُلَّ شَیْءٍ عِلْمًا۝۹۸",
