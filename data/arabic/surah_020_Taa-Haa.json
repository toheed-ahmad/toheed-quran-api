    {
      "ayah_number": 114,
      "arabic_text": "فَتَعٰلَی اللّٰهُ الْمَلِكُ الْحَقُّ ۚ وَ لَا تَعْجَلْ بِالْقُرْاٰنِ مِنْ قَبْلِ اَنْ یُّقْضٰۤی اِلَیْكَ وَحْیُهٗ ؗ وَ قُلْ رَّبِّ زِدْنِیْ عِلْمًا۝۱۱۴",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 275,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:114"
    },
    {
      "ayah_number": 115,
      "arabic_text": "وَ لَقَدْ عَهِدْنَاۤ اِلٰۤی اٰدَمَ مِنْ قَبْلُ فَنَسِیَ وَ لَمْ نَجِدْ لَهٗ عَزْمًا۠۝۱۱۵",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 275,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:115"
    },
    {
      "ayah_number": 116,
      "arabic_text": "وَ اِذْ قُلْنَا لِلْمَلٰٓىِٕكَةِ اسْجُدُوْا لِاٰدَمَ فَسَجَدُوْۤا اِلَّاۤ اِبْلِیْسَ ؕ اَبٰی۝۱۱۶",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:116"
    },
    {
      "ayah_number": 117,
      "arabic_text": "فَقُلْنَا یٰۤاٰدَمُ اِنَّ هٰذَا عَدُوٌّ لَّكَ وَ لِزَوْجِكَ فَلَا یُخْرِجَنَّكُمَا مِنَ الْجَنَّةِ فَتَشْقٰی۝۱۱۷",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:117"
    },
    {
      "ayah_number": 118,
      "arabic_text": "اِنَّ لَكَ اَلَّا تَجُوْعَ فِیْهَا وَ لَا تَعْرٰیۙ۝۱۱۸",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:118"
    },
    {
      "ayah_number": 119,
      "arabic_text": "وَ اَنَّكَ لَا تَظْمَؤُا فِیْهَا وَ لَا تَضْحٰی۝۱۱۹",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:119"
    },
    {
      "ayah_number": 120,
      "arabic_text": "فَوَسْوَسَ اِلَیْهِ الشَّیْطٰنُ قَالَ یٰۤاٰدَمُ هَلْ اَدُلُّكَ عَلٰی شَجَرَةِ الْخُلْدِ وَ مُلْكٍ لَّا یَبْلٰی۝۱۲۰",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:120"
    },
    {
      "ayah_number": 121,
      "arabic_text": "فَاَكَلَا مِنْهَا فَبَدَتْ لَهُمَا سَوْاٰتُهُمَا وَ طَفِقَا یَخْصِفٰنِ عَلَیْهِمَا مِنْ وَّرَقِ الْجَنَّةِ ؗ وَ عَصٰۤی اٰدَمُ رَبَّهٗ فَغَوٰی۪ۖ۝۱۲۱",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:121"
    },
    {
      "ayah_number": 122,
      "arabic_text": "ثُمَّ اجْتَبٰهُ رَبُّهٗ فَتَابَ عَلَیْهِ وَ هَدٰی۝۱۲۲",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:122"
    },
    {
      "ayah_number": 123,
      "arabic_text": "قَالَ اهْبِطَا مِنْهَا جَمِیْعًۢا بَعْضُكُمْ لِبَعْضٍ عَدُوٌّ ۚ فَاِمَّا یَاْتِیَنَّكُمْ مِّنِّیْ هُدًی ۙ۬ فَمَنِ اتَّبَعَ هُدَایَ فَلَا یَضِلُّ وَ لَا یَشْقٰی۝۱۲۳",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:123"
    },
    {
      "ayah_number": 124,
      "arabic_text": "وَ مَنْ اَعْرَضَ عَنْ ذِكْرِیْ فَاِنَّ لَهٗ مَعِیْشَةً ضَنْكًا وَّ نَحْشُرُهٗ یَوْمَ الْقِیٰمَةِ اَعْمٰی۝۱۲۴",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:124"
    },
    {
      "ayah_number": 125,
      "arabic_text": "قَالَ رَبِّ لِمَ حَشَرْتَنِیْۤ اَعْمٰی وَ قَدْ كُنْتُ بَصِیْرًا۝۱۲۵",
      "juz": 16,
      "page": 320,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:125"
    },
    {
      "ayah_number": 126,
      "arabic_text": "قَالَ كَذٰلِكَ اَتَتْكَ اٰیٰتُنَا فَنَسِیْتَهَا ۚ وَ كَذٰلِكَ الْیَوْمَ تُنْسٰی۝۱۲۶",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:126"
    },
    {
      "ayah_number": 127,
      "arabic_text": "وَ كَذٰلِكَ نَجْزِیْ مَنْ اَسْرَفَ وَ لَمْ یُؤْمِنْۢ بِاٰیٰتِ رَبِّهٖ ؕ وَ لَعَذَابُ الْاٰخِرَةِ اَشَدُّ وَ اَبْقٰی۝۱۲۷",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:127"
    },
    {
      "ayah_number": 128,
      "arabic_text": "اَفَلَمْ یَهْدِ لَهُمْ كَمْ اَهْلَكْنَا قَبْلَهُمْ مِّنَ الْقُرُوْنِ یَمْشُوْنَ فِیْ مَسٰكِنِهِمْ ؕ اِنَّ فِیْ ذٰلِكَ لَاٰیٰتٍ لِّاُولِی النُّهٰی۠۝۱۲۸",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 276,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:128"
    },
    {
      "ayah_number": 129,
      "arabic_text": "وَ لَوْ لَا كَلِمَةٌ سَبَقَتْ مِنْ رَّبِّكَ لَكَانَ لِزَامًا وَّ اَجَلٌ مُّسَمًّیؕ۝۱۲۹",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 277,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:129"
    },
    {
      "ayah_number": 130,
      "arabic_text": "فَاصْبِرْ عَلٰی مَا یَقُوْلُوْنَ وَ سَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوْعِ الشَّمْسِ وَ قَبْلَ غُرُوْبِهَا ۚ وَ مِنْ اٰنَآئِ الَّیْلِ فَسَبِّحْ وَ اَطْرَافَ النَّهَارِ لَعَلَّكَ تَرْضٰی۝۱۳۰",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 277,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:130"
    },
    {
      "ayah_number": 131,
      "arabic_text": "وَ لَا تَمُدَّنَّ عَیْنَیْكَ اِلٰی مَا مَتَّعْنَا بِهٖۤ اَزْوَاجًا مِّنْهُمْ زَهْرَةَ الْحَیٰوةِ الدُّنْیَا ۙ۬ لِنَفْتِنَهُمْ فِیْهِ ؕ وَ رِزْقُ رَبِّكَ خَیْرٌ وَّ اَبْقٰی۝۱۳۱",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 277,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:131"
    },
    {
      "ayah_number": 132,
      "arabic_text": "وَ اْمُرْ اَهْلَكَ بِالصَّلٰوةِ وَ اصْطَبِرْ عَلَیْهَا ؕ لَا نَسْـَٔلُكَ رِزْقًا ؕ نَحْنُ نَرْزُقُكَ ؕ وَ الْعَاقِبَةُ لِلتَّقْوٰی۝۱۳۲",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 277,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:132"
    },
    {
      "ayah_number": 133,
      "arabic_text": "وَ قَالُوْا لَوْ لَا یَاْتِیْنَا بِاٰیَةٍ مِّنْ رَّبِّهٖ ؕ اَوَ لَمْ تَاْتِهِمْ بَیِّنَةُ مَا فِی الصُّحُفِ الْاُوْلٰی۝۱۳۳",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 277,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:133"
    },
    {
      "ayah_number": 134,
      "arabic_text": "وَ لَوْ اَنَّاۤ اَهْلَكْنٰهُمْ بِعَذَابٍ مِّنْ قَبْلِهٖ لَقَالُوْا رَبَّنَا لَوْ لَاۤ اَرْسَلْتَ اِلَیْنَا رَسُوْلًا فَنَتَّبِعَ اٰیٰتِكَ مِنْ قَبْلِ اَنْ نَّذِلَّ وَ نَخْزٰی۝۱۳۴",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 277,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:134"
    },
    {
      "ayah_number": 135,
      "arabic_text": "قُلْ كُلٌّ مُّتَرَبِّصٌ فَتَرَبَّصُوْا ۚ فَسَتَعْلَمُوْنَ مَنْ اَصْحٰبُ الصِّرَاطِ السَّوِیِّ وَ مَنِ اهْتَدٰی۠۝۱۳۵",
      "juz": 16,
      "page": 321,
      "manzil": 4,
      "ruku": 277,
      "hizb": 32,
      "hizbQuarter": 128,
      "sajdah": false,
      "verse_key": "20:135"
    }
  ]
}