      "ruku": 273,
      "hizb": 32,
      "hizbQuarter": 127,
      "sajdah": false,
      "verse_key": "20:86"
    },
    {
      "ayah_number": 87,
      "arabic_text": "قَالُوْا مَاۤ اَخْلَفْنَا مَوْعِدَكَ بِمَلْكِنَا وَ لٰكِنَّا حُمِّلْنَاۤ اَوْزَارًا مِّنْ زِیْنَةِ الْقَوْمِ فَقَذَفْنٰهَا فَكَذٰلِكَ اَلْقَی السَّامِرِیُّۙ۝۸۷",
