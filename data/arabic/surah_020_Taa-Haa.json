      "sajdah": false,
      "verse_key": "20:89"
    },
    {
      "ayah_number": 90,
      "arabic_text": "وَ لَقَدْ قَالَ لَهُمْ هٰرُوْنُ مِنْ قَبْلُ یٰقَوْمِ اِنَّمَا فُتِنْتُمْ بِهٖ ۚ وَ اِنَّ رَبَّكُمُ الرَّحْمٰنُ فَاتَّبِعُوْنِیْ وَ اَطِیْعُوْۤا اَمْرِیْ۝۹۰",
      "juz": 16,
