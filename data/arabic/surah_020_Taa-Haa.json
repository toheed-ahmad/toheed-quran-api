    },
    {
      "ayah_number": 84,
      "arabic_text": "قَالَ هُمْ اُولَآءِ عَلٰۤی اَثَرِیْ وَ عَجِلْتُ اِلَیْكَ رَبِّ لِتَرْضٰی۝۸۴",
