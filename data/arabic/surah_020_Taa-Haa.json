{
  "surah_id": 20,
  "surah_name": "Taa-Haa",
  "arabic_name": "سُورَةُ طه",
  "revelation_type": "Meccan",
  "total_ayahs": 135,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "طٰهٰۚ۝۱",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "مَاۤ اَنْزَلْنَا عَلَیْكَ الْقُرْاٰنَ لِتَشْقٰۤیۙ۝۲",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "اِلَّا تَذْكِرَةً لِّمَنْ یَّخْشٰیۙ۝۳",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "تَنْزِیْلًا مِّمَّنْ خَلَقَ الْاَرْضَ وَ السَّمٰوٰتِ الْعُلٰیؕ۝۴",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "اَلرَّحْمٰنُ عَلَی الْعَرْشِ اسْتَوٰی۝۵",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "لَهٗ مَا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ وَ مَا بَیْنَهُمَا وَ مَا تَحْتَ الثَّرٰی۝۶",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ اِنْ تَجْهَرْ بِالْقَوْلِ فَاِنَّهٗ یَعْلَمُ السِّرَّ وَ اَخْفٰی۝۷",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اَللّٰهُ لَاۤ اِلٰهَ اِلَّا هُوَ ؕ لَهُ الْاَسْمَآءُ الْحُسْنٰی۝۸",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ هَلْ اَتٰىكَ حَدِیْثُ مُوْسٰیۘ۝۹",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "اِذْ رَاٰ نَارًا فَقَالَ لِاَهْلِهِ امْكُثُوْۤا اِنِّیْۤ اٰنَسْتُ نَارًا لَّعَلِّیْۤ اٰتِیْكُمْ مِّنْهَا بِقَبَسٍ اَوْ اَجِدُ عَلَی النَّارِ هُدًی۝۱۰",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "فَلَمَّاۤ اَتٰىهَا نُوْدِیَ یٰمُوْسٰیؕ۝۱۱",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "اِنِّیْۤ اَنَا رَبُّكَ فَاخْلَعْ نَعْلَیْكَ ۚ اِنَّكَ بِالْوَادِ الْمُقَدَّسِ طُوًیؕ۝۱۲",
      "juz": 16,
      "page": 312,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَ اَنَا اخْتَرْتُكَ فَاسْتَمِعْ لِمَا یُوْحٰی۝۱۳",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "اِنَّنِیْۤ اَنَا اللّٰهُ لَاۤ اِلٰهَ اِلَّاۤ اَنَا فَاعْبُدْنِیْ ۙ وَ اَقِمِ الصَّلٰوةَ لِذِكْرِیْ۝۱۴",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "اِنَّ السَّاعَةَ اٰتِیَةٌ اَكَادُ اُخْفِیْهَا لِتُجْزٰی كُلُّ نَفْسٍۭ بِمَا تَسْعٰی۝۱۵",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "فَلَا یَصُدَّنَّكَ عَنْهَا مَنْ لَّا یُؤْمِنُ بِهَا وَ اتَّبَعَ هَوٰىهُ فَتَرْدٰی۝۱۶",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ مَا تِلْكَ بِیَمِیْنِكَ یٰمُوْسٰی۝۱۷",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "قَالَ هِیَ عَصَایَ ۚ اَتَوَكَّؤُا عَلَیْهَا وَ اَهُشُّ بِهَا عَلٰی غَنَمِیْ وَ لِیَ فِیْهَا مَاٰرِبُ اُخْرٰی۝۱۸",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "قَالَ اَلْقِهَا یٰمُوْسٰی۝۱۹",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "فَاَلْقٰىهَا فَاِذَا هِیَ حَیَّةٌ تَسْعٰی۝۲۰",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "قَالَ خُذْهَا وَ لَا تَخَفْ ۥ سَنُعِیْدُهَا سِیْرَتَهَا الْاُوْلٰی۝۲۱",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "وَ اضْمُمْ یَدَكَ اِلٰی جَنَاحِكَ تَخْرُجْ بَیْضَآءَ مِنْ غَیْرِ سُوْٓءٍ اٰیَةً اُخْرٰیۙ۝۲۲",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "لِنُرِیَكَ مِنْ اٰیٰتِنَا الْكُبْرٰیۚ۝۲۳",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "اِذْهَبْ اِلٰی فِرْعَوْنَ اِنَّهٗ طَغٰی۠۝۲۴",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 270,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "قَالَ رَبِّ اشْرَحْ لِیْ صَدْرِیْۙ۝۲۵",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَ یَسِّرْ لِیْۤ اَمْرِیْۙ۝۲۶",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَ احْلُلْ عُقْدَةً مِّنْ لِّسَانِیْۙ۝۲۷",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "یَفْقَهُوْا قَوْلِیْ۪۝۲۸",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَ اجْعَلْ لِّیْ وَزِیْرًا مِّنْ اَهْلِیْۙ۝۲۹",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "هٰرُوْنَ اَخِیۙ۝۳۰",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "اشْدُدْ بِهٖۤ اَزْرِیْۙ۝۳۱",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "وَ اَشْرِكْهُ فِیْۤ اَمْرِیْۙ۝۳۲",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "كَیْ نُسَبِّحَكَ كَثِیْرًاۙ۝۳۳",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَّ نَذْكُرَكَ كَثِیْرًاؕ۝۳۴",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اِنَّكَ كُنْتَ بِنَا بَصِیْرًا۝۳۵",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "قَالَ قَدْ اُوْتِیْتَ سُؤْلَكَ یٰمُوْسٰی۝۳۶",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "وَ لَقَدْ مَنَنَّا عَلَیْكَ مَرَّةً اُخْرٰۤیۙ۝۳۷",
      "juz": 16,
      "page": 313,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "اِذْ اَوْحَیْنَاۤ اِلٰۤی اُمِّكَ مَا یُوْحٰۤیۙ۝۳۸",
      "juz": 16,
      "page": 314,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "اَنِ اقْذِفِیْهِ فِی التَّابُوْتِ فَاقْذِفِیْهِ فِی الْیَمِّ فَلْیُلْقِهِ الْیَمُّ بِالسَّاحِلِ یَاْخُذْهُ عَدُوٌّ لِّیْ وَ عَدُوٌّ لَّهٗ ؕ وَ اَلْقَیْتُ عَلَیْكَ مَحَبَّةً مِّنِّیْ ۚ۬ وَ لِتُصْنَعَ عَلٰی عَیْنِیْۘ۝۳۹",
      "juz": 16,
      "page": 314,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "اِذْ تَمْشِیْۤ اُخْتُكَ فَتَقُوْلُ هَلْ اَدُلُّكُمْ عَلٰی مَنْ یَّكْفُلُهٗ ؕ فَرَجَعْنٰكَ اِلٰۤی اُمِّكَ كَیْ تَقَرَّ عَیْنُهَا وَ لَا تَحْزَنَ ؕ۬ وَ قَتَلْتَ نَفْسًا فَنَجَّیْنٰكَ مِنَ الْغَمِّ وَ فَتَنّٰكَ فُتُوْنًا ۫۬ فَلَبِثْتَ سِنِیْنَ فِیْۤ اَهْلِ مَدْیَنَ ۙ۬ ثُمَّ جِئْتَ عَلٰی قَدَرٍ یّٰمُوْسٰی۝۴۰",
      "juz": 16,
      "page": 314,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "وَ اصْطَنَعْتُكَ لِنَفْسِیْۚ۝۴۱",
      "juz": 16,
      "page": 314,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "اِذْهَبْ اَنْتَ وَ اَخُوْكَ بِاٰیٰتِیْ وَ لَا تَنِیَا فِیْ ذِكْرِیْۚ۝۴۲",
      "juz": 16,
      "page": 314,
      "manzil": 4,
      "ruku": 271,
      "hizb": 32,
      "hizbQuarter": 125,
      "sajdah": false,
      "verse_key": "20:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "اِذْهَبَاۤ اِلٰی فِرْعَوْنَ اِنَّهٗ طَغٰیۚۖ۝۴۳",
      "juz": 16,
      "page": 314,
