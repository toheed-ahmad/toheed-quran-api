    },
    {
      "ayah_number": 108,
      "arabic_text": "یَوْمَىِٕذٍ یَّتَّبِعُوْنَ الدَّاعِیَ لَا عِوَجَ لَهٗ ۚ وَ خَشَعَتِ الْاَصْوَاتُ لِلرَّحْمٰنِ فَلَا تَسْمَعُ اِلَّا هَمْسًا۝۱۰۸",
