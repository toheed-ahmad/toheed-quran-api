      "hizbQuarter": 126,
      "sajdah": false,
      "verse_key": "20:80"
    },
    {
      "ayah_number": 81,
      "arabic_text": "كُلُوْا مِنْ طَیِّبٰتِ مَا رَزَقْنٰكُمْ وَ لَا تَطْغَوْا فِیْهِ فَیَحِلَّ عَلَیْكُمْ غَضَبِیْ ۚ وَ مَنْ یَّحْلِلْ عَلَیْهِ غَضَبِیْ فَقَدْ هَوٰی۝۸۱",
