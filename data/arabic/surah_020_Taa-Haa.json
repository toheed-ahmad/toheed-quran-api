    },
    {
      "ayah_number": 80,
      "arabic_text": "یٰبَنِیْۤ اِسْرَآءِیْلَ قَدْ اَنْجَیْنٰكُمْ مِّنْ عَدُوِّكُمْ وَ وٰعَدْنٰكُمْ جَانِبَ الطُّوْرِ الْاَیْمَنَ وَ نَزَّلْنَا عَلَیْكُمُ الْمَنَّ وَ السَّلْوٰی۝۸۰",
