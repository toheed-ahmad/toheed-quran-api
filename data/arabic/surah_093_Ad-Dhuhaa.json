  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الضُّحٰیۙ۝۱",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ الَّیْلِ اِذَا سَجٰیۙ۝۲",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "مَا وَدَّعَكَ رَبُّكَ وَ مَا قَلٰیؕ۝۳",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ لَلْاٰخِرَةُ خَیْرٌ لَّكَ مِنَ الْاُوْلٰیؕ۝۴",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ لَسَوْفَ یُعْطِیْكَ رَبُّكَ فَتَرْضٰیؕ۝۵",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اَلَمْ یَجِدْكَ یَتِیْمًا فَاٰوٰی۪۝۶",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ وَجَدَكَ ضَآلًّا فَهَدٰی۪۝۷",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ وَجَدَكَ عَآىِٕلًا فَاَغْنٰیؕ۝۸",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "فَاَمَّا الْیَتِیْمَ فَلَا تَقْهَرْؕ۝۹",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ اَمَّا السَّآىِٕلَ فَلَا تَنْهَرْؕ۝۱۰",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ اَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ۠۝۱۱",
      "juz": 30,
      "page": 596,
      "manzil": 7,
      "ruku": 535,
      "hizb": 60,
      "hizbQuarter": 238,
      "sajdah": false,
      "verse_key": "93:11"
    }
  ]
