{
  "surah_id": 91,
  "surah_name": "Ash-Shams",
  "arabic_name": "سُورَةُ الشَّمْسِ",
  "revelation_type": "Meccan",
  "total_ayahs": 15,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الشَّمْسِ وَ ضُحٰىهَا۪ۙ",
      "verse_key": "91:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ الْقَمَرِ اِذَا تَلٰىهَا۪ۙ",
      "verse_key": "91:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ النَّهَارِ اِذَا جَلّٰىهَا۪ۙ",
      "verse_key": "91:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ الَّیْلِ اِذَا یَغْشٰىهَا۪ۙ",
      "verse_key": "91:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ السَّمَآءِ وَ مَا بَنٰىهَا۪ۙ",
      "verse_key": "91:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَ الْاَرْضِ وَ مَا طَحٰىهَا۪ۙ",
      "verse_key": "91:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ نَفْسٍ وَّ مَا سَوّٰىهَا۪ۙ",
      "verse_key": "91:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "فَاَلْهَمَهَا فُجُوْرَهَا وَ تَقْوٰىهَا۪ۙ",
      "verse_key": "91:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "قَدْ اَفْلَحَ مَنْ زَكّٰىهَا۪ۙ",
      "verse_key": "91:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ قَدْ خَابَ مَنْ دَسّٰىهَاؕ",
      "verse_key": "91:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "كَذَّبَتْ ثَمُوْدُ بِطَغْوٰىهَا۪ۤۙ",
      "verse_key": "91:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "اِذِ انْۢبَعَثَ اَشْقٰىهَا۪ۙ",
      "verse_key": "91:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "فَقَالَ لَهُمْ رَسُوْلُ اللّٰهِ نَاقَةَ اللّٰهِ وَ سُقْیٰهَاؕ",
      "verse_key": "91:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "فَكَذَّبُوْهُ فَعَقَرُوْهَا١۪ۙ۬ فَدَمْدَمَ عَلَیْهِمْ رَبُّهُمْ بِذَنْۢبِهِمْ فَسَوّٰىهَا۪ۙ",
      "verse_key": "91:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَ لَا یَخَافُ عُقْبٰهَا۠",
      "verse_key": "91:15"
    }
  ]
}