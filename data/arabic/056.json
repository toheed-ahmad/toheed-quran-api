      "verse_key": "56:85"
    },
    {
      "ayah_number": 86,
      "arabic_text": "فَلَوْ لَاۤ اِنْ كُنْتُمْ غَیْرَ مَدِیْنِیْنَۙ",
      "verse_key": "56:86"
    },
