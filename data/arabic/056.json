{
  "surah_id": 56,
  "surah_name": "Al-Waqi'ah",
  "arabic_name": "سُورَةُ الْوَاقِعَةِ",
  "revelation_type": "Meccan",
  "total_ayahs": 96,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اِذَا وَقَعَتِ الْوَاقِعَةُۙ",
      "verse_key": "56:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "لَیْسَ لِوَقْعَتِهَا كَاذِبَةٌۘ",
      "verse_key": "56:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "خَافِضَةٌ رَّافِعَةٌۙ",
      "verse_key": "56:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اِذَا رُجَّتِ الْاَرْضُ رَجًّاۙ",
      "verse_key": "56:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَّ بُسَّتِ الْجِبَالُ بَسًّاۙ",
      "verse_key": "56:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "فَكَانَتْ هَبَآءً مُّنْۢبَثًّاۙ",
      "verse_key": "56:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَّ كُنْتُمْ اَزْوَاجًا ثَلٰثَةًؕ",
      "verse_key": "56:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "فَاَصْحٰبُ الْمَیْمَنَةِ١ۙ۬ مَاۤ اَصْحٰبُ الْمَیْمَنَةِؕ",
      "verse_key": "56:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ اَصْحٰبُ الْمَشْئَمَةِ١ۙ۬ مَاۤ اَصْحٰبُ الْمَشْئَمَةِؕ",
      "verse_key": "56:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ السّٰبِقُوْنَ السّٰبِقُوْنَۚۙ",
      "verse_key": "56:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "اُولٰٓئِكَ الْمُقَرَّبُوْنَۚ",
      "verse_key": "56:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "فِیْ جَنّٰتِ النَّعِیْمِ",
      "verse_key": "56:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "ثُلَّةٌ مِّنَ الْاَوَّلِیْنَۙ",
      "verse_key": "56:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ قَلِیْلٌ مِّنَ الْاٰخِرِیْنَؕ",
      "verse_key": "56:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "عَلٰى سُرُرٍ مَّوْضُوْنَةٍۙ",
      "verse_key": "56:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "مُّتَّكِئِیْنَ عَلَیْهَا مُتَقٰبِلِیْنَ",
      "verse_key": "56:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "یَطُوْفُ عَلَیْهِمْ وِلْدَانٌ مُّخَلَّدُوْنَۙ",
      "verse_key": "56:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "بِاَكْوَابٍ وَّ اَبَارِیْقَ١ۙ۬ وَ كَاْسٍ مِّنْ مَّعِیْنٍۙ",
      "verse_key": "56:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "لَّا یُصَدَّعُوْنَ عَنْهَا وَ لَا یُنْزِفُوْنَۙ",
      "verse_key": "56:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ فَاكِهَةٍ مِّمَّا یَتَخَیَّرُوْنَۙ",
      "verse_key": "56:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَ لَحْمِ طَیْرٍ مِّمَّا یَشْتَهُوْنَؕ",
      "verse_key": "56:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "وَ حُوْرٌ عِیْنٌۙ",
      "verse_key": "56:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "كَاَمْثَالِ اللُّؤْلُؤِ الْمَكْنُوْنِۚ",
      "verse_key": "56:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "جَزَآءًۢ بِمَا كَانُوْا یَعْمَلُوْنَ",
      "verse_key": "56:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "لَا یَسْمَعُوْنَ فِیْهَا لَغْوًا وَّ لَا تَاْثِیْمًاۙ",
      "verse_key": "56:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "اِلَّا قِیْلًا سَلٰمًا سَلٰمًا",
      "verse_key": "56:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَ اَصْحٰبُ الْیَمِیْنِ١ۙ۬ مَاۤ اَصْحٰبُ الْیَمِیْنِؕ",
      "verse_key": "56:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "فِیْ سِدْرٍ مَّخْضُوْدٍۙ",
      "verse_key": "56:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَّ طَلْحٍ مَّنْضُوْدٍۙ",
      "verse_key": "56:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَّ ظِلٍّ مَّمْدُوْدٍۙ",
      "verse_key": "56:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "وَّ مَآءٍ مَّسْكُوْبٍۙ",
      "verse_key": "56:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "وَّ فَاكِهَةٍ كَثِیْرَةٍۙ",
      "verse_key": "56:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "لَّا مَقْطُوْعَةٍ وَّ لَا مَمْنُوْعَةٍۙ",
      "verse_key": "56:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَّ فُرُشٍ مَّرْفُوْعَةٍؕ",
      "verse_key": "56:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اِنَّاۤ اَنْشَاْنٰهُنَّ اِنْشَآءًۙ",
      "verse_key": "56:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "فَجَعَلْنٰهُنَّ اَبْكَارًاۙ",
      "verse_key": "56:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "عُرُبًا اَتْرَابًاۙ",
      "verse_key": "56:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "لِّاَصْحٰبِ الْیَمِیْنِ٢ؕ۠",
      "verse_key": "56:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "ثُلَّةٌ مِّنَ الْاَوَّلِیْنَۙ",
      "verse_key": "56:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "وَ ثُلَّةٌ مِّنَ الْاٰخِرِیْنَؕ",
      "verse_key": "56:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "وَ اَصْحٰبُ الشِّمَالِ١ۙ۬ مَاۤ اَصْحٰبُ الشِّمَالِؕ",
      "verse_key": "56:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "فِیْ سَمُوْمٍ وَّ حَمِیْمٍۙ",
      "verse_key": "56:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "وَّ ظِلٍّ مِّنْ یَّحْمُوْمٍۙ",
      "verse_key": "56:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "لَّا بَارِدٍ وَّ لَا كَرِیْمٍ",
      "verse_key": "56:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "اِنَّهُمْ كَانُوْا قَبْلَ ذٰلِكَ مُتْرَفِیْنَۚۖ",
      "verse_key": "56:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "وَ كَانُوْا یُصِرُّوْنَ عَلَى الْحِنْثِ الْعَظِیْمِۚ",
      "verse_key": "56:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "وَ كَانُوْا یَقُوْلُوْنَ١ۙ۬ اَئِذَا مِتْنَا وَ كُنَّا تُرَابًا وَّ عِظَامًا ءَاِنَّا لَمَبْعُوْثُوْنَۙ",
      "verse_key": "56:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "اَوَ اٰبَآؤُنَا الْاَوَّلُوْنَ",
      "verse_key": "56:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "قُلْ اِنَّ الْاَوَّلِیْنَ وَ الْاٰخِرِیْنَۙ",
      "verse_key": "56:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "لَمَجْمُوْعُوْنَ١ۙ۬ اِلٰى مِیْقَاتِ یَوْمٍ مَّعْلُوْمٍ",
      "verse_key": "56:50"
    },
    {
      "ayah_number": 51,
      "arabic_text": "ثُمَّ اِنَّكُمْ اَیُّهَا الضَّآلُّوْنَ الْمُكَذِّبُوْنَۙ",
      "verse_key": "56:51"
    },
    {
      "ayah_number": 52,
      "arabic_text": "لَاٰكِلُوْنَ مِنْ شَجَرٍ مِّنْ زَقُّوْمٍۙ",
      "verse_key": "56:52"
    },
    {
      "ayah_number": 53,
      "arabic_text": "فَمَالِئُوْنَ مِنْهَا الْبُطُوْنَۚ",
      "verse_key": "56:53"
    },
    {
      "ayah_number": 54,
      "arabic_text": "فَشٰرِبُوْنَ عَلَیْهِ مِنَ الْحَمِیْمِۚ",
      "verse_key": "56:54"
    },
    {
      "ayah_number": 55,
      "arabic_text": "فَشٰرِبُوْنَ شُرْبَ الْهِیْمِؕ",
      "verse_key": "56:55"
    },
    {
      "ayah_number": 56,
      "arabic_text": "هٰذَا نُزُلُهُمْ یَوْمَ الدِّیْنِؕ",
      "verse_key": "56:56"
    },
    {
      "ayah_number": 57,
      "arabic_text": "نَحْنُ خَلَقْنٰكُمْ فَلَوْ لَا تُصَدِّقُوْنَ",
      "verse_key": "56:57"
    },
    {
      "ayah_number": 58,
      "arabic_text": "اَفَرَءَیْتُمْ مَّا تُمْنُوْنَؕ",
      "verse_key": "56:58"
    },
    {
      "ayah_number": 59,
      "arabic_text": "ءَاَنْتُمْ تَخْلُقُوْنَهٗۤ اَمْ نَحْنُ الْخٰلِقُوْنَ",
      "verse_key": "56:59"
    },
    {
      "ayah_number": 60,
      "arabic_text": "نَحْنُ قَدَّرْنَا بَیْنَكُمُ الْمَوْتَ وَ مَا نَحْنُ بِمَسْبُوْقِیْنَۙ",
      "verse_key": "56:60"
    },
    {
      "ayah_number": 61,
      "arabic_text": "عَلٰۤى اَنْ نُّبَدِّلَ اَمْثَالَكُمْ وَ نُنْشِئَكُمْ فِیْ مَا لَا تَعْلَمُوْنَ",
      "verse_key": "56:61"
    },
    {
      "ayah_number": 62,
      "arabic_text": "وَ لَقَدْ عَلِمْتُمُ النَّشْاَةَ الْاُوْلٰى فَلَوْ لَا تَذَكَّرُوْنَ",
      "verse_key": "56:62"
    },
    {
      "ayah_number": 63,
      "arabic_text": "اَفَرَءَیْتُمْ مَّا تَحْرُثُوْنَؕ",
      "verse_key": "56:63"
    },
    {
      "ayah_number": 64,
      "arabic_text": "ءَاَنْتُمْ تَزْرَعُوْنَهٗۤ اَمْ نَحْنُ الزّٰرِعُوْنَ",
      "verse_key": "56:64"
    },
    {
      "ayah_number": 65,
      "arabic_text": "لَوْ نَشَآءُ لَجَعَلْنٰهُ حُطَامًا فَظَلْتُمْ تَفَكَّهُوْنَ",
      "verse_key": "56:65"
    },
    {
      "ayah_number": 66,
      "arabic_text": "اِنَّا لَمُغْرَمُوْنَۙ",
      "verse_key": "56:66"
    },
    {
      "ayah_number": 67,
      "arabic_text": "بَلْ نَحْنُ مَحْرُوْمُوْنَ",
      "verse_key": "56:67"
    },
    {
      "ayah_number": 68,
      "arabic_text": "اَفَرَءَیْتُمُ الْمَآءَ الَّذِیْ تَشْرَبُوْنَؕ",
      "verse_key": "56:68"
    },
    {
      "ayah_number": 69,
      "arabic_text": "ءَاَنْتُمْ اَنْزَلْتُمُوْهُ مِنَ الْمُزْنِ اَمْ نَحْنُ الْمُنْزِلُوْنَ",
      "verse_key": "56:69"
    },
    {
      "ayah_number": 70,
      "arabic_text": "لَوْ نَشَآءُ جَعَلْنٰهُ اُجَاجًا فَلَوْ لَا تَشْكُرُوْنَ",
      "verse_key": "56:70"
    },
    {
      "ayah_number": 71,
      "arabic_text": "اَفَرَءَیْتُمُ النَّارَ الَّتِیْ تُوْرُوْنَؕ",
      "verse_key": "56:71"
    },
    {
      "ayah_number": 72,
      "arabic_text": "ءَاَنْتُمْ اَنْشَاْتُمْ شَجَرَتَهَاۤ اَمْ نَحْنُ الْمُنْشِئُوْنَ",
      "verse_key": "56:72"
    },
    {
      "ayah_number": 73,
      "arabic_text": "نَحْنُ جَعَلْنٰهَا تَذْكِرَةً وَّ مَتَاعًا لِّلْمُقْوِیْنَۚ",
      "verse_key": "56:73"
    },
    {
      "ayah_number": 74,
      "arabic_text": "فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِیْمِ۠",
      "verse_key": "56:74"
    },
    {
      "ayah_number": 75,
      "arabic_text": "فَلَاۤ اُقْسِمُ بِمَوٰقِعِ النُّجُوْمِۙ",
      "verse_key": "56:75"
    },
    {
      "ayah_number": 76,
      "arabic_text": "وَ اِنَّهٗ لَقَسَمٌ لَّوْ تَعْلَمُوْنَ عَظِیْمٌۙ",
      "verse_key": "56:76"
    },
    {
      "ayah_number": 77,
      "arabic_text": "اِنَّهٗ لَقُرْاٰنٌ كَرِیْمٌۙ",
      "verse_key": "56:77"
    },
    {
      "ayah_number": 78,
      "arabic_text": "فِیْ كِتٰبٍ مَّكْنُوْنٍۙ",
      "verse_key": "56:78"
    },
    {
      "ayah_number": 79,
      "arabic_text": "لَّا یَمَسُّهٗۤ اِلَّا الْمُطَهَّرُوْنَؕ",
      "verse_key": "56:79"
    },
    {
      "ayah_number": 80,
      "arabic_text": "تَنْزِیْلٌ مِّنْ رَّبِّ الْعٰلَمِیْنَ",
      "verse_key": "56:80"
    },
    {
      "ayah_number": 81,
      "arabic_text": "اَفَبِهٰذَا الْحَدِیْثِ اَنْتُمْ مُّدْهِنُوْنَۙ",
      "verse_key": "56:81"
    },
    {
      "ayah_number": 82,
      "arabic_text": "وَ تَجْعَلُوْنَ رِزْقَكُمْ اَنَّكُمْ تُكَذِّبُوْنَ",
      "verse_key": "56:82"
    },
    {
      "ayah_number": 83,
      "arabic_text": "فَلَوْ لَاۤ اِذَا بَلَغَتِ الْحُلْقُوْمَۙ",
      "verse_key": "56:83"
    },
    {
      "ayah_number": 84,
      "arabic_text": "وَ اَنْتُمْ حِیْنَئِذٍ تَنْظُرُوْنَۙ",
      "verse_key": "56:84"
    },
    {
      "ayah_number": 85,
