{
  "surah_id": 71,
  "surah_name": "Nooh",
  "arabic_name": "سُورَةُ نُوحٍ",
  "revelation_type": "Meccan",
  "total_ayahs": 28,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اِنَّاۤ اَرْسَلْنَا نُوْحًا اِلٰی قَوْمِهٖۤ اَنْ اَنْذِرْ قَوْمَكَ مِنْ قَبْلِ اَنْ یَّاْتِیَهُمْ عَذَابٌ اَلِیْمٌ۝۱",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "قَالَ یٰقَوْمِ اِنِّیْ لَكُمْ نَذِیْرٌ مُّبِیْنٌۙ۝۲",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "اَنِ اعْبُدُوا اللّٰهَ وَ اتَّقُوْهُ وَ اَطِیْعُوْنِۙ۝۳",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "یَغْفِرْ لَكُمْ مِّنْ ذُنُوْبِكُمْ وَ یُؤَخِّرْكُمْ اِلٰۤی اَجَلٍ مُّسَمًّی ؕ اِنَّ اَجَلَ اللّٰهِ اِذَا جَآءَ لَا یُؤَخَّرُ ۘ لَوْ كُنْتُمْ تَعْلَمُوْنَ۝۴",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "قَالَ رَبِّ اِنِّیْ دَعَوْتُ قَوْمِیْ لَیْلًا وَّ نَهَارًاۙ۝۵",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "فَلَمْ یَزِدْهُمْ دُعَآءِیْۤ اِلَّا فِرَارًا۝۶",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ اِنِّیْ كُلَّمَا دَعَوْتُهُمْ لِتَغْفِرَ لَهُمْ جَعَلُوْۤا اَصَابِعَهُمْ فِیْۤ اٰذَانِهِمْ وَ اسْتَغْشَوْا ثِیَابَهُمْ وَ اَصَرُّوْا وَ اسْتَكْبَرُوا اسْتِكْبَارًاۚ۝۷",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "ثُمَّ اِنِّیْ دَعَوْتُهُمْ جِهَارًاۙ۝۸",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "ثُمَّ اِنِّیْۤ اَعْلَنْتُ لَهُمْ وَ اَسْرَرْتُ لَهُمْ اِسْرَارًاۙ۝۹",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فَقُلْتُ اسْتَغْفِرُوْا رَبَّكُمْ ؕ اِنَّهٗ كَانَ غَفَّارًاۙ۝۱۰",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "یُّرْسِلِ السَّمَآءَ عَلَیْكُمْ مِّدْرَارًاۙ۝۱۱",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَّ یُمْدِدْكُمْ بِاَمْوَالٍ وَّ بَنِیْنَ وَ یَجْعَلْ لَّكُمْ جَنّٰتٍ وَّ یَجْعَلْ لَّكُمْ اَنْهٰرًاؕ۝۱۲",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "مَا لَكُمْ لَا تَرْجُوْنَ لِلّٰهِ وَقَارًاۚ۝۱۳",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ قَدْ خَلَقَكُمْ اَطْوَارًا۝۱۴",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "اَلَمْ تَرَوْا كَیْفَ خَلَقَ اللّٰهُ سَبْعَ سَمٰوٰتٍ طِبَاقًاۙ۝۱۵",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "وَّ جَعَلَ الْقَمَرَ فِیْهِنَّ نُوْرًا وَّ جَعَلَ الشَّمْسَ سِرَاجًا۝۱۶",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ اللّٰهُ اَنْۢبَتَكُمْ مِّنَ الْاَرْضِ نَبَاتًاۙ۝۱۷",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "ثُمَّ یُعِیْدُكُمْ فِیْهَا وَ یُخْرِجُكُمْ اِخْرَاجًا۝۱۸",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ اللّٰهُ جَعَلَ لَكُمُ الْاَرْضَ بِسَاطًاۙ۝۱۹",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "لِّتَسْلُكُوْا مِنْهَا سُبُلًا فِجَاجًا۠۝۲۰",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 504,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "قَالَ نُوْحٌ رَّبِّ اِنَّهُمْ عَصَوْنِیْ وَ اتَّبَعُوْا مَنْ لَّمْ یَزِدْهُ مَالُهٗ وَ وَلَدُهٗۤ اِلَّا خَسَارًاۚ۝۲۱",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 505,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "وَ مَكَرُوْا مَكْرًا كُبَّارًاۚ۝۲۲",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 505,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "وَ قَالُوْا لَا تَذَرُنَّ اٰلِهَتَكُمْ وَ لَا تَذَرُنَّ وَدًّا وَّ لَا سُوَاعًا ۙ۬ وَّ لَا یَغُوْثَ وَ یَعُوْقَ وَ نَسْرًاۚ۝۲۳",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 505,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَ قَدْ اَضَلُّوْا كَثِیْرًا ۚ۬ وَ لَا تَزِدِ الظّٰلِمِیْنَ اِلَّا ضَلٰلًا۝۲۴",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 505,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "مِمَّا خَطِیْٓـٰٔتِهِمْ اُغْرِقُوْا فَاُدْخِلُوْا نَارًا ۙ۬ فَلَمْ یَجِدُوْا لَهُمْ مِّنْ دُوْنِ اللّٰهِ اَنْصَارًا۝۲۵",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 505,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَ قَالَ نُوْحٌ رَّبِّ لَا تَذَرْ عَلَی الْاَرْضِ مِنَ الْكٰفِرِیْنَ دَیَّارًا۝۲۶",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 505,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "اِنَّكَ اِنْ تَذَرْهُمْ یُضِلُّوْا عِبَادَكَ وَ لَا یَلِدُوْۤا اِلَّا فَاجِرًا كَفَّارًا۝۲۷",
      "juz": 29,
      "page": 571,
      "manzil": 7,
      "ruku": 505,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "71:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "رَبِّ اغْفِرْ لِیْ وَ لِوَالِدَیَّ وَ لِمَنْ دَخَلَ بَیْتِیَ مُؤْمِنًا وَّ لِلْمُؤْمِنِیْنَ وَ الْمُؤْمِنٰتِ ؕ وَ لَا تَزِدِ الظّٰلِمِیْنَ اِلَّا تَبَارًا۠۝۲۸",
