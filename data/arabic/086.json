      "sajdah": false,
      "verse_key": "86:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "النَّجْمُ الثَّاقِبُۙ۝۳",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اِنْ كُلُّ نَفْسٍ لَّمَّا عَلَیْهَا حَافِظٌؕ۝۴",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَلْیَنْظُرِ الْاِنْسَانُ مِمَّ خُلِقَؕ۝۵",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "خُلِقَ مِنْ مَّآءٍ دَافِقٍۙ۝۶",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "یَّخْرُجُ مِنْۢ بَیْنِ الصُّلْبِ وَ التَّرَآىِٕبِؕ۝۷",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اِنَّهٗ عَلٰی رَجْعِهٖ لَقَادِرٌؕ۝۸",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "یَوْمَ تُبْلَی السَّرَآىِٕرُۙ۝۹",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فَمَا لَهٗ مِنْ قُوَّةٍ وَّ لَا نَاصِرٍؕ۝۱۰",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ السَّمَآءِ ذَاتِ الرَّجْعِۙ۝۱۱",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ الْاَرْضِ ذَاتِ الصَّدْعِۙ۝۱۲",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 528,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "86:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "اِنَّهٗ لَقَوْلٌ فَصْلٌۙ۝۱۳",
