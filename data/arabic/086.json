{
  "surah_id": 86,
  "surah_name": "At-Tariq",
  "arabic_name": "سُورَةُ الطَّارِقِ",
  "revelation_type": "Meccan",
  "total_ayahs": 17,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ السَّمَآءِ وَ الطَّارِقِۙ",
      "verse_key": "86:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا الطَّارِقُۙ",
      "verse_key": "86:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "النَّجْمُ الثَّاقِبُۙ",
      "verse_key": "86:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اِنْ كُلُّ نَفْسٍ لَّمَّا عَلَیْهَا حَافِظٌؕ",
      "verse_key": "86:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَلْیَنْظُرِ الْاِنْسَانُ مِمَّ خُلِقَؕ",
      "verse_key": "86:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "خُلِقَ مِنْ مَّآءٍ دَافِقٍۙ",
      "verse_key": "86:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "یَّخْرُجُ مِنْۢ بَیْنِ الصُّلْبِ وَ التَّرَآئِبِؕ",
      "verse_key": "86:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اِنَّهٗ عَلٰى رَجْعِهٖ لَقَادِرٌؕ",
      "verse_key": "86:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "یَوْمَ تُبْلَى السَّرَآئِرُۙ",
      "verse_key": "86:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فَمَا لَهٗ مِنْ قُوَّةٍ وَّ لَا نَاصِرٍؕ",
      "verse_key": "86:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ السَّمَآءِ ذَاتِ الرَّجْعِۙ",
      "verse_key": "86:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ الْاَرْضِ ذَاتِ الصَّدْعِۙ",
      "verse_key": "86:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "اِنَّهٗ لَقَوْلٌ فَصْلٌۙ",
      "verse_key": "86:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَّ مَا هُوَ بِالْهَزْلِؕ",
      "verse_key": "86:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "اِنَّهُمْ یَكِیْدُوْنَ كَیْدًاۙ",
      "verse_key": "86:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "وَّ اَكِیْدُ كَیْدًاۚۖ",
      "verse_key": "86:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "فَمَهِّلِ الْكٰفِرِیْنَ اَمْهِلْهُمْ رُوَیْدًا۠",
      "verse_key": "86:17"
    }
  ]
}