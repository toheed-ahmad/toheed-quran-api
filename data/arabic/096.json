      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "96:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "عَلَّمَ الْاِنْسَانَ مَا لَمْ یَعْلَمْؕ۝۵",
      "juz": 30,
      "page": 597,
      "manzil": 7,
      "ruku": 538,
      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "96:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "كَلَّاۤ اِنَّ الْاِنْسَانَ لَیَطْغٰۤیۙ۝۶",
      "juz": 30,
      "page": 597,
      "manzil": 7,
      "ruku": 538,
      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "96:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "اَنْ رَّاٰهُ اسْتَغْنٰیؕ۝۷",
      "juz": 30,
      "page": 597,
      "manzil": 7,
      "ruku": 538,
      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "96:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اِنَّ اِلٰی رَبِّكَ الرُّجْعٰیؕ۝۸",
      "juz": 30,
      "page": 597,
      "manzil": 7,
      "ruku": 538,
      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "96:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "اَرَءَیْتَ الَّذِیْ یَنْهٰیۙ۝۹",
      "juz": 30,
      "page": 597,
      "manzil": 7,
      "ruku": 538,
      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "96:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "عَبْدًا اِذَا صَلّٰیؕ۝۱۰",
      "juz": 30,
      "page": 597,
      "manzil": 7,
      "ruku": 538,
      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "96:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "اَرَءَیْتَ اِنْ كَانَ عَلَی الْهُدٰۤیۙ۝۱۱",
      "juz": 30,
      "page": 597,
      "manzil": 7,
