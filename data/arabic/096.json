{
  "surah_id": 96,
  "surah_name": "Al-'Alaq",
  "arabic_name": "سُورَةُ الْعَلَقِ",
  "revelation_type": "Meccan",
  "total_ayahs": 19,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اِقْرَاْ بِاسْمِ رَبِّكَ الَّذِیْ خَلَقَۚ",
      "verse_key": "96:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "خَلَقَ الْاِنْسَانَ مِنْ عَلَقٍۚ",
      "verse_key": "96:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "اِقْرَاْ وَ رَبُّكَ الْاَكْرَمُۙ",
      "verse_key": "96:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "الَّذِیْ عَلَّمَ بِالْقَلَمِۙ",
      "verse_key": "96:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "عَلَّمَ الْاِنْسَانَ مَا لَمْ یَعْلَمْؕ",
      "verse_key": "96:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "كَلَّاۤ اِنَّ الْاِنْسَانَ لَیَطْغٰۤىۙ",
      "verse_key": "96:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "اَنْ رَّاٰهُ اسْتَغْنٰىؕ",
      "verse_key": "96:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اِنَّ اِلٰى رَبِّكَ الرُّجْعٰىؕ",
      "verse_key": "96:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "اَرَءَیْتَ الَّذِیْ یَنْهٰىۙ",
      "verse_key": "96:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "عَبْدًا اِذَا صَلّٰىؕ",
      "verse_key": "96:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "اَرَءَیْتَ اِنْ كَانَ عَلَى الْهُدٰۤىۙ",
      "verse_key": "96:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "اَوْ اَمَرَ بِالتَّقْوٰىؕ",
      "verse_key": "96:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "اَرَءَیْتَ اِنْ كَذَّبَ وَ تَوَلّٰىؕ",
      "verse_key": "96:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "اَلَمْ یَعْلَمْ بِاَنَّ اللّٰهَ یَرٰىؕ",
      "verse_key": "96:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "كَلَّا لَئِنْ لَّمْ یَنْتَهِ١ۙ۬ لَنَسْفَعًۢا بِالنَّاصِیَةِۙ",
      "verse_key": "96:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "نَاصِیَةٍ كَاذِبَةٍ خَاطِئَةٍۚ",
      "verse_key": "96:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "فَلْیَدْعُ نَادِیَهٗۙ",
      "verse_key": "96:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "سَنَدْعُ الزَّبَانِیَةَۙ",
      "verse_key": "96:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "كَلَّا١ؕ لَا تُطِعْهُ وَ اسْجُدْ وَ اقْتَرِبْ۠۩",
      "verse_key": "96:19"
    }
  ]
}