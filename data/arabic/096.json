      "hizb": 60,
      "hizbQuarter": 239,
      "sajdah": false,
      "verse_key": "96:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "اَلَمْ یَعْلَمْ بِاَنَّ اللّٰهَ یَرٰیؕ۝۱۴",
      "juz": 30,
      "page": 597,
