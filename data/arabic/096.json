      "sajdah": false,
      "verse_key": "96:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "كَلَّا لَىِٕنْ لَّمْ یَنْتَهِ ۙ۬ لَنَسْفَعًۢا بِالنَّاصِیَةِۙ۝۱۵",
