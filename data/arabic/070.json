{
  "surah_id": 70,
  "surah_name": "Al-Ma'arij",
  "arabic_name": "سُورَةُ الْمَعَارِجِ",
  "revelation_type": "Meccan",
  "total_ayahs": 44,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "سَاَلَ سَآئِلٌۢ بِعَذَابٍ وَّاقِعٍۙ",
      "verse_key": "70:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "لِّلْكٰفِرِیْنَ لَیْسَ لَهٗ دَافِعٌۙ",
      "verse_key": "70:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "مِّنَ اللّٰهِ ذِی الْمَعَارِجِؕ",
      "verse_key": "70:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "تَعْرُجُ الْمَلٰٓئِكَةُ وَ الرُّوْحُ اِلَیْهِ فِیْ یَوْمٍ كَانَ مِقْدَارُهٗ خَمْسِیْنَ اَلْفَ سَنَةٍۚ",
      "verse_key": "70:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَاصْبِرْ صَبْرًا جَمِیْلًا",
      "verse_key": "70:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اِنَّهُمْ یَرَوْنَهٗ بَعِیْدًاۙ",
      "verse_key": "70:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَّ نَرٰىهُ قَرِیْبًاؕ",
      "verse_key": "70:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "یَوْمَ تَكُوْنُ السَّمَآءُ كَالْمُهْلِۙ",
      "verse_key": "70:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ تَكُوْنُ الْجِبَالُ كَالْعِهْنِۙ",
      "verse_key": "70:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ لَا یَسْئَلُ حَمِیْمٌ حَمِیْمًاۚۖ",
      "verse_key": "70:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "یُّبَصَّرُوْنَهُمْ١ؕ یَوَدُّ الْمُجْرِمُ لَوْ یَفْتَدِیْ مِنْ عَذَابِ یَوْمِئِذٍۭ بِبَنِیْهِۙ",
      "verse_key": "70:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ صَاحِبَتِهٖ وَ اَخِیْهِۙ",
      "verse_key": "70:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَ فَصِیْلَتِهِ الَّتِیْ تُئْوِیْهِۙ",
      "verse_key": "70:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ مَنْ فِی الْاَرْضِ جَمِیْعًا١ۙ ثُمَّ یُنْجِیْهِۙ",
      "verse_key": "70:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "كَلَّا١ؕ اِنَّهَا لَظٰىۙ",
      "verse_key": "70:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "نَزَّاعَةً لِّلشَّوٰىۚۖ",
      "verse_key": "70:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "تَدْعُوْا مَنْ اَدْبَرَ وَ تَوَلّٰىۙ",
      "verse_key": "70:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَ جَمَعَ فَاَوْعٰى",
      "verse_key": "70:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "اِنَّ الْاِنْسَانَ خُلِقَ هَلُوْعًاۙ",
      "verse_key": "70:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "اِذَا مَسَّهُ الشَّرُّ جَزُوْعًاۙ",
      "verse_key": "70:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَّ اِذَا مَسَّهُ الْخَیْرُ مَنُوْعًاۙ",
      "verse_key": "70:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "اِلَّا الْمُصَلِّیْنَۙ",
      "verse_key": "70:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "الَّذِیْنَ هُمْ عَلٰى صَلَاتِهِمْ دَآئِمُوْنَ۪ۙ",
      "verse_key": "70:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَ الَّذِیْنَ فِیْۤ اَمْوَالِهِمْ حَقٌّ مَّعْلُوْمٌ۪ۙ",
      "verse_key": "70:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "لِّلسَّآئِلِ وَ الْمَحْرُوْمِ۪ۙ",
      "verse_key": "70:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَ الَّذِیْنَ یُصَدِّقُوْنَ بِیَوْمِ الدِّیْنِ۪ۙ",
      "verse_key": "70:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَ الَّذِیْنَ هُمْ مِّنْ عَذَابِ رَبِّهِمْ مُّشْفِقُوْنَۚ",
      "verse_key": "70:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "اِنَّ عَذَابَ رَبِّهِمْ غَیْرُ مَاْمُوْنٍ",
      "verse_key": "70:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَ الَّذِیْنَ هُمْ لِفُرُوْجِهِمْ حٰفِظُوْنَۙ",
      "verse_key": "70:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "اِلَّا عَلٰۤى اَزْوَاجِهِمْ اَوْ مَا مَلَكَتْ اَیْمَانُهُمْ فَاِنَّهُمْ غَیْرُ مَلُوْمِیْنَۚ",
      "verse_key": "70:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "فَمَنِ ابْتَغٰى وَرَآءَ ذٰلِكَ فَاُولٰٓئِكَ هُمُ الْعٰدُوْنَۚ",
      "verse_key": "70:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "وَ الَّذِیْنَ هُمْ لِاَمٰنٰتِهِمْ وَ عَهْدِهِمْ رٰعُوْنَ۪ۙ",
      "verse_key": "70:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "وَ الَّذِیْنَ هُمْ بِشَهٰدٰتِهِمْ قَآئِمُوْنَ۪ۙ",
      "verse_key": "70:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَ الَّذِیْنَ هُمْ عَلٰى صَلَاتِهِمْ یُحَافِظُوْنَؕ",
      "verse_key": "70:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اُولٰٓئِكَ فِیْ جَنّٰتٍ مُّكْرَمُوْنَ٢ؕ۠",
      "verse_key": "70:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "فَمَالِ الَّذِیْنَ كَفَرُوْا قِبَلَكَ مُهْطِعِیْنَۙ",
      "verse_key": "70:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "عَنِ الْیَمِیْنِ وَ عَنِ الشِّمَالِ عِزِیْنَ",
      "verse_key": "70:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "اَیَطْمَعُ كُلُّ امْرِئٍ مِّنْهُمْ اَنْ یُّدْخَلَ جَنَّةَ نَعِیْمٍۙ",
      "verse_key": "70:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "كَلَّا١ؕ اِنَّا خَلَقْنٰهُمْ مِّمَّا یَعْلَمُوْنَ",
      "verse_key": "70:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "فَلَاۤ اُقْسِمُ بِرَبِّ الْمَشٰرِقِ وَ الْمَغٰرِبِ اِنَّا لَقٰدِرُوْنَۙ",
      "verse_key": "70:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "عَلٰۤى اَنْ نُّبَدِّلَ خَیْرًا مِّنْهُمْ١ۙ وَ مَا نَحْنُ بِمَسْبُوْقِیْنَ",
      "verse_key": "70:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "فَذَرْهُمْ یَخُوْضُوْا وَ یَلْعَبُوْا حَتّٰى یُلٰقُوْا یَوْمَهُمُ الَّذِیْ یُوْعَدُوْنَۙ",
      "verse_key": "70:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "یَوْمَ یَخْرُجُوْنَ مِنَ الْاَجْدَاثِ سِرَاعًا كَاَنَّهُمْ اِلٰى نُصُبٍ یُّوْفِضُوْنَۙ",
      "verse_key": "70:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "خَاشِعَةً اَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ١ؕ ذٰلِكَ الْیَوْمُ الَّذِیْ كَانُوْا یُوْعَدُوْنَ۠",
      "verse_key": "70:44"
    }
  ]
}