{
  "surah_id": 37,
  "surah_name": "As-Saffat",
  "arabic_name": "سُورَةُ الصَّافَّاتِ",
  "revelation_type": "Meccan",
  "total_ayahs": 182,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الصّٰٓفّٰتِ صَفًّاۙ",
      "verse_key": "37:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "فَالزّٰجِرٰتِ زَجْرًاۙ",
      "verse_key": "37:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "فَالتّٰلِیٰتِ ذِكْرًاۙ",
      "verse_key": "37:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اِنَّ اِلٰهَكُمْ لَوَاحِدٌؕ",
      "verse_key": "37:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "رَبُّ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا وَ رَبُّ الْمَشَارِقِؕ",
      "verse_key": "37:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اِنَّا زَیَّنَّا السَّمَآءَ الدُّنْیَا بِزِیْنَةِ اِ۟لْكَوَاكِبِۙ",
      "verse_key": "37:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ حِفْظًا مِّنْ كُلِّ شَیْطٰنٍ مَّارِدٍۚ",
      "verse_key": "37:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "لَا یَسَّمَّعُوْنَ اِلَى الْمَلَاِ الْاَعْلٰى وَ یُقْذَفُوْنَ مِنْ كُلِّ جَانِبٍۗۖ",
      "verse_key": "37:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "دُحُوْرًا وَّ لَهُمْ عَذَابٌ وَّاصِبٌۙ",
      "verse_key": "37:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "اِلَّا مَنْ خَطِفَ الْخَطْفَةَ فَاَتْبَعَهٗ شِهَابٌ ثَاقِبٌ",
      "verse_key": "37:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "فَاسْتَفْتِهِمْ اَهُمْ اَشَدُّ خَلْقًا اَمْ مَّنْ خَلَقْنَا١ؕ اِنَّا خَلَقْنٰهُمْ مِّنْ طِیْنٍ لَّازِبٍ",
      "verse_key": "37:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "بَلْ عَجِبْتَ وَ یَسْخَرُوْنَ۪",
      "verse_key": "37:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَ اِذَا ذُكِّرُوْا لَا یَذْكُرُوْنَ۪",
      "verse_key": "37:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ اِذَا رَاَوْا اٰیَةً یَّسْتَسْخِرُوْنَ۪",
      "verse_key": "37:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَ قَالُوْۤا اِنْ هٰذَاۤ اِلَّا سِحْرٌ مُّبِیْنٌۚۖ",
      "verse_key": "37:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "ءَاِذَا مِتْنَا وَ كُنَّا تُرَابًا وَّ عِظَامًا ءَاِنَّا لَمَبْعُوْثُوْنَۙ",
      "verse_key": "37:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "اَوَ اٰبَآؤُنَا الْاَوَّلُوْنَؕ",
      "verse_key": "37:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "قُلْ نَعَمْ وَ اَنْتُمْ دَاخِرُوْنَۚ",
      "verse_key": "37:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "فَاِنَّمَا هِیَ زَجْرَةٌ وَّاحِدَةٌ فَاِذَا هُمْ یَنْظُرُوْنَ",
      "verse_key": "37:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ قَالُوْا یٰوَیْلَنَا هٰذَا یَوْمُ الدِّیْنِ",
      "verse_key": "37:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "هٰذَا یَوْمُ الْفَصْلِ الَّذِیْ كُنْتُمْ بِهٖ تُكَذِّبُوْنَ۠",
      "verse_key": "37:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "اُحْشُرُوا الَّذِیْنَ ظَلَمُوْا وَ اَزْوَاجَهُمْ وَ مَا كَانُوْا یَعْبُدُوْنَۙ",
      "verse_key": "37:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "مِنْ دُوْنِ اللّٰهِ فَاهْدُوْهُمْ اِلٰى صِرَاطِ الْجَحِیْمِ",
      "verse_key": "37:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَ قِفُوْهُمْ اِنَّهُمْ مَّسْئُوْلُوْنَۙ",
      "verse_key": "37:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "مَا لَكُمْ لَا تَنَاصَرُوْنَ",
      "verse_key": "37:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "بَلْ هُمُ الْیَوْمَ مُسْتَسْلِمُوْنَ",
      "verse_key": "37:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَ اَقْبَلَ بَعْضُهُمْ عَلٰى بَعْضٍ یَّتَسَآءَلُوْنَ",
      "verse_key": "37:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "قَالُوْۤا اِنَّكُمْ كُنْتُمْ تَاْتُوْنَنَا عَنِ الْیَمِیْنِ",
      "verse_key": "37:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "قَالُوْا بَلْ لَّمْ تَكُوْنُوْا مُؤْمِنِیْنَۚ",
      "verse_key": "37:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَ مَا كَانَ لَنَا عَلَیْكُمْ مِّنْ سُلْطٰنٍ١ۚ بَلْ كُنْتُمْ قَوْمًا طٰغِیْنَ",
      "verse_key": "37:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "فَحَقَّ عَلَیْنَا قَوْلُ رَبِّنَاۤ١ۖۗ اِنَّا لَذَآئِقُوْنَ",
      "verse_key": "37:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "فَاَغْوَیْنٰكُمْ اِنَّا كُنَّا غٰوِیْنَ",
      "verse_key": "37:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "فَاِنَّهُمْ یَوْمَئِذٍ فِی الْعَذَابِ مُشْتَرِكُوْنَ",
      "verse_key": "37:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "اِنَّا كَذٰلِكَ نَفْعَلُ بِالْمُجْرِمِیْنَ",
      "verse_key": "37:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اِنَّهُمْ كَانُوْۤا اِذَا قِیْلَ لَهُمْ لَاۤ اِلٰهَ اِلَّا اللّٰهُ١ۙ یَسْتَكْبِرُوْنَۙ",
      "verse_key": "37:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "وَ یَقُوْلُوْنَ اَئِنَّا لَتَارِكُوْۤا اٰلِهَتِنَا لِشَاعِرٍ مَّجْنُوْنٍؕ",
      "verse_key": "37:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "بَلْ جَآءَ بِالْحَقِّ وَ صَدَّقَ الْمُرْسَلِیْنَ",
      "verse_key": "37:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "اِنَّكُمْ لَذَآئِقُوا الْعَذَابِ الْاَلِیْمِۚ",
      "verse_key": "37:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "وَ مَا تُجْزَوْنَ اِلَّا مَا كُنْتُمْ تَعْمَلُوْنَۙ",
      "verse_key": "37:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "اِلَّا عِبَادَ اللّٰهِ الْمُخْلَصِیْنَ",
      "verse_key": "37:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "اُولٰٓئِكَ لَهُمْ رِزْقٌ مَّعْلُوْمٌۙ",
      "verse_key": "37:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "فَوَاكِهُ١ۚ وَ هُمْ مُّكْرَمُوْنَۙ",
      "verse_key": "37:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "فِیْ جَنّٰتِ النَّعِیْمِۙ",
      "verse_key": "37:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "عَلٰى سُرُرٍ مُّتَقٰبِلِیْنَ",
      "verse_key": "37:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "یُطَافُ عَلَیْهِمْ بِكَاْسٍ مِّنْ مَّعِیْنٍۭۙ",
      "verse_key": "37:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "بَیْضَآءَ لَذَّةٍ لِّلشّٰرِبِیْنَۚۖ",
      "verse_key": "37:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "لَا فِیْهَا غَوْلٌ وَّ لَا هُمْ عَنْهَا یُنْزَفُوْنَ",
      "verse_key": "37:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "وَ عِنْدَهُمْ قٰصِرٰتُ الطَّرْفِ عِیْنٌۙ",
      "verse_key": "37:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "كَاَنَّهُنَّ بَیْضٌ مَّكْنُوْنٌ",
      "verse_key": "37:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "فَاَقْبَلَ بَعْضُهُمْ عَلٰى بَعْضٍ یَّتَسَآءَلُوْنَ",
      "verse_key": "37:50"
    },
    {
      "ayah_number": 51,
      "arabic_text": "قَالَ قَآئِلٌ مِّنْهُمْ اِنِّیْ كَانَ لِیْ قَرِیْنٌۙ",
      "verse_key": "37:51"
    },
    {
      "ayah_number": 52,
      "arabic_text": "یَّقُوْلُ اَئِنَّكَ لَمِنَ الْمُصَدِّقِیْنَ",
      "verse_key": "37:52"
    },
    {
      "ayah_number": 53,
      "arabic_text": "ءَاِذَا مِتْنَا وَ كُنَّا تُرَابًا وَّ عِظَامًا ءَاِنَّا لَمَدِیْنُوْنَ",
      "verse_key": "37:53"
    },
    {
      "ayah_number": 54,
      "arabic_text": "قَالَ هَلْ اَنْتُمْ مُّطَّلِعُوْنَ",
      "verse_key": "37:54"
    },
    {
      "ayah_number": 55,
      "arabic_text": "فَاطَّلَعَ فَرَاٰهُ فِیْ سَوَآءِ الْجَحِیْمِ",
      "verse_key": "37:55"
    },
    {
      "ayah_number": 56,
      "arabic_text": "قَالَ تَاللّٰهِ اِنْ كِدْتَّ لَتُرْدِیْنِۙ",
      "verse_key": "37:56"
    },
    {
      "ayah_number": 57,
      "arabic_text": "وَ لَوْ لَا نِعْمَةُ رَبِّیْ لَكُنْتُ مِنَ الْمُحْضَرِیْنَ",
      "verse_key": "37:57"
    },
    {
      "ayah_number": 58,
      "arabic_text": "اَفَمَا نَحْنُ بِمَیِّتِیْنَۙ",
      "verse_key": "37:58"
    },
    {
      "ayah_number": 59,
      "arabic_text": "اِلَّا مَوْتَتَنَا الْاُوْلٰى وَ مَا نَحْنُ بِمُعَذَّبِیْنَ",
      "verse_key": "37:59"
    },
    {
      "ayah_number": 60,
      "arabic_text": "اِنَّ هٰذَا لَهُوَ الْفَوْزُ الْعَظِیْمُ",
      "verse_key": "37:60"
    },
    {
      "ayah_number": 61,
      "arabic_text": "لِمِثْلِ هٰذَا فَلْیَعْمَلِ الْعٰمِلُوْنَ",
      "verse_key": "37:61"
    },
    {
      "ayah_number": 62,
      "arabic_text": "اَذٰلِكَ خَیْرٌ نُّزُلًا اَمْ شَجَرَةُ الزَّقُّوْمِ",
      "verse_key": "37:62"
    },
    {
      "ayah_number": 63,
      "arabic_text": "اِنَّا جَعَلْنٰهَا فِتْنَةً لِّلظّٰلِمِیْنَ",
      "verse_key": "37:63"
    },
    {
      "ayah_number": 64,
      "arabic_text": "اِنَّهَا شَجَرَةٌ تَخْرُجُ فِیْۤ اَصْلِ الْجَحِیْمِۙ",
      "verse_key": "37:64"
    },
    {
      "ayah_number": 65,
      "arabic_text": "طَلْعُهَا كَاَنَّهٗ رُءُوْسُ الشَّیٰطِیْنِ",
      "verse_key": "37:65"
    },
    {
      "ayah_number": 66,
      "arabic_text": "فَاِنَّهُمْ لَاٰكِلُوْنَ مِنْهَا فَمَالِئُوْنَ مِنْهَا الْبُطُوْنَؕ",
      "verse_key": "37:66"
    },
    {
      "ayah_number": 67,
      "arabic_text": "ثُمَّ اِنَّ لَهُمْ عَلَیْهَا لَشَوْبًا مِّنْ حَمِیْمٍۚ",
      "verse_key": "37:67"
    },
    {
      "ayah_number": 68,
      "arabic_text": "ثُمَّ اِنَّ مَرْجِعَهُمْ لَاۡاِلَى الْجَحِیْمِ",
      "verse_key": "37:68"
    },
    {
      "ayah_number": 69,
      "arabic_text": "اِنَّهُمْ اَلْفَوْا اٰبَآءَهُمْ ضَآلِّیْنَۙ",
      "verse_key": "37:69"
    },
    {
      "ayah_number": 70,
      "arabic_text": "فَهُمْ عَلٰۤى اٰثٰرِهِمْ یُهْرَعُوْنَ",
      "verse_key": "37:70"
    },
    {
      "ayah_number": 71,
      "arabic_text": "وَ لَقَدْ ضَلَّ قَبْلَهُمْ اَكْثَرُ الْاَوَّلِیْنَۙ",
      "verse_key": "37:71"
    },
    {
      "ayah_number": 72,
      "arabic_text": "وَ لَقَدْ اَرْسَلْنَا فِیْهِمْ مُّنْذِرِیْنَ",
      "verse_key": "37:72"
    },
    {
      "ayah_number": 73,
      "arabic_text": "فَانْظُرْ كَیْفَ كَانَ عَاقِبَةُ الْمُنْذَرِیْنَۙ",
      "verse_key": "37:73"
    },
    {
      "ayah_number": 74,
      "arabic_text": "اِلَّا عِبَادَ اللّٰهِ الْمُخْلَصِیْنَ۠",
      "verse_key": "37:74"
    },
    {
      "ayah_number": 75,
      "arabic_text": "وَ لَقَدْ نَادٰىنَا نُوْحٌ فَلَنِعْمَ الْمُجِیْبُوْنَ٘ۖ",
      "verse_key": "37:75"
    },
    {
      "ayah_number": 76,
      "arabic_text": "وَ نَجَّیْنٰهُ وَ اَهْلَهٗ مِنَ الْكَرْبِ الْعَظِیْمِ٘ۖ",
      "verse_key": "37:76"
    },
    {
      "ayah_number": 77,
      "arabic_text": "وَ جَعَلْنَا ذُرِّیَّتَهٗ هُمُ الْبٰقِیْنَ٘ۖ",
      "verse_key": "37:77"
    },
    {
      "ayah_number": 78,
      "arabic_text": "وَ تَرَكْنَا عَلَیْهِ فِی الْاٰخِرِیْنَ٘ۖ",
      "verse_key": "37:78"
    },
    {
      "ayah_number": 79,
      "arabic_text": "سَلٰمٌ عَلٰى نُوْحٍ فِی الْعٰلَمِیْنَ",
      "verse_key": "37:79"
    },
    {
      "ayah_number": 80,
