{
  "surah_id": 104,
  "surah_name": "Al-Humazah",
  "arabic_name": "سُورَةُ الْهُمَزَةِ",
  "revelation_type": "Meccan",
  "total_ayahs": 9,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَیْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةِۙ",
      "verse_key": "104:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "اِ۟لَّذِیْ جَمَعَ مَالًا وَّ عَدَّدَهٗۙ",
      "verse_key": "104:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "یَحْسَبُ اَنَّ مَالَهٗۤ اَخْلَدَهٗۚ",
      "verse_key": "104:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "كَلَّا لَیُنْۢبَذَنَّ فِی الْحُطَمَةِ٘ۖ",
      "verse_key": "104:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا الْحُطَمَةُؕ",
      "verse_key": "104:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "نَارُ اللّٰهِ الْمُوْقَدَةُۙ",
      "verse_key": "104:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "الَّتِیْ تَطَّلِعُ عَلَى الْاَفْئِدَةِؕ",
      "verse_key": "104:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اِنَّهَا عَلَیْهِمْ مُّؤْصَدَةٌۙ",
      "verse_key": "104:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "فِیْ عَمَدٍ مُّمَدَّدَةٍ۠",
      "verse_key": "104:9"
    }
  ]
}