{
  "surah_id": 99,
  "surah_name": "Az-Zalzalah",
  "arabic_name": "سُورَةُ الزَّلْزَلَةِ",
  "revelation_type": "Medinan",
  "total_ayahs": 8,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اِذَا زُلْزِلَتِ الْاَرْضُ زِلْزَالَهَاۙ",
      "verse_key": "99:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ اَخْرَجَتِ الْاَرْضُ اَثْقَالَهَاۙ",
      "verse_key": "99:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ قَالَ الْاِنْسَانُ مَا لَهَاۚ",
      "verse_key": "99:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "یَوْمَئِذٍ تُحَدِّثُ اَخْبَارَهَاۙ",
      "verse_key": "99:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "بِاَنَّ رَبَّكَ اَوْحٰى لَهَاؕ",
      "verse_key": "99:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "یَوْمَئِذٍ یَّصْدُرُ النَّاسُ اَشْتَاتًا١ۙ۬ لِّیُرَوْا اَعْمَالَهُمْؕ",
      "verse_key": "99:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "فَمَنْ یَّعْمَلْ مِثْقَالَ ذَرَّةٍ خَیْرًا یَّرَهٗؕ",
      "verse_key": "99:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ مَنْ یَّعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا یَّرَهٗ۠",
      "verse_key": "99:8"
    }
  ]
}