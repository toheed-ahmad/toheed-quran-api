  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اَلْهٰىكُمُ التَّكَاثُرُۙ",
      "verse_key": "102:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "حَتّٰى زُرْتُمُ الْمَقَابِرَؕ",
      "verse_key": "102:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "كَلَّا سَوْفَ تَعْلَمُوْنَۙ",
      "verse_key": "102:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُوْنَؕ",
      "verse_key": "102:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "كَلَّا لَوْ تَعْلَمُوْنَ عِلْمَ الْیَقِیْنِؕ",
      "verse_key": "102:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "لَتَرَوُنَّ الْجَحِیْمَۙ",
      "verse_key": "102:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "ثُمَّ لَتَرَوُنَّهَا عَیْنَ الْیَقِیْۙنِ",
      "verse_key": "102:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "ثُمَّ لَتُسْئَلُنَّ یَوْمَئِذٍ عَنِ النَّعِیْمِ۠",
      "verse_key": "102:8"
    }
  ]
