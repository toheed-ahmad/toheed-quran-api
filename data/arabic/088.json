{
  "surah_id": 88,
  "surah_name": "Al-Ghaashiya",
  "arabic_name": "سُورَةُ الغَاشِيَةِ",
  "revelation_type": "Meccan",
  "total_ayahs": 26,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "هَلْ اَتٰىكَ حَدِیْثُ الْغَاشِیَةِؕ۝۱",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وُجُوْهٌ یَّوْمَىِٕذٍ خَاشِعَةٌۙ۝۲",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "عَامِلَةٌ نَّاصِبَةٌۙ۝۳",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "تَصْلٰی نَارًا حَامِیَةًۙ۝۴",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "تُسْقٰی مِنْ عَیْنٍ اٰنِیَةٍؕ۝۵",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "لَیْسَ لَهُمْ طَعَامٌ اِلَّا مِنْ ضَرِیْعٍۙ۝۶",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "لَّا یُسْمِنُ وَ لَا یُغْنِیْ مِنْ جُوْعٍؕ۝۷",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وُجُوْهٌ یَّوْمَىِٕذٍ نَّاعِمَةٌۙ۝۸",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "لِّسَعْیِهَا رَاضِیَةٌۙ۝۹",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فِیْ جَنَّةٍ عَالِیَةٍۙ۝۱۰",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "لَّا تَسْمَعُ فِیْهَا لَاغِیَةًؕ۝۱۱",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "فِیْهَا عَیْنٌ جَارِیَةٌۘ۝۱۲",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "فِیْهَا سُرُرٌ مَّرْفُوْعَةٌۙ۝۱۳",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَّ اَكْوَابٌ مَّوْضُوْعَةٌۙ۝۱۴",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَّ نَمَارِقُ مَصْفُوْفَةٌۙ۝۱۵",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "وَّ زَرَابِیُّ مَبْثُوْثَةٌؕ۝۱۶",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "اَفَلَا یَنْظُرُوْنَ اِلَی الْاِبِلِ كَیْفَ خُلِقَتْۥ۝۱۷",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَ اِلَی السَّمَآءِ كَیْفَ رُفِعَتْۥ۝۱۸",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ اِلَی الْجِبَالِ كَیْفَ نُصِبَتْۥ۝۱۹",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ اِلَی الْاَرْضِ كَیْفَ سُطِحَتْۥ۝۲۰",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "فَذَكِّرْ ؕ۫ اِنَّمَاۤ اَنْتَ مُذَكِّرٌؕ۝۲۱",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "لَسْتَ عَلَیْهِمْ بِمُصَۜیْطِرٍۙ۝۲۲",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "اِلَّا مَنْ تَوَلّٰی وَ كَفَرَۙ۝۲۳",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "فَیُعَذِّبُهُ اللّٰهُ الْعَذَابَ الْاَكْبَرَؕ۝۲۴",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اِنَّ اِلَیْنَاۤ اِیَابَهُمْۙ۝۲۵",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "ثُمَّ اِنَّ عَلَیْنَا حِسَابَهُمْ۠۝۲۶",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 530,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "88:26"
    }
  ]
}