{
  "surah_id": 88,
  "surah_name": "Al-Ghashiyah",
  "arabic_name": "سُورَةُ الْغَاشِيَةِ",
  "revelation_type": "Meccan",
  "total_ayahs": 26,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "هَلْ اَتٰىكَ حَدِیْثُ الْغَاشِیَةِؕ",
      "verse_key": "88:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وُجُوْهٌ یَّوْمَئِذٍ خَاشِعَةٌۙ",
      "verse_key": "88:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "عَامِلَةٌ نَّاصِبَةٌۙ",
      "verse_key": "88:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "تَصْلٰى نَارًا حَامِیَةًۙ",
      "verse_key": "88:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "تُسْقٰى مِنْ عَیْنٍ اٰنِیَةٍؕ",
      "verse_key": "88:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "لَیْسَ لَهُمْ طَعَامٌ اِلَّا مِنْ ضَرِیْعٍۙ",
      "verse_key": "88:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "لَّا یُسْمِنُ وَ لَا یُغْنِیْ مِنْ جُوْعٍؕ",
      "verse_key": "88:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وُجُوْهٌ یَّوْمَئِذٍ نَّاعِمَةٌۙ",
      "verse_key": "88:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "لِّسَعْیِهَا رَاضِیَةٌۙ",
      "verse_key": "88:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فِیْ جَنَّةٍ عَالِیَةٍۙ",
      "verse_key": "88:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "لَّا تَسْمَعُ فِیْهَا لَاغِیَةًؕ",
      "verse_key": "88:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "فِیْهَا عَیْنٌ جَارِیَةٌۘ",
      "verse_key": "88:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "فِیْهَا سُرُرٌ مَّرْفُوْعَةٌۙ",
      "verse_key": "88:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَّ اَكْوَابٌ مَّوْضُوْعَةٌۙ",
      "verse_key": "88:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَّ نَمَارِقُ مَصْفُوْفَةٌۙ",
      "verse_key": "88:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "وَّ زَرَابِیُّ مَبْثُوْثَةٌؕ",
      "verse_key": "88:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "اَفَلَا یَنْظُرُوْنَ اِلَى الْاِبِلِ كَیْفَ خُلِقَتْٙ",
      "verse_key": "88:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَ اِلَى السَّمَآءِ كَیْفَ رُفِعَتْٙ",
      "verse_key": "88:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ اِلَى الْجِبَالِ كَیْفَ نُصِبَتْٙ",
      "verse_key": "88:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ اِلَى الْاَرْضِ كَیْفَ سُطِحَتْٙ",
      "verse_key": "88:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "فَذَكِّرْ١ؕ۫ اِنَّمَاۤ اَنْتَ مُذَكِّرٌؕ",
      "verse_key": "88:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "لَسْتَ عَلَیْهِمْ بِمُصَۜیْطِرٍۙ",
      "verse_key": "88:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "اِلَّا مَنْ تَوَلّٰى وَ كَفَرَۙ",
      "verse_key": "88:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "فَیُعَذِّبُهُ اللّٰهُ الْعَذَابَ الْاَكْبَرَؕ",
      "verse_key": "88:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اِنَّ اِلَیْنَاۤ اِیَابَهُمْۙ",
      "verse_key": "88:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "ثُمَّ اِنَّ عَلَیْنَا حِسَابَهُمْ۠",
      "verse_key": "88:26"
    }
  ]
}