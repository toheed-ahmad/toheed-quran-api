{
  "surah_id": 50,
  "surah_name": "Qaaf",
  "arabic_name": "爻購賵乇賻丞購 賯贀",
  "revelation_type": "Meccan",
  "total_ayahs": 45,
  "bismillah": "亘賽爻賿賲賽 丕賱賱賾侔賴賽 丕賱乇賾賻丨賿賲侔賳賽 丕賱乇賾賻丨賽蹖賿賲賽",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "賯贀 蹥郢 賵賻 丕賱賿賯購乇賿丕侔賳賽 丕賱賿賲賻噩賽蹖賿丿賽蹥蹪郾",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "亘賻賱賿 毓賻噩賽亘購賵賿郅丕 丕賻賳賿 噩賻丕贀亍賻賴購賲賿 賲賾購賳賿匕賽乇賹 賲賾賽賳賿賴購賲賿 賮賻賯賻丕賱賻 丕賱賿賰侔賮賽乇購賵賿賳賻 賴侔匕賻丕 卮賻蹖賿亍賹 毓賻噩賽蹖賿亘賹蹥蹪鄄",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "亍賻丕賽匕賻丕 賲賽鬲賿賳賻丕 賵賻 賰購賳賾賻丕 鬲購乇賻丕亘賸丕 蹥 匕侔賱賽賰賻 乇賻噩賿毓賹邰 亘賻毓賽蹖賿丿賹蹪鄢",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "賯賻丿賿 毓賻賱賽賲賿賳賻丕 賲賻丕 鬲賻賳賿賯購氐購 丕賱賿丕賻乇賿囟購 賲賽賳賿賴購賲賿 蹥 賵賻 毓賽賳賿丿賻賳賻丕 賰賽鬲侔亘賹 丨賻賮賽蹖賿馗賹蹪鄞",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "亘賻賱賿 賰賻匕賾賻亘購賵賿丕 亘賽丕賱賿丨賻賯賾賽 賱賻賲賾賻丕 噩賻丕贀亍賻賴購賲賿 賮賻賴購賲賿 賮賽蹖賿郅 丕賻賲賿乇賺 賲賾賻乇賽蹖賿噩賺蹪鄣",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "丕賻賮賻賱賻賲賿 蹖賻賳賿馗購乇購賵賿郅丕 丕賽賱賻蹖 丕賱爻賾賻賲賻丕贀亍賽 賮賻賵賿賯賻賴購賲賿 賰賻蹖賿賮賻 亘賻賳賻蹖賿賳侔賴賻丕 賵賻 夭賻蹖賾賻賳賾侔賴賻丕 賵賻 賲賻丕 賱賻賴賻丕 賲賽賳賿 賮購乇購賵賿噩賺蹪鄱",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "賵賻 丕賱賿丕賻乇賿囟賻 賲賻丿賻丿賿賳侔賴賻丕 賵賻 丕賻賱賿賯賻蹖賿賳賻丕 賮賽蹖賿賴賻丕 乇賻賵賻丕爻賽蹖賻 賵賻 丕賻賳邰賿亘賻鬲賿賳賻丕 賮賽蹖賿賴賻丕 賲賽賳賿 賰購賱賾賽 夭賻賵賿噩賺郗 亘賻賴賽蹖賿噩賺蹤蹪鄯",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "鬲賻亘賿氐賽乇賻丞賸 賵賾賻 匕賽賰賿乇侔蹖 賱賽賰購賱賾賽 毓賻亘賿丿賺 賲賾購賳賽蹖賿亘賺蹪鄹",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "賵賻 賳賻夭賾賻賱賿賳賻丕 賲賽賳賻 丕賱爻賾賻賲賻丕贀亍賽 賲賻丕贀亍賸 賲賾購亘侔乇賻賰賸丕 賮賻丕賻賳邰賿亘賻鬲賿賳賻丕 亘賽賴贃 噩賻賳賾侔鬲賺 賵賾賻 丨賻亘賾賻 丕賱賿丨賻氐賽蹖賿丿賽蹤蹪酃",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "賵賻 丕賱賳賾賻禺賿賱賻 亘侔爻賽賯侔鬲賺 賱賾賻賴賻丕 胤賻賱賿毓賹 賳賾賻囟賽蹖賿丿賹蹤蹪郾郯",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "乇賾賽夭賿賯賸丕 賱賾賽賱賿毓賽亘賻丕丿賽 蹤 賵賻 丕賻丨賿蹖賻蹖賿賳賻丕 亘賽賴贃 亘賻賱賿丿賻丞賸 賲賾賻蹖賿鬲賸丕 貢 賰賻匕侔賱賽賰賻 丕賱賿禺購乇購賵賿噩購蹪郾郾",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "賰賻匕賾賻亘賻鬲賿 賯賻亘賿賱賻賴購賲賿 賯賻賵賿賲購 賳購賵賿丨賺 賵賾賻 丕賻氐賿丨侔亘購 丕賱乇賾賻爻賾賽 賵賻 孬賻賲購賵賿丿購蹤蹪郾鄄",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "賵賻 毓賻丕丿賹 賵賾賻 賮賽乇賿毓賻賵賿賳購 賵賻 丕賽禺賿賵賻丕賳購 賱購賵賿胤賺蹤蹪郾鄢",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "賵賾賻 丕賻氐賿丨侔亘購 丕賱賿丕賻蹖賿賰賻丞賽 賵賻 賯賻賵賿賲購 鬲購亘賾賻毓賺 貢 賰購賱賾賹 賰賻匕賾賻亘賻 丕賱乇賾購爻購賱賻 賮賻丨賻賯賾賻 賵賻毓賽蹖賿丿賽蹪郾鄞",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "丕賻賮賻毓賻蹖賽蹖賿賳賻丕 亘賽丕賱賿禺賻賱賿賯賽 丕賱賿丕賻賵賾賻賱賽 貢 亘賻賱賿 賴購賲賿 賮賽蹖賿 賱賻亘賿爻賺 賲賾賽賳賿 禺賻賱賿賯賺 噩賻丿賽蹖賿丿賺蹱蹪郾鄣",
      "juz": 26,
      "page": 518,
      "manzil": 7,
      "ruku": 452,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "賵賻 賱賻賯賻丿賿 禺賻賱賻賯賿賳賻丕 丕賱賿丕賽賳賿爻賻丕賳賻 賵賻 賳賻毓賿賱賻賲購 賲賻丕 鬲購賵賻爻賿賵賽爻購 亘賽賴贃 賳賻賮賿爻購賴贄 蹡蹥 賵賻 賳賻丨賿賳購 丕賻賯賿乇賻亘購 丕賽賱賻蹖賿賴賽 賲賽賳賿 丨賻亘賿賱賽 丕賱賿賵賻乇賽蹖賿丿賽蹪郾鄱",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "丕賽匕賿 蹖賻鬲賻賱賻賯賾賻蹖 丕賱賿賲購鬲賻賱賻賯賾賽蹖侔賳賽 毓賻賳賽 丕賱賿蹖賻賲賽蹖賿賳賽 賵賻 毓賻賳賽 丕賱卮賾賽賲賻丕賱賽 賯賻毓賽蹖賿丿賹蹪郾鄯",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "賲賻丕 蹖賻賱賿賮賽馗購 賲賽賳賿 賯賻賵賿賱賺 丕賽賱賾賻丕 賱賻丿賻蹖賿賴賽 乇賻賯賽蹖賿亘賹 毓賻鬲賽蹖賿丿賹蹪郾鄹",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "賵賻 噩賻丕贀亍賻鬲賿 爻賻賰賿乇賻丞購 丕賱賿賲賻賵賿鬲賽 亘賽丕賱賿丨賻賯賾賽 貢 匕侔賱賽賰賻 賲賻丕 賰購賳賿鬲賻 賲賽賳賿賴購 鬲賻丨賽蹖賿丿購蹪郾酃",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "賵賻 賳購賮賽禺賻 賮賽蹖 丕賱氐賾購賵賿乇賽 貢 匕侔賱賽賰賻 蹖賻賵賿賲購 丕賱賿賵賻毓賽蹖賿丿賽蹪鄄郯",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "賵賻 噩賻丕贀亍賻鬲賿 賰購賱賾購 賳賻賮賿爻賺 賲賾賻毓賻賴賻丕 爻賻丕贀賶贂賽賯賹 賵賾賻 卮賻賴賽蹖賿丿賹蹪鄄郾",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "賱賻賯賻丿賿 賰購賳賿鬲賻 賮賽蹖賿 睾賻賮賿賱賻丞賺 賲賾賽賳賿 賴侔匕賻丕 賮賻賰賻卮賻賮賿賳賻丕 毓賻賳賿賰賻 睾賽胤賻丕贀亍賻賰賻 賮賻亘賻氐賻乇購賰賻 丕賱賿蹖賻賵賿賲賻 丨賻丿賽蹖賿丿賹蹪鄄鄄",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "賵賻 賯賻丕賱賻 賯賻乇賽蹖賿賳購賴贄 賴侔匕賻丕 賲賻丕 賱賻丿賻蹖賾賻 毓賻鬲賽蹖賿丿賹貢蹪鄄鄢",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "丕賻賱賿賯賽蹖賻丕 賮賽蹖賿 噩賻賴賻賳賾賻賲賻 賰購賱賾賻 賰賻賮賾賻丕乇賺 毓賻賳賽蹖賿丿賺蹤蹪鄄鄞",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "賲賾賻賳賾賻丕毓賺 賱賾賽賱賿禺賻蹖賿乇賽 賲購毓賿鬲賻丿賺 賲賾購乇賽蹖賿亘賽蹤蹪鄄鄣",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "蹮賽丕賱賾賻匕賽蹖賿 噩賻毓賻賱賻 賲賻毓賻 丕賱賱賾侔賴賽 丕賽賱侔賴賸丕 丕侔禺賻乇賻 賮賻丕賻賱賿賯賽蹖侔賴購 賮賽蹖 丕賱賿毓賻匕賻丕亘賽 丕賱卮賾賻丿賽蹖賿丿賽蹪鄄鄱",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 207,
      "sajdah": false,
      "verse_key": "50:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "賯賻丕賱賻 賯賻乇賽蹖賿賳購賴贄 乇賻亘賾賻賳賻丕 賲賻丕郅 丕賻胤賿睾賻蹖賿鬲購賴贄 賵賻 賱侔賰賽賳賿 賰賻丕賳賻 賮賽蹖賿 囟賻賱侔賱賺郗 亘賻毓賽蹖賿丿賺蹪鄄鄯",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "50:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "賯賻丕賱賻 賱賻丕 鬲賻禺賿鬲賻氐賽賲購賵賿丕 賱賻丿賻蹖賾賻 賵賻 賯賻丿賿 賯賻丿賾賻賲賿鬲購 丕賽賱賻蹖賿賰購賲賿 亘賽丕賱賿賵賻毓賽蹖賿丿賽蹪鄄鄹",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "50:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "賲賻丕 蹖購亘賻丿賾賻賱購 丕賱賿賯賻賵賿賱購 賱賻丿賻蹖賾賻 賵賻 賲賻丕郅 丕賻賳賻丕 亘賽馗賻賱賾賻丕賲賺 賱賾賽賱賿毓賻亘賽蹖賿丿賽蹱蹪鄄酃",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 453,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "50:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "蹖賻賵賿賲賻 賳賻賯購賵賿賱購 賱賽噩賻賴賻賳賾賻賲賻 賴賻賱賽 丕賲賿鬲賻賱賻丕賿鬲賽 賵賻 鬲賻賯購賵賿賱購 賴賻賱賿 賲賽賳賿 賲賾賻夭賽蹖賿丿賺蹪鄢郯",
      "juz": 26,
      "page": 519,
      "manzil": 7,
      "ruku": 454,
      "hizb": 52,
      "hizbQuarter": 208,
      "sajdah": false,
      "verse_key": "50:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "賵賻 丕購夭賿賱賽賮賻鬲賽 丕賱賿噩賻賳賾賻丞購 賱賽賱賿賲購鬲賾賻賯賽蹖賿賳賻 睾賻蹖賿乇賻 亘賻毓賽蹖賿丿賺蹪鄢郾",
