{
  "surah_id": 77,
  "surah_name": "Al-Mursalat",
  "arabic_name": "سُورَةُ الْمُرْسَلَاتِ",
  "revelation_type": "Meccan",
  "total_ayahs": 50,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الْمُرْسَلٰتِ عُرْفًاۙ",
      "verse_key": "77:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "فَالْعٰصِفٰتِ عَصْفًاۙ",
      "verse_key": "77:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَّ النّٰشِرٰتِ نَشْرًاۙ",
      "verse_key": "77:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "فَالْفٰرِقٰتِ فَرْقًاۙ",
      "verse_key": "77:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَالْمُلْقِیٰتِ ذِكْرًاۙ",
      "verse_key": "77:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "عُذْرًا اَوْ نُذْرًاۙ",
      "verse_key": "77:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "اِنَّمَا تُوْعَدُوْنَ لَوَاقِعٌؕ",
      "verse_key": "77:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "فَاِذَا النُّجُوْمُ طُمِسَتْۙ",
      "verse_key": "77:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ اِذَا السَّمَآءُ فُرِجَتْۙ",
      "verse_key": "77:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ اِذَا الْجِبَالُ نُسِفَتْۙ",
      "verse_key": "77:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ اِذَا الرُّسُلُ اُقِّتَتْؕ",
      "verse_key": "77:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "لِاَیِّ یَوْمٍ اُجِّلَتْؕ",
      "verse_key": "77:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "لِیَوْمِ الْفَصْلِۚ",
      "verse_key": "77:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا یَوْمُ الْفَصْلِؕ",
      "verse_key": "77:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ",
      "verse_key": "77:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "اَلَمْ نُهْلِكِ الْاَوَّلِیْنَؕ",
      "verse_key": "77:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "ثُمَّ نُتْبِعُهُمُ الْاٰخِرِیْنَ",
      "verse_key": "77:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "كَذٰلِكَ نَفْعَلُ بِالْمُجْرِمِیْنَ",
      "verse_key": "77:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ",
      "verse_key": "77:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "اَلَمْ نَخْلُقْكُّمْ مِّنْ مَّآءٍ مَّهِیْنٍۙ",
      "verse_key": "77:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "فَجَعَلْنٰهُ فِیْ قَرَارٍ مَّكِیْنٍۙ",
      "verse_key": "77:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "اِلٰى قَدَرٍ مَّعْلُوْمٍۙ",
      "verse_key": "77:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "فَقَدَرْنَا١ۖۗ فَنِعْمَ الْقٰدِرُوْنَ",
      "verse_key": "77:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ",
      "verse_key": "77:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اَلَمْ نَجْعَلِ الْاَرْضَ كِفَاتًاۙ",
      "verse_key": "77:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "اَحْیَآءً وَّ اَمْوَاتًاۙ",
      "verse_key": "77:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَّ جَعَلْنَا فِیْهَا رَوَاسِیَ شٰمِخٰتٍ وَّ اَسْقَیْنٰكُمْ مَّآءً فُرَاتًاؕ",
      "verse_key": "77:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ",
      "verse_key": "77:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "اِنْطَلِقُوْۤا اِلٰى مَا كُنْتُمْ بِهٖ تُكَذِّبُوْنَۚ",
      "verse_key": "77:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "اِنْطَلِقُوْۤا اِلٰى ظِلٍّ ذِیْ ثَلٰثِ شُعَبٍۙ",
      "verse_key": "77:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "لَّا ظَلِیْلٍ وَّ لَا یُغْنِیْ مِنَ اللَّهَبِؕ",
      "verse_key": "77:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "اِنَّهَا تَرْمِیْ بِشَرَرٍ كَالْقَصْرِۚ",
      "verse_key": "77:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "كَاَنَّهٗ جِمٰلَتٌ صُفْرٌؕ",
      "verse_key": "77:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ",
      "verse_key": "77:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "هٰذَا یَوْمُ لَا یَنْطِقُوْنَۙ",
      "verse_key": "77:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "وَ لَا یُؤْذَنُ لَهُمْ فَیَعْتَذِرُوْنَ",
      "verse_key": "77:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ",
      "verse_key": "77:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "هٰذَا یَوْمُ الْفَصْلِ١ۚ جَمَعْنٰكُمْ وَ الْاَوَّلِیْنَ",
      "verse_key": "77:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "فَاِنْ كَانَ لَكُمْ كَیْدٌ فَكِیْدُوْنِ",
      "verse_key": "77:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ۠",
      "verse_key": "77:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "اِنَّ الْمُتَّقِیْنَ فِیْ ظِلٰلٍ وَّ عُیُوْنٍۙ",
      "verse_key": "77:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "وَّ فَوَاكِهَ مِمَّا یَشْتَهُوْنَؕ",
      "verse_key": "77:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "كُلُوْا وَ اشْرَبُوْا هَنِیْٓئًۢا بِمَا كُنْتُمْ تَعْمَلُوْنَ",
      "verse_key": "77:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "اِنَّا كَذٰلِكَ نَجْزِی الْمُحْسِنِیْنَ",
      "verse_key": "77:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ",
      "verse_key": "77:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "كُلُوْا وَ تَمَتَّعُوْا قَلِیْلًا اِنَّكُمْ مُّجْرِمُوْنَ",
      "verse_key": "77:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ",
      "verse_key": "77:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "وَ اِذَا قِیْلَ لَهُمُ ارْكَعُوْا لَا یَرْكَعُوْنَ",
      "verse_key": "77:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "وَیْلٌ یَّوْمَئِذٍ لِّلْمُكَذِّبِیْنَ",
      "verse_key": "77:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "فَبِاَیِّ حَدِیْثٍۭ بَعْدَهٗ یُؤْمِنُوْنَ۠",
      "verse_key": "77:50"
    }
  ]
}