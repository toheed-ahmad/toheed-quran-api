{
  "surah_id": 75,
  "surah_name": "Al-Qiyamah",
  "arabic_name": "سُورَةُ الْقِيَامَةِ",
  "revelation_type": "Meccan",
  "total_ayahs": 40,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "لَاۤ اُقْسِمُ بِیَوْمِ الْقِیٰمَةِۙ",
      "verse_key": "75:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ لَاۤ اُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِؕ",
      "verse_key": "75:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "اَیَحْسَبُ الْاِنْسَانُ اَلَّنْ نَّجْمَعَ عِظَامَهٗؕ",
      "verse_key": "75:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "بَلٰى قٰدِرِیْنَ عَلٰۤى اَنْ نُّسَوِّیَ بَنَانَهٗ",
      "verse_key": "75:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "بَلْ یُرِیْدُ الْاِنْسَانُ لِیَفْجُرَ اَمَامَهٗۚ",
      "verse_key": "75:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "یَسْئَلُ اَیَّانَ یَوْمُ الْقِیٰمَةِؕ",
      "verse_key": "75:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "فَاِذَا بَرِقَ الْبَصَرُۙ",
      "verse_key": "75:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ خَسَفَ الْقَمَرُۙ",
      "verse_key": "75:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ جُمِعَ الشَّمْسُ وَ الْقَمَرُۙ",
      "verse_key": "75:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "یَقُوْلُ الْاِنْسَانُ یَوْمَئِذٍ اَیْنَ الْمَفَرُّۚ",
      "verse_key": "75:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "كَلَّا لَا وَزَرَؕ",
      "verse_key": "75:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "اِلٰى رَبِّكَ یَوْمَئِذِ اِ۟لْمُسْتَقَرُّؕ",
      "verse_key": "75:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "یُنَبَّؤُا الْاِنْسَانُ یَوْمَئِذٍۭ بِمَا قَدَّمَ وَ اَخَّرَؕ",
      "verse_key": "75:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "بَلِ الْاِنْسَانُ عَلٰى نَفْسِهٖ بَصِیْرَةٌۙ",
      "verse_key": "75:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَّ لَوْ اَلْقٰى مَعَاذِیْرَهٗؕ",
      "verse_key": "75:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "لَا تُحَرِّكْ بِهٖ لِسَانَكَ لِتَعْجَلَ بِهٖؕ",
      "verse_key": "75:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "اِنَّ عَلَیْنَا جَمْعَهٗ وَ قُرْاٰنَهٗۚۖ",
      "verse_key": "75:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "فَاِذَا قَرَاْنٰهُ فَاتَّبِعْ قُرْاٰنَهٗۚ",
      "verse_key": "75:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "ثُمَّ اِنَّ عَلَیْنَا بَیَانَهٗؕ",
      "verse_key": "75:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "كَلَّا بَلْ تُحِبُّوْنَ الْعَاجِلَةَۙ",
      "verse_key": "75:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَ تَذَرُوْنَ الْاٰخِرَةَؕ",
      "verse_key": "75:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "وُجُوْهٌ یَّوْمَئِذٍ نَّاضِرَةٌۙ",
      "verse_key": "75:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "اِلٰى رَبِّهَا نَاظِرَةٌۚ",
      "verse_key": "75:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَ وُجُوْهٌ یَّوْمَئِذٍۭ بَاسِرَةٌۙ",
      "verse_key": "75:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "تَظُنُّ اَنْ یُّفْعَلَ بِهَا فَاقِرَةٌؕ",
      "verse_key": "75:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "كَلَّاۤ اِذَا بَلَغَتِ التَّرَاقِیَۙ",
      "verse_key": "75:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَ قِیْلَ مَنْ١ٚ رَاقٍۙ",
      "verse_key": "75:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "وَّ ظَنَّ اَنَّهُ الْفِرَاقُۙ",
      "verse_key": "75:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَ الْتَفَّتِ السَّاقُ بِالسَّاقِۙ",
      "verse_key": "75:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "اِلٰى رَبِّكَ یَوْمَئِذِ اِ۟لْمَسَاقُ٢ؕ۠",
      "verse_key": "75:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "فَلَا صَدَّقَ وَ لَا صَلّٰىۙ",
      "verse_key": "75:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "وَ لٰكِنْ كَذَّبَ وَ تَوَلّٰىۙ",
      "verse_key": "75:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "ثُمَّ ذَهَبَ اِلٰۤى اَهْلِهٖ یَتَمَطّٰىؕ",
      "verse_key": "75:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "اَوْلٰى لَكَ فَاَوْلٰىۙ",
      "verse_key": "75:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "ثُمَّ اَوْلٰى لَكَ فَاَوْلٰىؕ",
      "verse_key": "75:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "اَیَحْسَبُ الْاِنْسَانُ اَنْ یُّتْرَكَ سُدًىؕ",
      "verse_key": "75:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "اَلَمْ یَكُ نُطْفَةً مِّنْ مَّنِیٍّ یُّمْنٰىۙ",
      "verse_key": "75:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوّٰىۙ",
      "verse_key": "75:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "فَجَعَلَ مِنْهُ الزَّوْجَیْنِ الذَّكَرَ وَ الْاُنْثٰىؕ",
      "verse_key": "75:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "اَلَیْسَ ذٰلِكَ بِقٰدِرٍ عَلٰۤى اَنْ یُّحْیَِۧ الْمَوْتٰى۠",
      "verse_key": "75:40"
    }
  ]
}