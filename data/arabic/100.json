{
  "surah_id": 100,
  "surah_name": "Al-'Adiyat",
  "arabic_name": "سُورَةُ الْعَادِيَاتِ",
  "revelation_type": "Meccan",
  "total_ayahs": 11,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الْعٰدِیٰتِ ضَبْحًاۙ",
      "verse_key": "100:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "فَالْمُوْرِیٰتِ قَدْحًاۙ",
      "verse_key": "100:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "فَالْمُغِیْرٰتِ صُبْحًاۙ",
      "verse_key": "100:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "فَاَثَرْنَ بِهٖ نَقْعًاۙ",
      "verse_key": "100:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَوَسَطْنَ بِهٖ جَمْعًاۙ",
      "verse_key": "100:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اِنَّ الْاِنْسَانَ لِرَبِّهٖ لَكَنُوْدٌۚ",
      "verse_key": "100:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ اِنَّهٗ عَلٰى ذٰلِكَ لَشَهِیْدٌۚ",
      "verse_key": "100:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ اِنَّهٗ لِحُبِّ الْخَیْرِ لَشَدِیْدٌؕ",
      "verse_key": "100:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "اَفَلَا یَعْلَمُ اِذَا بُعْثِرَ مَا فِی الْقُبُوْرِۙ",
      "verse_key": "100:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ حُصِّلَ مَا فِی الصُّدُوْرِۙ",
      "verse_key": "100:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "اِنَّ رَبَّهُمْ بِهِمْ یَوْمَئِذٍ لَّخَبِیْرٌ۠",
      "verse_key": "100:11"
    }
  ]
}