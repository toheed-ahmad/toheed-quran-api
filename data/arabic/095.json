{
  "surah_id": 95,
  "surah_name": "At-Tin",
  "arabic_name": "سُورَةُ التِّينِ",
  "revelation_type": "Meccan",
  "total_ayahs": 8,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ التِّیْنِ وَ الزَّیْتُوْنِۙ",
      "verse_key": "95:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ طُوْرِ سِیْنِیْنَۙ",
      "verse_key": "95:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ هٰذَا الْبَلَدِ الْاَمِیْنِۙ",
      "verse_key": "95:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "لَقَدْ خَلَقْنَا الْاِنْسَانَ فِیْۤ اَحْسَنِ تَقْوِیْمٍ٘",
      "verse_key": "95:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "ثُمَّ رَدَدْنٰهُ اَسْفَلَ سٰفِلِیْنَۙ",
      "verse_key": "95:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اِلَّا الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ فَلَهُمْ اَجْرٌ غَیْرُ مَمْنُوْنٍؕ",
      "verse_key": "95:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "فَمَا یُكَذِّبُكَ بَعْدُ بِالدِّیْنِؕ",
      "verse_key": "95:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اَلَیْسَ اللّٰهُ بِاَحْكَمِ الْحٰكِمِیْنَ۠",
      "verse_key": "95:8"
    }
  ]
}