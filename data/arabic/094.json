  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اَلَمْ نَشْرَحْ لَكَ صَدْرَكَۙ",
      "verse_key": "94:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ وَضَعْنَا عَنْكَ وِزْرَكَۙ",
      "verse_key": "94:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "الَّذِیْۤ اَنْقَضَ ظَهْرَكَۙ",
      "verse_key": "94:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ رَفَعْنَا لَكَ ذِكْرَكَؕ",
      "verse_key": "94:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَاِنَّ مَعَ الْعُسْرِ یُسْرًاۙ",
      "verse_key": "94:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اِنَّ مَعَ الْعُسْرِ یُسْرًاؕ",
      "verse_key": "94:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "فَاِذَا فَرَغْتَ فَانْصَبْۙ",
      "verse_key": "94:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ اِلٰى رَبِّكَ فَارْغَبْ۠",
      "verse_key": "94:8"
    }
