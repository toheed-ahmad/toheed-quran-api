{
  "surah_id": 89,
  "surah_name": "Al-Fajr",
  "arabic_name": "سُورَةُ الْفَجْرِ",
  "revelation_type": "Meccan",
  "total_ayahs": 30,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الْفَجْرِۙ",
      "verse_key": "89:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ لَیَالٍ عَشْرٍۙ",
      "verse_key": "89:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَّ الشَّفْعِ وَ الْوَتْرِۙ",
      "verse_key": "89:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ الَّیْلِ اِذَا یَسْرِۚ",
      "verse_key": "89:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "هَلْ فِیْ ذٰلِكَ قَسَمٌ لِّذِیْ حِجْرٍؕ",
      "verse_key": "89:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اَلَمْ تَرَ كَیْفَ فَعَلَ رَبُّكَ بِعَادٍ۪ۙ",
      "verse_key": "89:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "اِرَمَ ذَاتِ الْعِمَادِ۪ۙ",
      "verse_key": "89:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "الَّتِیْ لَمْ یُخْلَقْ مِثْلُهَا فِی الْبِلَادِ۪ۙ",
      "verse_key": "89:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ ثَمُوْدَ الَّذِیْنَ جَابُوا الصَّخْرَ بِالْوَادِ۪ۙ",
      "verse_key": "89:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ فِرْعَوْنَ ذِی الْاَوْتَادِ۪ۙ",
      "verse_key": "89:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "الَّذِیْنَ طَغَوْا فِی الْبِلَادِ۪ۙ",
      "verse_key": "89:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "فَاَكْثَرُوْا فِیْهَا الْفَسَادَ۪ۙ",
      "verse_key": "89:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "فَصَبَّ عَلَیْهِمْ رَبُّكَ سَوْطَ عَذَابٍۚۙ",
      "verse_key": "89:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "اِنَّ رَبَّكَ لَبِالْمِرْصَادِؕ",
      "verse_key": "89:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "فَاَمَّا الْاِنْسَانُ اِذَا مَا ابْتَلٰىهُ رَبُّهٗ فَاَكْرَمَهٗ وَ نَعَّمَهٗ١ۙ۬ فَیَقُوْلُ رَبِّیْۤ اَكْرَمَنِؕ",
      "verse_key": "89:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "وَ اَمَّاۤ اِذَا مَا ابْتَلٰىهُ فَقَدَرَ عَلَیْهِ رِزْقَهٗ١ۙ۬ فَیَقُوْلُ رَبِّیْۤ اَهَانَنِۚ",
      "verse_key": "89:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "كَلَّا بَلْ لَّا تُكْرِمُوْنَ الْیَتِیْمَۙ",
      "verse_key": "89:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَ لَا تَحٰٓضُّوْنَ عَلٰى طَعَامِ الْمِسْكِیْنِۙ",
      "verse_key": "89:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ تَاْكُلُوْنَ التُّرَاثَ اَكْلًا لَّمًّاۙ",
      "verse_key": "89:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَّ تُحِبُّوْنَ الْمَالَ حُبًّا جَمًّاؕ",
      "verse_key": "89:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "كَلَّاۤ اِذَا دُكَّتِ الْاَرْضُ دَكًّا دَكًّاۙ",
      "verse_key": "89:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "وَّ جَآءَ رَبُّكَ وَ الْمَلَكُ صَفًّا صَفًّاۚ",
      "verse_key": "89:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "وَ جِایْٓءَ یَوْمَئِذٍۭ بِجَهَنَّمَ١ۙ۬ یَوْمَئِذٍ یَّتَذَكَّرُ الْاِنْسَانُ وَ اَنّٰى لَهُ الذِّكْرٰىؕ",
      "verse_key": "89:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "یَقُوْلُ یٰلَیْتَنِیْ قَدَّمْتُ لِحَیَاتِیْۚ",
      "verse_key": "89:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "فَیَوْمَئِذٍ لَّا یُعَذِّبُ عَذَابَهٗۤ اَحَدٌۙ",
      "verse_key": "89:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَّ لَا یُوْثِقُ وَ ثَاقَهٗۤ اَحَدٌؕ",
      "verse_key": "89:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "یٰۤاَیَّتُهَا النَّفْسُ الْمُطْمَئِنَّةُۗۖ",
      "verse_key": "89:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "ارْجِعِیْۤ اِلٰى رَبِّكِ رَاضِیَةً مَّرْضِیَّةًۚ",
      "verse_key": "89:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "فَادْخُلِیْ فِیْ عِبٰدِیْۙ",
      "verse_key": "89:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَ ادْخُلِیْ جَنَّتِیْ۠",
      "verse_key": "89:30"
    }
  ]
}