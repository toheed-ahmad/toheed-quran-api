{
  "surah_id": 82,
  "surah_name": "Al-Infitaar",
  "arabic_name": "爻購賵乇賻丞購 丕賱丕賳賮賽胤賻丕乇賽",
  "revelation_type": "Meccan",
  "total_ayahs": 19,
  "bismillah": "亘賽爻賿賲賽 丕賱賱賾侔賴賽 丕賱乇賾賻丨賿賲侔賳賽 丕賱乇賾賻丨賽蹖賿賲賽",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "丕賽匕賻丕 丕賱爻賾賻賲賻丕贀亍購 丕賳賿賮賻胤賻乇賻鬲賿蹤蹪郾",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "賵賻 丕賽匕賻丕 丕賱賿賰賻賵賻丕賰賽亘購 丕賳賿鬲賻孬賻乇賻鬲賿蹤蹪鄄",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "賵賻 丕賽匕賻丕 丕賱賿亘賽丨賻丕乇購 賮購噩賾賽乇賻鬲賿蹤蹪鄢",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "賵賻 丕賽匕賻丕 丕賱賿賯購亘購賵賿乇購 亘購毓賿孬賽乇賻鬲賿蹤蹪鄞",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "毓賻賱賽賲賻鬲賿 賳賻賮賿爻賹 賲賾賻丕 賯賻丿賾賻賲賻鬲賿 賵賻 丕賻禺賾賻乇賻鬲賿貢蹪鄣",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "蹖侔郅丕賻蹖賾購賴賻丕 丕賱賿丕賽賳賿爻賻丕賳購 賲賻丕 睾賻乇賾賻賰賻 亘賽乇賻亘賾賽賰賻 丕賱賿賰賻乇賽蹖賿賲賽蹤蹪鄱",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "丕賱賾賻匕賽蹖賿 禺賻賱賻賯賻賰賻 賮賻爻賻賵賾侔賶賰賻 賮賻毓賻丿賻賱賻賰賻蹤蹪鄯",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "賮賽蹖賿郅 丕賻蹖賾賽 氐購賵賿乇賻丞賺 賲賾賻丕 卮賻丕贀亍賻 乇賻賰賾賻亘賻賰賻貢蹪鄹",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "賰賻賱賾賻丕 亘賻賱賿 鬲購賰賻匕賾賽亘購賵賿賳賻 亘賽丕賱丿賾賽蹖賿賳賽蹤蹪酃",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "賵賻 丕賽賳賾賻 毓賻賱賻蹖賿賰購賲賿 賱賻丨侔賮賽馗賽蹖賿賳賻蹤蹪郾郯",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "賰賽乇賻丕賲賸丕 賰賻丕鬲賽亘賽蹖賿賳賻蹤蹪郾郾",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "蹖賻毓賿賱賻賲購賵賿賳賻 賲賻丕 鬲賻賮賿毓賻賱購賵賿賳賻蹪郾鄄",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "丕賽賳賾賻 丕賱賿丕賻亘賿乇賻丕乇賻 賱賻賮賽蹖賿 賳賻毓賽蹖賿賲賺蹥蹪郾鄢",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "賵賻 丕賽賳賾賻 丕賱賿賮購噩賾賻丕乇賻 賱賻賮賽蹖賿 噩賻丨賽蹖賿賲賺蹥蹡蹪郾鄞",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "蹖賾賻氐賿賱賻賵賿賳賻賴賻丕 蹖賻賵賿賲賻 丕賱丿賾賽蹖賿賳賽蹪郾鄣",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "賵賻 賲賻丕 賴購賲賿 毓賻賳賿賴賻丕 亘賽睾賻丕贀賶贂賽亘賽蹖賿賳賻貢蹪郾鄱",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "賵賻 賲賻丕郅 丕賻丿賿乇侔賶賰賻 賲賻丕 蹖賻賵賿賲購 丕賱丿賾賽蹖賿賳賽蹤蹪郾鄯",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "孬購賲賾賻 賲賻丕郅 丕賻丿賿乇侔賶賰賻 賲賻丕 蹖賻賵賿賲購 丕賱丿賾賽蹖賿賳賽貢蹪郾鄹",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "蹖賻賵賿賲賻 賱賻丕 鬲賻賲賿賱賽賰購 賳賻賮賿爻賹 賱賾賽賳賻賮賿爻賺 卮賻蹖賿賭贁賸丕 貢 賵賻 丕賱賿丕賻賲賿乇購 蹖賻賵賿賲賻賶贂賽匕賺 賱賾賽賱賾侔賴賽蹱蹪郾酃",
      "juz": 30,
      "page": 587,
      "manzil": 7,
      "ruku": 524,
      "hizb": 59,
      "hizbQuarter": 235,
      "sajdah": false,
      "verse_key": "82:19"
    }
  ]
}