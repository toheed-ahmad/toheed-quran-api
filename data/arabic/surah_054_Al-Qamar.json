      "sajdah": false,
      "verse_key": "54:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "賮賻賰賻蹖賿賮賻 賰賻丕賳賻 毓賻匕賻丕亘賽蹖賿 賵賻 賳購匕購乇賽蹪鄄郾",
      "juz": 27,
