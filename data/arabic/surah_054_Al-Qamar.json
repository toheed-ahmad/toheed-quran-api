      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "賰賻匕賾賻亘賻鬲賿 孬賻賲購賵賿丿購 亘賽丕賱賳賾購匕購乇賽蹪鄄鄢",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 464,
