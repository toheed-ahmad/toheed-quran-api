      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "賮賻賯賻丕賱購賵賿郅丕 丕賻亘賻卮賻乇賸丕 賲賾賽賳賾賻丕 賵賻丕丨賽丿賸丕 賳賾賻鬲賾賻亘賽毓購賴贄郅 蹤 丕賽賳賾賻丕郅 丕賽匕賸丕 賱賾賻賮賽蹖賿 囟賻賱侔賱賺 賵賾賻 爻購毓購乇賺蹪鄄鄞",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 464,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "亍賻丕購賱賿賯賽蹖賻 丕賱匕賾賽賰賿乇購 毓賻賱賻蹖賿賴賽 賲賽賳邰賿 亘賻蹖賿賳賽賳賻丕 亘賻賱賿 賴購賵賻 賰賻匕賾賻丕亘賹 丕賻卮賽乇賹蹪鄄鄣",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 464,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "爻賻蹖賻毓賿賱賻賲購賵賿賳賻 睾賻丿賸丕 賲賾賻賳賽 丕賱賿賰賻匕賾賻丕亘購 丕賱賿丕賻卮賽乇購蹪鄄鄱",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 464,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "丕賽賳賾賻丕 賲購乇賿爻賽賱購賵丕 丕賱賳賾賻丕賯賻丞賽 賮賽鬲賿賳賻丞賸 賱賾賻賴購賲賿 賮賻丕乇賿鬲賻賯賽亘賿賴購賲賿 賵賻 丕氐賿胤賻亘賽乇賿貤蹪鄄鄯",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 464,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "賵賻 賳賻亘賾賽卅賿賴購賲賿 丕賻賳賾賻 丕賱賿賲賻丕贀亍賻 賯賽爻賿賲賻丞賹邰 亘賻蹖賿賳賻賴購賲賿 蹥 賰購賱賾購 卮賽乇賿亘賺 賲賾購丨賿鬲賻囟賻乇賹蹪鄄鄹",
      "juz": 27,
      "page": 530,
      "manzil": 7,
      "ruku": 464,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "賮賻賳賻丕丿賻賵賿丕 氐賻丕丨賽亘賻賴購賲賿 賮賻鬲賻毓賻丕胤侔蹖 賮賻毓賻賯賻乇賻蹪鄄酃",
      "juz": 27,
      "page": 530,
      "manzil": 7,
      "ruku": 464,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "賮賻賰賻蹖賿賮賻 賰賻丕賳賻 毓賻匕賻丕亘賽蹖賿 賵賻 賳購匕購乇賽蹪鄢郯",
