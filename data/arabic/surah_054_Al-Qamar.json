      "manzil": 7,
      "ruku": 464,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "賵賻 賱賻賯賻丿賿 蹖賻爻賾賻乇賿賳賻丕 丕賱賿賯購乇賿丕侔賳賻 賱賽賱匕賾賽賰賿乇賽 賮賻賴賻賱賿 賲賽賳賿 賲賾購丿賾賻賰賽乇賺蹪鄢鄄",
      "juz": 27,
