      "manzil": 7,
      "ruku": 464,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "賰賻匕賾賻亘賻鬲賿 賯賻賵賿賲購 賱購賵賿胤賺郗 亘賽丕賱賳賾購匕購乇賽蹪鄢鄢",
