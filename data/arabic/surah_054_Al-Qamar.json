{
  "surah_id": 54,
  "surah_name": "Al-Qamar",
  "arabic_name": "爻購賵乇賻丞購 丕賱賯賻賲賻乇賽",
  "revelation_type": "Meccan",
  "total_ayahs": 55,
  "bismillah": "亘賽爻賿賲賽 丕賱賱賾侔賴賽 丕賱乇賾賻丨賿賲侔賳賽 丕賱乇賾賻丨賽蹖賿賲賽",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "丕賽賯賿鬲賻乇賻亘賻鬲賽 丕賱爻賾賻丕毓賻丞購 賵賻 丕賳賿卮賻賯賾賻 丕賱賿賯賻賲賻乇購蹪郾",
      "juz": 27,
      "page": 528,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 211,
      "sajdah": false,
      "verse_key": "54:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "賵賻 丕賽賳賿 蹖賾賻乇賻賵賿丕 丕侔蹖賻丞賸 蹖賾購毓賿乇賽囟購賵賿丕 賵賻 蹖賻賯購賵賿賱購賵賿丕 爻賽丨賿乇賹 賲賾購爻賿鬲賻賲賽乇賾賹蹪鄄",
      "juz": 27,
      "page": 528,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 211,
      "sajdah": false,
      "verse_key": "54:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "賵賻 賰賻匕賾賻亘購賵賿丕 賵賻 丕鬲賾賻亘賻毓購賵賿郅丕 丕賻賴賿賵賻丕贀亍賻賴購賲賿 賵賻 賰購賱賾購 丕賻賲賿乇賺 賲賾購爻賿鬲賻賯賽乇賾賹蹪鄢",
      "juz": 27,
      "page": 528,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 211,
      "sajdah": false,
      "verse_key": "54:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "賵賻 賱賻賯賻丿賿 噩賻丕贀亍賻賴購賲賿 賲賾賽賳賻 丕賱賿丕賻賳邰賿亘賻丕贀亍賽 賲賻丕 賮賽蹖賿賴賽 賲購夭賿丿賻噩賻乇賹蹤蹪鄞",
      "juz": 27,
      "page": 528,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 211,
      "sajdah": false,
      "verse_key": "54:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "丨賽賰賿賲賻丞賹邰 亘賻丕賱賽睾賻丞賹 賮賻賲賻丕 鬲購睾賿賳賽 丕賱賳賾購匕購乇購蹤蹪鄣",
      "juz": 27,
      "page": 528,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 211,
      "sajdah": false,
      "verse_key": "54:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "賮賻鬲賻賵賻賱賾賻 毓賻賳賿賴購賲賿 蹣 蹖賻賵賿賲賻 蹖賻丿賿毓購 丕賱丿賾賻丕毓賽 丕賽賱侔蹖 卮賻蹖賿亍賺 賳賾購賰購乇賺蹤蹪鄱",
      "juz": 27,
      "page": 528,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 211,
      "sajdah": false,
      "verse_key": "54:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "禺購卮賾賻毓賸丕 丕賻亘賿氐賻丕乇購賴購賲賿 蹖賻禺賿乇購噩購賵賿賳賻 賲賽賳賻 丕賱賿丕賻噩賿丿賻丕孬賽 賰賻丕賻賳賾賻賴購賲賿 噩賻乇賻丕丿賹 賲賾購賳賿鬲賻卮賽乇賹蹤蹪鄯",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 211,
      "sajdah": false,
      "verse_key": "54:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "賲賾購賴賿胤賽毓賽蹖賿賳賻 丕賽賱賻蹖 丕賱丿賾賻丕毓賽 貢 蹖賻賯購賵賿賱購 丕賱賿賰侔賮賽乇購賵賿賳賻 賴侔匕賻丕 蹖賻賵賿賲賹 毓賻爻賽乇賹蹪鄹",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 211,
      "sajdah": false,
      "verse_key": "54:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "賰賻匕賾賻亘賻鬲賿 賯賻亘賿賱賻賴購賲賿 賯賻賵賿賲購 賳購賵賿丨賺 賮賻賰賻匕賾賻亘購賵賿丕 毓賻亘賿丿賻賳賻丕 賵賻 賯賻丕賱購賵賿丕 賲賻噩賿賳購賵賿賳賹 賵賾賻 丕夭賿丿購噩賽乇賻蹪酃",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "賮賻丿賻毓賻丕 乇賻亘賾賻賴贄郅 丕賻賳賾賽蹖賿 賲賻睾賿賱購賵賿亘賹 賮賻丕賳賿鬲賻氐賽乇賿蹪郾郯",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "賮賻賮賻鬲賻丨賿賳賻丕郅 丕賻亘賿賵賻丕亘賻 丕賱爻賾賻賲賻丕贀亍賽 亘賽賲賻丕贀亍賺 賲賾購賳賿賴賻賲賽乇賺貤蹡蹪郾郾",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "賵賾賻 賮賻噩賾賻乇賿賳賻丕 丕賱賿丕賻乇賿囟賻 毓購蹖購賵賿賳賸丕 賮賻丕賱賿鬲賻賯賻蹖 丕賱賿賲賻丕贀亍購 毓賻賱侔郅蹖 丕賻賲賿乇賺 賯賻丿賿 賯購丿賽乇賻蹥蹪郾鄄",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "賵賻 丨賻賲賻賱賿賳侔賴購 毓賻賱侔蹖 匕賻丕鬲賽 丕賻賱賿賵賻丕丨賺 賵賾賻 丿購爻購乇賺蹤蹪郾鄢",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "鬲賻噩賿乇賽蹖賿 亘賽丕賻毓賿蹖購賳賽賳賻丕 蹥 噩賻夭賻丕贀亍賸 賱賾賽賲賻賳賿 賰賻丕賳賻 賰購賮賽乇賻蹪郾鄞",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "賵賻 賱賻賯賻丿賿 鬲賾賻乇賻賰賿賳侔賴賻丕郅 丕侔蹖賻丞賸 賮賻賴賻賱賿 賲賽賳賿 賲賾購丿賾賻賰賽乇賺蹪郾鄣",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "賮賻賰賻蹖賿賮賻 賰賻丕賳賻 毓賻匕賻丕亘賽蹖賿 賵賻 賳購匕購乇賽蹪郾鄱",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "賵賻 賱賻賯賻丿賿 蹖賻爻賾賻乇賿賳賻丕 丕賱賿賯購乇賿丕侔賳賻 賱賽賱匕賾賽賰賿乇賽 賮賻賴賻賱賿 賲賽賳賿 賲賾購丿賾賻賰賽乇賺蹪郾鄯",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "賰賻匕賾賻亘賻鬲賿 毓賻丕丿賹 賮賻賰賻蹖賿賮賻 賰賻丕賳賻 毓賻匕賻丕亘賽蹖賿 賵賻 賳購匕購乇賽蹪郾鄹",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "丕賽賳賾賻丕郅 丕賻乇賿爻賻賱賿賳賻丕 毓賻賱賻蹖賿賴賽賲賿 乇賽蹖賿丨賸丕 氐賻乇賿氐賻乇賸丕 賮賽蹖賿 蹖賻賵賿賲賽 賳賻丨賿爻賺 賲賾購爻賿鬲賻賲賽乇賾賺蹤蹪郾酃",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "鬲賻賳賿夭賽毓購 丕賱賳賾賻丕爻賻 蹤 賰賻丕賻賳賾賻賴購賲賿 丕賻毓賿噩賻丕夭購 賳賻禺賿賱賺 賲賾購賳賿賯賻毓賽乇賺蹪鄄郯",
      "juz": 27,
      "page": 529,
      "manzil": 7,
      "ruku": 463,
      "hizb": 53,
