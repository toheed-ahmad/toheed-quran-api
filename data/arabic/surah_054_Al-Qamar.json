      "manzil": 7,
      "ruku": 464,
      "hizb": 53,
      "hizbQuarter": 212,
      "sajdah": false,
      "verse_key": "54:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "丕賽賳賾賻丕郅 丕賻乇賿爻賻賱賿賳賻丕 毓賻賱賻蹖賿賴賽賲賿 氐賻蹖賿丨賻丞賸 賵賾賻丕丨賽丿賻丞賸 賮賻賰賻丕賳購賵賿丕 賰賻賴賻卮賽蹖賿賲賽 丕賱賿賲購丨賿鬲賻馗賽乇賽蹪鄢郾",
      "juz": 27,
