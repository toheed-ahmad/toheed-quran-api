  "revelation_type": "Medinan",
  "total_ayahs": 78,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اَلرَّحْمٰنُۙ",
      "verse_key": "55:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "عَلَّمَ الْقُرْاٰنَؕ",
      "verse_key": "55:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "خَلَقَ الْاِنْسَانَۙ",
      "verse_key": "55:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "عَلَّمَهُ الْبَیَانَ",
      "verse_key": "55:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "اَلشَّمْسُ وَ الْقَمَرُ بِحُسْبَانٍ۪",
      "verse_key": "55:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَّ النَّجْمُ وَ الشَّجَرُ یَسْجُدٰنِ",
      "verse_key": "55:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ السَّمَآءَ رَفَعَهَا وَ وَضَعَ الْمِیْزَانَۙ",
      "verse_key": "55:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "اَلَّا تَطْغَوْا فِی الْمِیْزَانِ",
      "verse_key": "55:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ اَقِیْمُوا الْوَزْنَ بِالْقِسْطِ وَ لَا تُخْسِرُوا الْمِیْزَانَ",
      "verse_key": "55:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ الْاَرْضَ وَ ضَعَهَا لِلْاَنَامِۙ",
      "verse_key": "55:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "فِیْهَا فَاكِهَةٌ١۪ۙ وَّ النَّخْلُ ذَاتُ الْاَكْمَامِۖ",
      "verse_key": "55:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ الْحَبُّ ذُو الْعَصْفِ وَ الرَّیْحَانُۚ",
      "verse_key": "55:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ",
      "verse_key": "55:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "خَلَقَ الْاِنْسَانَ مِنْ صَلْصَالٍ كَالْفَخَّارِۙ",
      "verse_key": "55:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَ خَلَقَ الْجَآنَّ مِنْ مَّارِجٍ مِّنْ نَّارٍۚ",
      "verse_key": "55:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ",
      "verse_key": "55:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "رَبُّ الْمَشْرِقَیْنِ وَ رَبُّ الْمَغْرِبَیْنِۚ",
      "verse_key": "55:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ",
      "verse_key": "55:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "مَرَجَ الْبَحْرَیْنِ یَلْتَقِیٰنِۙ",
      "verse_key": "55:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "بَیْنَهُمَا بَرْزَخٌ لَّا یَبْغِیٰنِۚ",
      "verse_key": "55:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ",
      "verse_key": "55:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "یَخْرُجُ مِنْهُمَا اللُّؤْلُؤُ وَ الْمَرْجَانُۚ",
      "verse_key": "55:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ",
      "verse_key": "55:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَ لَهُ الْجَوَارِ الْمُنْشَئٰتُ فِی الْبَحْرِ كَالْاَعْلَامِۚ",
      "verse_key": "55:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "فَبِاَیِّ اٰلَآءِ رَبِّكُمَا تُكَذِّبٰنِ۠",
      "verse_key": "55:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "كُلُّ مَنْ عَلَیْهَا فَانٍۚۖ",
      "verse_key": "55:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَّ یَبْقٰى وَجْهُ رَبِّكَ ذُو الْجَلٰلِ وَ الْاِكْرَامِۚ",
