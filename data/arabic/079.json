{
  "surah_id": 79,
  "surah_name": "An-Nazi'at",
  "arabic_name": "سُورَةُ النَّازِعَاتِ",
  "revelation_type": "Meccan",
  "total_ayahs": 46,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ النّٰزِعٰتِ غَرْقًاۙ",
      "verse_key": "79:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَّ النّٰشِطٰتِ نَشْطًاۙ",
      "verse_key": "79:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَّ السّٰبِحٰتِ سَبْحًاۙ",
      "verse_key": "79:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "فَالسّٰبِقٰتِ سَبْقًاۙ",
      "verse_key": "79:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَالْمُدَبِّرٰتِ اَمْرًاۘ",
      "verse_key": "79:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "یَوْمَ تَرْجُفُ الرَّاجِفَةُۙ",
      "verse_key": "79:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "تَتْبَعُهَا الرَّادِفَةُؕ",
      "verse_key": "79:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "قُلُوْبٌ یَّوْمَئِذٍ وَّاجِفَةٌۙ",
      "verse_key": "79:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "اَبْصَارُهَا خَاشِعَةٌۘ",
      "verse_key": "79:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "یَقُوْلُوْنَ ءَاِنَّا لَمَرْدُوْدُوْنَ فِی الْحَافِرَةِؕ",
      "verse_key": "79:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "ءَاِذَا كُنَّا عِظَامًا نَّخِرَةًؕ",
      "verse_key": "79:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "قَالُوْا تِلْكَ اِذًا كَرَّةٌ خَاسِرَةٌۘ",
      "verse_key": "79:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "فَاِنَّمَا هِیَ زَجْرَةٌ وَّاحِدَةٌۙ",
      "verse_key": "79:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "فَاِذَا هُمْ بِالسَّاهِرَةِؕ",
      "verse_key": "79:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "هَلْ اَتٰىكَ حَدِیْثُ مُوْسٰىۘ",
      "verse_key": "79:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "اِذْ نَادٰىهُ رَبُّهٗ بِالْوَادِ الْمُقَدَّسِ طُوًىۚ",
      "verse_key": "79:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "اِذْهَبْ اِلٰى فِرْعَوْنَ اِنَّهٗ طَغٰى٘ۖ",
      "verse_key": "79:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "فَقُلْ هَلْ لَّكَ اِلٰۤى اَنْ تَزَكّٰىۙ",
      "verse_key": "79:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ اَهْدِیَكَ اِلٰى رَبِّكَ فَتَخْشٰىۚ",
      "verse_key": "79:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "فَاَرٰىهُ الْاٰیَةَ الْكُبْرٰى٘ۖ",
      "verse_key": "79:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "فَكَذَّبَ وَعَصٰى٘ۖ",
      "verse_key": "79:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "ثُمَّ اَدْبَرَ یَسْعٰى٘ۖ",
      "verse_key": "79:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "فَحَشَرَ فَنَادٰى٘ۖ",
      "verse_key": "79:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "فَقَالَ اَنَا رَبُّكُمُ الْاَعْلٰى٘ۖ",
      "verse_key": "79:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "فَاَخَذَهُ اللّٰهُ نَكَالَ الْاٰخِرَةِ وَ الْاُوْلٰىؕ",
      "verse_key": "79:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "اِنَّ فِیْ ذٰلِكَ لَعِبْرَةً لِّمَنْ یَّخْشٰى٢ؕ۠",
      "verse_key": "79:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "ءَاَنْتُمْ اَشَدُّ خَلْقًا اَمِ السَّمَآءُ١ؕ بَنٰىهَاٙ",
      "verse_key": "79:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "رَفَعَ سَمْكَهَا فَسَوّٰىهَاۙ",
      "verse_key": "79:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَ اَغْطَشَ لَیْلَهَا وَ اَخْرَجَ ضُحٰىهَا۪",
      "verse_key": "79:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَ الْاَرْضَ بَعْدَ ذٰلِكَ دَحٰىهَاؕ",
      "verse_key": "79:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "اَخْرَجَ مِنْهَا مَآءَهَا وَ مَرْعٰىهَا۪",
      "verse_key": "79:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "وَ الْجِبَالَ اَرْسٰىهَاۙ",
      "verse_key": "79:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "مَتَاعًا لَّكُمْ وَ لِاَنْعَامِكُمْؕ",
      "verse_key": "79:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "فَاِذَا جَآءَتِ الطَّآمَّةُ الْكُبْرٰى٘ۖ",
      "verse_key": "79:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "یَوْمَ یَتَذَكَّرُ الْاِنْسَانُ مَا سَعٰىۙ",
      "verse_key": "79:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "وَ بُرِّزَتِ الْجَحِیْمُ لِمَنْ یَّرٰى",
      "verse_key": "79:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "فَاَمَّا مَنْ طَغٰىۙ",
      "verse_key": "79:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "وَ اٰثَرَ الْحَیٰوةَ الدُّنْیَاۙ",
      "verse_key": "79:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "فَاِنَّ الْجَحِیْمَ هِیَ الْمَاْوٰىؕ",
      "verse_key": "79:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "وَ اَمَّا مَنْ خَافَ مَقَامَ رَبِّهٖ وَ نَهَى النَّفْسَ عَنِ الْهَوٰىۙ",
      "verse_key": "79:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "فَاِنَّ الْجَنَّةَ هِیَ الْمَاْوٰىؕ",
      "verse_key": "79:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "یَسْئَلُوْنَكَ عَنِ السَّاعَةِ اَیَّانَ مُرْسٰىهَاؕ",
      "verse_key": "79:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "فِیْمَ اَنْتَ مِنْ ذِكْرٰىهَاؕ",
      "verse_key": "79:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "اِلٰى رَبِّكَ مُنْتَهٰىهَاؕ",
      "verse_key": "79:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "اِنَّمَاۤ اَنْتَ مُنْذِرُ مَنْ یَّخْشٰىهَاؕ",
      "verse_key": "79:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "كَاَنَّهُمْ یَوْمَ یَرَوْنَهَا لَمْ یَلْبَثُوْۤا اِلَّا عَشِیَّةً اَوْ ضُحٰىهَا۠",
      "verse_key": "79:46"
    }
  ]
}