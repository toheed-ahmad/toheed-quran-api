  "arabic_name": "سُورَةُ الزُّخۡرُفِ",
  "revelation_type": "Meccan",
  "total_ayahs": 89,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "حٰمٓۚۛ۝۱",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ الْكِتٰبِ الْمُبِیْنِۙۛ۝۲",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "اِنَّا جَعَلْنٰهُ قُرْءٰنًا عَرَبِیًّا لَّعَلَّكُمْ تَعْقِلُوْنَۚ۝۳",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ اِنَّهٗ فِیْۤ اُمِّ الْكِتٰبِ لَدَیْنَا لَعَلِیٌّ حَكِیْمٌؕ۝۴",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "اَفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا اَنْ كُنْتُمْ قَوْمًا مُّسْرِفِیْنَ۝۵",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَ كَمْ اَرْسَلْنَا مِنْ نَّبِیٍّ فِی الْاَوَّلِیْنَ۝۶",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ مَا یَاْتِیْهِمْ مِّنْ نَّبِیٍّ اِلَّا كَانُوْا بِهٖ یَسْتَهْزِءُوْنَ۝۷",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "فَاَهْلَكْنَاۤ اَشَدَّ مِنْهُمْ بَطْشًا وَّ مَضٰی مَثَلُ الْاَوَّلِیْنَ۝۸",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ لَىِٕنْ سَاَلْتَهُمْ مَّنْ خَلَقَ السَّمٰوٰتِ وَ الْاَرْضَ لَیَقُوْلُنَّ خَلَقَهُنَّ الْعَزِیْزُ الْعَلِیْمُۙ۝۹",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "الَّذِیْ جَعَلَ لَكُمُ الْاَرْضَ مَهْدًا وَّ جَعَلَ لَكُمْ فِیْهَا سُبُلًا لَّعَلَّكُمْ تَهْتَدُوْنَۚ۝۱۰",
      "juz": 25,
      "page": 489,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ الَّذِیْ نَزَّلَ مِنَ السَّمَآءِ مَآءًۢ بِقَدَرٍ ۚ فَاَنْشَرْنَا بِهٖ بَلْدَةً مَّیْتًا ۚ كَذٰلِكَ تُخْرَجُوْنَ۝۱۱",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ الَّذِیْ خَلَقَ الْاَزْوَاجَ كُلَّهَا وَ جَعَلَ لَكُمْ مِّنَ الْفُلْكِ وَ الْاَنْعَامِ مَا تَرْكَبُوْنَۙ۝۱۲",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "لِتَسْتَوٗا عَلٰی ظُهُوْرِهٖ ثُمَّ تَذْكُرُوْا نِعْمَةَ رَبِّكُمْ اِذَا اسْتَوَیْتُمْ عَلَیْهِ وَ تَقُوْلُوْا سُبْحٰنَ الَّذِیْ سَخَّرَ لَنَا هٰذَا وَ مَا كُنَّا لَهٗ مُقْرِنِیْنَۙ۝۱۳",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ اِنَّاۤ اِلٰی رَبِّنَا لَمُنْقَلِبُوْنَ۝۱۴",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَ جَعَلُوْا لَهٗ مِنْ عِبَادِهٖ جُزْءًا ؕ اِنَّ الْاِنْسَانَ لَكَفُوْرٌ مُّبِیْنٌؕ۠۝۱۵",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 424,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "اَمِ اتَّخَذَ مِمَّا یَخْلُقُ بَنٰتٍ وَّ اَصْفٰىكُمْ بِالْبَنِیْنَ۝۱۶",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 425,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ اِذَا بُشِّرَ اَحَدُهُمْ بِمَا ضَرَبَ لِلرَّحْمٰنِ مَثَلًا ظَلَّ وَجْهُهٗ مُسْوَدًّا وَّ هُوَ كَظِیْمٌ۝۱۷",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 425,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "اَوَ مَنْ یُّنَشَّؤُا فِی الْحِلْیَةِ وَ هُوَ فِی الْخِصَامِ غَیْرُ مُبِیْنٍ۝۱۸",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 425,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ جَعَلُوا الْمَلٰٓىِٕكَةَ الَّذِیْنَ هُمْ عِبٰدُ الرَّحْمٰنِ اِنَاثًا ؕ اَشَهِدُوْا خَلْقَهُمْ ؕ سَتُكْتَبُ شَهَادَتُهُمْ وَ یُسْـَٔلُوْنَ۝۱۹",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 425,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ قَالُوْا لَوْ شَآءَ الرَّحْمٰنُ مَا عَبَدْنٰهُمْ ؕ مَا لَهُمْ بِذٰلِكَ مِنْ عِلْمٍ ۗ اِنْ هُمْ اِلَّا یَخْرُصُوْنَؕ۝۲۰",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 425,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "اَمْ اٰتَیْنٰهُمْ كِتٰبًا مِّنْ قَبْلِهٖ فَهُمْ بِهٖ مُسْتَمْسِكُوْنَ۝۲۱",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 425,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "بَلْ قَالُوْۤا اِنَّا وَجَدْنَاۤ اٰبَآءَنَا عَلٰۤی اُمَّةٍ وَّ اِنَّا عَلٰۤی اٰثٰرِهِمْ مُّهْتَدُوْنَ۝۲۲",
      "juz": 25,
      "page": 490,
      "manzil": 6,
      "ruku": 425,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "وَ كَذٰلِكَ مَاۤ اَرْسَلْنَا مِنْ قَبْلِكَ فِیْ قَرْیَةٍ مِّنْ نَّذِیْرٍ اِلَّا قَالَ مُتْرَفُوْهَاۤ ۙ اِنَّا وَجَدْنَاۤ اٰبَآءَنَا عَلٰۤی اُمَّةٍ وَّ اِنَّا عَلٰۤی اٰثٰرِهِمْ مُّقْتَدُوْنَ۝۲۳",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 425,
      "hizb": 49,
      "hizbQuarter": 196,
      "sajdah": false,
      "verse_key": "43:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "قٰلَ اَوَ لَوْ جِئْتُكُمْ بِاَهْدٰی مِمَّا وَجَدْتُّمْ عَلَیْهِ اٰبَآءَكُمْ ؕ قَالُوْۤا اِنَّا بِمَاۤ اُرْسِلْتُمْ بِهٖ كٰفِرُوْنَ۝۲۴",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 425,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "فَانْتَقَمْنَا مِنْهُمْ فَانْظُرْ كَیْفَ كَانَ عَاقِبَةُ الْمُكَذِّبِیْنَ۠۝۲۵",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 425,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَ اِذْ قَالَ اِبْرٰهِیْمُ لِاَبِیْهِ وَ قَوْمِهٖۤ اِنَّنِیْ بَرَآءٌ مِّمَّا تَعْبُدُوْنَۙ۝۲۶",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "اِلَّا الَّذِیْ فَطَرَنِیْ فَاِنَّهٗ سَیَهْدِیْنِ۝۲۷",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "وَ جَعَلَهَا كَلِمَةًۢ بَاقِیَةً فِیْ عَقِبِهٖ لَعَلَّهُمْ یَرْجِعُوْنَ۝۲۸",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "بَلْ مَتَّعْتُ هٰۤؤُلَآءِ وَ اٰبَآءَهُمْ حَتّٰی جَآءَهُمُ الْحَقُّ وَ رَسُوْلٌ مُّبِیْنٌ۝۲۹",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "وَ لَمَّا جَآءَهُمُ الْحَقُّ قَالُوْا هٰذَا سِحْرٌ وَّ اِنَّا بِهٖ كٰفِرُوْنَ۝۳۰",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "وَ قَالُوْا لَوْ لَا نُزِّلَ هٰذَا الْقُرْاٰنُ عَلٰی رَجُلٍ مِّنَ الْقَرْیَتَیْنِ عَظِیْمٍ۝۳۱",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "اَهُمْ یَقْسِمُوْنَ رَحْمَتَ رَبِّكَ ؕ نَحْنُ قَسَمْنَا بَیْنَهُمْ مَّعِیْشَتَهُمْ فِی الْحَیٰوةِ الدُّنْیَا وَ رَفَعْنَا بَعْضَهُمْ فَوْقَ بَعْضٍ دَرَجٰتٍ لِّیَتَّخِذَ بَعْضُهُمْ بَعْضًا سُخْرِیًّا ؕ وَ رَحْمَتُ رَبِّكَ خَیْرٌ مِّمَّا یَجْمَعُوْنَ۝۳۲",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "وَ لَوْ لَاۤ اَنْ یَّكُوْنَ النَّاسُ اُمَّةً وَّاحِدَةً لَّجَعَلْنَا لِمَنْ یَّكْفُرُ بِالرَّحْمٰنِ لِبُیُوْتِهِمْ سُقُفًا مِّنْ فِضَّةٍ وَّ مَعَارِجَ عَلَیْهَا یَظْهَرُوْنَۙ۝۳۳",
      "juz": 25,
      "page": 491,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَ لِبُیُوْتِهِمْ اَبْوَابًا وَّ سُرُرًا عَلَیْهَا یَتَّكِـُٔوْنَۙ۝۳۴",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "وَ زُخْرُفًا ؕ وَ اِنْ كُلُّ ذٰلِكَ لَمَّا مَتَاعُ الْحَیٰوةِ الدُّنْیَا ؕ وَ الْاٰخِرَةُ عِنْدَ رَبِّكَ لِلْمُتَّقِیْنَ۠۝۳۵",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 426,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "وَ مَنْ یَّعْشُ عَنْ ذِكْرِ الرَّحْمٰنِ نُقَیِّضْ لَهٗ شَیْطٰنًا فَهُوَ لَهٗ قَرِیْنٌ۝۳۶",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "وَ اِنَّهُمْ لَیَصُدُّوْنَهُمْ عَنِ السَّبِیْلِ وَ یَحْسَبُوْنَ اَنَّهُمْ مُّهْتَدُوْنَ۝۳۷",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "حَتّٰۤی اِذَا جَآءَنَا قَالَ یٰلَیْتَ بَیْنِیْ وَ بَیْنَكَ بُعْدَ الْمَشْرِقَیْنِ فَبِئْسَ الْقَرِیْنُ۝۳۸",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "وَ لَنْ یَّنْفَعَكُمُ الْیَوْمَ اِذْ ظَّلَمْتُمْ اَنَّكُمْ فِی الْعَذَابِ مُشْتَرِكُوْنَ۝۳۹",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "اَفَاَنْتَ تُسْمِعُ الصُّمَّ اَوْ تَهْدِی الْعُمْیَ وَ مَنْ كَانَ فِیْ ضَلٰلٍ مُّبِیْنٍ۝۴۰",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "فَاِمَّا نَذْهَبَنَّ بِكَ فَاِنَّا مِنْهُمْ مُّنْتَقِمُوْنَۙ۝۴۱",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "اَوْ نُرِیَنَّكَ الَّذِیْ وَعَدْنٰهُمْ فَاِنَّا عَلَیْهِمْ مُّقْتَدِرُوْنَ۝۴۲",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "فَاسْتَمْسِكْ بِالَّذِیْۤ اُوْحِیَ اِلَیْكَ ۚ اِنَّكَ عَلٰی صِرَاطٍ مُّسْتَقِیْمٍ۝۴۳",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "وَ اِنَّهٗ لَذِكْرٌ لَّكَ وَ لِقَوْمِكَ ۚ وَ سَوْفَ تُسْـَٔلُوْنَ۝۴۴",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "وَ سْـَٔلْ مَنْ اَرْسَلْنَا مِنْ قَبْلِكَ مِنْ رُّسُلِنَاۤ اَجَعَلْنَا مِنْ دُوْنِ الرَّحْمٰنِ اٰلِهَةً یُّعْبَدُوْنَ۠۝۴۵",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 427,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "وَ لَقَدْ اَرْسَلْنَا مُوْسٰی بِاٰیٰتِنَاۤ اِلٰی فِرْعَوْنَ وَ مَلَاۡىِٕهٖ فَقَالَ اِنِّیْ رَسُوْلُ رَبِّ الْعٰلَمِیْنَ۝۴۶",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "فَلَمَّا جَآءَهُمْ بِاٰیٰتِنَاۤ اِذَا هُمْ مِّنْهَا یَضْحَكُوْنَ۝۴۷",
      "juz": 25,
      "page": 492,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "وَ مَا نُرِیْهِمْ مِّنْ اٰیَةٍ اِلَّا هِیَ اَكْبَرُ مِنْ اُخْتِهَا ؗ وَ اَخَذْنٰهُمْ بِالْعَذَابِ لَعَلَّهُمْ یَرْجِعُوْنَ۝۴۸",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "وَ قَالُوْا یٰۤاَیُّهَ السّٰحِرُ ادْعُ لَنَا رَبَّكَ بِمَا عَهِدَ عِنْدَكَ ۚ اِنَّنَا لَمُهْتَدُوْنَ۝۴۹",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "فَلَمَّا كَشَفْنَا عَنْهُمُ الْعَذَابَ اِذَا هُمْ یَنْكُثُوْنَ۝۵۰",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:50"
    },
    {
      "ayah_number": 51,
      "arabic_text": "وَ نَادٰی فِرْعَوْنُ فِیْ قَوْمِهٖ قَالَ یٰقَوْمِ اَلَیْسَ لِیْ مُلْكُ مِصْرَ وَ هٰذِهِ الْاَنْهٰرُ تَجْرِیْ مِنْ تَحْتِیْ ۚ اَفَلَا تُبْصِرُوْنَؕ۝۵۱",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:51"
    },
    {
      "ayah_number": 52,
      "arabic_text": "اَمْ اَنَا خَیْرٌ مِّنْ هٰذَا الَّذِیْ هُوَ مَهِیْنٌ ۙ۬ وَّ لَا یَكَادُ یُبِیْنُ۝۵۲",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:52"
    },
    {
      "ayah_number": 53,
      "arabic_text": "فَلَوْ لَاۤ اُلْقِیَ عَلَیْهِ اَسْوِرَةٌ مِّنْ ذَهَبٍ اَوْ جَآءَ مَعَهُ الْمَلٰٓىِٕكَةُ مُقْتَرِنِیْنَ۝۵۳",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:53"
    },
    {
      "ayah_number": 54,
      "arabic_text": "فَاسْتَخَفَّ قَوْمَهٗ فَاَطَاعُوْهُ ؕ اِنَّهُمْ كَانُوْا قَوْمًا فٰسِقِیْنَ۝۵۴",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:54"
    },
    {
      "ayah_number": 55,
      "arabic_text": "فَلَمَّاۤ اٰسَفُوْنَا انْتَقَمْنَا مِنْهُمْ فَاَغْرَقْنٰهُمْ اَجْمَعِیْنَۙ۝۵۵",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:55"
    },
    {
      "ayah_number": 56,
      "arabic_text": "فَجَعَلْنٰهُمْ سَلَفًا وَّ مَثَلًا لِّلْاٰخِرِیْنَ۠۝۵۶",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 428,
      "hizb": 50,
      "hizbQuarter": 197,
      "sajdah": false,
      "verse_key": "43:56"
    },
    {
      "ayah_number": 57,
      "arabic_text": "وَ لَمَّا ضُرِبَ ابْنُ مَرْیَمَ مَثَلًا اِذَا قَوْمُكَ مِنْهُ یَصِدُّوْنَ۝۵۷",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:57"
    },
    {
      "ayah_number": 58,
      "arabic_text": "وَ قَالُوْۤا ءَاٰلِهَتُنَا خَیْرٌ اَمْ هُوَ ؕ مَا ضَرَبُوْهُ لَكَ اِلَّا جَدَلًا ؕ بَلْ هُمْ قَوْمٌ خَصِمُوْنَ۝۵۸",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:58"
    },
    {
      "ayah_number": 59,
      "arabic_text": "اِنْ هُوَ اِلَّا عَبْدٌ اَنْعَمْنَا عَلَیْهِ وَ جَعَلْنٰهُ مَثَلًا لِّبَنِیْۤ اِسْرَآءِیْلَؕ۝۵۹",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:59"
    },
    {
      "ayah_number": 60,
      "arabic_text": "وَ لَوْ نَشَآءُ لَجَعَلْنَا مِنْكُمْ مَّلٰٓىِٕكَةً فِی الْاَرْضِ یَخْلُفُوْنَ۝۶۰",
      "juz": 25,
      "page": 493,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:60"
    },
    {
      "ayah_number": 61,
      "arabic_text": "وَ اِنَّهٗ لَعِلْمٌ لِّلسَّاعَةِ فَلَا تَمْتَرُنَّ بِهَا وَ اتَّبِعُوْنِ ؕ هٰذَا صِرَاطٌ مُّسْتَقِیْمٌ۝۶۱",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:61"
    },
    {
      "ayah_number": 62,
      "arabic_text": "وَ لَا یَصُدَّنَّكُمُ الشَّیْطٰنُ ۚ اِنَّهٗ لَكُمْ عَدُوٌّ مُّبِیْنٌ۝۶۲",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:62"
    },
    {
      "ayah_number": 63,
      "arabic_text": "وَ لَمَّا جَآءَ عِیْسٰی بِالْبَیِّنٰتِ قَالَ قَدْ جِئْتُكُمْ بِالْحِكْمَةِ وَ لِاُبَیِّنَ لَكُمْ بَعْضَ الَّذِیْ تَخْتَلِفُوْنَ فِیْهِ ۚ فَاتَّقُوا اللّٰهَ وَ اَطِیْعُوْنِ۝۶۳",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:63"
    },
    {
      "ayah_number": 64,
      "arabic_text": "اِنَّ اللّٰهَ هُوَ رَبِّیْ وَ رَبُّكُمْ فَاعْبُدُوْهُ ؕ هٰذَا صِرَاطٌ مُّسْتَقِیْمٌ۝۶۴",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:64"
    },
    {
      "ayah_number": 65,
      "arabic_text": "فَاخْتَلَفَ الْاَحْزَابُ مِنْۢ بَیْنِهِمْ ۚ فَوَیْلٌ لِّلَّذِیْنَ ظَلَمُوْا مِنْ عَذَابِ یَوْمٍ اَلِیْمٍ۝۶۵",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:65"
    },
    {
      "ayah_number": 66,
      "arabic_text": "هَلْ یَنْظُرُوْنَ اِلَّا السَّاعَةَ اَنْ تَاْتِیَهُمْ بَغْتَةً وَّ هُمْ لَا یَشْعُرُوْنَ۝۶۶",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:66"
    },
    {
      "ayah_number": 67,
      "arabic_text": "اَلْاَخِلَّآءُ یَوْمَىِٕذٍۭ بَعْضُهُمْ لِبَعْضٍ عَدُوٌّ اِلَّا الْمُتَّقِیْنَؕ۠۝۶۷",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 429,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:67"
    },
    {
      "ayah_number": 68,
      "arabic_text": "یٰعِبَادِ لَا خَوْفٌ عَلَیْكُمُ الْیَوْمَ وَ لَاۤ اَنْتُمْ تَحْزَنُوْنَۚ۝۶۸",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:68"
    },
    {
      "ayah_number": 69,
      "arabic_text": "اَلَّذِیْنَ اٰمَنُوْا بِاٰیٰتِنَا وَ كَانُوْا مُسْلِمِیْنَۚ۝۶۹",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:69"
    },
    {
      "ayah_number": 70,
      "arabic_text": "اُدْخُلُوا الْجَنَّةَ اَنْتُمْ وَ اَزْوَاجُكُمْ تُحْبَرُوْنَ۝۷۰",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:70"
    },
    {
      "ayah_number": 71,
      "arabic_text": "یُطَافُ عَلَیْهِمْ بِصِحَافٍ مِّنْ ذَهَبٍ وَّ اَكْوَابٍ ۚ وَ فِیْهَا مَا تَشْتَهِیْهِ الْاَنْفُسُ وَ تَلَذُّ الْاَعْیُنُ ۚ وَ اَنْتُمْ فِیْهَا خٰلِدُوْنَۚ۝۷۱",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:71"
    },
    {
      "ayah_number": 72,
      "arabic_text": "وَ تِلْكَ الْجَنَّةُ الَّتِیْۤ اُوْرِثْتُمُوْهَا بِمَا كُنْتُمْ تَعْمَلُوْنَ۝۷۲",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:72"
    },
    {
      "ayah_number": 73,
      "arabic_text": "لَكُمْ فِیْهَا فَاكِهَةٌ كَثِیْرَةٌ مِّنْهَا تَاْكُلُوْنَ۝۷۳",
      "juz": 25,
      "page": 494,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:73"
    },
    {
      "ayah_number": 74,
      "arabic_text": "اِنَّ الْمُجْرِمِیْنَ فِیْ عَذَابِ جَهَنَّمَ خٰلِدُوْنَۚۖ۝۷۴",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:74"
    },
    {
      "ayah_number": 75,
      "arabic_text": "لَا یُفَتَّرُ عَنْهُمْ وَ هُمْ فِیْهِ مُبْلِسُوْنَۚ۝۷۵",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:75"
    },
    {
      "ayah_number": 76,
      "arabic_text": "وَ مَا ظَلَمْنٰهُمْ وَ لٰكِنْ كَانُوْا هُمُ الظّٰلِمِیْنَ۝۷۶",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:76"
    },
    {
      "ayah_number": 77,
      "arabic_text": "وَ نَادَوْا یٰمٰلِكُ لِیَقْضِ عَلَیْنَا رَبُّكَ ؕ قَالَ اِنَّكُمْ مّٰكِثُوْنَ۝۷۷",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:77"
    },
    {
      "ayah_number": 78,
      "arabic_text": "لَقَدْ جِئْنٰكُمْ بِالْحَقِّ وَ لٰكِنَّ اَكْثَرَكُمْ لِلْحَقِّ كٰرِهُوْنَ۝۷۸",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:78"
    },
    {
      "ayah_number": 79,
      "arabic_text": "اَمْ اَبْرَمُوْۤا اَمْرًا فَاِنَّا مُبْرِمُوْنَۚ۝۷۹",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:79"
    },
    {
      "ayah_number": 80,
      "arabic_text": "اَمْ یَحْسَبُوْنَ اَنَّا لَا نَسْمَعُ سِرَّهُمْ وَ نَجْوٰىهُمْ ؕ بَلٰی وَ رُسُلُنَا لَدَیْهِمْ یَكْتُبُوْنَ۝۸۰",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:80"
    },
    {
      "ayah_number": 81,
      "arabic_text": "قُلْ اِنْ كَانَ لِلرَّحْمٰنِ وَلَدٌ ۖۗ فَاَنَا اَوَّلُ الْعٰبِدِیْنَ۝۸۱",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:81"
    },
    {
      "ayah_number": 82,
      "arabic_text": "سُبْحٰنَ رَبِّ السَّمٰوٰتِ وَ الْاَرْضِ رَبِّ الْعَرْشِ عَمَّا یَصِفُوْنَ۝۸۲",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:82"
    },
    {
      "ayah_number": 83,
      "arabic_text": "فَذَرْهُمْ یَخُوْضُوْا وَ یَلْعَبُوْا حَتّٰی یُلٰقُوْا یَوْمَهُمُ الَّذِیْ یُوْعَدُوْنَ۝۸۳",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:83"
    },
    {
      "ayah_number": 84,
      "arabic_text": "وَ هُوَ الَّذِیْ فِی السَّمَآءِ اِلٰهٌ وَّ فِی الْاَرْضِ اِلٰهٌ ؕ وَ هُوَ الْحَكِیْمُ الْعَلِیْمُ۝۸۴",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:84"
    },
    {
      "ayah_number": 85,
      "arabic_text": "وَ تَبٰرَكَ الَّذِیْ لَهٗ مُلْكُ السَّمٰوٰتِ وَ الْاَرْضِ وَ مَا بَیْنَهُمَا ۚ وَ عِنْدَهٗ عِلْمُ السَّاعَةِ ۚ وَ اِلَیْهِ تُرْجَعُوْنَ۝۸۵",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:85"
    },
    {
      "ayah_number": 86,
      "arabic_text": "وَ لَا یَمْلِكُ الَّذِیْنَ یَدْعُوْنَ مِنْ دُوْنِهِ الشَّفَاعَةَ اِلَّا مَنْ شَهِدَ بِالْحَقِّ وَ هُمْ یَعْلَمُوْنَ۝۸۶",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:86"
    },
    {
      "ayah_number": 87,
      "arabic_text": "وَ لَىِٕنْ سَاَلْتَهُمْ مَّنْ خَلَقَهُمْ لَیَقُوْلُنَّ اللّٰهُ فَاَنّٰی یُؤْفَكُوْنَۙ۝۸۷",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:87"
    },
    {
      "ayah_number": 88,
      "arabic_text": "وَ قِیْلِهٖ یٰرَبِّ اِنَّ هٰۤؤُلَآءِ قَوْمٌ لَّا یُؤْمِنُوْنَۘ۝۸۸",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:88"
    },
    {
      "ayah_number": 89,
      "arabic_text": "فَاصْفَحْ عَنْهُمْ وَ قُلْ سَلٰمٌ ؕ فَسَوْفَ یَعْلَمُوْنَ۠۝۸۹",
      "juz": 25,
      "page": 495,
      "manzil": 6,
      "ruku": 430,
      "hizb": 50,
      "hizbQuarter": 198,
      "sajdah": false,
      "verse_key": "43:89"
    }
  ]
}