{
  "surah_id": 87,
  "surah_name": "Al-A'laa",
  "arabic_name": "سُورَةُ الأَعۡلَىٰ",
  "revelation_type": "Meccan",
  "total_ayahs": 19,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "سَبِّحِ اسْمَ رَبِّكَ الْاَعْلَیۙ۝۱",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "الَّذِیْ خَلَقَ فَسَوّٰی۪ۙ۝۲",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ الَّذِیْ قَدَّرَ فَهَدٰی۪ۙ۝۳",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ الَّذِیْۤ اَخْرَجَ الْمَرْعٰی۪ۙ۝۴",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَجَعَلَهٗ غُثَآءً اَحْوٰیؕ۝۵",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "سَنُقْرِئُكَ فَلَا تَنْسٰۤیۙ۝۶",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "اِلَّا مَا شَآءَ اللّٰهُ ؕ اِنَّهٗ یَعْلَمُ الْجَهْرَ وَ مَا یَخْفٰیؕ۝۷",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ نُیَسِّرُكَ لِلْیُسْرٰیۚۖ۝۸",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "فَذَكِّرْ اِنْ نَّفَعَتِ الذِّكْرٰیؕ۝۹",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "سَیَذَّكَّرُ مَنْ یَّخْشٰیۙ۝۱۰",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ یَتَجَنَّبُهَا الْاَشْقَیۙ۝۱۱",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "الَّذِیْ یَصْلَی النَّارَ الْكُبْرٰیۚ۝۱۲",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "ثُمَّ لَا یَمُوْتُ فِیْهَا وَ لَا یَحْیٰیؕ۝۱۳",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "قَدْ اَفْلَحَ مَنْ تَزَكّٰیۙ۝۱۴",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "وَ ذَكَرَ اسْمَ رَبِّهٖ فَصَلّٰیؕ۝۱۵",
      "juz": 30,
      "page": 591,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "بَلْ تُؤْثِرُوْنَ الْحَیٰوةَ الدُّنْیَاؗۖ۝۱۶",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ الْاٰخِرَةُ خَیْرٌ وَّ اَبْقٰیؕ۝۱۷",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "اِنَّ هٰذَا لَفِی الصُّحُفِ الْاُوْلٰیۙ۝۱۸",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "صُحُفِ اِبْرٰهِیْمَ وَ مُوْسٰی۠۝۱۹",
      "juz": 30,
      "page": 592,
      "manzil": 7,
      "ruku": 529,
      "hizb": 60,
      "hizbQuarter": 237,
      "sajdah": false,
      "verse_key": "87:19"
    }
  ]
}