{
  "surah_id": 70,
  "surah_name": "Al-Ma'aarij",
  "arabic_name": "سُورَةُ المَعَارِجِ",
  "revelation_type": "Meccan",
  "total_ayahs": 44,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "سَاَلَ سَآىِٕلٌۢ بِعَذَابٍ وَّاقِعٍۙ۝۱",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "لِّلْكٰفِرِیْنَ لَیْسَ لَهٗ دَافِعٌۙ۝۲",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "مِّنَ اللّٰهِ ذِی الْمَعَارِجِؕ۝۳",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "تَعْرُجُ الْمَلٰٓىِٕكَةُ وَ الرُّوْحُ اِلَیْهِ فِیْ یَوْمٍ كَانَ مِقْدَارُهٗ خَمْسِیْنَ اَلْفَ سَنَةٍۚ۝۴",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَاصْبِرْ صَبْرًا جَمِیْلًا۝۵",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اِنَّهُمْ یَرَوْنَهٗ بَعِیْدًاۙ۝۶",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَّ نَرٰىهُ قَرِیْبًاؕ۝۷",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "یَوْمَ تَكُوْنُ السَّمَآءُ كَالْمُهْلِۙ۝۸",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ تَكُوْنُ الْجِبَالُ كَالْعِهْنِۙ۝۹",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ لَا یَسْـَٔلُ حَمِیْمٌ حَمِیْمًاۚۖ۝۱۰",
      "juz": 29,
      "page": 568,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "یُّبَصَّرُوْنَهُمْ ؕ یَوَدُّ الْمُجْرِمُ لَوْ یَفْتَدِیْ مِنْ عَذَابِ یَوْمِىِٕذٍۭ بِبَنِیْهِۙ۝۱۱",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَ صَاحِبَتِهٖ وَ اَخِیْهِۙ۝۱۲",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَ فَصِیْلَتِهِ الَّتِیْ تُـْٔوِیْهِۙ۝۱۳",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ مَنْ فِی الْاَرْضِ جَمِیْعًا ۙ ثُمَّ یُنْجِیْهِۙ۝۱۴",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "كَلَّا ؕ اِنَّهَا لَظٰیۙ۝۱۵",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "نَزَّاعَةً لِّلشَّوٰیۚۖ۝۱۶",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "تَدْعُوْا مَنْ اَدْبَرَ وَ تَوَلّٰیۙ۝۱۷",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَ جَمَعَ فَاَوْعٰی۝۱۸",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 227,
      "sajdah": false,
      "verse_key": "70:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "اِنَّ الْاِنْسَانَ خُلِقَ هَلُوْعًاۙ۝۱۹",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "اِذَا مَسَّهُ الشَّرُّ جَزُوْعًاۙ۝۲۰",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَّ اِذَا مَسَّهُ الْخَیْرُ مَنُوْعًاۙ۝۲۱",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "اِلَّا الْمُصَلِّیْنَۙ۝۲۲",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "الَّذِیْنَ هُمْ عَلٰی صَلَاتِهِمْ دَآىِٕمُوْنَ۪ۙ۝۲۳",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَ الَّذِیْنَ فِیْۤ اَمْوَالِهِمْ حَقٌّ مَّعْلُوْمٌ۪ۙ۝۲۴",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "لِّلسَّآىِٕلِ وَ الْمَحْرُوْمِ۪ۙ۝۲۵",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَ الَّذِیْنَ یُصَدِّقُوْنَ بِیَوْمِ الدِّیْنِ۪ۙ۝۲۶",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "وَ الَّذِیْنَ هُمْ مِّنْ عَذَابِ رَبِّهِمْ مُّشْفِقُوْنَۚ۝۲۷",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "اِنَّ عَذَابَ رَبِّهِمْ غَیْرُ مَاْمُوْنٍ۝۲۸",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "وَ الَّذِیْنَ هُمْ لِفُرُوْجِهِمْ حٰفِظُوْنَۙ۝۲۹",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "اِلَّا عَلٰۤی اَزْوَاجِهِمْ اَوْ مَا مَلَكَتْ اَیْمَانُهُمْ فَاِنَّهُمْ غَیْرُ مَلُوْمِیْنَۚ۝۳۰",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "فَمَنِ ابْتَغٰی وَرَآءَ ذٰلِكَ فَاُولٰٓىِٕكَ هُمُ الْعٰدُوْنَۚ۝۳۱",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "وَ الَّذِیْنَ هُمْ لِاَمٰنٰتِهِمْ وَ عَهْدِهِمْ رٰعُوْنَ۪ۙ۝۳۲",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "وَ الَّذِیْنَ هُمْ بِشَهٰدٰتِهِمْ قَآىِٕمُوْنَ۪ۙ۝۳۳",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَ الَّذِیْنَ هُمْ عَلٰی صَلَاتِهِمْ یُحَافِظُوْنَؕ۝۳۴",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اُولٰٓىِٕكَ فِیْ جَنّٰتٍ مُّكْرَمُوْنَ  ؕ۠۝۳۵",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 502,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "فَمَالِ الَّذِیْنَ كَفَرُوْا قِبَلَكَ مُهْطِعِیْنَۙ۝۳۶",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 503,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "عَنِ الْیَمِیْنِ وَ عَنِ الشِّمَالِ عِزِیْنَ۝۳۷",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 503,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "اَیَطْمَعُ كُلُّ امْرِئٍ مِّنْهُمْ اَنْ یُّدْخَلَ جَنَّةَ نَعِیْمٍۙ۝۳۸",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 503,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "كَلَّا ؕ اِنَّا خَلَقْنٰهُمْ مِّمَّا یَعْلَمُوْنَ۝۳۹",
      "juz": 29,
      "page": 569,
      "manzil": 7,
      "ruku": 503,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "فَلَاۤ اُقْسِمُ بِرَبِّ الْمَشٰرِقِ وَ الْمَغٰرِبِ اِنَّا لَقٰدِرُوْنَۙ۝۴۰",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 503,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "عَلٰۤی اَنْ نُّبَدِّلَ خَیْرًا مِّنْهُمْ ۙ وَ مَا نَحْنُ بِمَسْبُوْقِیْنَ۝۴۱",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 503,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "فَذَرْهُمْ یَخُوْضُوْا وَ یَلْعَبُوْا حَتّٰی یُلٰقُوْا یَوْمَهُمُ الَّذِیْ یُوْعَدُوْنَۙ۝۴۲",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 503,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "یَوْمَ یَخْرُجُوْنَ مِنَ الْاَجْدَاثِ سِرَاعًا كَاَنَّهُمْ اِلٰی نُصُبٍ یُّوْفِضُوْنَۙ۝۴۳",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 503,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "خَاشِعَةً اَبْصَارُهُمْ تَرْهَقُهُمْ ذِلَّةٌ ؕ ذٰلِكَ الْیَوْمُ الَّذِیْ كَانُوْا یُوْعَدُوْنَ۠۝۴۴",
      "juz": 29,
      "page": 570,
      "manzil": 7,
      "ruku": 503,
      "hizb": 57,
      "hizbQuarter": 228,
      "sajdah": false,
      "verse_key": "70:44"
    }
  ]
}