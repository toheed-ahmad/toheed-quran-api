{
  "surah_id": 53,
  "surah_name": "An-Najm",
  "arabic_name": "سُورَةُ النَّجْمِ",
  "revelation_type": "Meccan",
  "total_ayahs": 62,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ النَّجْمِ اِذَا هَوٰىۙ",
      "verse_key": "53:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "مَا ضَلَّ صَاحِبُكُمْ وَ مَا غَوٰىۚ",
      "verse_key": "53:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ مَا یَنْطِقُ عَنِ الْهَوٰىؕ",
      "verse_key": "53:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اِنْ هُوَ اِلَّا وَحْیٌ یُّوْحٰىۙ",
      "verse_key": "53:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "عَلَّمَهٗ شَدِیْدُ الْقُوٰىۙ",
      "verse_key": "53:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "ذُوْ مِرَّةٍ١ؕ فَاسْتَوٰىۙ",
      "verse_key": "53:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ هُوَ بِالْاُفُقِ الْاَعْلٰىؕ",
      "verse_key": "53:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "ثُمَّ دَنَا فَتَدَلّٰىۙ",
      "verse_key": "53:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "فَكَانَ قَابَ قَوْسَیْنِ اَوْ اَدْنٰىۚ",
      "verse_key": "53:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فَاَوْحٰۤى اِلٰى عَبْدِهٖ مَاۤ اَوْحٰىؕ",
      "verse_key": "53:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "مَا كَذَبَ الْفُؤَادُ مَا رَاٰى",
      "verse_key": "53:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "اَفَتُمٰرُوْنَهٗ عَلٰى مَا یَرٰى",
      "verse_key": "53:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَ لَقَدْ رَاٰهُ نَزْلَةً اُخْرٰىۙ",
      "verse_key": "53:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "عِنْدَ سِدْرَةِ الْمُنْتَهٰى",
      "verse_key": "53:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "عِنْدَهَا جَنَّةُ الْمَاْوٰىؕ",
      "verse_key": "53:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "اِذْ یَغْشَى السِّدْرَةَ مَا یَغْشٰىۙ",
      "verse_key": "53:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "مَا زَاغَ الْبَصَرُ وَ مَا طَغٰى",
      "verse_key": "53:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "لَقَدْ رَاٰى مِنْ اٰیٰتِ رَبِّهِ الْكُبْرٰى",
      "verse_key": "53:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "اَفَرَءَیْتُمُ اللّٰتَ وَ الْعُزّٰىۙ",
      "verse_key": "53:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَ مَنٰوةَ الثَّالِثَةَ الْاُخْرٰى",
      "verse_key": "53:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "اَلَكُمُ الذَّكَرُ وَ لَهُ الْاُنْثٰى",
      "verse_key": "53:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "تِلْكَ اِذًا قِسْمَةٌ ضِیْزٰى",
      "verse_key": "53:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "اِنْ هِیَ اِلَّاۤ اَسْمَآءٌ سَمَّیْتُمُوْهَاۤ اَنْتُمْ وَ اٰبَآؤُكُمْ مَّاۤ اَنْزَلَ اللّٰهُ بِهَا مِنْ سُلْطٰنٍ١ؕ اِنْ یَّتَّبِعُوْنَ اِلَّا الظَّنَّ وَ مَا تَهْوَى الْاَنْفُسُ١ۚ وَ لَقَدْ جَآءَهُمْ مِّنْ رَّبِّهِمُ الْهُدٰىؕ",
      "verse_key": "53:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "اَمْ لِلْاِنْسَانِ مَا تَمَنّٰى٘ۖ",
      "verse_key": "53:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "فَلِلّٰهِ الْاٰخِرَةُ وَ الْاُوْلٰى۠",
      "verse_key": "53:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَ كَمْ مِّنْ مَّلَكٍ فِی السَّمٰوٰتِ لَا تُغْنِیْ شَفَاعَتُهُمْ شَیْئًا اِلَّا مِنْۢ بَعْدِ اَنْ یَّاْذَنَ اللّٰهُ لِمَنْ یَّشَآءُ وَ یَرْضٰى",
      "verse_key": "53:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "اِنَّ الَّذِیْنَ لَا یُؤْمِنُوْنَ بِالْاٰخِرَةِ لَیُسَمُّوْنَ الْمَلٰٓئِكَةَ تَسْمِیَةَ الْاُنْثٰى",
      "verse_key": "53:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "وَ مَا لَهُمْ بِهٖ مِنْ عِلْمٍ١ؕ اِنْ یَّتَّبِعُوْنَ اِلَّا الظَّنَّ١ۚ وَ اِنَّ الظَّنَّ لَا یُغْنِیْ مِنَ الْحَقِّ شَیْئًاۚ",
      "verse_key": "53:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "فَاَعْرِضْ عَنْ مَّنْ تَوَلّٰى١ۙ۬ عَنْ ذِكْرِنَا وَ لَمْ یُرِدْ اِلَّا الْحَیٰوةَ الدُّنْیَاؕ",
      "verse_key": "53:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "ذٰلِكَ مَبْلَغُهُمْ مِّنَ الْعِلْمِ١ؕ اِنَّ رَبَّكَ هُوَ اَعْلَمُ بِمَنْ ضَلَّ عَنْ سَبِیْلِهٖ١ۙ وَ هُوَ اَعْلَمُ بِمَنِ اهْتَدٰى",
      "verse_key": "53:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "وَ لِلّٰهِ مَا فِی السَّمٰوٰتِ وَ مَا فِی الْاَرْضِ١ۙ لِیَجْزِیَ الَّذِیْنَ اَسَآءُوْا بِمَا عَمِلُوْا وَ یَجْزِیَ الَّذِیْنَ اَحْسَنُوْا بِالْحُسْنٰىۚ",
      "verse_key": "53:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "اَلَّذِیْنَ یَجْتَنِبُوْنَ كَبٰٓئِرَ الْاِثْمِ وَ الْفَوَاحِشَ اِلَّا اللَّمَمَ١ؕ اِنَّ رَبَّكَ وَاسِعُ الْمَغْفِرَةِ١ؕ هُوَ اَعْلَمُ بِكُمْ اِذْ اَنْشَاَكُمْ مِّنَ الْاَرْضِ وَ اِذْ اَنْتُمْ اَجِنَّةٌ فِیْ بُطُوْنِ اُمَّهٰتِكُمْ١ۚ فَلَا تُزَكُّوْۤا اَنْفُسَكُمْ١ؕ هُوَ اَعْلَمُ بِمَنِ اتَّقٰى۠",
      "verse_key": "53:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "اَفَرَءَیْتَ الَّذِیْ تَوَلّٰىۙ",
      "verse_key": "53:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَ اَعْطٰى قَلِیْلًا وَّ اَكْدٰى",
      "verse_key": "53:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اَعِنْدَهٗ عِلْمُ الْغَیْبِ فَهُوَ یَرٰى",
      "verse_key": "53:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "اَمْ لَمْ یُنَبَّاْ بِمَا فِیْ صُحُفِ مُوْسٰىۙ",
      "verse_key": "53:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "وَ اِبْرٰهِیْمَ الَّذِیْ وَفّٰۤىۙ",
      "verse_key": "53:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "اَلَّا تَزِرُ وَازِرَةٌ وِّزْرَ اُخْرٰىۙ",
      "verse_key": "53:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "وَ اَنْ لَّیْسَ لِلْاِنْسَانِ اِلَّا مَا سَعٰىۙ",
      "verse_key": "53:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "وَ اَنَّ سَعْیَهٗ سَوْفَ یُرٰى۪",
      "verse_key": "53:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "ثُمَّ یُجْزٰىهُ الْجَزَآءَ الْاَوْفٰىۙ",
      "verse_key": "53:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "وَ اَنَّ اِلٰى رَبِّكَ الْمُنْتَهٰىۙ",
      "verse_key": "53:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "وَ اَنَّهٗ هُوَ اَضْحَكَ وَ اَبْكٰىۙ",
      "verse_key": "53:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "وَ اَنَّهٗ هُوَ اَمَاتَ وَ اَحْیَاۙ",
      "verse_key": "53:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "وَ اَنَّهٗ خَلَقَ الزَّوْجَیْنِ الذَّكَرَ وَ الْاُنْثٰىۙ",
      "verse_key": "53:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "مِنْ نُّطْفَةٍ اِذَا تُمْنٰى۪",
      "verse_key": "53:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "وَ اَنَّ عَلَیْهِ النَّشْاَةَ الْاُخْرٰىۙ",
      "verse_key": "53:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "وَ اَنَّهٗ هُوَ اَغْنٰى وَ اَقْنٰىۙ",
      "verse_key": "53:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "وَ اَنَّهٗ هُوَ رَبُّ الشِّعْرٰىۙ",
      "verse_key": "53:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "وَ اَنَّهٗۤ اَهْلَكَ عَادَا اِ۟لْاُوْلٰىۙ",
      "verse_key": "53:50"
    },
    {
      "ayah_number": 51,
      "arabic_text": "وَ ثَمُوْدَاۡ فَمَاۤ اَبْقٰىۙ",
      "verse_key": "53:51"
    },
    {
      "ayah_number": 52,
      "arabic_text": "وَ قَوْمَ نُوْحٍ مِّنْ قَبْلُ١ؕ اِنَّهُمْ كَانُوْا هُمْ اَظْلَمَ وَ اَطْغٰىؕ",
      "verse_key": "53:52"
    },
    {
      "ayah_number": 53,
      "arabic_text": "وَ الْمُؤْتَفِكَةَ اَهْوٰىۙ",
      "verse_key": "53:53"
    },
    {
      "ayah_number": 54,
      "arabic_text": "فَغَشّٰىهَا مَا غَشّٰىۚ",
      "verse_key": "53:54"
    },
    {
      "ayah_number": 55,
      "arabic_text": "فَبِاَیِّ اٰلَآءِ رَبِّكَ تَتَمَارٰى",
      "verse_key": "53:55"
    },
    {
      "ayah_number": 56,
      "arabic_text": "هٰذَا نَذِیْرٌ مِّنَ النُّذُرِ الْاُوْلٰى",
      "verse_key": "53:56"
    },
    {
      "ayah_number": 57,
      "arabic_text": "اَزِفَتِ الْاٰزِفَةُۚ",
      "verse_key": "53:57"
    },
    {
      "ayah_number": 58,
      "arabic_text": "لَیْسَ لَهَا مِنْ دُوْنِ اللّٰهِ كَاشِفَةٌؕ",
      "verse_key": "53:58"
    },
    {
      "ayah_number": 59,
      "arabic_text": "اَفَمِنْ هٰذَا الْحَدِیْثِ تَعْجَبُوْنَۙ",
      "verse_key": "53:59"
    },
    {
      "ayah_number": 60,
      "arabic_text": "وَ تَضْحَكُوْنَ وَ لَا تَبْكُوْنَۙ",
      "verse_key": "53:60"
    },
    {
      "ayah_number": 61,
      "arabic_text": "وَ اَنْتُمْ سٰمِدُوْنَ",
      "verse_key": "53:61"
    },
    {
      "ayah_number": 62,
      "arabic_text": "فَاسْجُدُوْا لِلّٰهِ وَ اعْبُدُوْا۠۩",
      "verse_key": "53:62"
    }
  ]
}