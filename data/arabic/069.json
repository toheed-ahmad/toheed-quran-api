{
  "surah_id": 69,
  "surah_name": "Al-Haqqah",
  "arabic_name": "سُورَةُ الْحَاقَّةِ",
  "revelation_type": "Meccan",
  "total_ayahs": 52,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اَلْحَآقَّةُۙ",
      "verse_key": "69:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "مَا الْحَآقَّةُۚ",
      "verse_key": "69:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ مَاۤ اَدْرٰىكَ مَا الْحَآقَّةُؕ",
      "verse_key": "69:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "كَذَّبَتْ ثَمُوْدُ وَ عَادٌۢ بِالْقَارِعَةِ",
      "verse_key": "69:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَاَمَّا ثَمُوْدُ فَاُهْلِكُوْا بِالطَّاغِیَةِ",
      "verse_key": "69:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَ اَمَّا عَادٌ فَاُهْلِكُوْا بِرِیْحٍ صَرْصَرٍ عَاتِیَةٍۙ",
      "verse_key": "69:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "سَخَّرَهَا عَلَیْهِمْ سَبْعَ لَیَالٍ وَّ ثَمٰنِیَةَ اَیَّامٍ١ۙ حُسُوْمًا١ۙ فَتَرَى الْقَوْمَ فِیْهَا صَرْعٰى١ۙ كَاَنَّهُمْ اَعْجَازُ نَخْلٍ خَاوِیَةٍۚ",
      "verse_key": "69:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "فَهَلْ تَرٰى لَهُمْ مِّنْۢ بَاقِیَةٍ",
      "verse_key": "69:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ جَآءَ فِرْعَوْنُ وَ مَنْ قَبْلَهٗ وَ الْمُؤْتَفِكٰتُ بِالْخَاطِئَةِۚ",
      "verse_key": "69:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فَعَصَوْا رَسُوْلَ رَبِّهِمْ فَاَخَذَهُمْ اَخْذَةً رَّابِیَةً",
      "verse_key": "69:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "اِنَّا لَمَّا طَغَا الْمَآءُ حَمَلْنٰكُمْ فِی الْجَارِیَةِۙ",
      "verse_key": "69:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "لِنَجْعَلَهَا لَكُمْ تَذْكِرَةً وَّ تَعِیَهَاۤ اُذُنٌ وَّاعِیَةٌ",
      "verse_key": "69:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "فَاِذَا نُفِخَ فِی الصُّوْرِ نَفْخَةٌ وَّاحِدَةٌۙ",
      "verse_key": "69:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَّ حُمِلَتِ الْاَرْضُ وَ الْجِبَالُ فَدُكَّتَا دَكَّةً وَّاحِدَةًۙ",
      "verse_key": "69:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "فَیَوْمَئِذٍ وَّقَعَتِ الْوَاقِعَةُۙ",
      "verse_key": "69:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "وَ انْشَقَّتِ السَّمَآءُ فَهِیَ یَوْمَئِذٍ وَّاهِیَةٌۙ",
      "verse_key": "69:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَّ الْمَلَكُ عَلٰۤى اَرْجَآئِهَا١ؕ وَ یَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ یَوْمَئِذٍ ثَمٰنِیَةٌؕ",
      "verse_key": "69:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "یَوْمَئِذٍ تُعْرَضُوْنَ لَا تَخْفٰى مِنْكُمْ خَافِیَةٌ",
      "verse_key": "69:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "فَاَمَّا مَنْ اُوْتِیَ كِتٰبَهٗ بِیَمِیْنِهٖ١ۙ فَیَقُوْلُ هَآؤُمُ اقْرَءُوْا كِتٰبِیَهْۚ",
      "verse_key": "69:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "اِنِّیْ ظَنَنْتُ اَنِّیْ مُلٰقٍ حِسَابِیَهْۚ",
      "verse_key": "69:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "فَهُوَ فِیْ عِیْشَةٍ رَّاضِیَةٍۙ",
      "verse_key": "69:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "فِیْ جَنَّةٍ عَالِیَةٍۙ",
      "verse_key": "69:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "قُطُوْفُهَا دَانِیَةٌ",
      "verse_key": "69:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "كُلُوْا وَ اشْرَبُوْا هَنِیْٓئًۢا بِمَاۤ اَسْلَفْتُمْ فِی الْاَیَّامِ الْخَالِیَةِ",
      "verse_key": "69:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "وَ اَمَّا مَنْ اُوْتِیَ كِتٰبَهٗ بِشِمَالِهٖ١ۙ۬ فَیَقُوْلُ یٰلَیْتَنِیْ لَمْ اُوْتَ كِتٰبِیَهْۚ",
      "verse_key": "69:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "وَ لَمْ اَدْرِ مَا حِسَابِیَهْۚ",
      "verse_key": "69:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "یٰلَیْتَهَا كَانَتِ الْقَاضِیَةَۚ",
      "verse_key": "69:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "مَاۤ اَغْنٰى عَنِّیْ مَالِیَهْۚ",
      "verse_key": "69:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "هَلَكَ عَنِّیْ سُلْطٰنِیَهْۚ",
      "verse_key": "69:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "خُذُوْهُ فَغُلُّوْهُۙ",
      "verse_key": "69:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "ثُمَّ الْجَحِیْمَ صَلُّوْهُۙ",
      "verse_key": "69:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "ثُمَّ فِیْ سِلْسِلَةٍ ذَرْعُهَا سَبْعُوْنَ ذِرَاعًا فَاسْلُكُوْهُؕ",
      "verse_key": "69:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "اِنَّهٗ كَانَ لَا یُؤْمِنُ بِاللّٰهِ الْعَظِیْمِۙ",
      "verse_key": "69:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "وَ لَا یَحُضُّ عَلٰى طَعَامِ الْمِسْكِیْنِؕ",
      "verse_key": "69:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "فَلَیْسَ لَهُ الْیَوْمَ هٰهُنَا حَمِیْمٌۙ",
      "verse_key": "69:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "وَّ لَا طَعَامٌ اِلَّا مِنْ غِسْلِیْنٍۙ",
      "verse_key": "69:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "لَّا یَاْكُلُهٗۤ اِلَّا الْخَاطِئُوْنَ۠",
      "verse_key": "69:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "فَلَاۤ اُقْسِمُ بِمَا تُبْصِرُوْنَۙ",
      "verse_key": "69:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "وَ مَا لَا تُبْصِرُوْنَۙ",
      "verse_key": "69:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "اِنَّهٗ لَقَوْلُ رَسُوْلٍ كَرِیْمٍۚۙ",
      "verse_key": "69:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "وَّ مَا هُوَ بِقَوْلِ شَاعِرٍ١ؕ قَلِیْلًا مَّا تُؤْمِنُوْنَۙ",
      "verse_key": "69:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "وَ لَا بِقَوْلِ كَاهِنٍ١ؕ قَلِیْلًا مَّا تَذَكَّرُوْنَؕ",
      "verse_key": "69:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "تَنْزِیْلٌ مِّنْ رَّبِّ الْعٰلَمِیْنَ",
      "verse_key": "69:43"
    },
    {
      "ayah_number": 44,
      "arabic_text": "وَ لَوْ تَقَوَّلَ عَلَیْنَا بَعْضَ الْاَقَاوِیْلِۙ",
      "verse_key": "69:44"
    },
    {
      "ayah_number": 45,
      "arabic_text": "لَاَخَذْنَا مِنْهُ بِالْیَمِیْنِۙ",
      "verse_key": "69:45"
    },
    {
      "ayah_number": 46,
      "arabic_text": "ثُمَّ لَقَطَعْنَا مِنْهُ الْوَتِیْنَ٘ۖ",
      "verse_key": "69:46"
    },
    {
      "ayah_number": 47,
      "arabic_text": "فَمَا مِنْكُمْ مِّنْ اَحَدٍ عَنْهُ حٰجِزِیْنَ",
      "verse_key": "69:47"
    },
    {
      "ayah_number": 48,
      "arabic_text": "وَ اِنَّهٗ لَتَذْكِرَةٌ لِّلْمُتَّقِیْنَ",
      "verse_key": "69:48"
    },
    {
      "ayah_number": 49,
      "arabic_text": "وَ اِنَّا لَنَعْلَمُ اَنَّ مِنْكُمْ مُّكَذِّبِیْنَ",
      "verse_key": "69:49"
    },
    {
      "ayah_number": 50,
      "arabic_text": "وَ اِنَّهٗ لَحَسْرَةٌ عَلَى الْكٰفِرِیْنَ",
      "verse_key": "69:50"
    },
    {
      "ayah_number": 51,
      "arabic_text": "وَ اِنَّهٗ لَحَقُّ الْیَقِیْنِ",
      "verse_key": "69:51"
    },
    {
      "ayah_number": 52,
      "arabic_text": "فَسَبِّحْ بِاسْمِ رَبِّكَ الْعَظِیْمِ۠",
      "verse_key": "69:52"
    }
  ]
}