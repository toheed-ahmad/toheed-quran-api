{
  "surah_id": 92,
  "surah_name": "Al-Layl",
  "arabic_name": "سُورَةُ اللَّيْلِ",
  "revelation_type": "Meccan",
  "total_ayahs": 21,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الَّیْلِ اِذَا یَغْشٰىۙ",
      "verse_key": "92:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ النَّهَارِ اِذَا تَجَلّٰىۙ",
      "verse_key": "92:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ مَا خَلَقَ الذَّكَرَ وَ الْاُنْثٰۤىۙ",
      "verse_key": "92:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "اِنَّ سَعْیَكُمْ لَشَتّٰىؕ",
      "verse_key": "92:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "فَاَمَّا مَنْ اَعْطٰى وَ اتَّقٰىۙ",
      "verse_key": "92:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَ صَدَّقَ بِالْحُسْنٰىۙ",
      "verse_key": "92:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "فَسَنُیَسِّرُهٗ لِلْیُسْرٰىؕ",
      "verse_key": "92:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ اَمَّا مَنْۢ بَخِلَ وَ اسْتَغْنٰىۙ",
      "verse_key": "92:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَ كَذَّبَ بِالْحُسْنٰىۙ",
      "verse_key": "92:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "فَسَنُیَسِّرُهٗ لِلْعُسْرٰىؕ",
      "verse_key": "92:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "وَ مَا یُغْنِیْ عَنْهُ مَالُهٗۤ اِذَا تَرَدّٰىؕ",
      "verse_key": "92:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "اِنَّ عَلَیْنَا لَلْهُدٰى٘ۖ",
      "verse_key": "92:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَ اِنَّ لَنَا لَلْاٰخِرَةَ وَ الْاُوْلٰى",
      "verse_key": "92:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "فَاَنْذَرْتُكُمْ نَارًا تَلَظّٰىۚ",
      "verse_key": "92:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "لَا یَصْلٰىهَاۤ اِلَّا الْاَشْقَىۙ",
      "verse_key": "92:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "الَّذِیْ كَذَّبَ وَ تَوَلّٰىؕ",
      "verse_key": "92:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ سَیُجَنَّبُهَا الْاَتْقَىۙ",
      "verse_key": "92:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "الَّذِیْ یُؤْتِیْ مَالَهٗ یَتَزَكّٰىۚ",
      "verse_key": "92:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "وَ مَا لِاَحَدٍ عِنْدَهٗ مِنْ نِّعْمَةٍ تُجْزٰۤىۙ",
      "verse_key": "92:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "اِلَّا ابْتِغَآءَ وَجْهِ رَبِّهِ الْاَعْلٰىۚ",
      "verse_key": "92:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَ لَسَوْفَ یَرْضٰى۠",
      "verse_key": "92:21"
    }
  ]
}