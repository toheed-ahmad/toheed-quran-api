{
  "surah_id": 52,
  "surah_name": "At-Tur",
  "arabic_name": "سُورَةُ الطُّورِ",
  "revelation_type": "Meccan",
  "total_ayahs": 49,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ الطُّوْرِۙ۝۱",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ كِتٰبٍ مَّسْطُوْرٍۙ۝۲",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "فِیْ رَقٍّ مَّنْشُوْرٍۙ۝۳",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَّ الْبَیْتِ الْمَعْمُوْرِۙ۝۴",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ السَّقْفِ الْمَرْفُوْعِۙ۝۵",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَ الْبَحْرِ الْمَسْجُوْرِۙ۝۶",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "اِنَّ عَذَابَ رَبِّكَ لَوَاقِعٌۙ۝۷",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "مَّا لَهٗ مِنْ دَافِعٍۙ۝۸",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "یَّوْمَ تَمُوْرُ السَّمَآءُ مَوْرًاۙ۝۹",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَّ تَسِیْرُ الْجِبَالُ سَیْرًاؕ۝۱۰",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "فَوَیْلٌ یَّوْمَىِٕذٍ لِّلْمُكَذِّبِیْنَۙ۝۱۱",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "الَّذِیْنَ هُمْ فِیْ خَوْضٍ یَّلْعَبُوْنَۘ۝۱۲",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "یَوْمَ یُدَعُّوْنَ اِلٰی نَارِ جَهَنَّمَ دَعًّاؕ۝۱۳",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "هٰذِهِ النَّارُ الَّتِیْ كُنْتُمْ بِهَا تُكَذِّبُوْنَ۝۱۴",
      "juz": 27,
      "page": 523,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "اَفَسِحْرٌ هٰذَاۤ اَمْ اَنْتُمْ لَا تُبْصِرُوْنَۚ۝۱۵",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "اِصْلَوْهَا فَاصْبِرُوْۤا اَوْ لَا تَصْبِرُوْا ۚ سَوَآءٌ عَلَیْكُمْ ؕ اِنَّمَا تُجْزَوْنَ مَا كُنْتُمْ تَعْمَلُوْنَ۝۱۶",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "اِنَّ الْمُتَّقِیْنَ فِیْ جَنّٰتٍ وَّ نَعِیْمٍۙ۝۱۷",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "فٰكِهِیْنَ بِمَاۤ اٰتٰىهُمْ رَبُّهُمْ ۚ وَ وَقٰىهُمْ رَبُّهُمْ عَذَابَ الْجَحِیْمِ۝۱۸",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "كُلُوْا وَ اشْرَبُوْا هَنِیْٓـًٔۢا بِمَا كُنْتُمْ تَعْمَلُوْنَۙ۝۱۹",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "مُتَّكِـِٕیْنَ عَلٰی سُرُرٍ مَّصْفُوْفَةٍ ۚ وَ زَوَّجْنٰهُمْ بِحُوْرٍ عِیْنٍ۝۲۰",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَ الَّذِیْنَ اٰمَنُوْا وَ اتَّبَعَتْهُمْ ذُرِّیَّتُهُمْ بِاِیْمَانٍ اَلْحَقْنَا بِهِمْ ذُرِّیَّتَهُمْ وَ مَاۤ اَلَتْنٰهُمْ مِّنْ عَمَلِهِمْ مِّنْ شَیْءٍ ؕ كُلُّ امْرِئٍۭ بِمَا كَسَبَ رَهِیْنٌ۝۲۱",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "وَ اَمْدَدْنٰهُمْ بِفَاكِهَةٍ وَّ لَحْمٍ مِّمَّا یَشْتَهُوْنَ۝۲۲",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "یَتَنَازَعُوْنَ فِیْهَا كَاْسًا لَّا لَغْوٌ فِیْهَا وَ لَا تَاْثِیْمٌ۝۲۳",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 209,
      "sajdah": false,
      "verse_key": "52:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "وَ یَطُوْفُ عَلَیْهِمْ غِلْمَانٌ لَّهُمْ كَاَنَّهُمْ لُؤْلُؤٌ مَّكْنُوْنٌ۝۲۴",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "وَ اَقْبَلَ بَعْضُهُمْ عَلٰی بَعْضٍ یَّتَسَآءَلُوْنَ۝۲۵",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:25"
    },
    {
      "ayah_number": 26,
      "arabic_text": "قَالُوْۤا اِنَّا كُنَّا قَبْلُ فِیْۤ اَهْلِنَا مُشْفِقِیْنَ۝۲۶",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:26"
    },
    {
      "ayah_number": 27,
      "arabic_text": "فَمَنَّ اللّٰهُ عَلَیْنَا وَ وَقٰىنَا عَذَابَ السَّمُوْمِ۝۲۷",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:27"
    },
    {
      "ayah_number": 28,
      "arabic_text": "اِنَّا كُنَّا مِنْ قَبْلُ نَدْعُوْهُ ؕ اِنَّهٗ هُوَ الْبَرُّ الرَّحِیْمُ۠۝۲۸",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 458,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "فَذَكِّرْ فَمَاۤ اَنْتَ بِنِعْمَتِ رَبِّكَ بِكَاهِنٍ وَّ لَا مَجْنُوْنٍؕ۝۲۹",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "اَمْ یَقُوْلُوْنَ شَاعِرٌ نَّتَرَبَّصُ بِهٖ رَیْبَ الْمَنُوْنِ۝۳۰",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:30"
    },
    {
      "ayah_number": 31,
      "arabic_text": "قُلْ تَرَبَّصُوْا فَاِنِّیْ مَعَكُمْ مِّنَ الْمُتَرَبِّصِیْنَؕ۝۳۱",
      "juz": 27,
      "page": 524,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:31"
    },
    {
      "ayah_number": 32,
      "arabic_text": "اَمْ تَاْمُرُهُمْ اَحْلَامُهُمْ بِهٰذَاۤ اَمْ هُمْ قَوْمٌ طَاغُوْنَۚ۝۳۲",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:32"
    },
    {
      "ayah_number": 33,
      "arabic_text": "اَمْ یَقُوْلُوْنَ تَقَوَّلَهٗ ۚ بَلْ لَّا یُؤْمِنُوْنَۚ۝۳۳",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:33"
    },
    {
      "ayah_number": 34,
      "arabic_text": "فَلْیَاْتُوْا بِحَدِیْثٍ مِّثْلِهٖۤ اِنْ كَانُوْا صٰدِقِیْنَؕ۝۳۴",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:34"
    },
    {
      "ayah_number": 35,
      "arabic_text": "اَمْ خُلِقُوْا مِنْ غَیْرِ شَیْءٍ اَمْ هُمُ الْخٰلِقُوْنَؕ۝۳۵",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:35"
    },
    {
      "ayah_number": 36,
      "arabic_text": "اَمْ خَلَقُوا السَّمٰوٰتِ وَ الْاَرْضَ ۚ بَلْ لَّا یُوْقِنُوْنَؕ۝۳۶",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:36"
    },
    {
      "ayah_number": 37,
      "arabic_text": "اَمْ عِنْدَهُمْ خَزَآىِٕنُ رَبِّكَ اَمْ هُمُ الْمُصَۜیْطِرُوْنَؕ۝۳۷",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:37"
    },
    {
      "ayah_number": 38,
      "arabic_text": "اَمْ لَهُمْ سُلَّمٌ یَّسْتَمِعُوْنَ فِیْهِ ۚ فَلْیَاْتِ مُسْتَمِعُهُمْ بِسُلْطٰنٍ مُّبِیْنٍؕ۝۳۸",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:38"
    },
    {
      "ayah_number": 39,
      "arabic_text": "اَمْ لَهُ الْبَنٰتُ وَ لَكُمُ الْبَنُوْنَؕ۝۳۹",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "اَمْ تَسْـَٔلُهُمْ اَجْرًا فَهُمْ مِّنْ مَّغْرَمٍ مُّثْقَلُوْنَؕ۝۴۰",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:40"
    },
    {
      "ayah_number": 41,
      "arabic_text": "اَمْ عِنْدَهُمُ الْغَیْبُ فَهُمْ یَكْتُبُوْنَؕ۝۴۱",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:41"
    },
    {
      "ayah_number": 42,
      "arabic_text": "اَمْ یُرِیْدُوْنَ كَیْدًا ؕ فَالَّذِیْنَ كَفَرُوْا هُمُ الْمَكِیْدُوْنَؕ۝۴۲",
      "juz": 27,
      "page": 525,
      "manzil": 7,
      "ruku": 459,
      "hizb": 53,
      "hizbQuarter": 210,
      "sajdah": false,
      "verse_key": "52:42"
    },
    {
      "ayah_number": 43,
      "arabic_text": "اَمْ لَهُمْ اِلٰهٌ غَیْرُ اللّٰهِ ؕ سُبْحٰنَ اللّٰهِ عَمَّا یُشْرِكُوْنَ۝۴۳",
      "juz": 27,
      "page": 525,
      "manzil": 7,
