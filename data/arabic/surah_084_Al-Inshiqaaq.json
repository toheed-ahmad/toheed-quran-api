{
  "surah_id": 84,
  "surah_name": "Al-Inshiqaaq",
  "arabic_name": "سُورَةُ الانشِقَاقِ",
  "revelation_type": "Meccan",
  "total_ayahs": 25,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِیْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "اِذَا السَّمَآءُ انْشَقَّتْۙ۝۱",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ اَذِنَتْ لِرَبِّهَا وَ حُقَّتْۙ۝۲",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ اِذَا الْاَرْضُ مُدَّتْۙ۝۳",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ اَلْقَتْ مَا فِیْهَا وَ تَخَلَّتْۙ۝۴",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ اَذِنَتْ لِرَبِّهَا وَ حُقَّتْؕ۝۵",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "یٰۤاَیُّهَا الْاِنْسَانُ اِنَّكَ كَادِحٌ اِلٰی رَبِّكَ كَدْحًا فَمُلٰقِیْهِۚ۝۶",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "فَاَمَّا مَنْ اُوْتِیَ كِتٰبَهٗ بِیَمِیْنِهٖۙ۝۷",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "فَسَوْفَ یُحَاسَبُ حِسَابًا یَّسِیْرًاۙ۝۸",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "وَّ یَنْقَلِبُ اِلٰۤی اَهْلِهٖ مَسْرُوْرًاؕ۝۹",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "وَ اَمَّا مَنْ اُوْتِیَ كِتٰبَهٗ وَرَآءَ ظَهْرِهٖۙ۝۱۰",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "فَسَوْفَ یَدْعُوْا ثُبُوْرًاۙ۝۱۱",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَّ یَصْلٰی سَعِیْرًاؕ۝۱۲",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "اِنَّهٗ كَانَ فِیْۤ اَهْلِهٖ مَسْرُوْرًاؕ۝۱۳",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "اِنَّهٗ ظَنَّ اَنْ لَّنْ یَّحُوْرَۚۛ۝۱۴",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "بَلٰۤی ۛۚ اِنَّ رَبَّهٗ كَانَ بِهٖ بَصِیْرًاؕ۝۱۵",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "فَلَاۤ اُقْسِمُ بِالشَّفَقِۙ۝۱۶",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "وَ الَّیْلِ وَ مَا وَسَقَۙ۝۱۷",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "وَ الْقَمَرِ اِذَا اتَّسَقَۙ۝۱۸",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍؕ۝۱۹",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "فَمَا لَهُمْ لَا یُؤْمِنُوْنَۙ۝۲۰",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "وَ اِذَا قُرِئَ عَلَیْهِمُ الْقُرْاٰنُ لَا یَسْجُدُوْنَؕ۩۝۲۱",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "بَلِ الَّذِیْنَ كَفَرُوْا یُكَذِّبُوْنَؗۖ۝۲۲",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "وَ اللّٰهُ اَعْلَمُ بِمَا یُوْعُوْنَؗۖ۝۲۳",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "فَبَشِّرْهُمْ بِعَذَابٍ اَلِیْمٍۙ۝۲۴",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اِلَّا الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ لَهُمْ اَجْرٌ غَیْرُ مَمْنُوْنٍ۠۝۲۵",
      "juz": 30,
      "page": 589,
      "manzil": 7,
      "ruku": 526,
      "hizb": 59,
      "hizbQuarter": 236,
      "sajdah": false,
      "verse_key": "84:25"
    }
  ]
}