{
  "surah_id": 85,
  "surah_name": "Al-Buruj",
  "arabic_name": "سُورَةُ الْبُرُوجِ",
  "revelation_type": "Meccan",
  "total_ayahs": 22,
  "bismillah": "بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ",
  "content": [
    {
      "ayah_number": 1,
      "arabic_text": "وَ السَّمَآءِ ذَاتِ الْبُرُوْجِۙ",
      "verse_key": "85:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "وَ الْیَوْمِ الْمَوْعُوْدِۙ",
      "verse_key": "85:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ شَاهِدٍ وَّ مَشْهُوْدٍؕ",
      "verse_key": "85:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "قُتِلَ اَصْحٰبُ الْاُخْدُوْدِۙ",
      "verse_key": "85:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "النَّارِ ذَاتِ الْوَقُوْدِۙ",
      "verse_key": "85:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "اِذْ هُمْ عَلَیْهَا قُعُوْدٌۙ",
      "verse_key": "85:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَّ هُمْ عَلٰى مَا یَفْعَلُوْنَ بِالْمُؤْمِنِیْنَ شُهُوْدٌؕ",
      "verse_key": "85:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "وَ مَا نَقَمُوْا مِنْهُمْ اِلَّاۤ اَنْ یُّؤْمِنُوْا بِاللّٰهِ الْعَزِیْزِ الْحَمِیْدِۙ",
      "verse_key": "85:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "الَّذِیْ لَهٗ مُلْكُ السَّمٰوٰتِ وَ الْاَرْضِ١ؕ وَ اللّٰهُ عَلٰى كُلِّ شَیْءٍ شَهِیْدٌؕ",
      "verse_key": "85:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "اِنَّ الَّذِیْنَ فَتَنُوا الْمُؤْمِنِیْنَ وَ الْمُؤْمِنٰتِ ثُمَّ لَمْ یَتُوْبُوْا فَلَهُمْ عَذَابُ جَهَنَّمَ وَ لَهُمْ عَذَابُ الْحَرِیْقِؕ",
      "verse_key": "85:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "اِنَّ الَّذِیْنَ اٰمَنُوْا وَ عَمِلُوا الصّٰلِحٰتِ لَهُمْ جَنّٰتٌ تَجْرِیْ مِنْ تَحْتِهَا الْاَنْهٰرُ١ۣؕ۬ ذٰلِكَ الْفَوْزُ الْكَبِیْرُؕ",
      "verse_key": "85:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "اِنَّ بَطْشَ رَبِّكَ لَشَدِیْدٌؕ",
      "verse_key": "85:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "اِنَّهٗ هُوَ یُبْدِئُ وَ یُعِیْدُۚ",
      "verse_key": "85:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَ هُوَ الْغَفُوْرُ الْوَدُوْدُۙ",
      "verse_key": "85:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "ذُو الْعَرْشِ الْمَجِیْدُۙ",
      "verse_key": "85:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "فَعَّالٌ لِّمَا یُرِیْدُؕ",
      "verse_key": "85:16"
    },
    {
      "ayah_number": 17,
      "arabic_text": "هَلْ اَتٰىكَ حَدِیْثُ الْجُنُوْدِۙ",
      "verse_key": "85:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "فِرْعَوْنَ وَ ثَمُوْدَؕ",
      "verse_key": "85:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "بَلِ الَّذِیْنَ كَفَرُوْا فِیْ تَكْذِیْبٍۙ",
      "verse_key": "85:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "وَّ اللّٰهُ مِنْ وَّرَآئِهِمْ مُّحِیْطٌۚ",
      "verse_key": "85:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "بَلْ هُوَ قُرْاٰنٌ مَّجِیْدٌۙ",
      "verse_key": "85:21"
    },
    {
      "ayah_number": 22,
      "arabic_text": "فِیْ لَوْحٍ مَّحْفُوْظٍ۠",
      "verse_key": "85:22"
    }
  ]
}