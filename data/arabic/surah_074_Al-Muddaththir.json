      "page": 576,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:18"
    },
    {
      "ayah_number": 19,
      "arabic_text": "فَقُتِلَ كَیْفَ قَدَّرَۙ۝۱۹",
      "juz": 29,
      "page": 576,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:19"
    },
    {
      "ayah_number": 20,
      "arabic_text": "ثُمَّ قُتِلَ كَیْفَ قَدَّرَۙ۝۲۰",
      "juz": 29,
      "page": 576,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:20"
    },
    {
      "ayah_number": 21,
      "arabic_text": "ثُمَّ نَظَرَۙ۝۲۱",
      "juz": 29,
      "page": 576,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:21"
    },
    {
      "ayah_number": 22,
