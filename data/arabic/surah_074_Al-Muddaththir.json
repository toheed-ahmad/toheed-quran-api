      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:17"
    },
    {
      "ayah_number": 18,
      "arabic_text": "اِنَّهٗ فَكَّرَ وَ قَدَّرَۙ۝۱۸",
