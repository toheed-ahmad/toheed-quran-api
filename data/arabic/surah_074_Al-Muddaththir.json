      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:29"
    },
    {
      "ayah_number": 30,
      "arabic_text": "عَلَیْهَا تِسْعَةَ عَشَرَؕ۝۳۰",
