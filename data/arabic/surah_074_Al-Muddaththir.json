      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:24"
    },
    {
      "ayah_number": 25,
      "arabic_text": "اِنْ هٰذَاۤ اِلَّا قَوْلُ الْبَشَرِؕ۝۲۵",
