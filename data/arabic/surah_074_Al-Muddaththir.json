      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:4"
    },
    {
      "ayah_number": 5,
      "arabic_text": "وَ الرُّجْزَ فَاهْجُرْ۪ۙ۝۵",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:5"
    },
    {
      "ayah_number": 6,
      "arabic_text": "وَ لَا تَمْنُنْ تَسْتَكْثِرُ۪ۙ۝۶",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:6"
    },
    {
      "ayah_number": 7,
      "arabic_text": "وَ لِرَبِّكَ فَاصْبِرْؕ۝۷",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:7"
    },
    {
      "ayah_number": 8,
      "arabic_text": "فَاِذَا نُقِرَ فِی النَّاقُوْرِۙ۝۸",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:8"
    },
    {
      "ayah_number": 9,
      "arabic_text": "فَذٰلِكَ یَوْمَىِٕذٍ یَّوْمٌ عَسِیْرٌۙ۝۹",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:9"
    },
    {
      "ayah_number": 10,
      "arabic_text": "عَلَی الْكٰفِرِیْنَ غَیْرُ یَسِیْرٍ۝۱۰",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:10"
    },
    {
      "ayah_number": 11,
      "arabic_text": "ذَرْنِیْ وَ مَنْ خَلَقْتُ وَحِیْدًاۙ۝۱۱",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:11"
    },
    {
      "ayah_number": 12,
      "arabic_text": "وَّ جَعَلْتُ لَهٗ مَالًا مَّمْدُوْدًاۙ۝۱۲",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:12"
    },
    {
      "ayah_number": 13,
      "arabic_text": "وَّ بَنِیْنَ شُهُوْدًاۙ۝۱۳",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:13"
    },
    {
      "ayah_number": 14,
      "arabic_text": "وَّ مَهَّدْتُّ لَهٗ تَمْهِیْدًاۙ۝۱۴",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:14"
    },
    {
      "ayah_number": 15,
      "arabic_text": "ثُمَّ یَطْمَعُ اَنْ اَزِیْدَۗۙ۝۱۵",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:15"
    },
    {
      "ayah_number": 16,
      "arabic_text": "كَلَّا ؕ اِنَّهٗ كَانَ لِاٰیٰتِنَا عَنِیْدًاؕ۝۱۶",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:16"
    },
    {
