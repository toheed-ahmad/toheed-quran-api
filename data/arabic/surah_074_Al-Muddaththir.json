      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:1"
    },
    {
      "ayah_number": 2,
      "arabic_text": "قُمْ فَاَنْذِرْ۪ۙ۝۲",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:2"
    },
    {
      "ayah_number": 3,
      "arabic_text": "وَ رَبَّكَ فَكَبِّرْ۪ۙ۝۳",
      "juz": 29,
      "page": 575,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:3"
    },
    {
      "ayah_number": 4,
      "arabic_text": "وَ ثِیَابَكَ فَطَهِّرْ۪ۙ۝۴",
