      "page": 576,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:28"
    },
    {
      "ayah_number": 29,
      "arabic_text": "لَوَّاحَةٌ لِّلْبَشَرِۚۖ۝۲۹",
