      "page": 576,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:22"
    },
    {
      "ayah_number": 23,
      "arabic_text": "ثُمَّ اَدْبَرَ وَ اسْتَكْبَرَۙ۝۲۳",
      "juz": 29,
      "page": 576,
      "manzil": 7,
      "ruku": 510,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:23"
    },
    {
      "ayah_number": 24,
      "arabic_text": "فَقَالَ اِنْ هٰذَاۤ اِلَّا سِحْرٌ یُّؤْثَرُۙ۝۲۴",
