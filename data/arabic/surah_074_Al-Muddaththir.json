      "ruku": 511,
      "hizb": 58,
      "hizbQuarter": 230,
      "sajdah": false,
      "verse_key": "74:39"
    },
    {
      "ayah_number": 40,
      "arabic_text": "فِیْ جَنّٰتٍ ۛؕ۫ یَتَسَآءَلُوْنَۙ۝۴۰",
