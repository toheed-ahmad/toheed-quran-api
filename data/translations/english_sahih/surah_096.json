{
  "number": 96,
  "name": "Al-Alaq",
  "arabicName": "سُورَةُ العَلَقِ",
  "revelationType": "Meccan",
  "totalAyahs": 19,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "Recite in the name of your Lord who created -",
      "ayah_number": 1,
      "verse_key": "96:1"
    },
    {
      "number": 2,
      "text": "Created man from a clinging substance.",
      "ayah_number": 2,
      "verse_key": "96:2"
    },
    {
      "number": 3,
      "text": "Recite, and your Lord is the most Generous -",
      "ayah_number": 3,
      "verse_key": "96:3"
    },
    {
      "number": 4,
      "text": "Who taught by the pen -",
      "ayah_number": 4,
      "verse_key": "96:4"
    },
    {
      "number": 5,
      "text": "Taught man that which he knew not.",
      "ayah_number": 5,
      "verse_key": "96:5"
    },
    {
      "number": 6,
      "text": "No! [But] indeed, man transgresses",
      "ayah_number": 6,
      "verse_key": "96:6"
    },
    {
      "number": 7,
      "text": "Because he sees himself self-sufficient.",
      "ayah_number": 7,
      "verse_key": "96:7"
    },
    {
      "number": 8,
      "text": "Indeed, to your Lord is the return.",
      "ayah_number": 8,
      "verse_key": "96:8"
    },
    {
      "number": 9,
      "text": "Have you seen the one who forbids",
      "ayah_number": 9,
      "verse_key": "96:9"
    },
    {
      "number": 10,
      "text": "A servant when he prays?",
      "ayah_number": 10,
      "verse_key": "96:10"
    },
    {
      "number": 11,
      "text": "Have you seen if he is upon guidance",
      "ayah_number": 11,
      "verse_key": "96:11"
    },
    {
      "number": 12,
      "text": "Or enjoins righteousness?",
      "ayah_number": 12,
      "verse_key": "96:12"
    },
    {
      "number": 13,
      "text": "Have you seen if he denies and turns away -",
      "ayah_number": 13,
      "verse_key": "96:13"
    },
    {
      "number": 14,
      "text": "Does he not know that Allah sees?",
      "ayah_number": 14,
      "verse_key": "96:14"
    },
    {
      "number": 15,
      "text": "No! If he does not desist, We will surely drag him by the forelock -",
      "ayah_number": 15,
      "verse_key": "96:15"
    },
    {
      "number": 16,
      "text": "A lying, sinning forelock.",
      "ayah_number": 16,
      "verse_key": "96:16"
    },
    {
      "number": 17,
      "text": "Then let him call his associates;",
      "ayah_number": 17,
      "verse_key": "96:17"
    },
    {
      "number": 18,
      "text": "We will call the angels of Hell.",
      "ayah_number": 18,
      "verse_key": "96:18"
    },
    {
      "number": 19,
      "text": "No! Do not obey him. But prostrate and draw near [to Allah].",
      "ayah_number": 19,
      "verse_key": "96:19"
    }
  ]
}