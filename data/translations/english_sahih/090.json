{
  "number": 90,
  "name": "Al-Balad",
  "arabicName": "سُورَةُ البَلَدِ",
  "revelationType": "Meccan",
  "totalAyahs": 20,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "I swear by this city, Makkah -",
      "ayah_number": 1,
      "verse_key": "90:1"
    },
    {
      "number": 2,
      "text": "And you, [O Muhammad], are free of restriction in this city -",
      "ayah_number": 2,
      "verse_key": "90:2"
    },
    {
      "number": 3,
      "text": "And [by] the father and that which was born [of him],",
      "ayah_number": 3,
      "verse_key": "90:3"
    },
    {
      "number": 4,
      "text": "We have certainly created man into hardship.",
      "ayah_number": 4,
      "verse_key": "90:4"
    },
    {
      "number": 5,
      "text": "Does he think that never will anyone overcome him?",
      "ayah_number": 5,
      "verse_key": "90:5"
    },
    {
      "number": 6,
      "text": "He says, \"I have spent wealth in abundance.\"",
      "ayah_number": 6,
      "verse_key": "90:6"
    },
    {
      "number": 7,
      "text": "Does he think that no one has seen him?",
      "ayah_number": 7,
      "verse_key": "90:7"
    },
    {
      "number": 8,
      "text": "Have We not made for him two eyes?",
      "ayah_number": 8,
      "verse_key": "90:8"
    },
    {
      "number": 9,
      "text": "And a tongue and two lips?",
      "ayah_number": 9,
      "verse_key": "90:9"
    },
    {
      "number": 10,
      "text": "And have shown him the two ways?",
      "ayah_number": 10,
      "verse_key": "90:10"
    },
    {
      "number": 11,
      "text": "But he has not broken through the difficult pass.",
      "ayah_number": 11,
      "verse_key": "90:11"
    },
    {
      "number": 12,
      "text": "And what can make you know what is [breaking through] the difficult pass?",
      "ayah_number": 12,
      "verse_key": "90:12"
    },
    {
      "number": 13,
      "text": "It is the freeing of a slave",
      "ayah_number": 13,
      "verse_key": "90:13"
    },
    {
      "number": 14,
      "text": "Or feeding on a day of severe hunger",
      "ayah_number": 14,
      "verse_key": "90:14"
    },
    {
      "number": 15,
      "text": "An orphan of near relationship",
      "ayah_number": 15,
      "verse_key": "90:15"
    },
    {
      "number": 16,
      "text": "Or a needy person in misery",
      "ayah_number": 16,
      "verse_key": "90:16"
    },
    {
      "number": 17,
      "text": "And then being among those who believed and advised one another to patience and advised one another to compassion.",
      "ayah_number": 17,
      "verse_key": "90:17"
    },
    {
      "number": 18,
      "text": "Those are the companions of the right.",
      "ayah_number": 18,
      "verse_key": "90:18"
    },
    {
      "number": 19,
      "text": "But they who disbelieved in Our signs - those are the companions of the left.",
      "ayah_number": 19,
      "verse_key": "90:19"
    },
    {
      "number": 20,
      "text": "Over them will be fire closed in.",
      "ayah_number": 20,
      "verse_key": "90:20"
    }
  ]
}