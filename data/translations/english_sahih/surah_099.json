{
  "number": 99,
  "name": "Az-Zalzala",
  "arabicName": "سُورَةُ الزَّلۡزَلَةِ",
  "revelationType": "Medinan",
  "totalAyahs": 8,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "When the earth is shaken with its [final] earthquake",
      "ayah_number": 1,
      "verse_key": "99:1"
    },
    {
      "number": 2,
      "text": "And the earth discharges its burdens",
      "ayah_number": 2,
      "verse_key": "99:2"
    },
    {
      "number": 3,
      "text": "And man says, \"What is [wrong] with it?\" -",
      "ayah_number": 3,
      "verse_key": "99:3"
    },
    {
      "number": 4,
      "text": "That Day, it will report its news",
      "ayah_number": 4,
      "verse_key": "99:4"
    },
    {
      "number": 5,
      "text": "Because your Lord has commanded it.",
      "ayah_number": 5,
      "verse_key": "99:5"
    },
    {
      "number": 6,
      "text": "That Day, the people will depart separated [into categories] to be shown [the result of] their deeds.",
      "ayah_number": 6,
      "verse_key": "99:6"
    },
    {
      "number": 7,
      "text": "So whoever does an atom's weight of good will see it,",
      "ayah_number": 7,
      "verse_key": "99:7"
    },
    {
      "number": 8,
      "text": "And whoever does an atom's weight of evil will see it.",
      "ayah_number": 8,
      "verse_key": "99:8"
    }
  ]
}