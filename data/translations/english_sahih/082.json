{
  "number": 82,
  "name": "Al-Infitaar",
  "arabicName": "سُورَةُ الانفِطَارِ",
  "revelationType": "Meccan",
  "totalAyahs": 19,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "When the sky breaks apart",
      "ayah_number": 1,
      "verse_key": "82:1"
    },
    {
      "number": 2,
      "text": "And when the stars fall, scattering,",
      "ayah_number": 2,
      "verse_key": "82:2"
    },
    {
      "number": 3,
      "text": "And when the seas are erupted",
      "ayah_number": 3,
      "verse_key": "82:3"
    },
    {
      "number": 4,
      "text": "And when the [contents of] graves are scattered,",
      "ayah_number": 4,
      "verse_key": "82:4"
    },
    {
      "number": 5,
      "text": "A soul will [then] know what it has put forth and kept back.",
      "ayah_number": 5,
      "verse_key": "82:5"
    },
    {
      "number": 6,
      "text": "O mankind, what has deceived you concerning your Lord, the Generous,",
      "ayah_number": 6,
      "verse_key": "82:6"
    },
    {
      "number": 7,
      "text": "Who created you, proportioned you, and balanced you?",
      "ayah_number": 7,
      "verse_key": "82:7"
    },
    {
      "number": 8,
      "text": "In whatever form He willed has He assembled you.",
      "ayah_number": 8,
      "verse_key": "82:8"
    },
    {
      "number": 9,
      "text": "No! But you deny the Recompense.",
      "ayah_number": 9,
      "verse_key": "82:9"
    },
    {
      "number": 10,
      "text": "And indeed, [appointed] over you are keepers,",
      "ayah_number": 10,
      "verse_key": "82:10"
    },
    {
      "number": 11,
      "text": "Noble and recording;",
      "ayah_number": 11,
      "verse_key": "82:11"
    },
    {
      "number": 12,
      "text": "They know whatever you do.",
      "ayah_number": 12,
      "verse_key": "82:12"
    },
    {
      "number": 13,
      "text": "Indeed, the righteous will be in pleasure,",
      "ayah_number": 13,
      "verse_key": "82:13"
    },
    {
      "number": 14,
      "text": "And indeed, the wicked will be in Hellfire.",
      "ayah_number": 14,
      "verse_key": "82:14"
    },
    {
      "number": 15,
      "text": "They will [enter to] burn therein on the Day of Recompense,",
      "ayah_number": 15,
      "verse_key": "82:15"
    },
    {
      "number": 16,
      "text": "And never therefrom will they be absent.",
      "ayah_number": 16,
      "verse_key": "82:16"
    },
    {
      "number": 17,
      "text": "And what can make you know what is the Day of Recompense?",
      "ayah_number": 17,
      "verse_key": "82:17"
    },
    {
      "number": 18,
      "text": "Then, what can make you know what is the Day of Recompense?",
      "ayah_number": 18,
      "verse_key": "82:18"
    },
    {
      "number": 19,
      "text": "It is the Day when a soul will not possess for another soul [power to do] a thing; and the command, that Day, is [entirely] with Allah.",
      "ayah_number": 19,
      "verse_key": "82:19"
    }
  ]
}