{
  "number": 111,
  "name": "Al-Masad",
  "arabicName": "سُورَةُ المَسَدِ",
  "revelationType": "Meccan",
  "totalAyahs": 5,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "May the hands of Abu Lahab be ruined, and ruined is he.",
      "ayah_number": 1,
      "verse_key": "111:1"
    },
    {
      "number": 2,
      "text": "His wealth will not avail him or that which he gained.",
      "ayah_number": 2,
      "verse_key": "111:2"
    },
    {
      "number": 3,
      "text": "He will [enter to] burn in a Fire of [blazing] flame",
      "ayah_number": 3,
      "verse_key": "111:3"
    },
    {
      "number": 4,
      "text": "And his wife [as well] - the carrier of firewood.",
      "ayah_number": 4,
      "verse_key": "111:4"
    },
    {
      "number": 5,
      "text": "Around her neck is a rope of [twisted] fiber.",
      "ayah_number": 5,
      "verse_key": "111:5"
    }
  ]
}