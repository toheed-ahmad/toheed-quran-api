{
  "number": 88,
  "name": "Al-Ghaashiya",
  "arabicName": "سُورَةُ الغَاشِيَةِ",
  "revelationType": "Meccan",
  "totalAyahs": 26,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "Has there reached you the report of the Overwhelming [event]?",
      "ayah_number": 1,
      "verse_key": "88:1"
    },
    {
      "number": 2,
      "text": "[Some] faces, that Day, will be humbled,",
      "ayah_number": 2,
      "verse_key": "88:2"
    },
    {
      "number": 3,
      "text": "Working [hard] and exhausted.",
      "ayah_number": 3,
      "verse_key": "88:3"
    },
    {
      "number": 4,
      "text": "They will [enter to] burn in an intensely hot Fire.",
      "ayah_number": 4,
      "verse_key": "88:4"
    },
    {
      "number": 5,
      "text": "They will be given drink from a boiling spring.",
      "ayah_number": 5,
      "verse_key": "88:5"
    },
    {
      "number": 6,
      "text": "For them there will be no food except from a poisonous, thorny plant",
      "ayah_number": 6,
      "verse_key": "88:6"
    },
    {
      "number": 7,
      "text": "Which neither nourishes nor avails against hunger.",
      "ayah_number": 7,
      "verse_key": "88:7"
    },
    {
      "number": 8,
      "text": "[Other] faces, that Day, will show pleasure.",
      "ayah_number": 8,
      "verse_key": "88:8"
    },
    {
      "number": 9,
      "text": "With their effort [they are] satisfied",
      "ayah_number": 9,
      "verse_key": "88:9"
    },
    {
      "number": 10,
      "text": "In an elevated garden,",
      "ayah_number": 10,
      "verse_key": "88:10"
    },
    {
      "number": 11,
      "text": "Wherein they will hear no unsuitable speech.",
      "ayah_number": 11,
      "verse_key": "88:11"
    },
    {
      "number": 12,
      "text": "Within it is a flowing spring.",
      "ayah_number": 12,
      "verse_key": "88:12"
    },
    {
      "number": 13,
      "text": "Within it are couches raised high",
      "ayah_number": 13,
      "verse_key": "88:13"
    },
    {
      "number": 14,
      "text": "And cups put in place",
      "ayah_number": 14,
      "verse_key": "88:14"
    },
    {
      "number": 15,
      "text": "And cushions lined up",
      "ayah_number": 15,
      "verse_key": "88:15"
    },
    {
      "number": 16,
      "text": "And carpets spread around.",
      "ayah_number": 16,
      "verse_key": "88:16"
    },
    {
      "number": 17,
      "text": "Then do they not look at the camels - how they are created?",
      "ayah_number": 17,
      "verse_key": "88:17"
    },
    {
      "number": 18,
      "text": "And at the sky - how it is raised?",
      "ayah_number": 18,
      "verse_key": "88:18"
    },
    {
      "number": 19,
      "text": "And at the mountains - how they are erected?",
      "ayah_number": 19,
      "verse_key": "88:19"
    },
    {
      "number": 20,
      "text": "And at the earth - how it is spread out?",
      "ayah_number": 20,
      "verse_key": "88:20"
    },
    {
      "number": 21,
      "text": "So remind, [O Muhammad]; you are only a reminder.",
      "ayah_number": 21,
      "verse_key": "88:21"
    },
    {
      "number": 22,
      "text": "You are not over them a controller.",
      "ayah_number": 22,
      "verse_key": "88:22"
    },
    {
      "number": 23,
      "text": "However, he who turns away and disbelieves -",
      "ayah_number": 23,
      "verse_key": "88:23"
    },
    {
      "number": 24,
      "text": "Then Allah will punish him with the greatest punishment.",
      "ayah_number": 24,
      "verse_key": "88:24"
    },
    {
      "number": 25,
      "text": "Indeed, to Us is their return.",
      "ayah_number": 25,
      "verse_key": "88:25"
    },
    {
      "number": 26,
      "text": "Then indeed, upon Us is their account.",
      "ayah_number": 26,
      "verse_key": "88:26"
    }
  ]
}