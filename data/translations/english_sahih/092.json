{
  "number": 92,
  "name": "Al-Lail",
  "arabicName": "سُورَةُ اللَّيۡلِ",
  "revelationType": "Meccan",
  "totalAyahs": 21,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "By the night when it covers",
      "ayah_number": 1,
      "verse_key": "92:1"
    },
    {
      "number": 2,
      "text": "And [by] the day when it appears",
      "ayah_number": 2,
      "verse_key": "92:2"
    },
    {
      "number": 3,
      "text": "And [by] He who created the male and female,",
      "ayah_number": 3,
      "verse_key": "92:3"
    },
    {
      "number": 4,
      "text": "Indeed, your efforts are diverse.",
      "ayah_number": 4,
      "verse_key": "92:4"
    },
    {
      "number": 5,
      "text": "As for he who gives and fears Allah",
      "ayah_number": 5,
      "verse_key": "92:5"
    },
    {
      "number": 6,
      "text": "And believes in the best [reward],",
      "ayah_number": 6,
      "verse_key": "92:6"
    },
    {
      "number": 7,
      "text": "We will ease him toward ease.",
      "ayah_number": 7,
      "verse_key": "92:7"
    },
    {
      "number": 8,
      "text": "But as for he who withholds and considers himself free of need",
      "ayah_number": 8,
      "verse_key": "92:8"
    },
    {
      "number": 9,
      "text": "And denies the best [reward],",
      "ayah_number": 9,
      "verse_key": "92:9"
    },
    {
      "number": 10,
      "text": "We will ease him toward difficulty.",
      "ayah_number": 10,
      "verse_key": "92:10"
    },
    {
      "number": 11,
      "text": "And what will his wealth avail him when he falls?",
      "ayah_number": 11,
      "verse_key": "92:11"
    },
    {
      "number": 12,
      "text": "Indeed, [incumbent] upon Us is guidance.",
      "ayah_number": 12,
      "verse_key": "92:12"
    },
    {
      "number": 13,
      "text": "And indeed, to Us belongs the Hereafter and the first [life].",
      "ayah_number": 13,
      "verse_key": "92:13"
    },
    {
      "number": 14,
      "text": "So I have warned you of a Fire which is blazing.",
      "ayah_number": 14,
      "verse_key": "92:14"
    },
    {
      "number": 15,
      "text": "None will [enter to] burn therein except the most wretched one.",
      "ayah_number": 15,
      "verse_key": "92:15"
    },
    {
      "number": 16,
      "text": "Who had denied and turned away.",
      "ayah_number": 16,
      "verse_key": "92:16"
    },
    {
      "number": 17,
      "text": "But the righteous one will avoid it -",
      "ayah_number": 17,
      "verse_key": "92:17"
    },
    {
      "number": 18,
      "text": "[He] who gives [from] his wealth to purify himself",
      "ayah_number": 18,
      "verse_key": "92:18"
    },
    {
      "number": 19,
      "text": "And not [giving] for anyone who has [done him] a favor to be rewarded",
      "ayah_number": 19,
      "verse_key": "92:19"
    },
    {
      "number": 20,
      "text": "But only seeking the countenance of his Lord, Most High.",
      "ayah_number": 20,
      "verse_key": "92:20"
    },
    {
      "number": 21,
      "text": "And he is going to be satisfied.",
      "ayah_number": 21,
      "verse_key": "92:21"
    }
  ]
}