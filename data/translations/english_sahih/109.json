{
  "number": 109,
  "name": "Al-Kaafiroon",
  "arabicName": "سُورَةُ الكَافِرُونَ",
  "revelationType": "Meccan",
  "totalAyahs": 6,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "Say, \"O disbelievers,",
      "ayah_number": 1,
      "verse_key": "109:1"
    },
    {
      "number": 2,
      "text": "I do not worship what you worship.",
      "ayah_number": 2,
      "verse_key": "109:2"
    },
    {
      "number": 3,
      "text": "Nor are you worshippers of what I worship.",
      "ayah_number": 3,
      "verse_key": "109:3"
    },
    {
      "number": 4,
      "text": "Nor will I be a worshipper of what you worship.",
      "ayah_number": 4,
      "verse_key": "109:4"
    },
    {
      "number": 5,
      "text": "Nor will you be worshippers of what I worship.",
      "ayah_number": 5,
      "verse_key": "109:5"
    },
    {
      "number": 6,
      "text": "For you is your religion, and for me is my religion.\"",
      "ayah_number": 6,
      "verse_key": "109:6"
    }
  ]
}