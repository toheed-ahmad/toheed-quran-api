{
  "number": 113,
  "name": "Al-Falaq",
  "arabicName": "سُورَةُ الفَلَقِ",
  "revelationType": "Meccan",
  "totalAyahs": 5,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "Say, \"I seek refuge in the Lord of daybreak",
      "ayah_number": 1,
      "verse_key": "113:1"
    },
    {
      "number": 2,
      "text": "From the evil of that which He created",
      "ayah_number": 2,
      "verse_key": "113:2"
    },
    {
      "number": 3,
      "text": "And from the evil of darkness when it settles",
      "ayah_number": 3,
      "verse_key": "113:3"
    },
    {
      "number": 4,
      "text": "And from the evil of the blowers in knots",
      "ayah_number": 4,
      "verse_key": "113:4"
    },
    {
      "number": 5,
      "text": "And from the evil of an envier when he envies.\"",
      "ayah_number": 5,
      "verse_key": "113:5"
    }
  ]
}