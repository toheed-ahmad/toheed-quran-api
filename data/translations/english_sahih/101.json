{
  "number": 101,
  "name": "Al-Qaari'a",
  "arabicName": "سُورَةُ القَارِعَةِ",
  "revelationType": "Meccan",
  "totalAyahs": 11,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "The Striking Calamity -",
      "ayah_number": 1,
      "verse_key": "101:1"
    },
    {
      "number": 2,
      "text": "What is the Striking Calamity?",
      "ayah_number": 2,
      "verse_key": "101:2"
    },
    {
      "number": 3,
      "text": "And what can make you know what is the Striking Calamity?",
      "ayah_number": 3,
      "verse_key": "101:3"
    },
    {
      "number": 4,
      "text": "It is the Day when people will be like moths, dispersed,",
      "ayah_number": 4,
      "verse_key": "101:4"
    },
    {
      "number": 5,
      "text": "And the mountains will be like wool, fluffed up.",
      "ayah_number": 5,
      "verse_key": "101:5"
    },
    {
      "number": 6,
      "text": "Then as for one whose scales are heavy [with good deeds],",
      "ayah_number": 6,
      "verse_key": "101:6"
    },
    {
      "number": 7,
      "text": "He will be in a pleasant life.",
      "ayah_number": 7,
      "verse_key": "101:7"
    },
    {
      "number": 8,
      "text": "But as for one whose scales are light,",
      "ayah_number": 8,
      "verse_key": "101:8"
    },
    {
      "number": 9,
      "text": "His refuge will be an abyss.",
      "ayah_number": 9,
      "verse_key": "101:9"
    },
    {
      "number": 10,
      "text": "And what can make you know what that is?",
      "ayah_number": 10,
      "verse_key": "101:10"
    },
    {
      "number": 11,
      "text": "It is a Fire, intensely hot.",
      "ayah_number": 11,
      "verse_key": "101:11"
    }
  ]
}