{
  "number": 114,
  "name": "An-Naas",
  "arabicName": "سُورَةُ النَّاسِ",
  "revelationType": "Meccan",
  "totalAyahs": 6,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "Say, \"I seek refuge in the Lord of mankind,",
      "ayah_number": 1,
      "verse_key": "114:1"
    },
    {
      "number": 2,
      "text": "The Sovereign of mankind.",
      "ayah_number": 2,
      "verse_key": "114:2"
    },
    {
      "number": 3,
      "text": "The God of mankind,",
      "ayah_number": 3,
      "verse_key": "114:3"
    },
    {
      "number": 4,
      "text": "From the evil of the retreating whisperer -",
      "ayah_number": 4,
      "verse_key": "114:4"
    },
    {
      "number": 5,
      "text": "Who whispers [evil] into the breasts of mankind -",
      "ayah_number": 5,
      "verse_key": "114:5"
    },
    {
      "number": 6,
      "text": "From among the jinn and mankind.\"",
      "ayah_number": 6,
      "verse_key": "114:6"
    }
  ]
}