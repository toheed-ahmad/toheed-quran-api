{
  "number": 87,
  "name": "Al-A'laa",
  "arabicName": "سُورَةُ الأَعۡلَىٰ",
  "revelationType": "Meccan",
  "totalAyahs": 19,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "Exalt the name of your Lord, the Most High,",
      "ayah_number": 1,
      "verse_key": "87:1"
    },
    {
      "number": 2,
      "text": "Who created and proportioned",
      "ayah_number": 2,
      "verse_key": "87:2"
    },
    {
      "number": 3,
      "text": "And who destined and [then] guided",
      "ayah_number": 3,
      "verse_key": "87:3"
    },
    {
      "number": 4,
      "text": "And who brings out the pasture",
      "ayah_number": 4,
      "verse_key": "87:4"
    },
    {
      "number": 5,
      "text": "And [then] makes it black stubble.",
      "ayah_number": 5,
      "verse_key": "87:5"
    },
    {
      "number": 6,
      "text": "We will make you recite, [O Muhammad], and you will not forget,",
      "ayah_number": 6,
      "verse_key": "87:6"
    },
    {
      "number": 7,
      "text": "Except what Allah should will. Indeed, He knows what is declared and what is hidden.",
      "ayah_number": 7,
      "verse_key": "87:7"
    },
    {
      "number": 8,
      "text": "And We will ease you toward ease.",
      "ayah_number": 8,
      "verse_key": "87:8"
    },
    {
      "number": 9,
      "text": "So remind, if the reminder should benefit;",
      "ayah_number": 9,
      "verse_key": "87:9"
    },
    {
      "number": 10,
      "text": "He who fears [Allah] will be reminded.",
      "ayah_number": 10,
      "verse_key": "87:10"
    },
    {
      "number": 11,
      "text": "But the wretched one will avoid it -",
      "ayah_number": 11,
      "verse_key": "87:11"
    },
    {
      "number": 12,
      "text": "[He] who will [enter and] burn in the greatest Fire,",
      "ayah_number": 12,
      "verse_key": "87:12"
    },
    {
      "number": 13,
      "text": "Neither dying therein nor living.",
      "ayah_number": 13,
      "verse_key": "87:13"
    },
    {
      "number": 14,
      "text": "He has certainly succeeded who purifies himself",
      "ayah_number": 14,
      "verse_key": "87:14"
    },
    {
      "number": 15,
      "text": "And mentions the name of his Lord and prays.",
      "ayah_number": 15,
      "verse_key": "87:15"
    },
    {
      "number": 16,
      "text": "But you prefer the worldly life,",
      "ayah_number": 16,
      "verse_key": "87:16"
    },
    {
      "number": 17,
      "text": "While the Hereafter is better and more enduring.",
      "ayah_number": 17,
      "verse_key": "87:17"
    },
    {
      "number": 18,
      "text": "Indeed, this is in the former scriptures,",
      "ayah_number": 18,
      "verse_key": "87:18"
    },
    {
      "number": 19,
      "text": "The scriptures of Abraham and Moses.",
      "ayah_number": 19,
      "verse_key": "87:19"
    }
  ]
}