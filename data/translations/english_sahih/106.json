{
  "number": 106,
  "name": "Quraish",
  "arabicName": "سُورَةُ قُرَيۡشٍ",
  "revelationType": "Meccan",
  "totalAyahs": 4,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "For the accustomed security of the Quraysh -",
      "ayah_number": 1,
      "verse_key": "106:1"
    },
    {
      "number": 2,
      "text": "Their accustomed security [in] the caravan of winter and summer -",
      "ayah_number": 2,
      "verse_key": "106:2"
    },
    {
      "number": 3,
      "text": "Let them worship the Lord of this House,",
      "ayah_number": 3,
      "verse_key": "106:3"
    },
    {
      "number": 4,
      "text": "Who has fed them, [saving them] from hunger and made them safe, [saving them] from fear.",
      "ayah_number": 4,
      "verse_key": "106:4"
    }
  ]
}