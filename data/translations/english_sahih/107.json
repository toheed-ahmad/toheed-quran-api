{
  "number": 107,
  "name": "Al-Maa'un",
  "arabicName": "سُورَةُ المَاعُونِ",
  "revelationType": "Meccan",
  "totalAyahs": 7,
  "translator": "Saheeh International",
  "edition": "en.sahih",
  "language": "English",
  "ayahs": [
    {
      "number": 1,
      "text": "Have you seen the one who denies the Recompense?",
      "ayah_number": 1,
      "verse_key": "107:1"
    },
    {
      "number": 2,
      "text": "For that is the one who drives away the orphan",
      "ayah_number": 2,
      "verse_key": "107:2"
    },
    {
      "number": 3,
      "text": "And does not encourage the feeding of the poor.",
      "ayah_number": 3,
      "verse_key": "107:3"
    },
    {
      "number": 4,
      "text": "So woe to those who pray",
      "ayah_number": 4,
      "verse_key": "107:4"
    },
    {
      "number": 5,
      "text": "[But] who are heedless of their prayer -",
      "ayah_number": 5,
      "verse_key": "107:5"
    },
    {
      "number": 6,
      "text": "Those who make show [of their deeds]",
      "ayah_number": 6,
      "verse_key": "107:6"
    },
    {
      "number": 7,
      "text": "And withhold [simple] assistance.",
      "ayah_number": 7,
      "verse_key": "107:7"
    }
  ]
}