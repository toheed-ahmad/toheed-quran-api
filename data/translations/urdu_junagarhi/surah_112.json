{
  "number": 112,
  "name": "Al-Ikhlaas",
  "arabicName": "سُورَةُ الإِخۡلَاصِ",
  "revelationType": "Meccan",
  "totalAyahs": 4,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "112:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "آپ کہہ دیجئے کہ وه اللہ تعالیٰ ایک (ہی) ہے",
      "ayah_number": 1,
      "verse_key": "112:1"
    },
    {
      "number": 2,
      "text": "اللہ تعالیٰ بے نیاز ہے",
      "ayah_number": 2,
      "verse_key": "112:2"
    },
    {
      "number": 3,
      "text": "نہ اس سے کوئی پیدا ہوا نہ وه کسی سے پیدا ہوا",
      "ayah_number": 3,
      "verse_key": "112:3"
    },
    {
      "number": 4,
      "text": "اور نہ کوئی اس کا ہمسر ہے",
      "ayah_number": 4,
      "verse_key": "112:4"
    }
  ]
}