{
  "number": 114,
  "name": "An-Naas",
  "arabicName": "سُورَةُ النَّاسِ",
  "revelationType": "Meccan",
  "totalAyahs": 6,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "114:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "آپ کہہ دیجئے! کہ میں لوگوں کے پروردگار کی پناه میں آتا ہوں",
      "ayah_number": 1,
      "verse_key": "114:1"
    },
    {
      "number": 2,
      "text": "لوگوں کے مالک کی (اور)",
      "ayah_number": 2,
      "verse_key": "114:2"
    },
    {
      "number": 3,
      "text": "لوگوں کے معبود کی (پناه میں)",
      "ayah_number": 3,
      "verse_key": "114:3"
    },
    {
      "number": 4,
      "text": "وسوسہ ڈالنے والے پیچھے ہٹ جانے والے کے شر سے",
      "ayah_number": 4,
      "verse_key": "114:4"
    },
    {
      "number": 5,
      "text": "جو لوگوں کے سینوں میں وسوسہ ڈالتا ہے",
      "ayah_number": 5,
      "verse_key": "114:5"
    },
    {
      "number": 6,
      "text": "(خواه) وه جن میں سے ہو یا انسان میں سے",
      "ayah_number": 6,
      "verse_key": "114:6"
    }
  ]
}