{
  "number": 77,
  "name": "Al-Mursalaat",
  "arabicName": "سُورَةُ المُرۡسَلَاتِ",
  "revelationType": "Meccan",
  "totalAyahs": 50,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "77:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "دل خوش کن چلتی ہواؤں کی قسم",
      "ayah_number": 1,
      "verse_key": "77:1"
    },
    {
      "number": 2,
      "text": "پھر زور سے جھونکا دینے والیوں کی قسم",
      "ayah_number": 2,
      "verse_key": "77:2"
    },
    {
      "number": 3,
      "text": "پھر (ابر کو) ابھار کر پراگنده کرنے والیوں کی قسم",
      "ayah_number": 3,
      "verse_key": "77:3"
    },
    {
      "number": 4,
      "text": "پھر حق وباطل کو جدا جدا کر دینے والے",
      "ayah_number": 4,
      "verse_key": "77:4"
    },
    {
      "number": 5,
      "text": "اور وحی ﻻنے والے فرشتوں کی قسم",
      "ayah_number": 5,
      "verse_key": "77:5"
    },
    {
      "number": 6,
      "text": "جو (وحی) الزام اتارنے یا آگاه کردینے کے لیے ہوتی ہے",
      "ayah_number": 6,
      "verse_key": "77:6"
    },
    {
      "number": 7,
      "text": "جس چیز کا تم سے وعده کیا جاتا ہے وہ یقیناً ہونے والی ہے",
      "ayah_number": 7,
      "verse_key": "77:7"
    },
    {
      "number": 8,
      "text": "پس جب ستارے بے نور کردئے جائیں گے",
      "ayah_number": 8,
      "verse_key": "77:8"
    },
    {
      "number": 9,
      "text": "اور جب آسمان توڑ پھوڑ دیا جائے گا",
      "ayah_number": 9,
      "verse_key": "77:9"
    },
    {
      "number": 10,
      "text": "اور جب پہاڑ ٹکڑے ٹکڑے کر کے اڑا دیئے جائیں گے",
      "ayah_number": 10,
      "verse_key": "77:10"
    },
    {
      "number": 11,
      "text": "اور جب رسولوں کو وقت مقرره پر ﻻیا جائے گا",
      "ayah_number": 11,
      "verse_key": "77:11"
    },
    {
      "number": 12,
      "text": "کس دن کے لیے (ان سب کو) مؤخر کیا گیا ہے؟",
      "ayah_number": 12,
      "verse_key": "77:12"
    },
    {
      "number": 13,
      "text": "فیصلے کے دن کے لیے",
      "ayah_number": 13,
      "verse_key": "77:13"
    },
    {
      "number": 14,
      "text": "اور تجھے کیا معلوم کہ فیصلے کا دن کیا ہے؟",
      "ayah_number": 14,
      "verse_key": "77:14"
    },
    {
      "number": 15,
      "text": "اس دن جھٹلانے والوں کی خرابی ہے",
      "ayah_number": 15,
      "verse_key": "77:15"
    },
    {
      "number": 16,
      "text": "کیا ہم نے اگلوں کو ہلاک نہیں کیا؟",
      "ayah_number": 16,
      "verse_key": "77:16"
    },
    {
      "number": 17,
      "text": "پھر ہم ان کے بعد پچھلوں کو ﻻئے",
      "ayah_number": 17,
      "verse_key": "77:17"
    },
    {
      "number": 18,
      "text": "ہم گنہگاروں کے ساتھ اسی طرح کرتے ہیں",
      "ayah_number": 18,
      "verse_key": "77:18"
    },
    {
      "number": 19,
      "text": "اس دن جھٹلانے والوں کے لیے ویل (افسوس) ہے",
      "ayah_number": 19,
      "verse_key": "77:19"
    },
    {
      "number": 20,
      "text": "کیا ہم نے تمہیں حقیر پانی سے (منی سے) پیدا نہیں کیا",
      "ayah_number": 20,
      "verse_key": "77:20"
    },
    {
      "number": 21,
      "text": "پھر ہم نے اسے مضبوط ومحفوظ جگہ میں رکھا",
      "ayah_number": 21,
      "verse_key": "77:21"
    },
    {
      "number": 22,
      "text": "ایک مقرره وقت تک",
      "ayah_number": 22,
      "verse_key": "77:22"
    },
    {
      "number": 23,
      "text": "پھر ہم نے اندازه کیا اور ہم کیا خوب اندازه کرنے والے ہیں",
      "ayah_number": 23,
      "verse_key": "77:23"
    },
    {
      "number": 24,
      "text": "اس دن تکذیب کرنے والوں کی خرابی ہے",
      "ayah_number": 24,
      "verse_key": "77:24"
    },
    {
      "number": 25,
      "text": "کیا ہم نے زمین کو سمیٹنے والی نہیں بنایا؟",
      "ayah_number": 25,
      "verse_key": "77:25"
    },
    {
      "number": 26,
      "text": "زندوں کو بھی اور مردوں کو بھی",
      "ayah_number": 26,
      "verse_key": "77:26"
    },
    {
      "number": 27,
      "text": "اور ہم نے اس میں بلند وبھاری پہاڑ بنادیے اور تمہیں سیراب کرنے واﻻ میٹھا پانی پلایا",
      "ayah_number": 27,
      "verse_key": "77:27"
    },
    {
      "number": 28,
      "text": "اس دن جھٹلانے والوں کے لیے وائے اور افسوس ہے",
      "ayah_number": 28,
      "verse_key": "77:28"
    },
    {
      "number": 29,
      "text": "اس دوزخ کی طرف جاؤ جسے تم جھٹلاتے رہے تھے",
      "ayah_number": 29,
      "verse_key": "77:29"
    },
    {
      "number": 30,
      "text": "چلو تین شاخوں والے سائے کی طرف",
      "ayah_number": 30,
      "verse_key": "77:30"
    },
    {
      "number": 31,
      "text": "جو در اصل نہ سایہ دینے واﻻ ہے اور نہ شعلے سے بچاسکتا ہے",
      "ayah_number": 31,
      "verse_key": "77:31"
    },
    {
      "number": 32,
      "text": "یقیناً دوزخ چنگاریاں پھینکتی ہے جو مثل محل کے ہیں",
      "ayah_number": 32,
      "verse_key": "77:32"
    },
    {
      "number": 33,
      "text": "گویا کہ وه زرد اونٹ ہیں",
      "ayah_number": 33,
      "verse_key": "77:33"
    },
    {
      "number": 34,
      "text": "آج ان جھٹلانے والوں کی درگت ہے",
      "ayah_number": 34,
      "verse_key": "77:34"
    },
    {
      "number": 35,
      "text": "آج (کا دن) وه دن ہے کہ یہ بول بھی نہ سکیں گے",
      "ayah_number": 35,
      "verse_key": "77:35"
    },
    {
      "number": 36,
      "text": "نہ انہیں معذرت کی اجازت دی جائے گی",
      "ayah_number": 36,
      "verse_key": "77:36"
    },
    {
      "number": 37,
      "text": "اس دن جھٹلانے والوں کی خرابی ہے",
      "ayah_number": 37,
      "verse_key": "77:37"
    },
    {
      "number": 38,
      "text": "یہ ہے فیصلے کا دن ہم نے تمہیں اور اگلوں کو سب کو جمع کرلیا ہے",
      "ayah_number": 38,
      "verse_key": "77:38"
    },
    {
      "number": 39,
      "text": "پس اگر تم مجھ سے کوئی چال چل سکتے ہو تو چل لو",
      "ayah_number": 39,
      "verse_key": "77:39"
    },
    {
      "number": 40,
      "text": "وائے ہے اس دن جھٹلانے والوں کے لیے",
      "ayah_number": 40,
      "verse_key": "77:40"
    },
    {
      "number": 41,
      "text": "بیشک پرہیزگار لوگ سایوں میں ہیں اور بہتے چشموں میں",
      "ayah_number": 41,
      "verse_key": "77:41"
    },
    {
      "number": 42,
      "text": "اور ان میووں میں جن کی وه خواہش کریں",
      "ayah_number": 42,
      "verse_key": "77:42"
    },
    {
      "number": 43,
      "text": "(اے جنتیو!) کھاؤ پیو مزے سےاپنے کیے ہوئے اعمال کے بدلے",
      "ayah_number": 43,
      "verse_key": "77:43"
    },
    {
      "number": 44,
      "text": "یقیناً ہم نیکی کرنے والوں کو اسی طرح جزا دیتے ہیں",
      "ayah_number": 44,
      "verse_key": "77:44"
    },
    {
      "number": 45,
      "text": "اس دن سچا نہ جاننے والوں کے لیے ویل (افسوس) ہے",
      "ayah_number": 45,
      "verse_key": "77:45"
    },
    {
      "number": 46,
      "text": "(اے جھٹلانے والو) تم دنیا میں تھوڑا سا کھا لو اور فائده اٹھا لو بیشک تم گنہگار ہو",
      "ayah_number": 46,
      "verse_key": "77:46"
    },
    {
      "number": 47,
      "text": "اس دن جھٹلانے والوں کے لیے سخت ہلاکت ہے",
      "ayah_number": 47,
      "verse_key": "77:47"
    },
    {
      "number": 48,
      "text": "ان سے جب کہا جاتا ہے کہ رکوع کر لو تو نہیں کرتے",
      "ayah_number": 48,
      "verse_key": "77:48"
    },
    {
      "number": 49,
      "text": "اس دن جھٹلانے والوں کی تباہی ہے",
      "ayah_number": 49,
      "verse_key": "77:49"
    },
    {
      "number": 50,
      "text": "اب اس قرآن کے بعد کس بات پر ایمان ﻻئیں گے؟",
      "ayah_number": 50,
      "verse_key": "77:50"
    }
  ]
}