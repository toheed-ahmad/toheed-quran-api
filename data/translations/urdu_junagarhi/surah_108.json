{
  "number": 108,
  "name": "Al-Kawthar",
  "arabicName": "سُورَةُ الكَوۡثَرِ",
  "revelationType": "Meccan",
  "totalAyahs": 3,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "108:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "یقیناً ہم نے تجھے (حوض) کوﺛر (اور بہت کچھ) دیا ہے",
      "ayah_number": 1,
      "verse_key": "108:1"
    },
    {
      "number": 2,
      "text": "پس تو اپنے رب کے لئے نماز پڑھ اور قربانی کر",
      "ayah_number": 2,
      "verse_key": "108:2"
    },
    {
      "number": 3,
      "text": "یقیناً تیرا دشمن ہی ﻻوارث اور بے نام ونشان ہے",
      "ayah_number": 3,
      "verse_key": "108:3"
    }
  ]
}