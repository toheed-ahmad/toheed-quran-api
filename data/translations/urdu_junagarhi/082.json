{
  "number": 82,
  "name": "Al-Infitaar",
  "arabicName": "سُورَةُ الانفِطَارِ",
  "revelationType": "Meccan",
  "totalAyahs": 19,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "82:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "جب آسمان پھٹ جائے گا",
      "ayah_number": 1,
      "verse_key": "82:1"
    },
    {
      "number": 2,
      "text": "اور جب ستارے جھڑ جائیں گے",
      "ayah_number": 2,
      "verse_key": "82:2"
    },
    {
      "number": 3,
      "text": "اور جب سمندر بہہ نکلیں گے",
      "ayah_number": 3,
      "verse_key": "82:3"
    },
    {
      "number": 4,
      "text": "اور جب قبریں (شق کر کے) اکھاڑ دی جائیں گی",
      "ayah_number": 4,
      "verse_key": "82:4"
    },
    {
      "number": 5,
      "text": "(اس وقت) ہر شخص اپنے آگے بھیجے ہوئے اور پیچھے چھوڑے ہوئے (یعنی اگلے پچھلے اعمال) کو معلوم کر لے گا",
      "ayah_number": 5,
      "verse_key": "82:5"
    },
    {
      "number": 6,
      "text": "اے انسان! تجھے اپنے رب کریم سے کس چیز نے بہکایا",
      "ayah_number": 6,
      "verse_key": "82:6"
    },
    {
      "number": 7,
      "text": "جس (رب نے) تجھے پیدا کیا، پھر ٹھیک ٹھاک کیا، پھر (درست اور) برابر بنایا",
      "ayah_number": 7,
      "verse_key": "82:7"
    },
    {
      "number": 8,
      "text": "جس صورت میں چاہا تجھے جوڑ دیا",
      "ayah_number": 8,
      "verse_key": "82:8"
    },
    {
      "number": 9,
      "text": "ہرگز نہیں بلکہ تم تو جزا وسزا کے دن کو جھٹلاتے ہو",
      "ayah_number": 9,
      "verse_key": "82:9"
    },
    {
      "number": 10,
      "text": "یقیناً تم پر نگہبان عزت والے",
      "ayah_number": 10,
      "verse_key": "82:10"
    },
    {
      "number": 11,
      "text": "لکھنے والے مقرر ہیں",
      "ayah_number": 11,
      "verse_key": "82:11"
    },
    {
      "number": 12,
      "text": "جوکچھ تم کرتے ہو وه جانتے ہیں",
      "ayah_number": 12,
      "verse_key": "82:12"
    },
    {
      "number": 13,
      "text": "یقیناً نیک لوگ (جنت کے عیش وآرام اور) نعمتوں میں ہوں گے",
      "ayah_number": 13,
      "verse_key": "82:13"
    },
    {
      "number": 14,
      "text": "اور یقیناً بدکار لوگ دوزخ میں ہوں گے",
      "ayah_number": 14,
      "verse_key": "82:14"
    },
    {
      "number": 15,
      "text": "بدلے والے دن اس میں جائیں گے",
      "ayah_number": 15,
      "verse_key": "82:15"
    },
    {
      "number": 16,
      "text": "وه اس سے کبھی غائب نہ ہونے پائیں گے",
      "ayah_number": 16,
      "verse_key": "82:16"
    },
    {
      "number": 17,
      "text": "تجھے کچھ خبر بھی ہے کہ بدلے کا دن کیا ہے",
      "ayah_number": 17,
      "verse_key": "82:17"
    },
    {
      "number": 18,
      "text": "میں پھر (کہتا ہوں کہ) تجھے کیا معلوم کہ جزا (اور سزا) کا دن کیا ہے",
      "ayah_number": 18,
      "verse_key": "82:18"
    },
    {
      "number": 19,
      "text": "(وه ہے) جس دن کوئی شخص کسی شخص کے لئے کسی چیز کا مختار نہ ہوگا، اور (تمام تر) احکام اس روز اللہ کے ہی ہوں گے",
      "ayah_number": 19,
      "verse_key": "82:19"
    }
  ]
}