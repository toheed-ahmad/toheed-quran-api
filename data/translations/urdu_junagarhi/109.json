{
  "number": 109,
  "name": "Al-Kaafiroon",
  "arabicName": "سُورَةُ الكَافِرُونَ",
  "revelationType": "Meccan",
  "totalAyahs": 6,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "109:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "آپ کہہ دیجئے کہ اے کافرو!",
      "ayah_number": 1,
      "verse_key": "109:1"
    },
    {
      "number": 2,
      "text": "نہ میں عبادت کرتا ہوں اس کی جس کی تم عبادت کرتے ہو",
      "ayah_number": 2,
      "verse_key": "109:2"
    },
    {
      "number": 3,
      "text": "نہ تم عبادت کرنے والے ہو اس کی جس کی میں عبادت کرتا ہوں",
      "ayah_number": 3,
      "verse_key": "109:3"
    },
    {
      "number": 4,
      "text": "اور نہ میں عبادت کروں گا جس کی تم عبادت کرتے ہو",
      "ayah_number": 4,
      "verse_key": "109:4"
    },
    {
      "number": 5,
      "text": "اور نہ تم اس کی عبادت کرنے والے ہو جس کی میں عبادت کر رہا ہوں",
      "ayah_number": 5,
      "verse_key": "109:5"
    },
    {
      "number": 6,
      "text": "تمہارے لئے تمہارا دین ہے اور میرے لئے میرا دین ہے",
      "ayah_number": 6,
      "verse_key": "109:6"
    }
  ]
}