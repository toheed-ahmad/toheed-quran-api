{
  "number": 107,
  "name": "Al-Maa'un",
  "arabicName": "سُورَةُ المَاعُونِ",
  "revelationType": "Meccan",
  "totalAyahs": 7,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "107:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "کیا تو نے (اسے بھی) دیکھا جو (روز) جزا کو جھٹلاتا ہے؟",
      "ayah_number": 1,
      "verse_key": "107:1"
    },
    {
      "number": 2,
      "text": "یہی وه ہے جو یتیم کو دھکے دیتا ہے",
      "ayah_number": 2,
      "verse_key": "107:2"
    },
    {
      "number": 3,
      "text": "اور مسکین کو کھلانے کی ترغیب نہیں دیتا",
      "ayah_number": 3,
      "verse_key": "107:3"
    },
    {
      "number": 4,
      "text": "ان نمازیوں کے لئے افسوس (اور ویل نامی جہنم کی جگہ) ہے",
      "ayah_number": 4,
      "verse_key": "107:4"
    },
    {
      "number": 5,
      "text": "جو اپنی نماز سے غافل ہیں",
      "ayah_number": 5,
      "verse_key": "107:5"
    },
    {
      "number": 6,
      "text": "جو ریاکاری کرتے ہیں",
      "ayah_number": 6,
      "verse_key": "107:6"
    },
    {
      "number": 7,
      "text": "اور برتنے کی چیز روکتے ہیں",
      "ayah_number": 7,
      "verse_key": "107:7"
    }
  ]
}