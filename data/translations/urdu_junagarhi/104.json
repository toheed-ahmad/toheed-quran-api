{
  "number": 104,
  "name": "Al-Humaza",
  "arabicName": "سُورَةُ الهُمَزَةِ",
  "revelationType": "Meccan",
  "totalAyahs": 9,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "104:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "بڑی خرابی ہے ہر ایسے شخص کی جو عیب ٹٹولنے واﻻ غیبت کرنے واﻻ ہو",
      "ayah_number": 1,
      "verse_key": "104:1"
    },
    {
      "number": 2,
      "text": "جو مال کو جمع کرتا جائے اور گنتا جائے",
      "ayah_number": 2,
      "verse_key": "104:2"
    },
    {
      "number": 3,
      "text": "وه سمجھتا ہے کہ اس کا مال اس کے پاس سدا رہے گا",
      "ayah_number": 3,
      "verse_key": "104:3"
    },
    {
      "number": 4,
      "text": "ہرگز نہیں یہ تو ضرور توڑ پھوڑ دینے والی آگ میں پھینک دیا جائے گا",
      "ayah_number": 4,
      "verse_key": "104:4"
    },
    {
      "number": 5,
      "text": "اور تجھے کیا معلوم کہ ایسی آگ کیا ہوگی؟",
      "ayah_number": 5,
      "verse_key": "104:5"
    },
    {
      "number": 6,
      "text": "وه اللہ تعالیٰ کی سلگائی ہوئی آگ ہوگی",
      "ayah_number": 6,
      "verse_key": "104:6"
    },
    {
      "number": 7,
      "text": "جو دلوں پر چڑھتی چلی جائے گی",
      "ayah_number": 7,
      "verse_key": "104:7"
    },
    {
      "number": 8,
      "text": "وہ ان پر ہر طرف سے بند کی ہوئی ہوگی",
      "ayah_number": 8,
      "verse_key": "104:8"
    },
    {
      "number": 9,
      "text": "بڑے بڑے ستونوں میں",
      "ayah_number": 9,
      "verse_key": "104:9"
    }
  ]
}