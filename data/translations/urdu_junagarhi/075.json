{
  "number": 75,
  "name": "Al-Qiyaama",
  "arabicName": "سُورَةُ القِيَامَةِ",
  "revelationType": "Meccan",
  "totalAyahs": 40,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "75:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "میں قسم کھاتا ہوں قیامت کے دن کی",
      "ayah_number": 1,
      "verse_key": "75:1"
    },
    {
      "number": 2,
      "text": "اور قسم کھاتا ہوں اس نفس کی جو ملامت کرنے واﻻ ہو",
      "ayah_number": 2,
      "verse_key": "75:2"
    },
    {
      "number": 3,
      "text": "کیا انسان یہ خیال کرتا ہے کہ ہم اس کی ہڈیاں جمع کریں گے ہی نہیں",
      "ayah_number": 3,
      "verse_key": "75:3"
    },
    {
      "number": 4,
      "text": "ہاں ضرور کریں گے ہم تو قادر ہیں کہ اس کی پور پور تک درست کردیں",
      "ayah_number": 4,
      "verse_key": "75:4"
    },
    {
      "number": 5,
      "text": "بلکہ انسان تو چاہتا ہے کہ آگے آگے نافرمانیاں کرتا جائے",
      "ayah_number": 5,
      "verse_key": "75:5"
    },
    {
      "number": 6,
      "text": "پوچھتا ہے کہ قیامت کا دن کب آئے گا",
      "ayah_number": 6,
      "verse_key": "75:6"
    },
    {
      "number": 7,
      "text": "پس جس وقت کہ نگاه پتھرا جائے گی",
      "ayah_number": 7,
      "verse_key": "75:7"
    },
    {
      "number": 8,
      "text": "اور چاند بے نور ہو جائے گا",
      "ayah_number": 8,
      "verse_key": "75:8"
    },
    {
      "number": 9,
      "text": "اور سورج اور چاند جمع کردیئے جائیں گے",
      "ayah_number": 9,
      "verse_key": "75:9"
    },
    {
      "number": 10,
      "text": "اس دن انسان کہے گا کہ آج بھاگنے کی جگہ کہاں ہے؟",
      "ayah_number": 10,
      "verse_key": "75:10"
    },
    {
      "number": 11,
      "text": "نہیں نہیں کوئی پناہ گاه نہیں",
      "ayah_number": 11,
      "verse_key": "75:11"
    },
    {
      "number": 12,
      "text": "آج تو تیرے پروردگار کی طرف ہی قرار گاه ہے",
      "ayah_number": 12,
      "verse_key": "75:12"
    },
    {
      "number": 13,
      "text": "آج انسان کو اس کے آگے بھیجے ہوئے اور پیچھے چھوڑے ہوئے سے آگاه کیا جائے گا",
      "ayah_number": 13,
      "verse_key": "75:13"
    },
    {
      "number": 14,
      "text": "بلکہ انسان خود اپنے اوپر آپ حجت ہے",
      "ayah_number": 14,
      "verse_key": "75:14"
    },
    {
      "number": 15,
      "text": "اگر چہ کتنے ہی بہانے پیش کرے",
      "ayah_number": 15,
      "verse_key": "75:15"
    },
    {
      "number": 16,
      "text": "(اے نبی) آپ قرآن کو جلدی (یاد کرنے) کے لیے اپنی زبان کو حرکت نہ دیں",
      "ayah_number": 16,
      "verse_key": "75:16"
    },
    {
      "number": 17,
      "text": "اس کا جمع کرنا اور (آپ کی زبان سے) پڑھنا ہمارے ذمہ ہے",
      "ayah_number": 17,
      "verse_key": "75:17"
    },
    {
      "number": 18,
      "text": "ہم جب اسے پڑھ لیں تو آپ اس کے پڑھنے کی پیروی کریں",
      "ayah_number": 18,
      "verse_key": "75:18"
    },
    {
      "number": 19,
      "text": "پھر اس کا واضح کر دینا ہمارے ذمہ ہے",
      "ayah_number": 19,
      "verse_key": "75:19"
    },
    {
      "number": 20,
      "text": "نہیں نہیں تم جلدی ملنے والی (دنیا) کی محبت رکھتے ہو",
      "ayah_number": 20,
      "verse_key": "75:20"
    },
    {
      "number": 21,
      "text": "اور آخرت کو چھوڑ بیٹھے ہو",
      "ayah_number": 21,
      "verse_key": "75:21"
    },
    {
      "number": 22,
      "text": "اس روز بہت سے چہرے تروتازه اور بارونق ہوں گے",
      "ayah_number": 22,
      "verse_key": "75:22"
    },
    {
      "number": 23,
      "text": "اپنے رب کی طرف دیکھتے ہوں گے",
      "ayah_number": 23,
      "verse_key": "75:23"
    },
    {
      "number": 24,
      "text": "اور کتنے چہرے اس دن (بد رونق اور) اداس ہوں گے",
      "ayah_number": 24,
      "verse_key": "75:24"
    },
    {
      "number": 25,
      "text": "سمجھتے ہوں گے کہ ان کے ساتھ کمر توڑ دینے واﻻ معاملہ کیا جائے گا",
      "ayah_number": 25,
      "verse_key": "75:25"
    },
    {
      "number": 26,
      "text": "نہیں نہیں جب روح ہنسلی تک پہنچے گی",
      "ayah_number": 26,
      "verse_key": "75:26"
    },
    {
      "number": 27,
      "text": "اور کہا جائے گا کہ کوئی جھاڑ پھونک کرنے واﻻ ہے؟",
      "ayah_number": 27,
      "verse_key": "75:27"
    },
    {
      "number": 28,
      "text": "اور جان لیا اس نے کہ یہ وقت جدائی ہے",
      "ayah_number": 28,
      "verse_key": "75:28"
    },
    {
      "number": 29,
      "text": "اور پنڈلی سے پنڈلی لپٹ جائے گی",
      "ayah_number": 29,
      "verse_key": "75:29"
    },
    {
      "number": 30,
      "text": "آج تیرے پروردگار کی طرف چلنا ہے",
      "ayah_number": 30,
      "verse_key": "75:30"
    },
    {
      "number": 31,
      "text": "اس نے نہ تو تصدیق کی نہ نماز ادا کی",
      "ayah_number": 31,
      "verse_key": "75:31"
    },
    {
      "number": 32,
      "text": "بلکہ جھٹلایا اور روگردانی کی",
      "ayah_number": 32,
      "verse_key": "75:32"
    },
    {
      "number": 33,
      "text": "پھر اپنے گھر والوں کے پاس اتراتا ہوا گیا",
      "ayah_number": 33,
      "verse_key": "75:33"
    },
    {
      "number": 34,
      "text": "افسوس ہے تجھ پر حسرت ہے تجھ پر",
      "ayah_number": 34,
      "verse_key": "75:34"
    },
    {
      "number": 35,
      "text": "وائے ہے اور خرابی ہے تیرے لیے",
      "ayah_number": 35,
      "verse_key": "75:35"
    },
    {
      "number": 36,
      "text": "کیا انسان یہ سمجھتا ہے کہ اسے بیکار چھوڑ دیا جائے گا",
      "ayah_number": 36,
      "verse_key": "75:36"
    },
    {
      "number": 37,
      "text": "کیا وه ایک گاڑھے پانی کا قطره نہ تھا جو ٹپکایا گیا تھا؟",
      "ayah_number": 37,
      "verse_key": "75:37"
    },
    {
      "number": 38,
      "text": "پھر وه لہو کا لوتھڑا ہوگیا پھر اللہ نے اسے پیدا کیا اور درست بنا دیا",
      "ayah_number": 38,
      "verse_key": "75:38"
    },
    {
      "number": 39,
      "text": "پھر اس سے جوڑے یعنی نر وماده بنائے",
      "ayah_number": 39,
      "verse_key": "75:39"
    },
    {
      "number": 40,
      "text": "کیا (اللہ تعالیٰ) اس (امر) پر قادر نہیں کہ مردے کو زنده کردے",
      "ayah_number": 40,
      "verse_key": "75:40"
    }
  ]
}