{
  "number": 79,
  "name": "An-Naazi'aat",
  "arabicName": "سُورَةُ النَّازِعَاتِ",
  "revelationType": "Meccan",
  "totalAyahs": 46,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "79:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "ڈوب کر سختی سے کھینچنے والوں کی قسم!",
      "ayah_number": 1,
      "verse_key": "79:1"
    },
    {
      "number": 2,
      "text": "بند کھول کر چھڑا دینے والوں کی قسم!",
      "ayah_number": 2,
      "verse_key": "79:2"
    },
    {
      "number": 3,
      "text": "اور تیرنے پھرنے والوں کی قسم!",
      "ayah_number": 3,
      "verse_key": "79:3"
    },
    {
      "number": 4,
      "text": "پھر دوڑ کر آگے بڑھنے والوں کی قسم!",
      "ayah_number": 4,
      "verse_key": "79:4"
    },
    {
      "number": 5,
      "text": "پھر کام کی تدبیر کرنے والوں کی قسم!",
      "ayah_number": 5,
      "verse_key": "79:5"
    },
    {
      "number": 6,
      "text": "جس دن کانپنے والی کانپے گی",
      "ayah_number": 6,
      "verse_key": "79:6"
    },
    {
      "number": 7,
      "text": "اس کے بعد ایک پیچھے آنے والی (پیچھے پیچھے) آئے گی",
      "ayah_number": 7,
      "verse_key": "79:7"
    },
    {
      "number": 8,
      "text": "(بہت سے) دل اس دن دھڑکتے ہوں گے",
      "ayah_number": 8,
      "verse_key": "79:8"
    },
    {
      "number": 9,
      "text": "جن کی نگاہیں نیچی ہوں گی",
      "ayah_number": 9,
      "verse_key": "79:9"
    },
    {
      "number": 10,
      "text": "کہتے ہیں کہ کیا ہم پہلی کی سی حالت کی طرف پھر لوٹائے جائیں گے؟",
      "ayah_number": 10,
      "verse_key": "79:10"
    },
    {
      "number": 11,
      "text": "کیا اس وقت جب کہ ہم بوسیده ہڈیاں ہو جائیں گے؟",
      "ayah_number": 11,
      "verse_key": "79:11"
    },
    {
      "number": 12,
      "text": "کہتے ہیں کہ پھر تو یہ لوٹنا نقصان ده ہے",
      "ayah_number": 12,
      "verse_key": "79:12"
    },
    {
      "number": 13,
      "text": "(معلوم ہونا چاہئے) وه تو صرف ایک (خوفناک) ڈانٹ ہے",
      "ayah_number": 13,
      "verse_key": "79:13"
    },
    {
      "number": 14,
      "text": "کہ (جس کے ﻇاہر ہوتے ہی) وه ایک دم میدان میں جمع ہو جائیں گے",
      "ayah_number": 14,
      "verse_key": "79:14"
    },
    {
      "number": 15,
      "text": "کیا موسیٰ (علیہ السلام) کی خبر تمہیں پہنچی ہے؟",
      "ayah_number": 15,
      "verse_key": "79:15"
    },
    {
      "number": 16,
      "text": "جب کہ انہیں ان کے رب نے پاک میدان طویٰ میں پکارا",
      "ayah_number": 16,
      "verse_key": "79:16"
    },
    {
      "number": 17,
      "text": "(کہ) تم فرعون کے پاس جاؤ اس نے سرکشی اختیار کر لی ہے",
      "ayah_number": 17,
      "verse_key": "79:17"
    },
    {
      "number": 18,
      "text": "اس سے کہو کہ کیا تو اپنی درستگی اور اصلاح چاہتا ہے",
      "ayah_number": 18,
      "verse_key": "79:18"
    },
    {
      "number": 19,
      "text": "اور یہ کہ میں تجھے تیرے رب کی راه دکھاؤں تاکہ تو (اس سے) ڈرنے لگے",
      "ayah_number": 19,
      "verse_key": "79:19"
    },
    {
      "number": 20,
      "text": "پس اسے بڑی نشانی دکھائی",
      "ayah_number": 20,
      "verse_key": "79:20"
    },
    {
      "number": 21,
      "text": "تو اس نے جھٹلایا اور نافرمانی کی",
      "ayah_number": 21,
      "verse_key": "79:21"
    },
    {
      "number": 22,
      "text": "پھر پلٹا دوڑ دھوپ کرتے ہوئے",
      "ayah_number": 22,
      "verse_key": "79:22"
    },
    {
      "number": 23,
      "text": "پھر سب کو جمع کرکے پکارا",
      "ayah_number": 23,
      "verse_key": "79:23"
    },
    {
      "number": 24,
      "text": "تم سب کا رب میں ہی ہوں",
      "ayah_number": 24,
      "verse_key": "79:24"
    },
    {
      "number": 25,
      "text": "تو (سب سے بلند وباﻻ) اللہ نے بھی اسے آخرت کے اور دنیا کے عذاب میں گرفتار کرلیا",
      "ayah_number": 25,
      "verse_key": "79:25"
    },
    {
      "number": 26,
      "text": "بیشک اس میں اس شخص کے لئے عبرت ہے جو ڈرے",
      "ayah_number": 26,
      "verse_key": "79:26"
    },
    {
      "number": 27,
      "text": "کیا تمہارا پیدا کرنا زیاده دشوار ہے یا آسمان کا؟ اللہ تعالیٰ نے اسے بنایا",
      "ayah_number": 27,
      "verse_key": "79:27"
    },
    {
      "number": 28,
      "text": "اس کی بلندی اونچی کی پھر اسے ٹھیک ٹھاک کر دیا",
      "ayah_number": 28,
      "verse_key": "79:28"
    },
    {
      "number": 29,
      "text": "اسکی رات کو تاریک بنایا اور اس کے دن کو نکالا",
      "ayah_number": 29,
      "verse_key": "79:29"
    },
    {
      "number": 30,
      "text": "اور اس کے بعد زمین کو (ہموار) بچھا دیا",
      "ayah_number": 30,
      "verse_key": "79:30"
    },
    {
      "number": 31,
      "text": "اس میں سے پانی اور چاره نکالا",
      "ayah_number": 31,
      "verse_key": "79:31"
    },
    {
      "number": 32,
      "text": "اور پہاڑوں کو (مضبوط) گاڑ دیا",
      "ayah_number": 32,
      "verse_key": "79:32"
    },
    {
      "number": 33,
      "text": "یہ سب تمہارے اور تمہارے جانوروں کے فائدے کے لئے (ہیں)",
      "ayah_number": 33,
      "verse_key": "79:33"
    },
    {
      "number": 34,
      "text": "پس جب وه بڑی آفت (قیامت) آجائے گی",
      "ayah_number": 34,
      "verse_key": "79:34"
    },
    {
      "number": 35,
      "text": "جس دن کہ انسان اپنے کیے ہوئے کاموں کو یاد کرے گا",
      "ayah_number": 35,
      "verse_key": "79:35"
    },
    {
      "number": 36,
      "text": "اور (ہر) دیکھنے والے کے سامنے جہنم ﻇاہر کی جائے گی",
      "ayah_number": 36,
      "verse_key": "79:36"
    },
    {
      "number": 37,
      "text": "تو جس (شخص) نے سرکشی کی (ہوگی)",
      "ayah_number": 37,
      "verse_key": "79:37"
    },
    {
      "number": 38,
      "text": "اور دنیوی زندگی کو ترجیح دی (ہوگی)",
      "ayah_number": 38,
      "verse_key": "79:38"
    },
    {
      "number": 39,
      "text": "اس کا ٹھکانا جہنم ہی ہے",
      "ayah_number": 39,
      "verse_key": "79:39"
    },
    {
      "number": 40,
      "text": "ہاں جو شخص اپنے رب کے سامنے کھڑے ہونے سے ڈرتا رہا ہوگا اور اپنے نفس کو خواہش سے روکا ہوگا",
      "ayah_number": 40,
      "verse_key": "79:40"
    },
    {
      "number": 41,
      "text": "تو اس کا ٹھکانا جنت ہی ہے",
      "ayah_number": 41,
      "verse_key": "79:41"
    },
    {
      "number": 42,
      "text": "لوگ آپ سے قیامت کے واقع ہونے کا وقت دریافت کرتے ہیں",
      "ayah_number": 42,
      "verse_key": "79:42"
    },
    {
      "number": 43,
      "text": "آپ کو اس کے بیان کرنے سے کیا تعلق؟",
      "ayah_number": 43,
      "verse_key": "79:43"
    },
    {
      "number": 44,
      "text": "اس کے علم کی انتہا تو اللہ کی جانب ہے",
      "ayah_number": 44,
      "verse_key": "79:44"
    },
    {
      "number": 45,
      "text": "آپ تو صرف اس سے ڈرتے رہنے والوں کو آگاه کرنے والے ہیں",
      "ayah_number": 45,
      "verse_key": "79:45"
    },
    {
      "number": 46,
      "text": "جس روز یہ اسے دیکھ لیں گے تو ایسا معلوم ہوگا کہ صرف دن کا آخری حصہ یا اول حصہ ہی (دنیا میں) رہے ہیں",
      "ayah_number": 46,
      "verse_key": "79:46"
    }
  ]
}