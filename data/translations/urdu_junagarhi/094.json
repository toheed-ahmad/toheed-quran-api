{
  "number": 94,
  "name": "Ash-Sharh",
  "arabicName": "سُورَةُ الشَّرۡحِ",
  "revelationType": "Meccan",
  "totalAyahs": 8,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "94:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "کیا ہم نے تیرا سینہ نہیں کھول دیا",
      "ayah_number": 1,
      "verse_key": "94:1"
    },
    {
      "number": 2,
      "text": "اور تجھ پر سے تیرا بوجھ ہم نے اتار دیا",
      "ayah_number": 2,
      "verse_key": "94:2"
    },
    {
      "number": 3,
      "text": "جس نے تیری پیٹھ توڑ دی تھی",
      "ayah_number": 3,
      "verse_key": "94:3"
    },
    {
      "number": 4,
      "text": "اور ہمنے تیرا ذکر بلند کر دیا",
      "ayah_number": 4,
      "verse_key": "94:4"
    },
    {
      "number": 5,
      "text": "پس یقیناً مشکل کے ساتھ آسانی ہے",
      "ayah_number": 5,
      "verse_key": "94:5"
    },
    {
      "number": 6,
      "text": "بیشک مشکل کے ساتھ آسانی ہے",
      "ayah_number": 6,
      "verse_key": "94:6"
    },
    {
      "number": 7,
      "text": "پس جب تو فارغ ہو تو عبادت میں محنت کر",
      "ayah_number": 7,
      "verse_key": "94:7"
    },
    {
      "number": 8,
      "text": "اور اپنے پروردگار ہی کی طرف دل لگا",
      "ayah_number": 8,
      "verse_key": "94:8"
    }
  ]
}