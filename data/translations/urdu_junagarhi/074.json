{
  "number": 74,
  "name": "Al-Muddaththir",
  "arabicName": "سُورَةُ المُدَّثِّرِ",
  "revelationType": "Meccan",
  "totalAyahs": 56,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "74:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "اے کپڑا اوڑھنے والے",
      "ayah_number": 1,
      "verse_key": "74:1"
    },
    {
      "number": 2,
      "text": "کھڑا ہوجا اور آگاه کردے",
      "ayah_number": 2,
      "verse_key": "74:2"
    },
    {
      "number": 3,
      "text": "اور اپنے رب ہی کی بڑائیاں بیان کر",
      "ayah_number": 3,
      "verse_key": "74:3"
    },
    {
      "number": 4,
      "text": "اپنے کپڑوں کو پاک رکھا کر",
      "ayah_number": 4,
      "verse_key": "74:4"
    },
    {
      "number": 5,
      "text": "ناپاکی کو چھوڑ دے",
      "ayah_number": 5,
      "verse_key": "74:5"
    },
    {
      "number": 6,
      "text": "اور احسان کرکے زیاده لینے کی خواہش نہ کر",
      "ayah_number": 6,
      "verse_key": "74:6"
    },
    {
      "number": 7,
      "text": "اور اپنے رب کی راه میں صبر کر",
      "ayah_number": 7,
      "verse_key": "74:7"
    },
    {
      "number": 8,
      "text": "پس جب کہ صور میں پھونک ماری جائے گی",
      "ayah_number": 8,
      "verse_key": "74:8"
    },
    {
      "number": 9,
      "text": "تو وه دن بڑا سخت دن ہوگا",
      "ayah_number": 9,
      "verse_key": "74:9"
    },
    {
      "number": 10,
      "text": "جو کافروں پر آسان نہ ہوگا",
      "ayah_number": 10,
      "verse_key": "74:10"
    },
    {
      "number": 11,
      "text": "مجھے اور اسے چھوڑ دے جسے میں نے اکیلا پیدا کیا ہے",
      "ayah_number": 11,
      "verse_key": "74:11"
    },
    {
      "number": 12,
      "text": "اور اسے بہت سا مال دے رکھا ہے",
      "ayah_number": 12,
      "verse_key": "74:12"
    },
    {
      "number": 13,
      "text": "اور حاضر باش فرزند بھی",
      "ayah_number": 13,
      "verse_key": "74:13"
    },
    {
      "number": 14,
      "text": "اور میں نے اسے بہت کچھ کشادگی دے رکھی ہے",
      "ayah_number": 14,
      "verse_key": "74:14"
    },
    {
      "number": 15,
      "text": "پھر بھی اس کی چاہت ہے کہ میں اسے اور زیاده دوں",
      "ayah_number": 15,
      "verse_key": "74:15"
    },
    {
      "number": 16,
      "text": "نہیں نہیں، وه ہماری آیتوں کا مخالف ہے",
      "ayah_number": 16,
      "verse_key": "74:16"
    },
    {
      "number": 17,
      "text": "عنقریب میں اسے ایک سخت چڑھائی چڑھاؤں گا",
      "ayah_number": 17,
      "verse_key": "74:17"
    },
    {
      "number": 18,
      "text": "اس نے غور کرکے تجویز کی",
      "ayah_number": 18,
      "verse_key": "74:18"
    },
    {
      "number": 19,
      "text": "اسے ہلاکت ہو کیسی (تجویز) سوچی؟",
      "ayah_number": 19,
      "verse_key": "74:19"
    },
    {
      "number": 20,
      "text": "وه پھر غارت ہو کس طرح اندازه کیا",
      "ayah_number": 20,
      "verse_key": "74:20"
    },
    {
      "number": 21,
      "text": "اس نے پھر دیکھا",
      "ayah_number": 21,
      "verse_key": "74:21"
    },
    {
      "number": 22,
      "text": "پھر تیوری چڑھائی اور منھ بنایا",
      "ayah_number": 22,
      "verse_key": "74:22"
    },
    {
      "number": 23,
      "text": "پھر پیچھے ہٹ گیا اور غرور کیا",
      "ayah_number": 23,
      "verse_key": "74:23"
    },
    {
      "number": 24,
      "text": "اور کہنے لگا تو یہ صرف جادو ہے جو نقل کیا جاتا ہے",
      "ayah_number": 24,
      "verse_key": "74:24"
    },
    {
      "number": 25,
      "text": "سوائے انسانی کلام کے کچھ بھی نہیں ہے",
      "ayah_number": 25,
      "verse_key": "74:25"
    },
    {
      "number": 26,
      "text": "میں عنقریب اسے دوزخ میں ڈالوں گا",
      "ayah_number": 26,
      "verse_key": "74:26"
    },
    {
      "number": 27,
      "text": "اور تجھے کیا خبر کہ دوزخ کیا چیز ہے؟",
      "ayah_number": 27,
      "verse_key": "74:27"
    },
    {
      "number": 28,
      "text": "نہ وه باقی رکھتی ہے نہ چھوڑتی ہے",
      "ayah_number": 28,
      "verse_key": "74:28"
    },
    {
      "number": 29,
      "text": "کھال کو جھلسا دیتی ہے",
      "ayah_number": 29,
      "verse_key": "74:29"
    },
    {
      "number": 30,
      "text": "اور اس میں انیس (فرشتے مقرر) ہیں",
      "ayah_number": 30,
      "verse_key": "74:30"
    },
    {
      "number": 31,
      "text": "ہم نے دوزخ کے داروغے صرف فرشتے رکھے ہیں۔ اور ہم نے ان کی تعداد صرف کافروں کی آزمائش کے لیے مقرر کی ہے تاکہ اہل کتاب یقین کرلیں، اوراہل ایمان کے ایمان میں اضافہ ہو جائے اور اہل کتاب اور اہل ایمان شک نہ کریں اور جن کے دلوں میں بیماری ہے وه اور کافر کہیں کہ اس بیان سے اللہ تعالیٰ کی کیا مراد ہے؟ اسی طرح اللہ تعالیٰ جسے چاہتا ہے گمراه کرتا ہے اور جسے چاہتا ہے ہدایت دیتا ہے۔ تیرے رب کے لشکروں کو اس کے سوا کوئی نہیں جانتا، یہ تو کل بنی آدم کے لیے سراسر پند ونصیحت ہے",
      "ayah_number": 31,
      "verse_key": "74:31"
    },
    {
      "number": 32,
      "text": "سچ کہتا ہوں قسم ہے چاند کی",
      "ayah_number": 32,
      "verse_key": "74:32"
    },
    {
      "number": 33,
      "text": "اور رات کی جب وه پیچھے ہٹے",
      "ayah_number": 33,
      "verse_key": "74:33"
    },
    {
      "number": 34,
      "text": "اور صبح کی جب کہ روشن ہو جائے",
      "ayah_number": 34,
      "verse_key": "74:34"
    },
    {
      "number": 35,
      "text": "کہ (یقیناً وه جہنم) بڑی چیزوں میں سے ایک ہے",
      "ayah_number": 35,
      "verse_key": "74:35"
    },
    {
      "number": 36,
      "text": "بنی آدم کو ڈرانے والی",
      "ayah_number": 36,
      "verse_key": "74:36"
    },
    {
      "number": 37,
      "text": "(یعنی) اسے جو تم میں سے آگے بڑھنا چاہے یا پیچھے ہٹنا چاہے",
      "ayah_number": 37,
      "verse_key": "74:37"
    },
    {
      "number": 38,
      "text": "ہر شخص اپنے اعمال کے بدلے میں گروی ہے",
      "ayah_number": 38,
      "verse_key": "74:38"
    },
    {
      "number": 39,
      "text": "مگر دائیں ہاتھ والے",
      "ayah_number": 39,
      "verse_key": "74:39"
    },
    {
      "number": 40,
      "text": "کہ وه بہشتوں میں (بیٹھے ہوئے) گناه گاروں سے",
      "ayah_number": 40,
      "verse_key": "74:40"
    },
    {
      "number": 41,
      "text": "سوال کرتے ہوں گے",
      "ayah_number": 41,
      "verse_key": "74:41"
    },
    {
      "number": 42,
      "text": "تمہیں دوزخ میں کس چیز نے ڈاﻻ",
      "ayah_number": 42,
      "verse_key": "74:42"
    },
    {
      "number": 43,
      "text": "وه جواب دیں گے کہ ہم نمازی نہ تھے",
      "ayah_number": 43,
      "verse_key": "74:43"
    },
    {
      "number": 44,
      "text": "نہ مسکینوں کو کھانا کھلاتے تھے",
      "ayah_number": 44,
      "verse_key": "74:44"
    },
    {
      "number": 45,
      "text": "اور ہم بحﺚ کرنے والے (انکاریوں) کا ساتھ دے کر بحﺚ مباحثہ میں مشغول رہا کرتے تھے",
      "ayah_number": 45,
      "verse_key": "74:45"
    },
    {
      "number": 46,
      "text": "اور روز جزا کو جھٹلاتے تھے",
      "ayah_number": 46,
      "verse_key": "74:46"
    },
    {
      "number": 47,
      "text": "یہاں تک کہ ہمیں موت آگئی",
      "ayah_number": 47,
      "verse_key": "74:47"
    },
    {
      "number": 48,
      "text": "پس انہیں سفارش کرنے والوں کی سفارش نفع نہ دے گی",
      "ayah_number": 48,
      "verse_key": "74:48"
    },
    {
      "number": 49,
      "text": "انہیں کیا ہو گیا ہے؟ کہ نصیحت سے منھ موڑ رہے ہیں",
      "ayah_number": 49,
      "verse_key": "74:49"
    },
    {
      "number": 50,
      "text": "گویا کہ وه بِدکے ہوئے گدھے ہیں",
      "ayah_number": 50,
      "verse_key": "74:50"
    },
    {
      "number": 51,
      "text": "جو شیر سے بھاگے ہوں",
      "ayah_number": 51,
      "verse_key": "74:51"
    },
    {
      "number": 52,
      "text": "بلکہ ان میں سے ہر شخص چاہتا ہے کہ اسے کھلی ہوئی کتابیں دی جائیں",
      "ayah_number": 52,
      "verse_key": "74:52"
    },
    {
      "number": 53,
      "text": "ہرگز ایسا نہیں (ہوسکتا بلکہ) یہ قیامت سے بے خوف ہیں",
      "ayah_number": 53,
      "verse_key": "74:53"
    },
    {
      "number": 54,
      "text": "سچی بات تو یہ ہے کہ یہ (قرآن) ایک نصیحت ہے",
      "ayah_number": 54,
      "verse_key": "74:54"
    },
    {
      "number": 55,
      "text": "اب جو چاہے اس سے نصیحت حاصل کرے",
      "ayah_number": 55,
      "verse_key": "74:55"
    },
    {
      "number": 56,
      "text": "اور وه اس وقت نصیحت حاصل کریں گے جب اللہ تعالیٰ چاہے، وه اسی ﻻئق ہے کہ اس سے ڈریں اور اس ﻻئق بھی کہ وه بخشے",
      "ayah_number": 56,
      "verse_key": "74:56"
    }
  ]
}