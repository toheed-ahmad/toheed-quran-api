{
  "number": 86,
  "name": "At-Taariq",
  "arabicName": "سُورَةُ الطَّارِقِ",
  "revelationType": "Meccan",
  "totalAyahs": 17,
  "translator": "Muhammad Junagarhi",
  "edition": "ur.junagarhi",
  "language": "ur",
  "bismillah": {
    "verse_key": "86:0",
    "text": "اللہ کے نام سے جو نہایت مہربان بہت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "قسم ہے آسمان کی اور اندھیرے میں روشن ہونے والے کی",
      "ayah_number": 1,
      "verse_key": "86:1"
    },
    {
      "number": 2,
      "text": "تجھے معلوم بھی ہے کہ وه رات کو نمودار ہونے والی چیز کیا ہے؟",
      "ayah_number": 2,
      "verse_key": "86:2"
    },
    {
      "number": 3,
      "text": "وه روشن ستاره ہے",
      "ayah_number": 3,
      "verse_key": "86:3"
    },
    {
      "number": 4,
      "text": "کوئی ایسا نہیں جس پر نگہبان فرشتہ نہ ہو",
      "ayah_number": 4,
      "verse_key": "86:4"
    },
    {
      "number": 5,
      "text": "انسان کو دیکھنا چاہئے کہ وه کس چیز سے پیدا کیا گیا ہے",
      "ayah_number": 5,
      "verse_key": "86:5"
    },
    {
      "number": 6,
      "text": "وه ایک اچھلتے پانی سے پیدا کیا گیا ہے",
      "ayah_number": 6,
      "verse_key": "86:6"
    },
    {
      "number": 7,
      "text": "جو پیٹھ اور سینے کے درمیان سے نکلتا ہے",
      "ayah_number": 7,
      "verse_key": "86:7"
    },
    {
      "number": 8,
      "text": "بیشک وه اسے پھیر ﻻنے پر یقیناً قدرت رکھنے واﻻ ہے",
      "ayah_number": 8,
      "verse_key": "86:8"
    },
    {
      "number": 9,
      "text": "جس دن پوشیده بھیدوں کی جانچ پڑتال ہوگی",
      "ayah_number": 9,
      "verse_key": "86:9"
    },
    {
      "number": 10,
      "text": "تو نہ ہوگا اس کے پاس کچھ زور نہ مدددگار",
      "ayah_number": 10,
      "verse_key": "86:10"
    },
    {
      "number": 11,
      "text": "بارش والے آسمان کی قسم!",
      "ayah_number": 11,
      "verse_key": "86:11"
    },
    {
      "number": 12,
      "text": "اور پھٹنے والی زمین کی قسم!",
      "ayah_number": 12,
      "verse_key": "86:12"
    },
    {
      "number": 13,
      "text": "بیشک یہ (قرآن) البتہ دو ٹوک فیصلہ کرنے واﻻ کلام ہے",
      "ayah_number": 13,
      "verse_key": "86:13"
    },
    {
      "number": 14,
      "text": "یہ ہنسی کی (اور بے فائده) بات نہیں",
      "ayah_number": 14,
      "verse_key": "86:14"
    },
    {
      "number": 15,
      "text": "البتہ کافر داؤ گھات میں ہیں",
      "ayah_number": 15,
      "verse_key": "86:15"
    },
    {
      "number": 16,
      "text": "اور میں بھی ایک چال چل رہا ہوں",
      "ayah_number": 16,
      "verse_key": "86:16"
    },
    {
      "number": 17,
      "text": "تو کافروں کو مہلت دے انہیں تھوڑے دنوں چھوڑ دے",
      "ayah_number": 17,
      "verse_key": "86:17"
    }
  ]
}