{
  "number": 92,
  "name": "Al-Lail",
  "arabicName": "سُورَةُ اللَّيۡلِ",
  "revelationType": "Meccan",
  "totalAyahs": 21,
  "translator": "Suhel Farooq Khan & Saifur Rahman Nadwi",
  "language": "Hindi",
  "ayahs": [
    {
      "number": 1,
      "text": "रात की क़सम जब (सूरज को) छिपा ले",
      "ayah_number": 1,
      "verse_key": "92:1"
    },
    {
      "number": 2,
      "text": "और दिन की क़सम जब ख़ूब रौशन हो",
      "ayah_number": 2,
      "verse_key": "92:2"
    },
    {
      "number": 3,
      "text": "और उस (ज़ात) की जिसने नर व मादा को पैदा किया",
      "ayah_number": 3,
      "verse_key": "92:3"
    },
    {
      "number": 4,
      "text": "कि बेशक तुम्हारी कोशिश तरह तरह की है",
      "ayah_number": 4,
      "verse_key": "92:4"
    },
    {
      "number": 5,
      "text": "तो जिसने सख़ावत की और अच्छी बात (इस्लाम) की तस्दीक़ की",
      "ayah_number": 5,
      "verse_key": "92:5"
    },
    {
      "number": 6,
      "text": "तो हम उसके लिए राहत व आसानी",
      "ayah_number": 6,
      "verse_key": "92:6"
    },
    {
      "number": 7,
      "text": "(जन्नत) के असबाब मुहय्या कर देंगे",
      "ayah_number": 7,
      "verse_key": "92:7"
    },
    {
      "number": 8,
      "text": "और जिसने बुख्ल किया, और बेपरवाई की",
      "ayah_number": 8,
      "verse_key": "92:8"
    },
    {
      "number": 9,
      "text": "और अच्छी बात को झुठलाया",
      "ayah_number": 9,
      "verse_key": "92:9"
    },
    {
      "number": 10,
      "text": "तो हम उसे सख्ती (जहन्नुम) में पहुँचा देंगे,",
      "ayah_number": 10,
      "verse_key": "92:10"
    },
    {
      "number": 11,
      "text": "और जब वह हलाक होगा तो उसका माल उसके कुछ भी काम न आएगा",
      "ayah_number": 11,
      "verse_key": "92:11"
    },
    {
      "number": 12,
      "text": "हमें राह दिखा देना ज़रूर है",
      "ayah_number": 12,
      "verse_key": "92:12"
    },
    {
      "number": 13,
      "text": "और आख़ेरत और दुनिया (दोनों) ख़ास हमारी चीज़े हैं",
      "ayah_number": 13,
      "verse_key": "92:13"
    },
    {
      "number": 14,
      "text": "तो हमने तुम्हें भड़कती हुई आग से डरा दिया",
      "ayah_number": 14,
      "verse_key": "92:14"
    },
    {
      "number": 15,
      "text": "उसमें बस वही दाख़िल होगा जो बड़ा बदबख्त है",
      "ayah_number": 15,
      "verse_key": "92:15"
    },
    {
      "number": 16,
      "text": "जिसने झुठलाया और मुँह फेर लिया और जो बड़ा परहेज़गार है",
      "ayah_number": 16,
      "verse_key": "92:16"
    },
    {
      "number": 17,
      "text": "वह उससे बचा लिया जाएगा",
      "ayah_number": 17,
      "verse_key": "92:17"
    },
    {
      "number": 18,
      "text": "जो अपना माल (ख़ुदा की राह) में देता है ताकि पाक हो जाए",
      "ayah_number": 18,
      "verse_key": "92:18"
    },
    {
      "number": 19,
      "text": "और लुत्फ ये है कि किसी का उस पर कोई एहसान नहीं जिसका उसे बदला दिया जाता है",
      "ayah_number": 19,
      "verse_key": "92:19"
    },
    {
      "number": 20,
      "text": "बल्कि (वह तो) सिर्फ अपने आलीशान परवरदिगार की ख़ुशनूदी हासिल करने के लिए (देता है)",
      "ayah_number": 20,
      "verse_key": "92:20"
    },
    {
      "number": 21,
      "text": "और वह अनक़रीब भी ख़ुश हो जाएगा",
      "ayah_number": 21,
      "verse_key": "92:21"
    }
  ]
}