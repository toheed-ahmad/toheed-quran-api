{
  "number": 87,
  "name": "Al-A'laa",
  "arabicName": "سُورَةُ الأَعۡلَىٰ",
  "revelationType": "Meccan",
  "totalAyahs": 19,
  "translator": "Suhel Farooq Khan & Saifur Rahman Nadwi",
  "language": "Hindi",
  "ayahs": [
    {
      "number": 1,
      "text": "ऐ रसूल अपने आलीशान परवरदिगार के नाम की तस्बीह करो",
      "ayah_number": 1,
      "verse_key": "87:1"
    },
    {
      "number": 2,
      "text": "जिसने (हर चीज़ को) पैदा किया",
      "ayah_number": 2,
      "verse_key": "87:2"
    },
    {
      "number": 3,
      "text": "और दुरूस्त किया और जिसने (उसका) अन्दाज़ा मुक़र्रर किया फिर राह बतायी",
      "ayah_number": 3,
      "verse_key": "87:3"
    },
    {
      "number": 4,
      "text": "और जिसने (हैवानात के लिए) चारा उगाया",
      "ayah_number": 4,
      "verse_key": "87:4"
    },
    {
      "number": 5,
      "text": "फिर ख़ुश्क उसे सियाह रंग का कूड़ा कर दिया",
      "ayah_number": 5,
      "verse_key": "87:5"
    },
    {
      "number": 6,
      "text": "हम तुम्हें (ऐसा) पढ़ा देंगे कि कभी भूलो ही नहीं",
      "ayah_number": 6,
      "verse_key": "87:6"
    },
    {
      "number": 7,
      "text": "मगर जो ख़ुदा चाहे (मन्सूख़ कर दे) बेशक वह खुली बात को भी जानता है और छुपे हुए को भी",
      "ayah_number": 7,
      "verse_key": "87:7"
    },
    {
      "number": 8,
      "text": "और हम तुमको आसान तरीके की तौफ़ीक़ देंगे",
      "ayah_number": 8,
      "verse_key": "87:8"
    },
    {
      "number": 9,
      "text": "तो जहाँ तक समझाना मुफ़ीद हो समझते रहो",
      "ayah_number": 9,
      "verse_key": "87:9"
    },
    {
      "number": 10,
      "text": "जो खौफ रखता हो वह तो फौरी समझ जाएगा",
      "ayah_number": 10,
      "verse_key": "87:10"
    },
    {
      "number": 11,
      "text": "और बदबख्त उससे पहलू तही करेगा",
      "ayah_number": 11,
      "verse_key": "87:11"
    },
    {
      "number": 12,
      "text": "जो (क़यामत में) बड़ी (तेज़) आग में दाख़िल होगा",
      "ayah_number": 12,
      "verse_key": "87:12"
    },
    {
      "number": 13,
      "text": "फिर न वहाँ मरेगा ही न जीयेगा",
      "ayah_number": 13,
      "verse_key": "87:13"
    },
    {
      "number": 14,
      "text": "वह यक़ीनन मुराद दिली को पहुँचा जो (शिर्क से) पाक हो",
      "ayah_number": 14,
      "verse_key": "87:14"
    },
    {
      "number": 15,
      "text": "और अपने परवरदिगार का ज़िक्र करता और नमाज़ पढ़ता रहा",
      "ayah_number": 15,
      "verse_key": "87:15"
    },
    {
      "number": 16,
      "text": "मगर तुम लोग दुनियावी ज़िन्दगी को तरजीह देते हो",
      "ayah_number": 16,
      "verse_key": "87:16"
    },
    {
      "number": 17,
      "text": "हालॉकि आख़ोरत कहीं बेहतर और देर पा है",
      "ayah_number": 17,
      "verse_key": "87:17"
    },
    {
      "number": 18,
      "text": "बेशक यही बात अगले सहीफ़ों",
      "ayah_number": 18,
      "verse_key": "87:18"
    },
    {
      "number": 19,
      "text": "इबराहीम और मूसा के सहीफ़ों में भी है",
      "ayah_number": 19,
      "verse_key": "87:19"
    }
  ]
}