{
  "number": 114,
  "name": "An-Naas",
  "arabicName": "سُورَةُ النَّاسِ",
  "revelationType": "Meccan",
  "totalAyahs": 6,
  "translator": "Suhel Farooq Khan & Saifur Rahman Nadwi",
  "language": "Hindi",
  "ayahs": [
    {
      "number": 1,
      "text": "(ऐ रसूल) तुम कह दो मैं लोगों के परवरदिगार",
      "ayah_number": 1,
      "verse_key": "114:1"
    },
    {
      "number": 2,
      "text": "लोगों के बादशाह",
      "ayah_number": 2,
      "verse_key": "114:2"
    },
    {
      "number": 3,
      "text": "लोगों के माबूद की (शैतानी)",
      "ayah_number": 3,
      "verse_key": "114:3"
    },
    {
      "number": 4,
      "text": "वसवसे की बुराई से पनाह माँगता हूँ",
      "ayah_number": 4,
      "verse_key": "114:4"
    },
    {
      "number": 5,
      "text": "जो (ख़ुदा के नाम से) पीछे हट जाता है जो लोगों के दिलों में वसवसे डाला करता है",
      "ayah_number": 5,
      "verse_key": "114:5"
    },
    {
      "number": 6,
      "text": "जिन्नात में से ख्वाह आदमियों में से",
      "ayah_number": 6,
      "verse_key": "114:6"
    }
  ]
}