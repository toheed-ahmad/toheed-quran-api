{
  "number": 90,
  "name": "Al-Balad",
  "arabicName": "سُورَةُ البَلَدِ",
  "revelationType": "Meccan",
  "totalAyahs": 20,
  "translator": "Suhel Farooq Khan & Saifur Rahman Nadwi",
  "language": "Hindi",
  "ayahs": [
    {
      "number": 1,
      "text": "मुझे इस शहर (मक्का) की कसम",
      "ayah_number": 1,
      "verse_key": "90:1"
    },
    {
      "number": 2,
      "text": "और तुम इसी शहर में तो रहते हो",
      "ayah_number": 2,
      "verse_key": "90:2"
    },
    {
      "number": 3,
      "text": "और (तुम्हारे) बाप (आदम) और उसकी औलाद की क़सम",
      "ayah_number": 3,
      "verse_key": "90:3"
    },
    {
      "number": 4,
      "text": "हमने इन्सान को मशक्क़त में (रहने वाला) पैदा किया है",
      "ayah_number": 4,
      "verse_key": "90:4"
    },
    {
      "number": 5,
      "text": "क्या वह ये समझता है कि उस पर कोई काबू न पा सकेगा",
      "ayah_number": 5,
      "verse_key": "90:5"
    },
    {
      "number": 6,
      "text": "वह कहता है कि मैने अलग़ारों माल उड़ा दिया",
      "ayah_number": 6,
      "verse_key": "90:6"
    },
    {
      "number": 7,
      "text": "क्या वह ये ख्याल रखता है कि उसको किसी ने देखा ही नहीं",
      "ayah_number": 7,
      "verse_key": "90:7"
    },
    {
      "number": 8,
      "text": "क्या हमने उसे दोनों ऑंखें और ज़बान",
      "ayah_number": 8,
      "verse_key": "90:8"
    },
    {
      "number": 9,
      "text": "और दोनों लब नहीं दिए (ज़रूर दिए)",
      "ayah_number": 9,
      "verse_key": "90:9"
    },
    {
      "number": 10,
      "text": "और उसको (अच्छी बुरी) दोनों राहें भी दिखा दीं",
      "ayah_number": 10,
      "verse_key": "90:10"
    },
    {
      "number": 11,
      "text": "फिर वह घाटी पर से होकर (क्यों) नहीं गुज़रा",
      "ayah_number": 11,
      "verse_key": "90:11"
    },
    {
      "number": 12,
      "text": "और तुमको क्या मालूम कि घाटी क्या है",
      "ayah_number": 12,
      "verse_key": "90:12"
    },
    {
      "number": 13,
      "text": "किसी (की) गर्दन का (गुलामी या कर्ज से) छुड़ाना",
      "ayah_number": 13,
      "verse_key": "90:13"
    },
    {
      "number": 14,
      "text": "या भूख के दिन रिश्तेदार यतीम या ख़ाकसार",
      "ayah_number": 14,
      "verse_key": "90:14"
    },
    {
      "number": 15,
      "text": "मोहताज को",
      "ayah_number": 15,
      "verse_key": "90:15"
    },
    {
      "number": 16,
      "text": "खाना खिलाना",
      "ayah_number": 16,
      "verse_key": "90:16"
    },
    {
      "number": 17,
      "text": "फिर तो उन लोगों में (शामिल) हो जाता जो ईमान लाए और सब्र की नसीहत और तरस खाने की वसीयत करते रहे",
      "ayah_number": 17,
      "verse_key": "90:17"
    },
    {
      "number": 18,
      "text": "यही लोग ख़ुश नसीब हैं",
      "ayah_number": 18,
      "verse_key": "90:18"
    },
    {
      "number": 19,
      "text": "और जिन लोगों ने हमारी आयतों से इन्कार किया है यही लोग बदबख्त हैं",
      "ayah_number": 19,
      "verse_key": "90:19"
    },
    {
      "number": 20,
      "text": "कि उनको आग में डाल कर हर तरफ से बन्द कर दिया जाएगा",
      "ayah_number": 20,
      "verse_key": "90:20"
    }
  ]
}