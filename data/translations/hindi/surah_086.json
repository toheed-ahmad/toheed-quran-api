{
  "number": 86,
  "name": "At-Taariq",
  "arabicName": "سُورَةُ الطَّارِقِ",
  "revelationType": "Meccan",
  "totalAyahs": 17,
  "translator": "Suhel Farooq Khan & Saifur Rahman Nadwi",
  "language": "Hindi",
  "ayahs": [
    {
      "number": 1,
      "text": "आसमान और रात को आने वाले की क़सम",
      "ayah_number": 1,
      "verse_key": "86:1"
    },
    {
      "number": 2,
      "text": "और तुमको क्या मालूम रात को आने वाला क्या है",
      "ayah_number": 2,
      "verse_key": "86:2"
    },
    {
      "number": 3,
      "text": "(वह) चमकता हुआ तारा है",
      "ayah_number": 3,
      "verse_key": "86:3"
    },
    {
      "number": 4,
      "text": "(इस बात की क़सम) कि कोई शख़्श ऐसा नहीं जिस पर निगेहबान मुक़र्रर नहीं",
      "ayah_number": 4,
      "verse_key": "86:4"
    },
    {
      "number": 5,
      "text": "तो इन्सान को देखना चाहिए कि वह किस चीज़ से पैदा हुआ हैं",
      "ayah_number": 5,
      "verse_key": "86:5"
    },
    {
      "number": 6,
      "text": "वह उछलते हुए पानी (मनी) से पैदा हुआ है",
      "ayah_number": 6,
      "verse_key": "86:6"
    },
    {
      "number": 7,
      "text": "जो पीठ और सीने की हड्डियों के बीच में से निकलता है",
      "ayah_number": 7,
      "verse_key": "86:7"
    },
    {
      "number": 8,
      "text": "बेशक ख़ुदा उसके दोबारा (पैदा) करने पर ज़रूर कुदरत रखता है",
      "ayah_number": 8,
      "verse_key": "86:8"
    },
    {
      "number": 9,
      "text": "जिस दिन दिलों के भेद जाँचे जाएँगे",
      "ayah_number": 9,
      "verse_key": "86:9"
    },
    {
      "number": 10,
      "text": "तो (उस दिन) उसका न कुछ ज़ोर चलेगा और न कोई मददगार होगा",
      "ayah_number": 10,
      "verse_key": "86:10"
    },
    {
      "number": 11,
      "text": "चक्कर (खाने) वाले आसमान की क़सम",
      "ayah_number": 11,
      "verse_key": "86:11"
    },
    {
      "number": 12,
      "text": "और फटने वाली (ज़मीन की क़सम)",
      "ayah_number": 12,
      "verse_key": "86:12"
    },
    {
      "number": 13,
      "text": "बेशक ये क़ुरान क़ौले फ़ैसल है",
      "ayah_number": 13,
      "verse_key": "86:13"
    },
    {
      "number": 14,
      "text": "और लग़ो नहीं है",
      "ayah_number": 14,
      "verse_key": "86:14"
    },
    {
      "number": 15,
      "text": "बेशक ये कुफ्फ़ार अपनी तदबीर कर रहे हैं",
      "ayah_number": 15,
      "verse_key": "86:15"
    },
    {
      "number": 16,
      "text": "और मैं अपनी तद्बीर कर रहा हूँ",
      "ayah_number": 16,
      "verse_key": "86:16"
    },
    {
      "number": 17,
      "text": "तो काफ़िरों को मोहलत दो बस उनको थोड़ी सी मोहलत दो",
      "ayah_number": 17,
      "verse_key": "86:17"
    }
  ]
}