{
  "number": 81,
  "name": "At-Takwir",
  "arabicName": "سُورَةُ التَّكۡوِيرِ",
  "revelationType": "Meccan",
  "totalAyahs": 29,
  "translator": "Suhel Farooq Khan & Saifur Rahman Nadwi",
  "language": "Hindi",
  "ayahs": [
    {
      "number": 1,
      "text": "जिस वक्त आफ़ताब की चादर को लपेट लिया जाएगा",
      "ayah_number": 1,
      "verse_key": "81:1"
    },
    {
      "number": 2,
      "text": "और जिस वक्त तारे गिर पडेग़ें",
      "ayah_number": 2,
      "verse_key": "81:2"
    },
    {
      "number": 3,
      "text": "और जब पहाड़ चलाए जाएंगें",
      "ayah_number": 3,
      "verse_key": "81:3"
    },
    {
      "number": 4,
      "text": "और जब अनक़रीब जनने वाली ऊंटनियों बेकार कर दी जाएंगी",
      "ayah_number": 4,
      "verse_key": "81:4"
    },
    {
      "number": 5,
      "text": "और जिस वक्त वहशी जानवर इकट्ठा किये जायेंगे",
      "ayah_number": 5,
      "verse_key": "81:5"
    },
    {
      "number": 6,
      "text": "और जिस वक्त दरिया आग हो जायेंगे",
      "ayah_number": 6,
      "verse_key": "81:6"
    },
    {
      "number": 7,
      "text": "और जिस वक्त रुहें हवियों से मिला दी जाएंगी",
      "ayah_number": 7,
      "verse_key": "81:7"
    },
    {
      "number": 8,
      "text": "और जिस वक्त ज़िन्दा दर गोर लड़की से पूछा जाएगा",
      "ayah_number": 8,
      "verse_key": "81:8"
    },
    {
      "number": 9,
      "text": "कि वह किस गुनाह के बदले मारी गयी",
      "ayah_number": 9,
      "verse_key": "81:9"
    },
    {
      "number": 10,
      "text": "और जिस वक्त (आमाल के) दफ्तर खोले जाएं",
      "ayah_number": 10,
      "verse_key": "81:10"
    },
    {
      "number": 11,
      "text": "और जिस वक्त आसमान का छिलका उतारा जाएगा",
      "ayah_number": 11,
      "verse_key": "81:11"
    },
    {
      "number": 12,
      "text": "और जब दोज़ख़ (की आग) भड़कायी जाएगी",
      "ayah_number": 12,
      "verse_key": "81:12"
    },
    {
      "number": 13,
      "text": "और जब बेहिश्त क़रीब कर दी जाएगी",
      "ayah_number": 13,
      "verse_key": "81:13"
    },
    {
      "number": 14,
      "text": "तब हर शख़्श मालूम करेगा कि वह क्या (आमाल) लेकर आया",
      "ayah_number": 14,
      "verse_key": "81:14"
    },
    {
      "number": 15,
      "text": "तो मुझे उन सितारों की क़सम जो चलते चलते पीछे हट जाते",
      "ayah_number": 15,
      "verse_key": "81:15"
    },
    {
      "number": 16,
      "text": "और ग़ायब होते हैं",
      "ayah_number": 16,
      "verse_key": "81:16"
    },
    {
      "number": 17,
      "text": "और रात की क़सम जब ख़त्म होने को आए",
      "ayah_number": 17,
      "verse_key": "81:17"
    },
    {
      "number": 18,
      "text": "और सुबह की क़सम जब रौशन हो जाए",
      "ayah_number": 18,
      "verse_key": "81:18"
    },
    {
      "number": 19,
      "text": "कि बेशक यें (क़ुरान) एक मुअज़िज़ फरिश्ता (जिबरील की ज़बान का पैग़ाम है",
      "ayah_number": 19,
      "verse_key": "81:19"
    },
    {
      "number": 20,
      "text": "जो बड़े क़वी अर्श के मालिक की बारगाह में बुलन्द रुतबा है",
      "ayah_number": 20,
      "verse_key": "81:20"
    },
    {
      "number": 21,
      "text": "वहाँ (सब फरिश्तों का) सरदार अमानतदार है",
      "ayah_number": 21,
      "verse_key": "81:21"
    },
    {
      "number": 22,
      "text": "और (मक्के वालों) तुम्हारे साथी मोहम्मद दीवाने नहीं हैं",
      "ayah_number": 22,
      "verse_key": "81:22"
    },
    {
      "number": 23,
      "text": "और बेशक उन्होनें जिबरील को (आसमान के) खुले (शरक़ी) किनारे पर देखा है",
      "ayah_number": 23,
      "verse_key": "81:23"
    },
    {
      "number": 24,
      "text": "और वह ग़ैब की बातों के ज़ाहिर करने में बख़ील नहीं",
      "ayah_number": 24,
      "verse_key": "81:24"
    },
    {
      "number": 25,
      "text": "और न यह मरदूद शैतान का क़ौल है",
      "ayah_number": 25,
      "verse_key": "81:25"
    },
    {
      "number": 26,
      "text": "फिर तुम कहाँ जाते हो",
      "ayah_number": 26,
      "verse_key": "81:26"
    },
    {
      "number": 27,
      "text": "ये सारे जहॉन के लोगों के लिए बस नसीहत है",
      "ayah_number": 27,
      "verse_key": "81:27"
    },
    {
      "number": 28,
      "text": "(मगर) उसी के लिए जो तुममें सीधी राह चले",
      "ayah_number": 28,
      "verse_key": "81:28"
    },
    {
      "number": 29,
      "text": "और तुम तो सारे जहॉन के पालने वाले ख़ुदा के चाहे बग़ैर कुछ भी चाह नहीं सकते",
      "ayah_number": 29,
      "verse_key": "81:29"
    }
  ]
}