{
  "number": 88,
  "name": "Al-Ghaashiya",
  "arabicName": "سُورَةُ الغَاشِيَةِ",
  "revelationType": "Meccan",
  "totalAyahs": 26,
  "translator": "Suhel Farooq Khan & Saifur Rahman Nadwi",
  "language": "Hindi",
  "ayahs": [
    {
      "number": 1,
      "text": "भला तुमको ढाँप लेने वाली मुसीबत (क़यामत) का हाल मालुम हुआ है",
      "ayah_number": 1,
      "verse_key": "88:1"
    },
    {
      "number": 2,
      "text": "उस दिन बहुत से चेहरे ज़लील रूसवा होंगे",
      "ayah_number": 2,
      "verse_key": "88:2"
    },
    {
      "number": 3,
      "text": "(तौक़ व जंज़ीर से) मयक्क़त करने वाले",
      "ayah_number": 3,
      "verse_key": "88:3"
    },
    {
      "number": 4,
      "text": "थके माँदे दहकती हुई आग में दाखिल होंगे",
      "ayah_number": 4,
      "verse_key": "88:4"
    },
    {
      "number": 5,
      "text": "उन्हें एक खौलते हुए चशमें का पानी पिलाया जाएगा",
      "ayah_number": 5,
      "verse_key": "88:5"
    },
    {
      "number": 6,
      "text": "ख़ारदार झाड़ी के सिवा उनके लिए कोई खाना नहीं",
      "ayah_number": 6,
      "verse_key": "88:6"
    },
    {
      "number": 7,
      "text": "जो मोटाई पैदा करे न भूख में कुछ काम आएगा",
      "ayah_number": 7,
      "verse_key": "88:7"
    },
    {
      "number": 8,
      "text": "(और) बहुत से चेहरे उस दिन तरो ताज़ा होंगे",
      "ayah_number": 8,
      "verse_key": "88:8"
    },
    {
      "number": 9,
      "text": "अपनी कोशिश (के नतीजे) पर शादमान",
      "ayah_number": 9,
      "verse_key": "88:9"
    },
    {
      "number": 10,
      "text": "एक आलीशान बाग़ में",
      "ayah_number": 10,
      "verse_key": "88:10"
    },
    {
      "number": 11,
      "text": "वहाँ कोई लग़ो बात सुनेंगे ही नहीं",
      "ayah_number": 11,
      "verse_key": "88:11"
    },
    {
      "number": 12,
      "text": "उसमें चश्में जारी होंगें",
      "ayah_number": 12,
      "verse_key": "88:12"
    },
    {
      "number": 13,
      "text": "उसमें ऊँचे ऊँचे तख्त बिछे होंगे",
      "ayah_number": 13,
      "verse_key": "88:13"
    },
    {
      "number": 14,
      "text": "और (उनके किनारे) गिलास रखे होंगे",
      "ayah_number": 14,
      "verse_key": "88:14"
    },
    {
      "number": 15,
      "text": "और गाँव तकिए क़तार की क़तार लगे होंगे",
      "ayah_number": 15,
      "verse_key": "88:15"
    },
    {
      "number": 16,
      "text": "और नफ़ीस मसनदे बिछी हुई",
      "ayah_number": 16,
      "verse_key": "88:16"
    },
    {
      "number": 17,
      "text": "तो क्या ये लोग ऊँट की तरह ग़ौर नहीं करते कि कैसा अजीब पैदा किया गया है",
      "ayah_number": 17,
      "verse_key": "88:17"
    },
    {
      "number": 18,
      "text": "और आसमान की तरफ कि क्या बुलन्द बनाया गया है",
      "ayah_number": 18,
      "verse_key": "88:18"
    },
    {
      "number": 19,
      "text": "और पहाड़ों की तरफ़ कि किस तरह खड़े किए गए हैं",
      "ayah_number": 19,
      "verse_key": "88:19"
    },
    {
      "number": 20,
      "text": "और ज़मीन की तरफ कि किस तरह बिछायी गयी है",
      "ayah_number": 20,
      "verse_key": "88:20"
    },
    {
      "number": 21,
      "text": "तो तुम नसीहत करते रहो तुम तो बस नसीहत करने वाले हो",
      "ayah_number": 21,
      "verse_key": "88:21"
    },
    {
      "number": 22,
      "text": "तुम कुछ उन पर दरोग़ा तो हो नहीं",
      "ayah_number": 22,
      "verse_key": "88:22"
    },
    {
      "number": 23,
      "text": "हाँ जिसने मुँह फेर लिया",
      "ayah_number": 23,
      "verse_key": "88:23"
    },
    {
      "number": 24,
      "text": "और न माना तो ख़ुदा उसको बहुत बड़े अज़ाब की सज़ा देगा",
      "ayah_number": 24,
      "verse_key": "88:24"
    },
    {
      "number": 25,
      "text": "बेशक उनको हमारी तरफ़ लौट कर आना है",
      "ayah_number": 25,
      "verse_key": "88:25"
    },
    {
      "number": 26,
      "text": "फिर उनका हिसाब हमारे ज़िम्मे है",
      "ayah_number": 26,
      "verse_key": "88:26"
    }
  ]
}