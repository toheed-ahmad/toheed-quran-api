{
  "number": 82,
  "name": "Al-Infitaar",
  "arabicName": "سُورَةُ الانفِطَارِ",
  "revelationType": "Meccan",
  "totalAyahs": 19,
  "translator": "Suhel Farooq Khan & Saifur Rahman Nadwi",
  "language": "Hindi",
  "ayahs": [
    {
      "number": 1,
      "text": "जब आसमान तर्ख़ जाएगा",
      "ayah_number": 1,
      "verse_key": "82:1"
    },
    {
      "number": 2,
      "text": "और जब तारे झड़ पड़ेंगे",
      "ayah_number": 2,
      "verse_key": "82:2"
    },
    {
      "number": 3,
      "text": "और जब दरिया बह (कर एक दूसरे से मिल) जाएँगे",
      "ayah_number": 3,
      "verse_key": "82:3"
    },
    {
      "number": 4,
      "text": "और जब कब्रें उखाड़ दी जाएँगी",
      "ayah_number": 4,
      "verse_key": "82:4"
    },
    {
      "number": 5,
      "text": "तब हर शख़्श को मालूम हो जाएगा कि उसने आगे क्या भेजा था और पीछे क्या छोड़ा था",
      "ayah_number": 5,
      "verse_key": "82:5"
    },
    {
      "number": 6,
      "text": "ऐ इन्सान तुम्हें अपने परवरदिगार के बारे में किस चीज़ ने धोका दिया",
      "ayah_number": 6,
      "verse_key": "82:6"
    },
    {
      "number": 7,
      "text": "जिसने तुझे पैदा किया तो तुझे दुरूस्त बनाया और मुनासिब आज़ा दिए",
      "ayah_number": 7,
      "verse_key": "82:7"
    },
    {
      "number": 8,
      "text": "और जिस सूरत में उसने चाहा तेरे जोड़ बन्द मिलाए",
      "ayah_number": 8,
      "verse_key": "82:8"
    },
    {
      "number": 9,
      "text": "हाँ बात ये है कि तुम लोग जज़ा (के दिन) को झुठलाते हो",
      "ayah_number": 9,
      "verse_key": "82:9"
    },
    {
      "number": 10,
      "text": "हालॉकि तुम पर निगेहबान मुक़र्रर हैं",
      "ayah_number": 10,
      "verse_key": "82:10"
    },
    {
      "number": 11,
      "text": "बुर्ज़ुग लोग (फरिश्ते सब बातों को) लिखने वाले (केरामन क़ातेबीन)",
      "ayah_number": 11,
      "verse_key": "82:11"
    },
    {
      "number": 12,
      "text": "जो कुछ तुम करते हो वह सब जानते हैं",
      "ayah_number": 12,
      "verse_key": "82:12"
    },
    {
      "number": 13,
      "text": "बेशक नेको कार (बेहिश्त की) नेअमतों में होंगे",
      "ayah_number": 13,
      "verse_key": "82:13"
    },
    {
      "number": 14,
      "text": "और बदकार लोग यक़ीनन जहन्नुम में जज़ा के दिन",
      "ayah_number": 14,
      "verse_key": "82:14"
    },
    {
      "number": 15,
      "text": "उसी में झोंके जाएँगे",
      "ayah_number": 15,
      "verse_key": "82:15"
    },
    {
      "number": 16,
      "text": "और वह लोग उससे छुप न सकेंगे",
      "ayah_number": 16,
      "verse_key": "82:16"
    },
    {
      "number": 17,
      "text": "और तुम्हें क्या मालूम कि जज़ा का दिन क्या है",
      "ayah_number": 17,
      "verse_key": "82:17"
    },
    {
      "number": 18,
      "text": "फिर तुम्हें क्या मालूम कि जज़ा का दिन क्या चीज़ है",
      "ayah_number": 18,
      "verse_key": "82:18"
    },
    {
      "number": 19,
      "text": "उस दिन कोई शख़्श किसी शख़्श की भलाई न कर सकेगा और उस दिन हुक्म सिर्फ ख़ुदा ही का होगा",
      "ayah_number": 19,
      "verse_key": "82:19"
    }
  ]
}