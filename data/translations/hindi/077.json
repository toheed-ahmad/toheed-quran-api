{
  "number": 77,
  "name": "Al-Mursalaat",
  "arabicName": "سُورَةُ المُرۡسَلَاتِ",
  "revelationType": "Meccan",
  "totalAyahs": 50,
  "translator": "Suhel Farooq Khan & Saifur Rahman Nadwi",
  "language": "Hindi",
  "ayahs": [
    {
      "number": 1,
      "text": "हवाओं की क़सम जो (पहले) धीमी चलती हैं",
      "ayah_number": 1,
      "verse_key": "77:1"
    },
    {
      "number": 2,
      "text": "फिर ज़ोर पकड़ के ऑंधी हो जाती हैं",
      "ayah_number": 2,
      "verse_key": "77:2"
    },
    {
      "number": 3,
      "text": "और (बादलों को) उभार कर फैला देती हैं",
      "ayah_number": 3,
      "verse_key": "77:3"
    },
    {
      "number": 4,
      "text": "फिर (उनको) फाड़ कर जुदा कर देती हैं",
      "ayah_number": 4,
      "verse_key": "77:4"
    },
    {
      "number": 5,
      "text": "फिर फरिश्तों की क़सम जो वही लाते हैं",
      "ayah_number": 5,
      "verse_key": "77:5"
    },
    {
      "number": 6,
      "text": "ताकि हुज्जत तमाम हो और डरा दिया जाए",
      "ayah_number": 6,
      "verse_key": "77:6"
    },
    {
      "number": 7,
      "text": "कि जिस बात का तुमसे वायदा किया जाता है वह ज़रूर होकर रहेगा",
      "ayah_number": 7,
      "verse_key": "77:7"
    },
    {
      "number": 8,
      "text": "फिर जब तारों की चमक जाती रहेगी",
      "ayah_number": 8,
      "verse_key": "77:8"
    },
    {
      "number": 9,
      "text": "और जब आसमान फट जाएगा",
      "ayah_number": 9,
      "verse_key": "77:9"
    },
    {
      "number": 10,
      "text": "और जब पहाड़ (रूई की तरह) उड़े उड़े फिरेंगे",
      "ayah_number": 10,
      "verse_key": "77:10"
    },
    {
      "number": 11,
      "text": "और जब पैग़म्बर लोग एक मुअय्यन वक्त पर जमा किए जाएँगे",
      "ayah_number": 11,
      "verse_key": "77:11"
    },
    {
      "number": 12,
      "text": "(फिर) भला इन (बातों) में किस दिन के लिए ताख़ीर की गयी है",
      "ayah_number": 12,
      "verse_key": "77:12"
    },
    {
      "number": 13,
      "text": "फ़ैसले के दिन के लिए",
      "ayah_number": 13,
      "verse_key": "77:13"
    },
    {
      "number": 14,
      "text": "और तुमको क्या मालूम की फ़ैसले का दिन क्या है",
      "ayah_number": 14,
      "verse_key": "77:14"
    },
    {
      "number": 15,
      "text": "उस दिन झुठलाने वालों की मिट्टी ख़राब है",
      "ayah_number": 15,
      "verse_key": "77:15"
    },
    {
      "number": 16,
      "text": "क्या हमने अगलों को हलाक नहीं किया",
      "ayah_number": 16,
      "verse_key": "77:16"
    },
    {
      "number": 17,
      "text": "फिर उनके पीछे पीछे पिछलों को भी चलता करेंगे",
      "ayah_number": 17,
      "verse_key": "77:17"
    },
    {
      "number": 18,
      "text": "हम गुनेहगारों के साथ ऐसा ही किया करते हैं",
      "ayah_number": 18,
      "verse_key": "77:18"
    },
    {
      "number": 19,
      "text": "उस दिन झुठलाने वालों की मिट्टी ख़राब है",
      "ayah_number": 19,
      "verse_key": "77:19"
    },
    {
      "number": 20,
      "text": "क्या हमने तुमको ज़लील पानी (मनी) से पैदा नहीं किया",
      "ayah_number": 20,
      "verse_key": "77:20"
    },
    {
      "number": 21,
      "text": "फिर हमने उसको एक मुअय्यन वक्त तक",
      "ayah_number": 21,
      "verse_key": "77:21"
    },
    {
      "number": 22,
      "text": "एक महफूज़ मक़ाम (रहम) में रखा",
      "ayah_number": 22,
      "verse_key": "77:22"
    },
    {
      "number": 23,
      "text": "फिर (उसका) एक अन्दाज़ा मुक़र्रर किया तो हम कैसा अच्छा अन्दाज़ा मुक़र्रर करने वाले हैं",
      "ayah_number": 23,
      "verse_key": "77:23"
    },
    {
      "number": 24,
      "text": "उन दिन झुठलाने वालों की ख़राबी है",
      "ayah_number": 24,
      "verse_key": "77:24"
    },
    {
      "number": 25,
      "text": "क्या हमने ज़मीन को ज़िन्दों और मुर्दों को समेटने वाली नहीं बनाया",
      "ayah_number": 25,
      "verse_key": "77:25"
    },
    {
      "number": 26,
      "text": "और उसमें ऊँचे ऊँचे अटल पहाड़ रख दिए",
      "ayah_number": 26,
      "verse_key": "77:26"
    },
    {
      "number": 27,
      "text": "और तुम लोगों को मीठा पानी पिलाया",
      "ayah_number": 27,
      "verse_key": "77:27"
    },
    {
      "number": 28,
      "text": "उस दिन झुठलाने वालों की ख़राबी है",
      "ayah_number": 28,
      "verse_key": "77:28"
    },
    {
      "number": 29,
      "text": "जिस चीज़ को तुम झुठलाया करते थे अब उसकी तरफ़ चलो",
      "ayah_number": 29,
      "verse_key": "77:29"
    },
    {
      "number": 30,
      "text": "(धुएँ के) साये की तरफ़ चलो जिसके तीन हिस्से हैं",
      "ayah_number": 30,
      "verse_key": "77:30"
    },
    {
      "number": 31,
      "text": "जिसमें न ठन्डक है और न जहन्नुम की लपक से बचाएगा",
      "ayah_number": 31,
      "verse_key": "77:31"
    },
    {
      "number": 32,
      "text": "उससे इतने बड़े बड़े अंगारे बरसते होंगे जैसे महल",
      "ayah_number": 32,
      "verse_key": "77:32"
    },
    {
      "number": 33,
      "text": "गोया ज़र्द रंग के ऊँट हैं",
      "ayah_number": 33,
      "verse_key": "77:33"
    },
    {
      "number": 34,
      "text": "उस दिन झुठलाने वालों की ख़राबी है",
      "ayah_number": 34,
      "verse_key": "77:34"
    },
    {
      "number": 35,
      "text": "ये वह दिन होगा कि लोग लब तक न हिला सकेंगे",
      "ayah_number": 35,
      "verse_key": "77:35"
    },
    {
      "number": 36,
      "text": "और उनको इजाज़त दी जाएगी कि कुछ उज्र माअज़ेरत कर सकें",
      "ayah_number": 36,
      "verse_key": "77:36"
    },
    {
      "number": 37,
      "text": "उस दिन झुठलाने वालों की तबाही है",
      "ayah_number": 37,
      "verse_key": "77:37"
    },
    {
      "number": 38,
      "text": "यही फैसले का दिन है (जिस में) हमने तुमको और अगलों को इकट्ठा किया है",
      "ayah_number": 38,
      "verse_key": "77:38"
    },
    {
      "number": 39,
      "text": "तो अगर तुम्हें कोई दाँव करना हो तो आओ चल चुको",
      "ayah_number": 39,
      "verse_key": "77:39"
    },
    {
      "number": 40,
      "text": "उस दिन झुठलाने वालों की ख़राबी है",
      "ayah_number": 40,
      "verse_key": "77:40"
    },
    {
      "number": 41,
      "text": "बेशक परहेज़गार लोग (दरख्तों की) घनी छाँव में होंगे",
      "ayah_number": 41,
      "verse_key": "77:41"
    },
    {
      "number": 42,
      "text": "और चश्मों और आदमियों में जो उन्हें मरग़ूब हो",
      "ayah_number": 42,
      "verse_key": "77:42"
    },
    {
      "number": 43,
      "text": "(दुनिया में) जो अमल करते थे उसके बदले में मज़े से खाओ पियो",
      "ayah_number": 43,
      "verse_key": "77:43"
    },
    {
      "number": 44,
      "text": "मुबारक हम नेकोकारों को ऐसा ही बदला दिया करते हैं",
      "ayah_number": 44,
      "verse_key": "77:44"
    },
    {
      "number": 45,
      "text": "उस दिन झुठलाने वालों की ख़राबी है",
      "ayah_number": 45,
      "verse_key": "77:45"
    },
    {
      "number": 46,
      "text": "(झुठलाने वालों) चन्द दिन चैन से खा पी लो तुम बेशक गुनेहगार हो",
      "ayah_number": 46,
      "verse_key": "77:46"
    },
    {
      "number": 47,
      "text": "उस दिन झुठलाने वालों की मिट्टी ख़राब है",
      "ayah_number": 47,
      "verse_key": "77:47"
    },
    {
      "number": 48,
      "text": "और जब उनसे कहा जाता है कि रूकूउ करों तो रूकूउ नहीं करते",
      "ayah_number": 48,
      "verse_key": "77:48"
    },
    {
      "number": 49,
      "text": "उस दिन झुठलाने वालों की ख़राबी है",
      "ayah_number": 49,
      "verse_key": "77:49"
    },
    {
      "number": 50,
      "text": "अब इसके बाद ये किस बात पर ईमान लाएँगे",
      "ayah_number": 50,
      "verse_key": "77:50"
    }
  ]
}