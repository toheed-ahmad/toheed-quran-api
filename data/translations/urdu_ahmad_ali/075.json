{
  "number": 75,
  "name": "Al-Qiyaama",
  "arabicName": "سُورَةُ القِيَامَةِ",
  "revelationType": "Meccan",
  "totalAyahs": 40,
  "language": "ur",
  "bismillah": {
    "verse_key": "75:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "قیامت کے دن کی قسم ہے",
      "ayah_number": 1,
      "verse_key": "75:1"
    },
    {
      "number": 2,
      "text": "اور پشیمان ہونے والے شخص کی قسم ہے",
      "ayah_number": 2,
      "verse_key": "75:2"
    },
    {
      "number": 3,
      "text": "کیا انسان سمجھتا ہے کہ ہم اس کی ہڈیاں جمع نہ کریں گے",
      "ayah_number": 3,
      "verse_key": "75:3"
    },
    {
      "number": 4,
      "text": "ہاں ہم تو اس پر قادر ہیں کہ اس کی پور پور درست کر دیں",
      "ayah_number": 4,
      "verse_key": "75:4"
    },
    {
      "number": 5,
      "text": "بلکہ انسان تو چاہتا ہے کہ آئندہ بھی نافرمانی کرتا رہے",
      "ayah_number": 5,
      "verse_key": "75:5"
    },
    {
      "number": 6,
      "text": "پوچھتا ہےکہ قیامت کا دن کب ہو گا",
      "ayah_number": 6,
      "verse_key": "75:6"
    },
    {
      "number": 7,
      "text": "پس جب آنکھیں چندھیا جائیں گی",
      "ayah_number": 7,
      "verse_key": "75:7"
    },
    {
      "number": 8,
      "text": "اور چاند بے نور ہو جائے گا",
      "ayah_number": 8,
      "verse_key": "75:8"
    },
    {
      "number": 9,
      "text": "اور سورج اور چاند اکھٹے کیے جائیں گے",
      "ayah_number": 9,
      "verse_key": "75:9"
    },
    {
      "number": 10,
      "text": "اس دن انسان کہے گا کہ بھاگنے کی جگہ کہاں ہے",
      "ayah_number": 10,
      "verse_key": "75:10"
    },
    {
      "number": 11,
      "text": "ہر گز نہیں کہیں پناہ نہیں",
      "ayah_number": 11,
      "verse_key": "75:11"
    },
    {
      "number": 12,
      "text": "اس دن آپ کے رب ہی کی طرف ٹھکانہ ہے",
      "ayah_number": 12,
      "verse_key": "75:12"
    },
    {
      "number": 13,
      "text": "اس دن انسان کو بتا دیا جائے گا کہ وہ کیا لایا اور کیا چھوڑ آیا",
      "ayah_number": 13,
      "verse_key": "75:13"
    },
    {
      "number": 14,
      "text": "بلکہ انسان اپنے اوپر خود شاہد ہے",
      "ayah_number": 14,
      "verse_key": "75:14"
    },
    {
      "number": 15,
      "text": "گو وہ کتنے ہی بہانے پیش کرے",
      "ayah_number": 15,
      "verse_key": "75:15"
    },
    {
      "number": 16,
      "text": "آپ (وحی ختم ہونے سے پہلے) قرآن پراپنی زبان نہ ہلایا کیجیئے تاکہ آپ اسے جلدی جلدی لیں",
      "ayah_number": 16,
      "verse_key": "75:16"
    },
    {
      "number": 17,
      "text": "بے شک اس کا جمع کرنا اور پڑھا دینا ہمارے ذمہ ہے",
      "ayah_number": 17,
      "verse_key": "75:17"
    },
    {
      "number": 18,
      "text": "پھر جب ہم ا سکی قرأت کر چکیں تو اس کی قرأت کا اتباع کیجیئے",
      "ayah_number": 18,
      "verse_key": "75:18"
    },
    {
      "number": 19,
      "text": "پھر بے شک اس کا کھول کر بیان کرنا ہمارے ذمہ ہے",
      "ayah_number": 19,
      "verse_key": "75:19"
    },
    {
      "number": 20,
      "text": "ہر گز نہیں بلکہ تم تو دنیا کو چاہتے ہو",
      "ayah_number": 20,
      "verse_key": "75:20"
    },
    {
      "number": 21,
      "text": "اور آخرت کو چھوڑتے ہو",
      "ayah_number": 21,
      "verse_key": "75:21"
    },
    {
      "number": 22,
      "text": "کئی چہرے اس دن تر و تازہ ہو ں گے",
      "ayah_number": 22,
      "verse_key": "75:22"
    },
    {
      "number": 23,
      "text": "اپنے رب کی طرف دیکھتے ہوں گے",
      "ayah_number": 23,
      "verse_key": "75:23"
    },
    {
      "number": 24,
      "text": "اور کتنے چہرے اس دن اداس ہو ں گے",
      "ayah_number": 24,
      "verse_key": "75:24"
    },
    {
      "number": 25,
      "text": "خیال کر رہے ہوں گے کہ ان کے ساتھ کمر توڑ دینے والی سختی کی جائے گی",
      "ayah_number": 25,
      "verse_key": "75:25"
    },
    {
      "number": 26,
      "text": "نہیں نہیں جب کہ جان گلے تک پہنچ جائے گی",
      "ayah_number": 26,
      "verse_key": "75:26"
    },
    {
      "number": 27,
      "text": "اورلوگ کہیں گے کوئی جھاڑنے والا ہے",
      "ayah_number": 27,
      "verse_key": "75:27"
    },
    {
      "number": 28,
      "text": "اور وہ خیال کرے گا کہ یہ وقت جدائی کا ہے",
      "ayah_number": 28,
      "verse_key": "75:28"
    },
    {
      "number": 29,
      "text": "اور ایک پنڈلی دوسری پنڈلی سے لپٹ جائے گی",
      "ayah_number": 29,
      "verse_key": "75:29"
    },
    {
      "number": 30,
      "text": "تیرے رب کی طرف اس دن چلنا ہوگا",
      "ayah_number": 30,
      "verse_key": "75:30"
    },
    {
      "number": 31,
      "text": "پھر نہ تو اس نے تصدیق کی اور نہ نماز پڑھی",
      "ayah_number": 31,
      "verse_key": "75:31"
    },
    {
      "number": 32,
      "text": "بلکہ جھٹلایا اورمنہ موڑا",
      "ayah_number": 32,
      "verse_key": "75:32"
    },
    {
      "number": 33,
      "text": "پھر اپنے گھر والوں کی طرف اکڑتا ہوا چلا گیا",
      "ayah_number": 33,
      "verse_key": "75:33"
    },
    {
      "number": 34,
      "text": "(اے انسان) تیرے لیے افسوس پرافسوس ہے",
      "ayah_number": 34,
      "verse_key": "75:34"
    },
    {
      "number": 35,
      "text": "پھر تیرے لیے افسوس پر افسوس ہے",
      "ayah_number": 35,
      "verse_key": "75:35"
    },
    {
      "number": 36,
      "text": "کیاانسان یہ سمجھ رہا ہے کہ وہ یونہی چھوڑ دیا جائے گا",
      "ayah_number": 36,
      "verse_key": "75:36"
    },
    {
      "number": 37,
      "text": "کیا وہ ٹپکتی منی کی ایک بوند نہ تھا",
      "ayah_number": 37,
      "verse_key": "75:37"
    },
    {
      "number": 38,
      "text": "پھر وہ لوتھڑا بنا پھر الله نے اسے بنا کر ٹھیک کیا",
      "ayah_number": 38,
      "verse_key": "75:38"
    },
    {
      "number": 39,
      "text": "پھر اس نے مرد و عورت کا جوڑا بنایا",
      "ayah_number": 39,
      "verse_key": "75:39"
    },
    {
      "number": 40,
      "text": "پھر کیا وہ الله مردے زندہ کردینے پر قادر نہیں",
      "ayah_number": 40,
      "verse_key": "75:40"
    }
  ]
}