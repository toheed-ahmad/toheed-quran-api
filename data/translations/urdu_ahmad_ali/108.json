{
  "number": 108,
  "name": "Al-Kawthar",
  "arabicName": "سُورَةُ الكَوۡثَرِ",
  "revelationType": "Meccan",
  "totalAyahs": 3,
  "language": "ur",
  "bismillah": {
    "verse_key": "108:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "بے شک ہم نے آپ کو کوثر دی",
      "ayah_number": 1,
      "verse_key": "108:1"
    },
    {
      "number": 2,
      "text": "پس اپنے رب کے لیے نماز پڑھیئے اور قربانی کیجیئے",
      "ayah_number": 2,
      "verse_key": "108:2"
    },
    {
      "number": 3,
      "text": "بے شک آپ کا دشمن ہی بے نام و نشان ہے",
      "ayah_number": 3,
      "verse_key": "108:3"
    }
  ]
}