{
  "number": 84,
  "name": "Al-Inshiqaaq",
  "arabicName": "سُورَةُ الانشِقَاقِ",
  "revelationType": "Meccan",
  "totalAyahs": 25,
  "language": "ur",
  "bismillah": {
    "verse_key": "84:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "جب آسمان پھٹ جائے گا",
      "ayah_number": 1,
      "verse_key": "84:1"
    },
    {
      "number": 2,
      "text": "اور اپنے رب کا حکم سن لے گا اور وہ اسی لائق ہے",
      "ayah_number": 2,
      "verse_key": "84:2"
    },
    {
      "number": 3,
      "text": "اور جب زمین پھیلا دی جائے گی",
      "ayah_number": 3,
      "verse_key": "84:3"
    },
    {
      "number": 4,
      "text": "اور جو کچھ اس میں ہے ڈال دے گی اور خالی ہو جائے گی",
      "ayah_number": 4,
      "verse_key": "84:4"
    },
    {
      "number": 5,
      "text": "اور اپنے رب کا حکم سن لے گی اور وہ اسی لائق ہے",
      "ayah_number": 5,
      "verse_key": "84:5"
    },
    {
      "number": 6,
      "text": "اے انسان تو اپنے رب کے پاس پہنچنے تک کام میں کوشش کر رہا ہے پھر اس سے جا ملے گا",
      "ayah_number": 6,
      "verse_key": "84:6"
    },
    {
      "number": 7,
      "text": "پھر جس کا اعمال نامہ اس کے دائیں ہاتھ میں دیا گیا",
      "ayah_number": 7,
      "verse_key": "84:7"
    },
    {
      "number": 8,
      "text": "تو اس سے آسانی کے ساتھ حساب لیا جائے گا",
      "ayah_number": 8,
      "verse_key": "84:8"
    },
    {
      "number": 9,
      "text": "اور وہ اپنے اہل و عیال میں خوش واپس آئے گا",
      "ayah_number": 9,
      "verse_key": "84:9"
    },
    {
      "number": 10,
      "text": "اور لیکن جس کو نامہٴ اعمال پیٹھ پیچھے سے دیا گیا",
      "ayah_number": 10,
      "verse_key": "84:10"
    },
    {
      "number": 11,
      "text": "تو وہ موت کو پکارے گا",
      "ayah_number": 11,
      "verse_key": "84:11"
    },
    {
      "number": 12,
      "text": "اور دوزخ میں داخل ہوگا",
      "ayah_number": 12,
      "verse_key": "84:12"
    },
    {
      "number": 13,
      "text": "بے شک وہ اپنے اہل و عیال میں بڑا خوش و خرم تھا",
      "ayah_number": 13,
      "verse_key": "84:13"
    },
    {
      "number": 14,
      "text": "بے شک اس نے سمجھ لیا تھا کہ ہر گز نہ لوٹ کر جائے گا",
      "ayah_number": 14,
      "verse_key": "84:14"
    },
    {
      "number": 15,
      "text": "کیوں نہیں بے شک اس کا رب تو اس کو دیکھ رہا تھا",
      "ayah_number": 15,
      "verse_key": "84:15"
    },
    {
      "number": 16,
      "text": "پس شام کی سرخی کی قسم ہے",
      "ayah_number": 16,
      "verse_key": "84:16"
    },
    {
      "number": 17,
      "text": "اور رات کی اور جو کچھ اس نے سمیٹا",
      "ayah_number": 17,
      "verse_key": "84:17"
    },
    {
      "number": 18,
      "text": "اور چاند کی جب کہ وہ پورا ہوجائے",
      "ayah_number": 18,
      "verse_key": "84:18"
    },
    {
      "number": 19,
      "text": "کہ تمہیں ایک منزل سے دوسری منزل پر چڑھنا ہوگا",
      "ayah_number": 19,
      "verse_key": "84:19"
    },
    {
      "number": 20,
      "text": "پھر انہیں کیا ہو گیا کہ ایمان نہیں لاتے",
      "ayah_number": 20,
      "verse_key": "84:20"
    },
    {
      "number": 21,
      "text": "اور جب ان پر قرآن پڑھا جائے تو سجدہ نہیں کرتے",
      "ayah_number": 21,
      "verse_key": "84:21"
    },
    {
      "number": 22,
      "text": "بلکہ جو لوگ منکر ہیں جھٹلاتے ہیں",
      "ayah_number": 22,
      "verse_key": "84:22"
    },
    {
      "number": 23,
      "text": "اور الله خوب جانتا ہے وہ جو (دل میں) محفوظ رکھتے ہیں",
      "ayah_number": 23,
      "verse_key": "84:23"
    },
    {
      "number": 24,
      "text": "پس انہیں دردناک عذاب کی خوشخبری دے دو",
      "ayah_number": 24,
      "verse_key": "84:24"
    },
    {
      "number": 25,
      "text": "مگر جو لوگ ایمان لائے اورانہوں نے نیک عمل کیے ان کے لیے بے انتہا اجر ہے",
      "ayah_number": 25,
      "verse_key": "84:25"
    }
  ]
}