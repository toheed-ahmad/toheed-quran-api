{
  "number": 77,
  "name": "Al-Mursalaat",
  "arabicName": "سُورَةُ المُرۡسَلَاتِ",
  "revelationType": "Meccan",
  "totalAyahs": 50,
  "language": "ur",
  "bismillah": {
    "verse_key": "77:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "ان ہواؤں کی قسم ہے جو نفع پہنچانے کے لیے بھیجی جاتی ہیں",
      "ayah_number": 1,
      "verse_key": "77:1"
    },
    {
      "number": 2,
      "text": "پھر ان ہواؤں کی جو تندی سے چلتی ہیں",
      "ayah_number": 2,
      "verse_key": "77:2"
    },
    {
      "number": 3,
      "text": "اوران ہواؤں کی جو بادلوں کو اٹھا کر پھیلاتی ہیں",
      "ayah_number": 3,
      "verse_key": "77:3"
    },
    {
      "number": 4,
      "text": "پھر ان ہواؤں کی جو بادلوں کو متفرق کر دیتی ہیں",
      "ayah_number": 4,
      "verse_key": "77:4"
    },
    {
      "number": 5,
      "text": "پھر ان ہواؤں کی جو (دل میں) الله کی یاد کا القا کرتی ہیں",
      "ayah_number": 5,
      "verse_key": "77:5"
    },
    {
      "number": 6,
      "text": "الزام اتارنے یا ڈرانے کے لیے",
      "ayah_number": 6,
      "verse_key": "77:6"
    },
    {
      "number": 7,
      "text": "جن کا تم سے وعدہ کیا جاتا ہے وہ ضرور ہونے والی ہے",
      "ayah_number": 7,
      "verse_key": "77:7"
    },
    {
      "number": 8,
      "text": "پس جب ستارے مٹا دیئے جائیں گے",
      "ayah_number": 8,
      "verse_key": "77:8"
    },
    {
      "number": 9,
      "text": "اورجب آسمان پھٹ جائیں گے",
      "ayah_number": 9,
      "verse_key": "77:9"
    },
    {
      "number": 10,
      "text": "اورجب پہاڑ اڑائے جائیں گے",
      "ayah_number": 10,
      "verse_key": "77:10"
    },
    {
      "number": 11,
      "text": "اور جب رسول وقت معین پرجمع کیے جائیں گے",
      "ayah_number": 11,
      "verse_key": "77:11"
    },
    {
      "number": 12,
      "text": "کس دن کے لیے تاخیر کی گئی تھی",
      "ayah_number": 12,
      "verse_key": "77:12"
    },
    {
      "number": 13,
      "text": "فیصلہ کے دن کے لیے",
      "ayah_number": 13,
      "verse_key": "77:13"
    },
    {
      "number": 14,
      "text": "اور آپکو کیا معلوم کہ فیصلہ کا دن کیا ہے",
      "ayah_number": 14,
      "verse_key": "77:14"
    },
    {
      "number": 15,
      "text": "اس دن جھٹلانے والوں کے لیے تباہی ہے",
      "ayah_number": 15,
      "verse_key": "77:15"
    },
    {
      "number": 16,
      "text": "کیا ہم نے پہلوں کو ہلاک نہیں کر ڈالا",
      "ayah_number": 16,
      "verse_key": "77:16"
    },
    {
      "number": 17,
      "text": "پھر ہم ان کے پیچھے دوسروں کو چلائیں گے",
      "ayah_number": 17,
      "verse_key": "77:17"
    },
    {
      "number": 18,
      "text": "مجرموں کے ساتھ ہم ایسا ہی برتاؤ کرتے ہیں",
      "ayah_number": 18,
      "verse_key": "77:18"
    },
    {
      "number": 19,
      "text": "اس دن جھٹلانے والوں کے لیے تباہی ہے",
      "ayah_number": 19,
      "verse_key": "77:19"
    },
    {
      "number": 20,
      "text": "کیا ہم نے تمہیں ایک ذلیل پانی سے نہیں پیدا کیا",
      "ayah_number": 20,
      "verse_key": "77:20"
    },
    {
      "number": 21,
      "text": "پھر ہم نے اس کو ایک محفوظ ٹھکانے میں رکھ دیا",
      "ayah_number": 21,
      "verse_key": "77:21"
    },
    {
      "number": 22,
      "text": "ایک معین اندازے تک",
      "ayah_number": 22,
      "verse_key": "77:22"
    },
    {
      "number": 23,
      "text": "پھر ہم نے اندازہ لگایا تو ہم تو کیسے اچھے اندازہ لگانے والے ہیں",
      "ayah_number": 23,
      "verse_key": "77:23"
    },
    {
      "number": 24,
      "text": "اس دن جھٹلانے والوں کے لیےتباہی ہے",
      "ayah_number": 24,
      "verse_key": "77:24"
    },
    {
      "number": 25,
      "text": "کیا ہم نے زمین کو جمع کرنے والی نہیں بنایا",
      "ayah_number": 25,
      "verse_key": "77:25"
    },
    {
      "number": 26,
      "text": "زندوں اور مردوں کو",
      "ayah_number": 26,
      "verse_key": "77:26"
    },
    {
      "number": 27,
      "text": "اور ہم نے اس میں مضبوط اونچے اونچے پہاڑ رکھ دیئے اور ہم نے تمہیں میٹھا پانی پلایا",
      "ayah_number": 27,
      "verse_key": "77:27"
    },
    {
      "number": 28,
      "text": "اس دن جھٹلانے والوں کے لیے تباہی ہے",
      "ayah_number": 28,
      "verse_key": "77:28"
    },
    {
      "number": 29,
      "text": "اس (دوزخ) کی طرف چلو جسے تم جھٹلایا کرتےتھے",
      "ayah_number": 29,
      "verse_key": "77:29"
    },
    {
      "number": 30,
      "text": "ایک سائبان کی طرف چلو جسکے تین حصے ہیں",
      "ayah_number": 30,
      "verse_key": "77:30"
    },
    {
      "number": 31,
      "text": "نہ وہ سایہ کرے اور نہ تپش سے بچائے",
      "ayah_number": 31,
      "verse_key": "77:31"
    },
    {
      "number": 32,
      "text": "بے شک وہ محل جیسے انگارے پھینکے گی",
      "ayah_number": 32,
      "verse_key": "77:32"
    },
    {
      "number": 33,
      "text": "گویا کہ وہ زرد اونٹ ہیں",
      "ayah_number": 33,
      "verse_key": "77:33"
    },
    {
      "number": 34,
      "text": "اس دن جھٹلانے والوں کے لیے تباہی ہے",
      "ayah_number": 34,
      "verse_key": "77:34"
    },
    {
      "number": 35,
      "text": "یہ وہ دن ہے جس میں بات بھی نہ کر سکیں گے",
      "ayah_number": 35,
      "verse_key": "77:35"
    },
    {
      "number": 36,
      "text": "اور نہ انہیں عذر کرنے کی اجازت ہو گی",
      "ayah_number": 36,
      "verse_key": "77:36"
    },
    {
      "number": 37,
      "text": "اس دن جھٹلانے والوں کے لیے تباہی ہے",
      "ayah_number": 37,
      "verse_key": "77:37"
    },
    {
      "number": 38,
      "text": "یہ فیصلہ کا دن ہے ہم تمہیں اور پہلوں کو جمع کریں گے",
      "ayah_number": 38,
      "verse_key": "77:38"
    },
    {
      "number": 39,
      "text": "پس اگر تمہارے پاس کوئی تدبیر ہے تو مجھ پر کر دیکھو",
      "ayah_number": 39,
      "verse_key": "77:39"
    },
    {
      "number": 40,
      "text": "اس دن جھٹلانے والوں کے لیے تباہی ہے",
      "ayah_number": 40,
      "verse_key": "77:40"
    },
    {
      "number": 41,
      "text": "بے شک پرہیزگار ٹھنڈی چھاؤں اور چشموں میں ہوں گے",
      "ayah_number": 41,
      "verse_key": "77:41"
    },
    {
      "number": 42,
      "text": "اور میووں میں جو وہ چاہیں گے",
      "ayah_number": 42,
      "verse_key": "77:42"
    },
    {
      "number": 43,
      "text": "مزے سے کھاؤ اور پیئو ان کاموں کے بدلے جو تم کرتے رہے",
      "ayah_number": 43,
      "verse_key": "77:43"
    },
    {
      "number": 44,
      "text": "بے شک ہم اسی طرح نیکو کاروں کو بدلہ دیتے ہیں",
      "ayah_number": 44,
      "verse_key": "77:44"
    },
    {
      "number": 45,
      "text": "اس دن جھٹلانے والوں کے لیے تباہی ہے",
      "ayah_number": 45,
      "verse_key": "77:45"
    },
    {
      "number": 46,
      "text": "کھاؤ اور چند روز فائدہ اٹھاؤ بے شک تم مجرم ہو",
      "ayah_number": 46,
      "verse_key": "77:46"
    },
    {
      "number": 47,
      "text": "اس دن جھٹلانے والوں کے لیے تباہی ہے",
      "ayah_number": 47,
      "verse_key": "77:47"
    },
    {
      "number": 48,
      "text": "اورجب ان سے کہا جاتا تھا کہ رکوع کرو تورکوع نہ کرتے تھے",
      "ayah_number": 48,
      "verse_key": "77:48"
    },
    {
      "number": 49,
      "text": "اس دن جھٹلانے والوں کے لیے تباہی ہے",
      "ayah_number": 49,
      "verse_key": "77:49"
    },
    {
      "number": 50,
      "text": "پس اس کے بعد کس بات پر ایمان لائیں گے",
      "ayah_number": 50,
      "verse_key": "77:50"
    }
  ]
}