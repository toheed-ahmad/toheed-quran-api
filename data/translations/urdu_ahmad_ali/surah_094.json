{
  "number": 94,
  "name": "Ash-Sharh",
  "arabicName": "سُورَةُ الشَّرۡحِ",
  "revelationType": "Meccan",
  "totalAyahs": 8,
  "language": "ur",
  "bismillah": {
    "verse_key": "94:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "کیا ہم نے آپ کا سینہ نہیں کھول دیا",
      "ayah_number": 1,
      "verse_key": "94:1"
    },
    {
      "number": 2,
      "text": "اور کیا آپ سے آپ کا وہ بوجھ نہیں اتار دیا",
      "ayah_number": 2,
      "verse_key": "94:2"
    },
    {
      "number": 3,
      "text": "جس نے آپ کی کمر جھکا دی تھی",
      "ayah_number": 3,
      "verse_key": "94:3"
    },
    {
      "number": 4,
      "text": "اور ہم نے آپ کا ذکر بلند کر دیا",
      "ayah_number": 4,
      "verse_key": "94:4"
    },
    {
      "number": 5,
      "text": "پس بے شک ہر مشکل کے ساتھ آسانی ہے",
      "ayah_number": 5,
      "verse_key": "94:5"
    },
    {
      "number": 6,
      "text": "بے شک ہر مشکل کے ساتھ آسانی ہے",
      "ayah_number": 6,
      "verse_key": "94:6"
    },
    {
      "number": 7,
      "text": "پس جب آپ (تبلیغ احکام سے) فارغ ہوں تو ریاضت کیجئے",
      "ayah_number": 7,
      "verse_key": "94:7"
    },
    {
      "number": 8,
      "text": "اور اپنے رب کی طرف دل لگائیے",
      "ayah_number": 8,
      "verse_key": "94:8"
    }
  ]
}