{
  "number": 86,
  "name": "At-Taariq",
  "arabicName": "سُورَةُ الطَّارِقِ",
  "revelationType": "Meccan",
  "totalAyahs": 17,
  "language": "ur",
  "bismillah": {
    "verse_key": "86:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "آسمان کی قسم ہے اور رات کو آنے والے کی",
      "ayah_number": 1,
      "verse_key": "86:1"
    },
    {
      "number": 2,
      "text": "اور آپ کو کیا معلوم رات کو آنے والا کیا ہے",
      "ayah_number": 2,
      "verse_key": "86:2"
    },
    {
      "number": 3,
      "text": "وہ چمکتا ہوا ستارہ ہے",
      "ayah_number": 3,
      "verse_key": "86:3"
    },
    {
      "number": 4,
      "text": "ایسی کوئی بھی جان نہیں کہ جس پر ایک محافظ مقرر نہ ہو",
      "ayah_number": 4,
      "verse_key": "86:4"
    },
    {
      "number": 5,
      "text": "پس انسان کو دیکھنا چاہیے کہ وہ کس چیز سے پیدا کیا گیا ہے",
      "ayah_number": 5,
      "verse_key": "86:5"
    },
    {
      "number": 6,
      "text": "ایک اچھلتے ہوئے پانی سے پیدا کیا گیا ہے",
      "ayah_number": 6,
      "verse_key": "86:6"
    },
    {
      "number": 7,
      "text": "جو پیٹھ اور سینے کی ہڈیوں کے درمیان سے نکلتا ہے",
      "ayah_number": 7,
      "verse_key": "86:7"
    },
    {
      "number": 8,
      "text": "بے شک وہ اس کے لوٹانے پر قادر ہے",
      "ayah_number": 8,
      "verse_key": "86:8"
    },
    {
      "number": 9,
      "text": "جس دن بھید ظاہر کیے جائیں گے",
      "ayah_number": 9,
      "verse_key": "86:9"
    },
    {
      "number": 10,
      "text": "تو اس کے لیے نہ کوئی طاقت ہو گی اور نہ کوئی مددگار",
      "ayah_number": 10,
      "verse_key": "86:10"
    },
    {
      "number": 11,
      "text": "آسمان اور بارش والے کی قسم ہے",
      "ayah_number": 11,
      "verse_key": "86:11"
    },
    {
      "number": 12,
      "text": "اور زمین کی جو پھٹ جاتی ہے",
      "ayah_number": 12,
      "verse_key": "86:12"
    },
    {
      "number": 13,
      "text": "بے شک قرآن قطعی بات ہے",
      "ayah_number": 13,
      "verse_key": "86:13"
    },
    {
      "number": 14,
      "text": "اوروہ ہنسی کی بات نہیں ہے",
      "ayah_number": 14,
      "verse_key": "86:14"
    },
    {
      "number": 15,
      "text": "بے شک وہ ایک تدبیر کر رہے ہیں",
      "ayah_number": 15,
      "verse_key": "86:15"
    },
    {
      "number": 16,
      "text": "اور میں بھی ایک تدبیر کر رہا ہوں",
      "ayah_number": 16,
      "verse_key": "86:16"
    },
    {
      "number": 17,
      "text": "پس کافرو ں کو تھوڑے دنوں کی مہلت دے دو",
      "ayah_number": 17,
      "verse_key": "86:17"
    }
  ]
}