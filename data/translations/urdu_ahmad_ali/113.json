{
  "number": 113,
  "name": "Al-Falaq",
  "arabicName": "سُورَةُ الفَلَقِ",
  "revelationType": "Meccan",
  "totalAyahs": 5,
  "language": "ur",
  "bismillah": {
    "verse_key": "113:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "کہہ دو صبح کے پیدا کرنے والے کی پناہ مانگتا ہوں",
      "ayah_number": 1,
      "verse_key": "113:1"
    },
    {
      "number": 2,
      "text": "اس کی مخلوقات کے شر سے",
      "ayah_number": 2,
      "verse_key": "113:2"
    },
    {
      "number": 3,
      "text": "اور اندھیری رات کے شر سے جب وہ چھا جائے",
      "ayah_number": 3,
      "verse_key": "113:3"
    },
    {
      "number": 4,
      "text": "اورگرہوں میں پھونکنے والیوں کے شر سے",
      "ayah_number": 4,
      "verse_key": "113:4"
    },
    {
      "number": 5,
      "text": "اور حسد کرنے والے کے شر سے جب وہ حسد کرے",
      "ayah_number": 5,
      "verse_key": "113:5"
    }
  ]
}