{
  "number": 107,
  "name": "Al-Maa'un",
  "arabicName": "سُورَةُ المَاعُونِ",
  "revelationType": "Meccan",
  "totalAyahs": 7,
  "language": "ur",
  "bismillah": {
    "verse_key": "107:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "کیا آپ نے اس کو دیکھا جو روزِ جرا کو جھٹلاتا ہے",
      "ayah_number": 1,
      "verse_key": "107:1"
    },
    {
      "number": 2,
      "text": "پس وہ وہی ہے جو یتیم کو دھکے دیتا ہے",
      "ayah_number": 2,
      "verse_key": "107:2"
    },
    {
      "number": 3,
      "text": "اور مسکین کو کھانا کھلانے کی ترغیب نہیں دیتا",
      "ayah_number": 3,
      "verse_key": "107:3"
    },
    {
      "number": 4,
      "text": "پس ان نمازیوں کے لیے ہلاکت ہے",
      "ayah_number": 4,
      "verse_key": "107:4"
    },
    {
      "number": 5,
      "text": "جو اپنی نماز سے غافل ہیں",
      "ayah_number": 5,
      "verse_key": "107:5"
    },
    {
      "number": 6,
      "text": "جو دکھلاوا کرتے ہیں",
      "ayah_number": 6,
      "verse_key": "107:6"
    },
    {
      "number": 7,
      "text": "اور برتنے کی چیز تک روکتے ہیں",
      "ayah_number": 7,
      "verse_key": "107:7"
    }
  ]
}