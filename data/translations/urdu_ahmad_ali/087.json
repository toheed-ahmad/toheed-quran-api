{
  "number": 87,
  "name": "Al-A'laa",
  "arabicName": "سُورَةُ الأَعۡلَىٰ",
  "revelationType": "Meccan",
  "totalAyahs": 19,
  "language": "ur",
  "bismillah": {
    "verse_key": "87:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "اپنے رب کے نام کی تسبیح کیا کر جو سب سے اعلیٰ ہے",
      "ayah_number": 1,
      "verse_key": "87:1"
    },
    {
      "number": 2,
      "text": "وہ جس نے پیدا کیا پھر ٹھیک بنایا",
      "ayah_number": 2,
      "verse_key": "87:2"
    },
    {
      "number": 3,
      "text": "اور جس نے اندازہ ٹھہرایا پھر راہ دکھائی",
      "ayah_number": 3,
      "verse_key": "87:3"
    },
    {
      "number": 4,
      "text": "اور وہ جس نے چارہ نکالا",
      "ayah_number": 4,
      "verse_key": "87:4"
    },
    {
      "number": 5,
      "text": "پھر اس کو خشک چورا سیاہ کر دیا",
      "ayah_number": 5,
      "verse_key": "87:5"
    },
    {
      "number": 6,
      "text": "البتہ ہم آپ کو پڑھائیں گے پھر آپ نہ بھولیں گے",
      "ayah_number": 6,
      "verse_key": "87:6"
    },
    {
      "number": 7,
      "text": "مگر جو الله چاہے بے شک وہ ہرظاہر اور چھپی بات کو جانتا ہے",
      "ayah_number": 7,
      "verse_key": "87:7"
    },
    {
      "number": 8,
      "text": "اور ہم آپ کو آسان شریعت کے سمجھنے کی توفیق دیں گے",
      "ayah_number": 8,
      "verse_key": "87:8"
    },
    {
      "number": 9,
      "text": "پس آپ نصیحت کیجیئے اگر نصیحت فائدہ دے",
      "ayah_number": 9,
      "verse_key": "87:9"
    },
    {
      "number": 10,
      "text": "جو الله سے ڈرتا ہے وہ جلدی سمجھ جائے گا",
      "ayah_number": 10,
      "verse_key": "87:10"
    },
    {
      "number": 11,
      "text": "اور اس سے بڑا بدنصیب الگ رہے گا",
      "ayah_number": 11,
      "verse_key": "87:11"
    },
    {
      "number": 12,
      "text": "جو سخت آگ میں داخل ہوگا",
      "ayah_number": 12,
      "verse_key": "87:12"
    },
    {
      "number": 13,
      "text": "پھر اس میں نہ تو مرے گا اور نہ جیئے گا",
      "ayah_number": 13,
      "verse_key": "87:13"
    },
    {
      "number": 14,
      "text": "بے شک وہ کامیاب ہوا جو پاک ہو گیا",
      "ayah_number": 14,
      "verse_key": "87:14"
    },
    {
      "number": 15,
      "text": "اور اپنے رب کا نام یاد کیا پھر نماز پڑھی",
      "ayah_number": 15,
      "verse_key": "87:15"
    },
    {
      "number": 16,
      "text": "بلکہ تم تودنیا کی زندگی کو ترجیح دیتے ہو",
      "ayah_number": 16,
      "verse_key": "87:16"
    },
    {
      "number": 17,
      "text": "حالانکہ آخرت بہتر اور زیادہ پائدار ہے",
      "ayah_number": 17,
      "verse_key": "87:17"
    },
    {
      "number": 18,
      "text": "بے شک یہی پہلے صحیفوں میں ہے",
      "ayah_number": 18,
      "verse_key": "87:18"
    },
    {
      "number": 19,
      "text": "(یعنی) ابراھیم اور موسیٰ کے صحیفوں میں",
      "ayah_number": 19,
      "verse_key": "87:19"
    }
  ]
}