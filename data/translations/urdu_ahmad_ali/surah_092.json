{
  "number": 92,
  "name": "Al-Lail",
  "arabicName": "سُورَةُ اللَّيۡلِ",
  "revelationType": "Meccan",
  "totalAyahs": 21,
  "language": "ur",
  "bismillah": {
    "verse_key": "92:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "رات کی قسم ہے جب کہ وہ چھاجائے",
      "ayah_number": 1,
      "verse_key": "92:1"
    },
    {
      "number": 2,
      "text": "اور دن کی جبکہ وہ روشن ہو",
      "ayah_number": 2,
      "verse_key": "92:2"
    },
    {
      "number": 3,
      "text": "اوراس کی قسم کہ جس نے نر و مادہ کوبنایا",
      "ayah_number": 3,
      "verse_key": "92:3"
    },
    {
      "number": 4,
      "text": "بے شک تمہاری کوشش مختلف ہے",
      "ayah_number": 4,
      "verse_key": "92:4"
    },
    {
      "number": 5,
      "text": "پھر جس نے دیا اور پرہیز گاری کی",
      "ayah_number": 5,
      "verse_key": "92:5"
    },
    {
      "number": 6,
      "text": "اورنیک بات کی تصدیق کی",
      "ayah_number": 6,
      "verse_key": "92:6"
    },
    {
      "number": 7,
      "text": "تو ہم اس کے لیے جنت کی راہیں آسان کر دیں گے",
      "ayah_number": 7,
      "verse_key": "92:7"
    },
    {
      "number": 8,
      "text": "اورلیکن جس نے بخل کیا اوربے پرواہ رہا",
      "ayah_number": 8,
      "verse_key": "92:8"
    },
    {
      "number": 9,
      "text": "اور نیک بات کو جھٹلایا",
      "ayah_number": 9,
      "verse_key": "92:9"
    },
    {
      "number": 10,
      "text": "تو ہم اس کے لیے جہنم کی راہیں آسان کر دیں گے",
      "ayah_number": 10,
      "verse_key": "92:10"
    },
    {
      "number": 11,
      "text": "اوراس کا مال اس کے کچھ بھی کام نہ آئے گا جب کہ وہ گھڑے میں گرے گا",
      "ayah_number": 11,
      "verse_key": "92:11"
    },
    {
      "number": 12,
      "text": "بے شک ہمارے ذمے راہ دکھانا ہے",
      "ayah_number": 12,
      "verse_key": "92:12"
    },
    {
      "number": 13,
      "text": "اور بے شک ہمارے ہی ہاتھ میں آخرت بھی اور دنیا بھی ہے",
      "ayah_number": 13,
      "verse_key": "92:13"
    },
    {
      "number": 14,
      "text": "پس میں نے تمہیں بڑھکتی ہوئی آگ سے ڈرایا ہے",
      "ayah_number": 14,
      "verse_key": "92:14"
    },
    {
      "number": 15,
      "text": "جس میں صرف وہی بد بخت داخل ہوگا",
      "ayah_number": 15,
      "verse_key": "92:15"
    },
    {
      "number": 16,
      "text": "جس نے جھٹلایا اورمنہ موڑا",
      "ayah_number": 16,
      "verse_key": "92:16"
    },
    {
      "number": 17,
      "text": "اوراس آگ سے وہ بڑا پرہیز گار دور رہے گا",
      "ayah_number": 17,
      "verse_key": "92:17"
    },
    {
      "number": 18,
      "text": "جو اپنا مال دیتا ہے تاکہ وہ پاک ہو جائے",
      "ayah_number": 18,
      "verse_key": "92:18"
    },
    {
      "number": 19,
      "text": "اور اس پر کسی کا کوئی احسان نہیں کہ جس کا بدلہ دیا جائے",
      "ayah_number": 19,
      "verse_key": "92:19"
    },
    {
      "number": 20,
      "text": "وہ تو صرف اپنے سب سے برتر رب کی رضا مندی کے لیے دیتا ہے",
      "ayah_number": 20,
      "verse_key": "92:20"
    },
    {
      "number": 21,
      "text": "اوروہ عنقریب خوش ہو جائے گا",
      "ayah_number": 21,
      "verse_key": "92:21"
    }
  ]
}