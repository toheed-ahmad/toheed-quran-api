{
  "number": 102,
  "name": "At-Takaathur",
  "arabicName": "سُورَةُ التَّكَاثُرِ",
  "revelationType": "Meccan",
  "totalAyahs": 8,
  "language": "ur",
  "bismillah": {
    "verse_key": "102:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "تمہیں حرص نے غافل کر دیا",
      "ayah_number": 1,
      "verse_key": "102:1"
    },
    {
      "number": 2,
      "text": "یہاں تک کہ قبریں جا دیکھیں",
      "ayah_number": 2,
      "verse_key": "102:2"
    },
    {
      "number": 3,
      "text": "ایسا نہیں آئندہ تم جان لو گے",
      "ayah_number": 3,
      "verse_key": "102:3"
    },
    {
      "number": 4,
      "text": "پھر ایسا نہیں چاہیئے آئندہ تم جان لو گے",
      "ayah_number": 4,
      "verse_key": "102:4"
    },
    {
      "number": 5,
      "text": "ایسا نہیں چاہیئے کاش تم یقینی طور پر جانتے",
      "ayah_number": 5,
      "verse_key": "102:5"
    },
    {
      "number": 6,
      "text": "البتہ تم ضرور دوزخ کو دیکھو گے",
      "ayah_number": 6,
      "verse_key": "102:6"
    },
    {
      "number": 7,
      "text": "پھر تم اسے ضرور بالکل یقینی طور پر دیکھو گے",
      "ayah_number": 7,
      "verse_key": "102:7"
    },
    {
      "number": 8,
      "text": "پھر اس دن تم سے نعمتوں کے متعلق پوچھا جائے گا",
      "ayah_number": 8,
      "verse_key": "102:8"
    }
  ]
}