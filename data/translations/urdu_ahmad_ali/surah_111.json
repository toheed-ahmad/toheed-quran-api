{
  "number": 111,
  "name": "Al-Masad",
  "arabicName": "سُورَةُ المَسَدِ",
  "revelationType": "Meccan",
  "totalAyahs": 5,
  "language": "ur",
  "bismillah": {
    "verse_key": "111:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "ابو لہب کے دونوں ہاتھ ٹوٹ گئے اوروہ ہلاک ہو گیا",
      "ayah_number": 1,
      "verse_key": "111:1"
    },
    {
      "number": 2,
      "text": "اس کا مال اورجو کچھ اس نے کمایا اس کے کام نہ آیا",
      "ayah_number": 2,
      "verse_key": "111:2"
    },
    {
      "number": 3,
      "text": "وہ بھڑکتی ہوئی آگ میں پڑے گا",
      "ayah_number": 3,
      "verse_key": "111:3"
    },
    {
      "number": 4,
      "text": "اور اس کی عورت بھی جو ایندھن اٹھائے پھرتی تھی",
      "ayah_number": 4,
      "verse_key": "111:4"
    },
    {
      "number": 5,
      "text": "اس کی گردن میں موُنج کی رسیّ ہے",
      "ayah_number": 5,
      "verse_key": "111:5"
    }
  ]
}