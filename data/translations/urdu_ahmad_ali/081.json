{
  "number": 81,
  "name": "At-Takwir",
  "arabicName": "سُورَةُ التَّكۡوِيرِ",
  "revelationType": "Meccan",
  "totalAyahs": 29,
  "language": "ur",
  "bismillah": {
    "verse_key": "81:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "جب سورج کی روشنی لپیٹی جائے",
      "ayah_number": 1,
      "verse_key": "81:1"
    },
    {
      "number": 2,
      "text": "اور جب ستارے گر جائیں",
      "ayah_number": 2,
      "verse_key": "81:2"
    },
    {
      "number": 3,
      "text": "اور جب پہاڑ چلائے جائیں",
      "ayah_number": 3,
      "verse_key": "81:3"
    },
    {
      "number": 4,
      "text": "اور جب دس مہینے کی گابھن اونٹنیاں چھوڑ دی جائیں",
      "ayah_number": 4,
      "verse_key": "81:4"
    },
    {
      "number": 5,
      "text": "اور جب جنگلی جانور اکھٹے ہوجائیں",
      "ayah_number": 5,
      "verse_key": "81:5"
    },
    {
      "number": 6,
      "text": "اور جب سمندر جوش دیئے جائیں",
      "ayah_number": 6,
      "verse_key": "81:6"
    },
    {
      "number": 7,
      "text": "اور جب جانیں جسموں سے ملائی جائیں",
      "ayah_number": 7,
      "verse_key": "81:7"
    },
    {
      "number": 8,
      "text": "اور جب زندہ درگور لڑکی سے پوچھا جائے",
      "ayah_number": 8,
      "verse_key": "81:8"
    },
    {
      "number": 9,
      "text": "کہ کس گناہ پر ماری گئی تھی",
      "ayah_number": 9,
      "verse_key": "81:9"
    },
    {
      "number": 10,
      "text": "اور جب اعمال نامے کھل جائیں",
      "ayah_number": 10,
      "verse_key": "81:10"
    },
    {
      "number": 11,
      "text": "اور آسمان کا پوست اتارا جائے",
      "ayah_number": 11,
      "verse_key": "81:11"
    },
    {
      "number": 12,
      "text": "اورجب دوزخ دھکائی جائے",
      "ayah_number": 12,
      "verse_key": "81:12"
    },
    {
      "number": 13,
      "text": "اورجب جنت قریب لائی جائے",
      "ayah_number": 13,
      "verse_key": "81:13"
    },
    {
      "number": 14,
      "text": "تو ہر شخص جان لے گا کہ وہ کیا لے کر آیا ہے",
      "ayah_number": 14,
      "verse_key": "81:14"
    },
    {
      "number": 15,
      "text": "پس میں قسم کھاتا ہوں پیچھے ہٹنے والے",
      "ayah_number": 15,
      "verse_key": "81:15"
    },
    {
      "number": 16,
      "text": "سیدھے چلنے والے غیب ہو جانے والے ستارو ں کی",
      "ayah_number": 16,
      "verse_key": "81:16"
    },
    {
      "number": 17,
      "text": "اور قسم ہے رات کی جب وہ جانے لگے",
      "ayah_number": 17,
      "verse_key": "81:17"
    },
    {
      "number": 18,
      "text": "اور قسم ہے صبح کی جب وہ آنے لگے",
      "ayah_number": 18,
      "verse_key": "81:18"
    },
    {
      "number": 19,
      "text": "بے شک یہ قرآن ایک معزز رسول کا لایا ہوا ہے",
      "ayah_number": 19,
      "verse_key": "81:19"
    },
    {
      "number": 20,
      "text": "جو بڑا طاقتور ہے عرش کے مالک کے نزدیک بڑے رتبہ والا ہے",
      "ayah_number": 20,
      "verse_key": "81:20"
    },
    {
      "number": 21,
      "text": "وہاں کا سردار امانت دار ہے",
      "ayah_number": 21,
      "verse_key": "81:21"
    },
    {
      "number": 22,
      "text": "اور تمہارا رفیق کوئی دیوانہ نہیں ہے",
      "ayah_number": 22,
      "verse_key": "81:22"
    },
    {
      "number": 23,
      "text": "اور اس نے اس کو کُھلے کنارے پر دیکھا بھی ہے",
      "ayah_number": 23,
      "verse_key": "81:23"
    },
    {
      "number": 24,
      "text": "اور وہ غیب کی باتوں پر بخیل نہیں ہے",
      "ayah_number": 24,
      "verse_key": "81:24"
    },
    {
      "number": 25,
      "text": "اور وہ کسی شیطان مردود کا قول نہیں ہے",
      "ayah_number": 25,
      "verse_key": "81:25"
    },
    {
      "number": 26,
      "text": "پس تم کہاں چلے جا رہے ہو",
      "ayah_number": 26,
      "verse_key": "81:26"
    },
    {
      "number": 27,
      "text": "یہ تو جہان بھرکے لیے نصیحت ہی نصیحت ہے",
      "ayah_number": 27,
      "verse_key": "81:27"
    },
    {
      "number": 28,
      "text": "اس کے لیے جو تم میں سے سیدھا چلنا چاہے",
      "ayah_number": 28,
      "verse_key": "81:28"
    },
    {
      "number": 29,
      "text": "اور تم توجب ہی چاہو گے کہ جب الله چاہے گا جو تمام جہان کا رب ہے",
      "ayah_number": 29,
      "verse_key": "81:29"
    }
  ]
}