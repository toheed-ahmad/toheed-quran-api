{
  "number": 79,
  "name": "An-Naazi'aat",
  "arabicName": "سُورَةُ النَّازِعَاتِ",
  "revelationType": "Meccan",
  "totalAyahs": 46,
  "language": "ur",
  "bismillah": {
    "verse_key": "79:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "جورڑوں میں گھس کر نکالنے والوں کی قسم ہے",
      "ayah_number": 1,
      "verse_key": "79:1"
    },
    {
      "number": 2,
      "text": "اور بند کھولنے والوں کی",
      "ayah_number": 2,
      "verse_key": "79:2"
    },
    {
      "number": 3,
      "text": "اورتیزی سے تیرنے والوں کی",
      "ayah_number": 3,
      "verse_key": "79:3"
    },
    {
      "number": 4,
      "text": "پھر دوڑ کر آگے بڑھ جانے والوں کی",
      "ayah_number": 4,
      "verse_key": "79:4"
    },
    {
      "number": 5,
      "text": "پھر ہر امر کی تدبیر کرنے والوں کی",
      "ayah_number": 5,
      "verse_key": "79:5"
    },
    {
      "number": 6,
      "text": "جس دن کانپنے والی کانپے گی",
      "ayah_number": 6,
      "verse_key": "79:6"
    },
    {
      "number": 7,
      "text": "اس کے پیچھے آنے والی پیچھے آئے گی",
      "ayah_number": 7,
      "verse_key": "79:7"
    },
    {
      "number": 8,
      "text": "کئی دل اس دن دھڑک رہے ہوں گے",
      "ayah_number": 8,
      "verse_key": "79:8"
    },
    {
      "number": 9,
      "text": "ان کی آنکھیں جھکی ہوئی ہوں گی",
      "ayah_number": 9,
      "verse_key": "79:9"
    },
    {
      "number": 10,
      "text": "وہ کہتے ہیں کیا ہم پہلی حالت میں لوٹائے جائیں گے",
      "ayah_number": 10,
      "verse_key": "79:10"
    },
    {
      "number": 11,
      "text": "کیا جب ہم بوسیدہ ہڈیاں ہوجائیں گے",
      "ayah_number": 11,
      "verse_key": "79:11"
    },
    {
      "number": 12,
      "text": "کہتے ہیں کہ یہ تو اس وقت خسارہ کا لوٹنا ہوگا",
      "ayah_number": 12,
      "verse_key": "79:12"
    },
    {
      "number": 13,
      "text": "پھر وہ واقعہ صرف ایک ہی ہیبت ناک آواز ہے",
      "ayah_number": 13,
      "verse_key": "79:13"
    },
    {
      "number": 14,
      "text": "پس وہ اسی وقت میدان میں آ موجود ہوں گے",
      "ayah_number": 14,
      "verse_key": "79:14"
    },
    {
      "number": 15,
      "text": "کیا آپ کو موسیٰ کا حال معلوم ہوا ہے",
      "ayah_number": 15,
      "verse_key": "79:15"
    },
    {
      "number": 16,
      "text": "جب کہ مقدس وادی طویٰ میں اس کے رب نے اسےپکارا",
      "ayah_number": 16,
      "verse_key": "79:16"
    },
    {
      "number": 17,
      "text": "فرعون کے پاس جاؤ کیونکہ اس نے سرکشی کی ہے",
      "ayah_number": 17,
      "verse_key": "79:17"
    },
    {
      "number": 18,
      "text": "پس کہو کیا تیری خواہش ہے کہ تو پاک ہو",
      "ayah_number": 18,
      "verse_key": "79:18"
    },
    {
      "number": 19,
      "text": "اور میں تجھے تیرے رب کی طرف راہ بتاؤں کہ تو ڈرے",
      "ayah_number": 19,
      "verse_key": "79:19"
    },
    {
      "number": 20,
      "text": "پس اس نے اس کو بڑی نشانی دکھائی",
      "ayah_number": 20,
      "verse_key": "79:20"
    },
    {
      "number": 21,
      "text": "تو اس نے جھٹلایا اور نافرمانی کی",
      "ayah_number": 21,
      "verse_key": "79:21"
    },
    {
      "number": 22,
      "text": "پھر کوشش کرتا ہوا واپس لوٹا",
      "ayah_number": 22,
      "verse_key": "79:22"
    },
    {
      "number": 23,
      "text": "پھر اس نے سب کو جمع کیا پھر پکارا",
      "ayah_number": 23,
      "verse_key": "79:23"
    },
    {
      "number": 24,
      "text": "پھر کہا کہ میں تمہارا سب سے برتر رب ہوں",
      "ayah_number": 24,
      "verse_key": "79:24"
    },
    {
      "number": 25,
      "text": "پھر الله نے اس کو آخرت اور دنیا کے عذاب میں پکڑ لیا",
      "ayah_number": 25,
      "verse_key": "79:25"
    },
    {
      "number": 26,
      "text": "بے شک اس میں اس کے لیے عبرت ہے جو ڈرتا ہے",
      "ayah_number": 26,
      "verse_key": "79:26"
    },
    {
      "number": 27,
      "text": "کیا تمہارا بنانا بڑی بات ہے یا آسمان کا جس کو ہم نے بنایا ہے",
      "ayah_number": 27,
      "verse_key": "79:27"
    },
    {
      "number": 28,
      "text": "ا سکی چھت بلند کی پھر اس کو سنوارا",
      "ayah_number": 28,
      "verse_key": "79:28"
    },
    {
      "number": 29,
      "text": "اور اس کی رات اندھیری کی اور اس کے دن کو ظاہر کیا",
      "ayah_number": 29,
      "verse_key": "79:29"
    },
    {
      "number": 30,
      "text": "اور اس کے بعد زمین کو بچھا دیا",
      "ayah_number": 30,
      "verse_key": "79:30"
    },
    {
      "number": 31,
      "text": "اس سے اس کا پانی اور اس کا چارا نکالا",
      "ayah_number": 31,
      "verse_key": "79:31"
    },
    {
      "number": 32,
      "text": "او رپہاڑوں کو خوب جما دیا",
      "ayah_number": 32,
      "verse_key": "79:32"
    },
    {
      "number": 33,
      "text": "تمہارے لیے اور تمہارے چار پایوں کے لیے سامان حیات ہے",
      "ayah_number": 33,
      "verse_key": "79:33"
    },
    {
      "number": 34,
      "text": "پس جب وہ بڑا حادثہ آئے گا",
      "ayah_number": 34,
      "verse_key": "79:34"
    },
    {
      "number": 35,
      "text": "جس دن انسان اپنے کیے کو یاد کرے گا",
      "ayah_number": 35,
      "verse_key": "79:35"
    },
    {
      "number": 36,
      "text": "اور ہر دیکھنے والے کے لیے دوزخ سامنے لائی جائے گی",
      "ayah_number": 36,
      "verse_key": "79:36"
    },
    {
      "number": 37,
      "text": "سو جس نے سرکشی کی",
      "ayah_number": 37,
      "verse_key": "79:37"
    },
    {
      "number": 38,
      "text": "اور دنیا کی زندگی کو ترجیح دی",
      "ayah_number": 38,
      "verse_key": "79:38"
    },
    {
      "number": 39,
      "text": "سو بے شک اس کا ٹھکانا دوزخ ہی ہے",
      "ayah_number": 39,
      "verse_key": "79:39"
    },
    {
      "number": 40,
      "text": "اور لیکن جو اپنے رب کے سامنے کھڑا ہونے سے ڈرتارہا اور اس نے اپنے نفس کو بری خواہش سے روکا",
      "ayah_number": 40,
      "verse_key": "79:40"
    },
    {
      "number": 41,
      "text": "سو بے شک اس کا ٹھکانا بہشت ہی ہے",
      "ayah_number": 41,
      "verse_key": "79:41"
    },
    {
      "number": 42,
      "text": "آپ سے قیامت کی بابت پوچھتے ہیں کہ اس کا قیام کب ہوگا",
      "ayah_number": 42,
      "verse_key": "79:42"
    },
    {
      "number": 43,
      "text": "آپ کو اس کےذکر سے کیا واسطہ",
      "ayah_number": 43,
      "verse_key": "79:43"
    },
    {
      "number": 44,
      "text": "اس کے علم کی انتہا آپ کے رب ہی کی طرف ہے",
      "ayah_number": 44,
      "verse_key": "79:44"
    },
    {
      "number": 45,
      "text": "بے شک آپ تو صرف اس کو ڈرانے والے ہیں جو اس سے ڈرتا ہے",
      "ayah_number": 45,
      "verse_key": "79:45"
    },
    {
      "number": 46,
      "text": "جس دن اسے دیکھ لیں گے (تو یہی سمجھیں گے کہ دنیا میں) گویا ہم ایک شام یا اس کی صبح تک ٹھیرے تھے",
      "ayah_number": 46,
      "verse_key": "79:46"
    }
  ]
}