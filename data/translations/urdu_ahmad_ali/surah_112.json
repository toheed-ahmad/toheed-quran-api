{
  "number": 112,
  "name": "Al-Ikhlaas",
  "arabicName": "سُورَةُ الإِخۡلَاصِ",
  "revelationType": "Meccan",
  "totalAyahs": 4,
  "language": "ur",
  "bismillah": {
    "verse_key": "112:0",
    "text": "شروع الله کا نام لے کر جو بڑا مہربان نہایت رحم والا ہے"
  },
  "ayahs": [
    {
      "number": 1,
      "text": "کہہ دووہ الله ایک ہے",
      "ayah_number": 1,
      "verse_key": "112:1"
    },
    {
      "number": 2,
      "text": "اللہ بے نیاز ہے",
      "ayah_number": 2,
      "verse_key": "112:2"
    },
    {
      "number": 3,
      "text": "نہ اس کی کوئی اولاد ہے اور نہ وہ کسی کی اولاد ہے",
      "ayah_number": 3,
      "verse_key": "112:3"
    },
    {
      "number": 4,
      "text": "اور اس کے برابر کا کوئی نہیں ہے",
      "ayah_number": 4,
      "verse_key": "112:4"
    }
  ]
}