{
  "surah_id": 114,
  "surah_name": "An-Nas",
  "source": "ترجمہ مفتی تقی عثمانی (equranlibrary)",
  "language": "ur",
  "bismillah": {
    "verse_key": "114:0",
    "text": "اللہ کے نام سے جو رحمان و رحیم ہے"
  },
  "ayahs": [
    {
      "ayah_number": 1,
      "verse_key": "114:1",
      "text": "کہو کہ : میں پناہ مانگتا ہوں سب لوگوں کے پروردگار کی۔"
    },
    {
      "ayah_number": 2,
      "verse_key": "114:2",
      "text": "سب لوگوں کے بادشاہ کی۔"
    },
    {
      "ayah_number": 3,
      "verse_key": "114:3",
      "text": "سب لوگوں کے معبود کی۔"
    },
    {
      "ayah_number": 4,
      "verse_key": "114:4",
      "text": "اس وسوسہ ڈالنے والے کے شر سے جو پیچھے کو چھپ جاتا ہے۔"
    },
    {
      "ayah_number": 5,
      "verse_key": "114:5",
      "text": "جو لوگوں کے دلوں میں وسوسہ ڈالتا ہے۔"
    },
    {
      "ayah_number": 6,
      "verse_key": "114:6",
      "text": "چاہے وہ جنات میں سے ہو، یا انسانوں میں سے۔"
    }
  ]
}