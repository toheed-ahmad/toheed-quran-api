{
  "surah_id": 107,
  "surah_name": "Al-Ma'un",
  "source": "ترجمہ مفتی تقی عثمانی (equranlibrary)",
  "language": "ur",
  "bismillah": {
    "verse_key": "107:0",
    "text": "اللہ کے نام سے جو رحمان و رحیم ہے"
  },
  "ayahs": [
    {
      "ayah_number": 1,
      "verse_key": "107:1",
      "text": "کیا تم نے اسے دیکھا جو جزاء و سزا کو جھٹلاتا ہے ؟"
    },
    {
      "ayah_number": 2,
      "verse_key": "107:2",
      "text": "وہی تو ہے جو یتیم کو دھکے دیتا ہے۔"
    },
    {
      "ayah_number": 3,
      "verse_key": "107:3",
      "text": "اور مسکین کو کھانا دینے کی ترغیب نہیں دیتا۔"
    },
    {
      "ayah_number": 4,
      "verse_key": "107:4",
      "text": "پھر بڑی خرابی ہے ان نماز پڑھنے والوں کی"
    },
    {
      "ayah_number": 5,
      "verse_key": "107:5",
      "text": "جو اپنی نماز سے غفلت برتتے ہیں۔"
    },
    {
      "ayah_number": 6,
      "verse_key": "107:6",
      "text": "جو دکھاوا کرتے ہیں۔"
    },
    {
      "ayah_number": 7,
      "verse_key": "107:7",
      "text": "اور دوسروں کو معمولی چیز دینے سے بھی انکار کرتے ہیں۔"
    }
  ]
}